# Vercel Postgres Environment Variables
# Bu dosyayı .env olarak kopyalayın ve gerçek değerlerle doldurun

# Database Configuration
DATABASE_URL=postgresql://username:password@host:port/database

# SSL Certificates (Vercel Postgres için)
POSTGRES_CA_CERT=-----BEGIN CERTIFICATE-----
# Vercel Dashboard'dan alınacak
-----END CERTIFICATE-----

POSTGRES_CLIENT_KEY=-----BEGIN PRIVATE KEY-----
# Vercel Dashboard'dan alınacak
-----END PRIVATE KEY-----

POSTGRES_CLIENT_CERT=-----BEGIN CERTIFICATE-----
# Vercel Dashboard'dan alınacak
-----END CERTIFICATE-----

# Environment
NODE_ENV=production

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-here

# Stripe Payment Configuration
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Server Configuration
PORT=3000
HOST=localhost

# Instagram API Configuration
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token
INSTAGRAM_USER_ID=your-instagram-user-id
