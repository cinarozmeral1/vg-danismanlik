# Vercel Postgres Environment Variables
# Bu dosyayı .env olarak kopyalayın ve gerçek değerlerle doldurun

# Database Configuration
DATABASE_URL=postgresql://username:password@host:port/database

# SSL Certificates (Vercel Postgres için)
POSTGRES_CA_CERT=-----BEGIN CERTIFICATE-----
# Vercel Dashboard'dan alınacak
-----END CERTIFICATE-----

POSTGRES_CLIENT_KEY=-----BEGIN PRIVATE KEY-----
# Vercel Dashboard'dan alınacak
-----END PRIVATE KEY-----

POSTGRES_CLIENT_CERT=-----BEGIN CERTIFICATE-----
# Vercel Dashboard'dan alınacak
-----END CERTIFICATE-----

# Environment
NODE_ENV=production

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-here

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Server Configuration
PORT=3000
HOST=localhost

# Instagram API Configuration
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token
INSTAGRAM_USER_ID=your-instagram-user-id

# ========================================
# AUTOMATED BACKUP SYSTEM
# ========================================

# FTP/SFTP Server Configuration
FTP_HOST=ftp.example.com
FTP_PORT=21
FTP_USER=your-ftp-username
FTP_PASSWORD=your-ftp-password
FTP_SECURE=false
FTP_BACKUP_DIR=/venture-global-backups
FTP_AUTO_CLEANUP=true

# Cron Job Security
CRON_SECRET=your-super-secret-cron-key-here

# Backup Notifications
EMAIL_NOTIFICATIONS=true
ADMIN_EMAIL=admin@ventureglobal.com
EMAIL_SECURE=false

# Email ayarları yukarıda zaten var (EMAIL_HOST, EMAIL_PORT, EMAIL_USER, EMAIL_PASS)
