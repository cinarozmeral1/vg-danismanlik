# Vercel Postgres Environment Variables
# Bu dosyayı .env olarak kopyalayın ve gerçek değerlerle doldurun

# Database Configuration
DATABASE_URL=postgresql://username:password@host:port/database

# SSL Certificates (Vercel Postgres için)
POSTGRES_CA_CERT=-----BEGIN CERTIFICATE-----
# Vercel Dashboard'dan alınacak
-----END CERTIFICATE-----

POSTGRES_CLIENT_KEY=-----BEGIN PRIVATE KEY-----
# Vercel Dashboard'dan alınacak
-----END PRIVATE KEY-----

POSTGRES_CLIENT_CERT=-----BEGIN CERTIFICATE-----
# Vercel Dashboard'dan alınacak
-----END CERTIFICATE-----

# Environment
NODE_ENV=production

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-here

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Server Configuration
PORT=3000
HOST=localhost

# Instagram API Configuration
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token
INSTAGRAM_USER_ID=your-instagram-user-id

# Backup System Configuration
# FTP Server bilgileri (yedekleme için)
FTP_HOST=ftp.example.com
FTP_USER=your-ftp-username
FTP_PASSWORD=your-ftp-password
FTP_PORT=21
FTP_SECURE=false
FTP_REMOTE_PATH=/backups

# Backup Options
ENABLE_AUTO_BACKUP=true
USE_PG_DUMP=false
BACKUP_KEEP_DAYS=30
BACKUP_LOCAL_CLEANUP=true
