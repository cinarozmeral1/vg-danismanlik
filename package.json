{
  "name": "venture-global-website",
  "version": "1.0.2",
  "description": "Venture Global - Avrupa Üniversite ve Dil Okulu Danışmanlığı",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "https": "NODE_ENV=development node server.js",
    "build": "echo 'No build step required'",
    "vercel-build": "echo 'Vercel build completed'",
    "migrate:vercel": "node scripts/migrate-to-vercel.js",
    "db:test": "node scripts/test-database.js",
    "db:check": "node -e \"console.log('Database URL:', process.env.DATABASE_URL || 'Not set')\"",
    "report:export": "node scripts/export-universities-for-report.js",
    "report:html": "node scripts/build-report-html.js",
    "report:html:populer": "node scripts/build-report-html.js --populer",
    "report:pdf": "node scripts/generate-report-pdf.js",
    "report:short": "node scripts/export-universities-for-report.js && node scripts/build-report-html.js --populer && node scripts/generate-report-pdf.js",
    "deploy": "npx vercel --yes",
    "deploy:preview": "npx vercel --yes",
    "deploy:prod": "npx vercel --prod"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "archiver": "^7.0.1",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "body-parser": "^1.20.2",
    "cloudinary": "^2.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^8.2.1",
    "google-auth-library": "^10.5.0",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.7.2",
    "mkcert": "^3.2.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.5",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.17.2",
    "pg": "^8.16.3",
    "sqlite3": "^5.1.7",
    "stripe": "^20.0.0",
    "tsdav": "^2.1.8"
  },
  "devDependencies": {
    "eslint": "^9.33.0",
    "html-minifier-terser": "^7.2.0",
    "marked": "^17.0.6",
    "nodemon": "^3.1.10"
  },
  "keywords": [
    "venture-global",
    "education",
    "consulting",
    "europe",
    "https",
    "security"
  ],
  "author": "Venture Global",
  "license": "MIT"
}
