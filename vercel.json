{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb"
      }
    },
    {
      "src": "api/cron/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/googlebf24a454ad6f83f0.html",
      "dest": "/public/googlebf24a454ad6f83f0.html"
    },
    {
      "src": "/favicon.ico",
      "dest": "/public/favicon.ico"
    },
    {
      "src": "/favicon.png",
      "dest": "/public/favicon.png"
    },
    {
      "src": "/favicon-192.png",
      "dest": "/public/favicon-192.png"
    },
    {
      "src": "/api/cron/(.*)",
      "dest": "/api/cron/$1.js"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate, private"
      }
    }
  ],
  "crons": [
    {
      "path": "/api/cron/generate-blog",
      "schedule": "0 9 */3 * *"
    },
    {
      "path": "/api/cron/backup-database",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/profile-reminder",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/zoom-reminder",
      "schedule": "*/10 * * * *"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
