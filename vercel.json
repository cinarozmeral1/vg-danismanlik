{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb"
      }
    },
    {
      "src": "api/cron/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/cron/(.*)",
      "dest": "/api/cron/$1.js"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/generate-blog",
      "schedule": "0 9 */3 * *"
    },
    {
      "path": "/api/cron/backup-database",
      "schedule": "0 3 * * *"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
