{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb",
        "includeFiles": [
          "views/**",
          "locales/**",
          "middleware/**",
          "services/**",
          "config/**",
          "public/css/**",
          "public/js/**",
          "public/images/partners/**",
          "public/images/logos/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/images/backgrounds/(.*)",
      "dest": "/public/images/backgrounds/$1"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/public/uploads/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "crons": [
    {
      "path": "/api/cron/backup-database",
      "schedule": "0 3 * * *"
    }
  ]
}
