<!-- Admin AI Recommendations Content -->
<div class="admin-container">
    <!-- Sidebar -->
    <div class="admin-sidebar">
        <div class="sidebar-header">
            <h6 class="mb-0"><i class="fas fa-cog me-2"></i>Yönetim Paneli</h6>
        </div>
        <nav class="sidebar-nav">
            <a href="/admin/dashboard" class="nav-item">
                <i class="fas fa-tachometer-alt"></i>
                <span>Dashboard</span>
            </a>
            <a href="/admin/users" class="nav-item">
                <i class="fas fa-users"></i>
                <span>Öğrenciler</span>
                <% if (typeof userCount !== 'undefined' && userCount > 0) { %>
                    <span class="badge bg-primary ms-auto"><%= userCount %></span>
                <% } %>
            </a>
            <a href="/admin/applications" class="nav-item">
                <i class="fas fa-file-alt"></i>
                <span>Başvurular</span>
                <% if (typeof applicationCount !== 'undefined' && applicationCount > 0) { %>
                    <span class="badge bg-success ms-auto"><%= applicationCount %></span>
                <% } %>
            </a>
            <a href="/admin/partners" class="nav-item">
                <i class="fas fa-handshake"></i>
                <span>Partnerler</span>
                <% if (typeof partnerCount !== 'undefined' && partnerCount > 0) { %>
                    <span class="badge bg-info ms-auto"><%= partnerCount %></span>
                <% } %>
            </a>
            <a href="/admin/universities" class="nav-item">
                <i class="fas fa-university"></i>
                <span>Üniversiteler</span>
            </a>
            <a href="/admin/backups" class="nav-item">
                <i class="fas fa-database"></i>
                <span>Yedekleme</span>
            </a>
            <a href="/admin/admins" class="nav-item">
                <i class="fas fa-user-shield"></i>
                <span>Adminler</span>
            </a>
        </nav>
    </div>

    <!-- Main Content Area -->
    <div class="admin-main">
        <!-- Header -->
        <div class="section-header">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2><i class="fas fa-magic me-2" style="color: #6f42c1;"></i>AI Önerileri</h2>
                    <p class="text-muted mb-0">Öğrenci sihirbazı tarafından yapılan tüm öneriler</p>
                </div>
                <a href="/admin/dashboard" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Dashboard'a Dön
                </a>
            </div>
        </div>

        <!-- Stats Cards -->
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="card shadow-sm" style="border-left: 4px solid #6f42c1;">
                    <div class="card-body text-center">
                        <h3 class="mb-1" id="totalCount">0</h3>
                        <small class="text-muted">Toplam Öneri</small>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm" style="border-left: 4px solid #28a745;">
                    <div class="card-body text-center">
                        <h3 class="mb-1" id="thisMonthCount">0</h3>
                        <small class="text-muted">Bu Ay</small>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm" style="border-left: 4px solid #fd7e14;">
                    <div class="card-body text-center">
                        <h3 class="mb-1" id="prepNeededCount">0</h3>
                        <small class="text-muted">Hazırlık Gerekli</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recommendations Table -->
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-list me-2"></i>Öneri Listesi</h5>
                    <input type="text" class="form-control" id="searchInput" placeholder="Ara..." style="max-width: 250px;">
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Öğrenci</th>
                                <th>Seviye</th>
                                <th>İngilizce</th>
                                <th>Önerilen Ülke</th>
                                <th>Önerilen Üniversite</th>
                                <th>Hazırlık</th>
                                <th>Tarih</th>
                                <th>İşlem</th>
                            </tr>
                        </thead>
                        <tbody id="recommendationsTable">
                            <tr>
                                <td colspan="8" class="text-center py-4">
                                    <i class="fas fa-spinner fa-spin me-2"></i>Yükleniyor...
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Detail Modal -->
<div class="modal fade" id="detailModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header" style="background: linear-gradient(135deg, #6f42c1, #0056b3); color: white;">
                <h5 class="modal-title"><i class="fas fa-magic me-2"></i>Öneri Detayı</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="detailContent">
                <!-- Content will be loaded here -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Kapat</button>
                <button type="button" class="btn btn-danger" id="deleteBtn">
                    <i class="fas fa-trash me-2"></i>Öneriyi Sil
                </button>
            </div>
        </div>
    </div>
</div>

<script>
let recommendations = [];
let currentRecommendationId = null;

document.addEventListener('DOMContentLoaded', function() {
    loadRecommendations();
    
    document.getElementById('searchInput').addEventListener('input', filterTable);
    document.getElementById('deleteBtn').addEventListener('click', deleteRecommendation);
});

async function loadRecommendations() {
    try {
        const response = await fetch('/admin/ai-recommendations/list', {
            credentials: 'include'
        });
        const data = await response.json();
        
        if (data.success) {
            recommendations = data.data;
            renderTable(recommendations);
            updateStats(recommendations);
        } else {
            throw new Error(data.message || 'Veri yüklenemedi');
        }
    } catch (error) {
        console.error('Error loading recommendations:', error);
        document.getElementById('recommendationsTable').innerHTML = `
            <tr>
                <td colspan="8" class="text-center py-4 text-danger">
                    <i class="fas fa-exclamation-circle me-2"></i>Veriler yüklenirken hata oluştu: ${error.message}
                </td>
            </tr>
        `;
    }
}

function updateStats(data) {
    document.getElementById('totalCount').textContent = data.length;
    
    const thisMonth = data.filter(r => {
        const date = new Date(r.created_at);
        const now = new Date();
        return date.getMonth() === now.getMonth() && date.getFullYear() === now.getFullYear();
    }).length;
    document.getElementById('thisMonthCount').textContent = thisMonth;
    
    const prepNeeded = data.filter(r => r.prep_school_needed).length;
    document.getElementById('prepNeededCount').textContent = prepNeeded;
}

function renderTable(data) {
    const tbody = document.getElementById('recommendationsTable');
    
    if (data.length === 0) {
        tbody.innerHTML = `
            <tr>
                <td colspan="8" class="text-center py-4 text-muted">
                    <i class="fas fa-inbox me-2"></i>Henüz öneri bulunmuyor
                </td>
            </tr>
        `;
        return;
    }
    
    tbody.innerHTML = data.map(r => `
        <tr>
            <td>
                <strong>${r.first_name} ${r.last_name}</strong><br>
                <small class="text-muted">${r.email}</small>
            </td>
            <td>
                <span class="badge ${r.education_level === 'bachelor' ? 'bg-primary' : 'bg-success'}">
                    ${r.education_level === 'bachelor' ? 'Lisans' : 'Y.Lisans'}
                </span>
            </td>
            <td>${r.english_level || '-'}</td>
            <td>
                ${r.recommended_country ? `<span class="badge bg-info">${r.recommended_country}</span>` : '-'}
            </td>
            <td>${r.recommended_city || '-'}</td>
            <td>
                ${r.prep_school_needed ? 
                    '<span class="badge bg-warning text-dark"><i class="fas fa-check me-1"></i>Gerekli</span>' : 
                    '<span class="badge bg-secondary">Gerekli Değil</span>'}
            </td>
            <td>
                <small>${new Date(r.created_at).toLocaleDateString('tr-TR')}</small>
            </td>
            <td>
                <button class="btn btn-sm btn-outline-primary" onclick="showDetail(${r.id})">
                    <i class="fas fa-eye"></i>
                </button>
                <button class="btn btn-sm btn-outline-danger" onclick="confirmDelete(${r.id})">
                    <i class="fas fa-trash"></i>
                </button>
            </td>
        </tr>
    `).join('');
}

function filterTable() {
    const search = document.getElementById('searchInput').value.toLowerCase();
    const filtered = recommendations.filter(r => 
        (r.first_name + ' ' + r.last_name).toLowerCase().includes(search) ||
        r.email.toLowerCase().includes(search) ||
        (r.recommended_country || '').toLowerCase().includes(search)
    );
    renderTable(filtered);
}

function showDetail(id) {
    const r = recommendations.find(rec => rec.id === id);
    if (!r) return;
    
    currentRecommendationId = id;
    
    const content = `
        <div class="row">
            <div class="col-md-6">
                <h6 class="text-primary"><i class="fas fa-user me-2"></i>Öğrenci Bilgileri</h6>
                <table class="table table-sm">
                    <tr><td><strong>Ad Soyad:</strong></td><td>${r.first_name} ${r.last_name}</td></tr>
                    <tr><td><strong>E-posta:</strong></td><td>${r.email}</td></tr>
                    <tr><td><strong>Eğitim:</strong></td><td>${r.education_level === 'bachelor' ? 'Lisans' : 'Yüksek Lisans'}</td></tr>
                    <tr><td><strong>İngilizce:</strong></td><td>${r.english_level || '-'}</td></tr>
                    ${r.english_exam_type ? `<tr><td><strong>Sınav:</strong></td><td>${r.english_exam_type} - ${r.english_exam_score}</td></tr>` : ''}
                </table>
            </div>
            <div class="col-md-6">
                <h6 class="text-success"><i class="fas fa-magic me-2"></i>AI Önerisi</h6>
                <table class="table table-sm">
                    <tr><td><strong>Ülke:</strong></td><td>${r.recommended_country || '-'}</td></tr>
                    <tr><td><strong>Şehir:</strong></td><td>${r.recommended_city || '-'}</td></tr>
                    <tr><td><strong>Ücret:</strong></td><td>${r.recommended_tuition || '-'}</td></tr>
                    <tr><td><strong>Hazırlık:</strong></td><td>${r.prep_school_needed ? '<span class="text-warning">Gerekli</span>' : 'Gerekli Değil'}</td></tr>
                </table>
            </div>
        </div>
        ${r.ai_reasoning ? `
            <div class="mt-3">
                <h6 class="text-info"><i class="fas fa-brain me-2"></i>AI Açıklaması</h6>
                <div class="bg-light p-3 rounded" style="max-height: 200px; overflow-y: auto;">
                    ${r.ai_reasoning}
                </div>
            </div>
        ` : ''}
        ${r.prep_school_suggestion ? `
            <div class="mt-3">
                <h6 class="text-warning"><i class="fas fa-school me-2"></i>Hazırlık Önerisi</h6>
                <div class="bg-warning bg-opacity-10 p-3 rounded">
                    ${r.prep_school_suggestion}
                </div>
            </div>
        ` : ''}
        <div class="mt-3 text-muted small">
            <i class="fas fa-calendar me-1"></i>Oluşturulma: ${new Date(r.created_at).toLocaleString('tr-TR')}
        </div>
    `;
    
    document.getElementById('detailContent').innerHTML = content;
    new bootstrap.Modal(document.getElementById('detailModal')).show();
}

function confirmDelete(id) {
    currentRecommendationId = id;
    if (confirm('Bu öneriyi silmek istediğinize emin misiniz?')) {
        deleteRecommendation();
    }
}

async function deleteRecommendation() {
    if (!currentRecommendationId) return;
    
    try {
        const response = await fetch(`/admin/api/ai-recommendations/${currentRecommendationId}`, {
            method: 'DELETE',
            credentials: 'include'
        });
        
        const data = await response.json();
        
        if (data.success) {
            // Close modal if open
            const modal = bootstrap.Modal.getInstance(document.getElementById('detailModal'));
            if (modal) modal.hide();
            
            // Reload data
            loadRecommendations();
            alert('Öneri başarıyla silindi');
        } else {
            alert('Hata: ' + data.message);
        }
    } catch (error) {
        console.error('Delete error:', error);
        alert('Silme işlemi sırasında hata oluştu');
    }
}
</script>
