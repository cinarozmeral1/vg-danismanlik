    // Add appointment row
    function addAppointmentRow() {
        const container = document.getElementById('appointmentsContainer');
        const newRow = document.createElement('div');
        newRow.className = 'row mb-2 appointment-row';
        newRow.innerHTML = `
            <div class="col-5">
                <input type="date" class="form-control appointment-date" placeholder="Tarih">
            </div>
            <div class="col-4">
                <input type="time" class="form-control appointment-time" placeholder="Saat">
            </div>
            <div class="col-3">
                <button type="button" class="btn btn-outline-danger w-100" onclick="removeAppointmentRow(this)">
                    <i class="fas fa-minus"></i>
                </button>
            </div>
        `;
        container.appendChild(newRow);
    }
    
    // Remove appointment row
    function removeAppointmentRow(btn) {
        btn.closest('.appointment-row').remove();
    }
    
    // Save visa application
    async function saveVisaApplication() {
        const form = document.getElementById('visaApplicationForm');
        const formData = new FormData(form);
        
        const userId = formData.get('user_id');
        const country = formData.get('country');
        const consulateCity = formData.get('consulate_city');
        const status = formData.get('status');
        const notes = formData.get('notes');
        const editId = formData.get('editId');
        
        // Get all appointments (combine date + time)
        const appointmentRows = document.querySelectorAll('.appointment-row');
        const appointments = [];
        appointmentRows.forEach(row => {
            const dateInput = row.querySelector('.appointment-date');
            const timeInput = row.querySelector('.appointment-time');
            if (dateInput && dateInput.value) {
                const date = dateInput.value;
                const time = timeInput && timeInput.value ? timeInput.value : '12:00';
                appointments.push(`${date}T${time}`);
            }
        });
        
        if (!userId || !country || !consulateCity) {
            alert('Lütfen tüm zorunlu alanları doldurun!');
            return;
        }
        
        const data = {
            user_id: userId,
            country: country,
            consulate_city: consulateCity,
            status: status,
            notes: notes,
            appointments: appointments
        };
        
        try {
            const url = editId ? `/api/admin/visa-applications/${editId}` : '/api/admin/visa-applications';
            const method = editId ? 'PUT' : 'POST';
            
            const response = await fetch(url, {
                method: method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            
            const result = await response.json();
            
            if (result.success) {
                alert(editId ? 'Vize başvurusu güncellendi!' : 'Vize başvurusu oluşturuldu!');
                bootstrap.Modal.getInstance(document.getElementById('visaApplicationModal')).hide();
                location.reload();
            } else {
                alert('Hata: ' + result.message);
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Bir hata oluştu!');
        }
    }
    
    // Edit visa application
    async function editVisaApplication(id) {
        try {
            const response = await fetch(`/api/admin/visa-applications/${id}`);
            const result = await response.json();
            
            if (result.success) {
                const visa = result.data;
                
                document.getElementById('visaEditId').value = visa.id;
                document.getElementById('visaUserId').value = visa.user_id;
                document.getElementById('visaCountry').value = visa.country;
                document.getElementById('visaConsulateCity').value = visa.consulate_city;
                document.getElementById('visaStatus').value = visa.status;
                document.getElementById('visaNotes').value = visa.notes || '';
                
                // Set appointments
                const container = document.getElementById('appointmentsContainer');
                container.innerHTML = '';
                
                if (visa.appointments && visa.appointments.length > 0) {
                    visa.appointments.forEach((apt, index) => {
                        const date = new Date(apt.appointment_date);
                        const dateStr = date.toISOString().slice(0, 10);
                        const timeStr = date.toTimeString().slice(0, 5);
                        
                        const row = document.createElement('div');
                        row.className = 'row mb-2 appointment-row';
                        row.innerHTML = `
                            <div class="col-5">
                                <input type="date" class="form-control appointment-date" value="${dateStr}">
                            </div>
                            <div class="col-4">
                                <input type="time" class="form-control appointment-time" value="${timeStr}">
                            </div>
                            <div class="col-3">
                                <button type="button" class="btn btn-outline-${index === 0 ? 'success' : 'danger'} w-100" onclick="${index === 0 ? 'addAppointmentRow()' : 'removeAppointmentRow(this)'}">
                                    <i class="fas fa-${index === 0 ? 'plus' : 'minus'}"></i>
                                </button>
                            </div>
                        `;
                        container.appendChild(row);
                    });
                } else {
                    container.innerHTML = `
                        <div class="row mb-2 appointment-row">
                            <div class="col-5">
                                <input type="date" class="form-control appointment-date" placeholder="Tarih">
                            </div>
                            <div class="col-4">
                                <input type="time" class="form-control appointment-time" placeholder="Saat">
                            </div>
                            <div class="col-3">
                                <button type="button" class="btn btn-outline-success w-100" onclick="addAppointmentRow()">
                                    <i class="fas fa-plus"></i>
                                </button>
                            </div>
                        </div>
                    `;
                }
                
                const modal = new bootstrap.Modal(document.getElementById('visaApplicationModal'));
                modal.show();
            } else {
                alert('Hata: ' + result.message);
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Bir hata oluştu!');
        }
    }
    
    // Update visa status
    async function updateVisaStatus(id, status) {
        const statusText = status === 'approved' ? 'kabul etmek' : (status === 'rejected' ? 'reddetmek' : 'beklemede almak');
        
        if (!confirm(`Bu vize başvurusunu ${statusText} istediğinizden emin misiniz?`)) {
            return;
        }
        
        try {
            const response = await fetch(`/api/admin/visa-applications/${id}/status`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status: status })
            });
            
            const result = await response.json();
            
            if (result.success) {
                alert('Vize başvurusu durumu güncellendi!');
                location.reload();
            } else {
                alert('Hata: ' + result.message);
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Bir hata oluştu!');
        }
    }
    
    // Delete visa application
    async function deleteVisaApplication(id) {
        if (!confirm('Bu vize başvurusunu silmek istediğinizden emin misiniz? Bu işlem geri alınamaz!')) {
            return;
        }
        
        try {
            const response = await fetch(`/api/admin/visa-applications/${id}`, {
                method: 'DELETE'
            });
            
            const result = await response.json();
            
            if (result.success) {
                alert('Vize başvurusu silindi!');
                location.reload();
            } else {
                alert('Hata: ' + result.message);
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Bir hata oluştu!');
        }
    }

