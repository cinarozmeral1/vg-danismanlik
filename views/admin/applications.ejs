<!-- Admin Applications Content -->
<div class="admin-container">
    <!-- Sidebar -->
    <div class="admin-sidebar">
        <div class="sidebar-header">
            <h6 class="mb-0"><i class="fas fa-cog me-2"></i>Yönetim Paneli</h6>
        </div>
        <nav class="sidebar-nav">
            <a href="/admin/dashboard" class="nav-item">
                <i class="fas fa-tachometer-alt"></i>
                <span>Dashboard</span>
            </a>
            <a href="/admin/users" class="nav-item">
                <i class="fas fa-users"></i>
                <span>Öğrenciler</span>
                <span class="badge bg-primary ms-auto"><%= userCount %></span>
            </a>
            <a href="/admin/applications" class="nav-item active">
                <i class="fas fa-file-alt"></i>
                <span>Başvurular</span>
                <span class="badge bg-success ms-auto"><%= applicationCount %></span>
            </a>
            <a href="/admin/partners" class="nav-item">
                <i class="fas fa-handshake"></i>
                <span>Partnerler</span>
                <% if (typeof partnerCount !== 'undefined' && partnerCount > 0) { %>
                    <span class="badge bg-info ms-auto"><%= partnerCount %></span>
                <% } %>
            </a>
            <a href="/admin/universities" class="nav-item">
                <i class="fas fa-university"></i>
                <span>Üniversiteler</span>
            </a>
            <a href="/admin/backups" class="nav-item">
                <i class="fas fa-database"></i>
                <span>Yedekleme</span>
            </a>
        </nav>
    </div>

    <!-- Main Content Area -->
    <div class="admin-main">
        <div class="section-header">
            <h2><i class="fas fa-file-alt me-2"></i>Başvurular</h2>
            <p class="text-muted">Sistemdeki tüm başvuruları yönetin</p>
        </div>

        <!-- Application Type Cards -->
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="card h-100 application-type-card active" id="universityCard" onclick="showUniversityApplications()">
                    <div class="card-body text-center py-4">
                        <div class="mb-3">
                            <i class="fas fa-university fa-3x text-primary"></i>
                        </div>
                        <h5 class="card-title">Üniversite Başvuruları</h5>
                        <p class="card-text text-muted">Üniversite ve program başvurularını yönetin</p>
                        <span class="badge bg-primary fs-5"><%= applications.length %></span>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100 application-type-card" id="visaCard" onclick="showVisaApplications()">
                    <div class="card-body text-center py-4">
                        <div class="mb-3">
                            <i class="fas fa-passport fa-3x text-success"></i>
                        </div>
                        <h5 class="card-title">Vize Başvuruları</h5>
                        <p class="card-text text-muted">Vize randevularını ve başvurularını yönetin</p>
                        <span class="badge bg-success fs-5" id="visaCount"><%= typeof visaApplications !== 'undefined' ? visaApplications.length : 0 %></span>
                    </div>
                </div>
            </div>
        </div>

        <style>
            .application-type-card {
                cursor: pointer;
                transition: all 0.3s ease;
                border: 2px solid transparent;
            }
            .application-type-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 30px rgba(0,0,0,0.15);
            }
            .application-type-card.active {
                border-color: #0d6efd;
                box-shadow: 0 5px 20px rgba(13, 110, 253, 0.3);
            }
            #visaApplicationsSection {
                display: none;
            }
        </style>

        <!-- University Applications Section -->
        <div id="universityApplicationsSection">
        <!-- Applications Table -->
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-university me-2"></i>Üniversite Başvuruları (<%= applications.length %>)</h5>
                <button class="btn btn-primary btn-sm" id="openUserSelectionModalBtn">
                    <i class="fas fa-plus me-2"></i>Yeni Başvuru
                </button>
            </div>
            <div class="card-body">
                <% if (applications.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Öğrenci</th>
                                    <th>Ülke</th>
                                    <th>Üniversite</th>
                                    <th>Program</th>
                                    <th>Durum</th>
                                    <th>Başvuru Ücreti</th>
                                    <th>Tarih</th>
                                    <th>İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% applications.forEach(app => { %>
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-sm me-2">
                                                <i class="fas fa-user-circle fa-2x text-primary"></i>
                                            </div>
                                            <div>
                                                <strong><%= app.first_name %> <%= app.last_name %></strong>
                                                <br><small class="text-muted"><%= app.email %></small>
                                            </div>
                                        </div>
                                    </td>
                                    <td><%= app.country || 'Türkiye' %></td>
                                    <td><%= app.university_name || app.university || '-' %></td>
                                    <td><%= app.program_name || app.program || '-' %></td>
                                    <td>
                                        <% if (app.status === 'pending') { %>
                                            <span class="badge bg-warning">Beklemede</span>
                                        <% } else if (app.status === 'approved') { %>
                                            <span class="badge bg-success">Onaylandı</span>
                                        <% } else if (app.status === 'rejected') { %>
                                            <span class="badge bg-danger">Reddedildi</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <div class="form-check form-switch">
                                            <input class="form-check-input js-fee-toggle" 
                                                   type="checkbox" 
                                                   id="feeToggle<%= app.id %>"
                                                   data-application-id="<%= app.id %>"
                                                   <%= app.application_fee_paid ? 'checked' : '' %>>
                                            <label class="form-check-label" for="feeToggle<%= app.id %>">
                                                <% if (app.application_fee_paid) { %>
                                                    <span class="text-success"><i class="fas fa-check-circle"></i> Ödendi</span>
                                                <% } else { %>
                                                    <span class="text-danger"><i class="fas fa-times-circle"></i> Ödenmedi</span>
                                                <% } %>
                                            </label>
                                        </div>
                                    </td>
                                    <td><%= new Date(app.created_at).toLocaleDateString('tr-TR') %></td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <button class="btn btn-sm btn-outline-primary js-edit-application" data-application-id="<%= app.id %>" title="Düzenle">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-success js-approve-application" data-application-id="<%= app.id %>" title="Onayla">
                                                <i class="fas fa-check"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger js-reject-application" data-application-id="<%= app.id %>" title="Reddet">
                                                <i class="fas fa-times"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-warning js-pending-application" data-application-id="<%= app.id %>" title="Beklemede">
                                                <i class="fas fa-clock"></i>
                                            </button>
                                        </div>
                                        <button class="btn btn-sm btn-outline-danger ms-2 js-delete-application" data-application-id="<%= app.id %>" title="Sil">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="text-center py-5">
                        <i class="fas fa-file-alt fa-3x text-muted mb-3"></i>
                        <h5 class="text-muted">Henüz başvuru bulunmuyor</h5>
                        <p class="text-muted">İlk başvuruyu oluşturmak için "Yeni Başvuru" butonuna tıklayın.</p>
                    </div>
                <% } %>
            </div>
        </div>
        </div><!-- End of University Applications Section -->

        <!-- Visa Applications Section -->
        <div id="visaApplicationsSection">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-passport me-2"></i>Vize Başvuruları (<span id="visaCountHeader"><%= typeof visaApplications !== 'undefined' ? visaApplications.length : 0 %></span>)</h5>
                    <button class="btn btn-success btn-sm" id="openVisaModalBtn" onclick="openVisaModal()">
                        <i class="fas fa-plus me-2"></i>Yeni Vize Başvurusu
                    </button>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover" id="visaTable">
                            <thead>
                                <tr>
                                    <th>Öğrenci</th>
                                    <th>Ülke</th>
                                    <th>Konsolosluk Şehri</th>
                                    <th>Randevu Tarihleri</th>
                                    <th>Durum</th>
                                    <th>Tarih</th>
                                    <th>İşlemler</th>
                                </tr>
                            </thead>
                            <tbody id="visaTableBody">
                                <% if (typeof visaApplications !== 'undefined' && visaApplications.length > 0) { %>
                                    <% visaApplications.forEach(visa => { %>
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="avatar-sm me-2">
                                                    <i class="fas fa-user-circle fa-2x text-success"></i>
                                                </div>
                                                <div>
                                                    <strong><%= visa.first_name %> <%= visa.last_name %></strong>
                                                    <br><small class="text-muted"><%= visa.email %></small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <% if (visa.country === 'Germany') { %>🇩🇪 Almanya
                                            <% } else if (visa.country === 'Czech Republic') { %>🇨🇿 Çekya
                                            <% } else if (visa.country === 'Italy') { %>🇮🇹 İtalya
                                            <% } else if (visa.country === 'Austria') { %>🇦🇹 Avusturya
                                            <% } else if (visa.country === 'UK') { %>🇬🇧 İngiltere
                                            <% } else if (visa.country === 'Poland') { %>🇵🇱 Polonya
                                            <% } else if (visa.country === 'Hungary') { %>🇭🇺 Macaristan
                                            <% } else { %><%= visa.country %>
                                            <% } %>
                                        </td>
                                        <td><%= visa.consulate_city %></td>
                                        <td>
                                            <% if (visa.appointments && visa.appointments.length > 0) { %>
                                                <% visa.appointments.forEach(apt => { %>
                                                    <span class="badge bg-info mb-1"><%= new Date(apt.appointment_date).toLocaleDateString('tr-TR') %></span><br>
                                                <% }); %>
                                            <% } else { %>
                                                <span class="text-muted">Randevu yok</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (visa.status === 'pending') { %>
                                                <span class="badge bg-warning">Beklemede</span>
                                            <% } else if (visa.status === 'approved') { %>
                                                <span class="badge bg-success">Kabul Edildi</span>
                                            <% } else if (visa.status === 'rejected') { %>
                                                <span class="badge bg-danger">Reddedildi</span>
                                            <% } %>
                                        </td>
                                        <td><%= new Date(visa.created_at).toLocaleDateString('tr-TR') %></td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                <button class="btn btn-sm btn-outline-primary" onclick="editVisaApplication(<%= visa.id %>)" title="Düzenle">
                                                    <i class="fas fa-edit"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-success" onclick="updateVisaStatus(<%= visa.id %>, 'approved')" title="Kabul Et">
                                                    <i class="fas fa-check"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger" onclick="updateVisaStatus(<%= visa.id %>, 'rejected')" title="Reddet">
                                                    <i class="fas fa-times"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-warning" onclick="updateVisaStatus(<%= visa.id %>, 'pending')" title="Beklemede">
                                                    <i class="fas fa-clock"></i>
                                                </button>
                                            </div>
                                            <button class="btn btn-sm btn-outline-danger ms-2" onclick="deleteVisaApplication(<%= visa.id %>)" title="Sil">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr id="noVisaRow">
                                        <td colspan="7" class="text-center py-5">
                                            <i class="fas fa-passport fa-3x text-muted mb-3"></i>
                                            <h5 class="text-muted">Henüz vize başvurusu bulunmuyor</h5>
                                            <p class="text-muted">İlk vize başvurusunu oluşturmak için "Yeni Vize Başvurusu" butonuna tıklayın.</p>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div><!-- End of Visa Applications Section -->

        <!-- Visa Application Modal -->
        <div class="modal fade" id="visaApplicationModal" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
                <div class="modal-content">
                    <div class="modal-header bg-success text-white">
                        <h5 class="modal-title"><i class="fas fa-passport me-2"></i>Yeni Vize Başvurusu</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body" style="max-height: 70vh; overflow-y: auto;">
                        <form id="visaApplicationForm">
                            <input type="hidden" id="visaEditId" name="editId">
                            
                            <!-- Öğrenci Seçimi -->
                            <div class="mb-3">
                                <label class="form-label">Öğrenci *</label>
                                <select class="form-select" id="visaUserId" name="user_id" required>
                                    <option value="">Öğrenci Seçin</option>
                                    <% if (typeof users !== 'undefined' && users) { %>
                                        <% users.forEach(user => { %>
                                            <option value="<%= user.id %>"><%= user.first_name %> <%= user.last_name %> (<%= user.email %>)</option>
                                        <% }); %>
                                    <% } %>
                                </select>
                            </div>
                            
                            <!-- Ülke Seçimi -->
                            <div class="mb-3">
                                <label class="form-label">Ülke *</label>
                                <select class="form-select" id="visaCountry" name="country" required>
                                    <option value="">Ülke Seçin</option>
                                    <option value="Germany">🇩🇪 Almanya</option>
                                    <option value="Czech Republic">🇨🇿 Çek Cumhuriyeti</option>
                                    <option value="Italy">🇮🇹 İtalya</option>
                                    <option value="Austria">🇦🇹 Avusturya</option>
                                    <option value="UK">🇬🇧 İngiltere</option>
                                    <option value="Poland">🇵🇱 Polonya</option>
                                    <option value="Hungary">🇭🇺 Macaristan</option>
                                </select>
                            </div>
                            
                            <!-- Konsolosluk Şehri -->
                            <div class="mb-3">
                                <label class="form-label">Konsolosluk Şehri (Türkiye) *</label>
                                <input type="text" class="form-control" id="visaConsulateCity" name="consulate_city" placeholder="Örn: İstanbul, Ankara, İzmir..." required>
                            </div>
                            
                            <!-- Randevu Tarihleri -->
                            <div class="mb-3">
                                <label class="form-label">Randevu Tarihleri</label>
                                <div id="appointmentsContainer">
                                    <div class="row mb-2 appointment-row">
                                        <div class="col-5">
                                            <input type="date" class="form-control appointment-date" placeholder="Tarih">
                                        </div>
                                        <div class="col-4">
                                            <input type="time" class="form-control appointment-time" placeholder="Saat">
                                        </div>
                                        <div class="col-3">
                                            <button type="button" class="btn btn-outline-success w-100" onclick="addAppointmentRow()">
                                                <i class="fas fa-plus"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                <small class="text-muted">İstediğiniz kadar randevu tarihi ve saati ekleyebilirsiniz</small>
                            </div>
                            
                            <!-- Durum -->
                            <div class="mb-3">
                                <label class="form-label">Durum</label>
                                <select class="form-select" id="visaStatus" name="status">
                                    <option value="pending">Beklemede</option>
                                    <option value="approved">Kabul Edildi</option>
                                    <option value="rejected">Reddedildi</option>
                                </select>
                            </div>
                            
                            <!-- Notlar -->
                            <div class="mb-3">
                                <label class="form-label">Notlar</label>
                                <textarea class="form-control" id="visaNotes" name="notes" rows="3" placeholder="Ek notlar..."></textarea>
                            </div>
                        </form>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                        <button type="button" class="btn btn-success" onclick="saveVisaApplication()">
                            <i class="fas fa-save me-2"></i>Kaydet
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- User Selection Modal -->
        <div class="modal fade" id="userSelectionModal" tabindex="-1" aria-labelledby="userSelectionModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
                <div class="modal-content">
                    <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title" id="userSelectionModalLabel">
                            <i class="fas fa-user-plus me-2"></i>Öğrenci Seçimi
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body" style="max-height: 60vh; overflow-y: auto;">
                        <!-- Search Bar -->
                        <div class="mb-3">
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-search"></i></span>
                                <input type="text" class="form-control" id="userSearchInput" placeholder="Öğrenci ara (ad, soyad, e-posta)...">
                            </div>
                        </div>

                        <!-- Users List -->
                        <div class="table-responsive">
                            <table class="table table-hover" id="usersTable">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>Öğrenci</th>
                                        <th>E-posta</th>
                                        <th>Telefon</th>
                                        <th>Başvuru Durumu</th>
                                        <th>Kayıt Tarihi</th>
                                        <th>İşlem</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (typeof users !== 'undefined' && users) { %>
                                        <% users.forEach(user => { %>
                                        <tr class="user-row" data-name="<%= user.first_name.toLowerCase() %> <%= user.last_name.toLowerCase() %>" data-email="<%= user.email.toLowerCase() %>">
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="avatar-sm me-2">
                                                        <i class="fas fa-user-circle fa-2x text-primary"></i>
                                                    </div>
                                                    <div>
                                                        <strong><%= user.first_name %> <%= user.last_name %></strong>
                                                        <% if (user.is_admin) { %>
                                                            <span class="badge bg-danger ms-1">Admin</span>
                                                        <% } %>
                                                    </div>
                                                </div>
                                            </td>
                                            <td><%= user.email %></td>
                                            <td><%= user.phone || '-' %></td>
                                            <td>
                                                <% if (user.application_status) { %>
                                                    <% if (user.application_status === 'pending') { %>
                                                        <span class="badge bg-warning">Beklemede</span>
                                                    <% } else if (user.application_status === 'approved') { %>
                                                        <span class="badge bg-success">Onaylandı</span>
                                                    <% } else if (user.application_status === 'rejected') { %>
                                                        <span class="badge bg-danger">Reddedildi</span>
                                                    <% } %>
                                                <% } else { %>
                                                    <span class="text-muted">Başvuru Yok</span>
                                                <% } %>
                                            </td>
                                            <td><%= new Date(user.created_at).toLocaleDateString('tr-TR') %></td>
                                            <td>
                                                <button class="btn btn-sm btn-primary js-select-user" 
                                                        data-user-id="<%= user.id %>" 
                                                        data-user-first-name="<%= user.first_name %>" 
                                                        data-user-last-name="<%= user.last_name %>" 
                                                        data-user-email="<%= user.email %>"
                                                        data-application-status="<%= user.application_status || 'none' %>"
                                                        data-application-id="<%= user.application_id || '' %>">
                                                    <i class="fas fa-check me-1"></i>Seç
                                                </button>
                                            </td>
                                        </tr>
                                        <% }); %>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Event delegation for all buttons
    document.addEventListener('DOMContentLoaded', function() {
        // Open user selection modal button
        document.getElementById('openUserSelectionModalBtn').addEventListener('click', openUserSelectionModal);
        
        // Event delegation for application action buttons
        document.addEventListener('click', function(e) {
            const editBtn = e.target.closest('.js-edit-application');
            const approveBtn = e.target.closest('.js-approve-application');
            const rejectBtn = e.target.closest('.js-reject-application');
            const pendingBtn = e.target.closest('.js-pending-application');
            const deleteBtn = e.target.closest('.js-delete-application');
            const selectUserBtn = e.target.closest('.js-select-user');

            if (editBtn) {
                const appId = editBtn.getAttribute('data-application-id');
                editApplication(appId);
                return;
            }

            if (approveBtn) {
                const appId = approveBtn.getAttribute('data-application-id');
                approveApplication(appId);
                return;
            }

            if (rejectBtn) {
                const appId = rejectBtn.getAttribute('data-application-id');
                rejectApplication(appId);
                return;
            }

            if (pendingBtn) {
                const appId = pendingBtn.getAttribute('data-application-id');
                pendingApplication(appId);
                return;
            }

            if (deleteBtn) {
                const appId = deleteBtn.getAttribute('data-application-id');
                deleteApplication(appId);
                return;
            }

            if (selectUserBtn) {
                const userId = selectUserBtn.getAttribute('data-user-id');
                const firstName = selectUserBtn.getAttribute('data-user-first-name');
                const lastName = selectUserBtn.getAttribute('data-user-last-name');
                const email = selectUserBtn.getAttribute('data-user-email');
                const applicationStatus = selectUserBtn.getAttribute('data-application-status');
                const applicationId = selectUserBtn.getAttribute('data-application-id');
                selectUser(userId, firstName, lastName, email, applicationStatus, applicationId);
                return;
            }
        });

        // Fee toggle event listener
        document.addEventListener('change', function(e) {
            if (e.target.classList.contains('js-fee-toggle')) {
                const appId = e.target.getAttribute('data-application-id');
                const isPaid = e.target.checked;
                toggleApplicationFee(appId, isPaid);
            }
        });
    });

    // Modal ve arama işlevselliği
    let selectedUserId = null;
    let selectedUserName = '';
    let selectedUserEmail = '';

    function openUserSelectionModal() {
        // Modal'ı aç
        const modal = new bootstrap.Modal(document.getElementById('userSelectionModal'));
        modal.show();
        
        // Arama input'unu temizle
        document.getElementById('userSearchInput').value = '';
        filterUsers('');
        
        // Arama fonksiyonunu kur
        setupUserSearch();
    }

    function selectUser(userId, firstName, lastName, email, applicationStatus, applicationId) {
        selectedUserId = userId;
        selectedUserName = `${firstName} ${lastName}`;
        selectedUserEmail = email;
        
        // Modal'ı kapat
        const modal = bootstrap.Modal.getInstance(document.getElementById('userSelectionModal'));
        modal.hide();
        
        // Başvuru durumuna göre yönlendir
        if (applicationStatus && applicationStatus !== 'none' && applicationId) {
            // Mevcut başvuru varsa düzenleme sayfasına yönlendir
            window.location.href = `/admin/applications/${applicationId}/edit`;
        } else {
            // Başvuru yoksa aynı sayfada yeni başvuru formunu göster
            showNewApplicationForm(userId, firstName, lastName, email);
        }
    }

    // Modal arama fonksiyonu - Modal açıldığında event listener ekle
    function setupUserSearch() {
        const userSearchInput = document.getElementById('userSearchInput');
        if (userSearchInput) {
            userSearchInput.addEventListener('input', function() {
                filterUsers(this.value);
            });
        }
    }

    function filterUsers(searchTerm) {
        const rows = document.querySelectorAll('.user-row');
        const term = searchTerm.toLowerCase().trim();
        
        if (term === '') {
            // Arama terimi boşsa tüm satırları göster
            rows.forEach(row => {
                row.style.display = '';
            });
            return;
        }
        
        rows.forEach(row => {
            const name = row.getAttribute('data-name') || '';
            const email = row.getAttribute('data-email') || '';
            const phone = row.querySelector('td:nth-child(3)')?.textContent?.toLowerCase() || '';
            
            if (name.includes(term) || email.includes(term) || phone.includes(term)) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }


