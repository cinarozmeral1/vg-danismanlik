    function toggleApplicationFee(appId, isPaid) {
        console.log(`Toggling fee for application ${appId} to:`, isPaid);
        
        fetch(`/api/admin/applications/${appId}/fee-status`, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                application_fee_paid: isPaid
            })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                console.log('✅ Fee status updated successfully');
                // Update the label text
                const label = document.querySelector(`label[for="feeToggle${appId}"] span`);
                if (label) {
                    if (isPaid) {
                        label.innerHTML = '<i class="fas fa-check-circle"></i> Ödendi';
                        label.className = 'text-success';
                    } else {
                        label.innerHTML = '<i class="fas fa-times-circle"></i> Ödenmedi';
                        label.className = 'text-danger';
                    }
                }
            } else {
                alert('Hata: ' + data.message);
                // Revert the toggle
                const toggle = document.getElementById(`feeToggle${appId}`);
                if (toggle) toggle.checked = !isPaid;
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Bir hata oluştu!');
            // Revert the toggle
            const toggle = document.getElementById(`feeToggle${appId}`);
            if (toggle) toggle.checked = !isPaid;
        });
    }

    // ==================== VISA APPLICATION FUNCTIONS ====================
    
