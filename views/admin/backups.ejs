<%- include('layout') %>

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2><i class="fas fa-database me-2"></i>Yedek Yönetimi</h2>
                    <p class="text-muted mb-0">FTP sunucusundaki yedekleri görüntüleyin ve indirin</p>
                </div>
                <div>
                    <button class="btn btn-primary" onclick="runBackup()">
                        <i class="fas fa-plus-circle me-2"></i>Yeni Yedek Al
                    </button>
                    <button class="btn btn-outline-secondary" onclick="refreshBackups()">
                        <i class="fas fa-sync-alt me-2"></i>Yenile
                    </button>
                </div>
            </div>

            <!-- Backup Info Card -->
            <div class="card mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Yedekleme Bilgileri</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Otomatik Yedekleme:</strong> Her gün saat 02:00</p>
                            <p><strong>Yedek Saklama:</strong> 30 gün</p>
                            <p><strong>FTP Sunucu:</strong> <%= typeof process !== 'undefined' && process.env && process.env.FTP_HOST ? process.env.FTP_HOST : 'Yapılandırılmamış' %></p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Yedek İçeriği:</strong></p>
                            <ul class="mb-0">
                                <li>PostgreSQL veritabanı</li>
                                <li>Tüm dosyalar (uploads, images, config, etc.)</li>
                                <li>ZIP formatında sıkıştırılmış</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Backups List -->
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-list me-2"></i>Yedek Listesi</h5>
                </div>
                <div class="card-body">
                    <div id="backupsListContainer">
                        <div class="text-center py-5">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Yükleniyor...</span>
                            </div>
                            <p class="mt-3 text-muted">Yedekler yükleniyor...</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .backup-item {
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 1.25rem;
        margin-bottom: 1rem;
        transition: all 0.2s ease;
    }
    
    .backup-item:hover {
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        transform: translateY(-2px);
    }
    
    .backup-info {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }
    
    .backup-details {
        flex: 1;
        min-width: 200px;
    }
    
    .backup-actions {
        display: flex;
        gap: 0.5rem;
    }
    
    .backup-filename {
        font-weight: 600;
        color: #212529;
        margin-bottom: 0.5rem;
    }
    
    .backup-meta {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
        font-size: 0.9rem;
        color: #6c757d;
    }
    
    .backup-meta-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .empty-state {
        text-align: center;
        padding: 3rem 1rem;
        color: #6c757d;
    }
    
    .empty-state i {
        font-size: 4rem;
        margin-bottom: 1rem;
        opacity: 0.5;
    }
</style>

<script>
let isLoading = false;

// Load backups on page load
document.addEventListener('DOMContentLoaded', function() {
    loadBackups();
});

// Load backups from FTP
async function loadBackups() {
    if (isLoading) return;
    
    isLoading = true;
    const container = document.getElementById('backupsListContainer');
    container.innerHTML = `
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
            <p class="mt-3 text-muted">Yedekler yükleniyor...</p>
        </div>
    `;
    
    try {
        const response = await fetch('/admin/api/backup/list');
        const data = await response.json();
        
        if (data.success && data.backups && data.backups.length > 0) {
            displayBackups(data.backups);
        } else {
            container.innerHTML = `
                <div class="empty-state">
                    <i class="fas fa-inbox"></i>
                    <h5>Henüz yedek bulunmuyor</h5>
                    <p class="text-muted">İlk yedeği almak için "Yeni Yedek Al" butonuna tıklayın.</p>
                </div>
            `;
        }
    } catch (error) {
        console.error('Error loading backups:', error);
        container.innerHTML = `
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-triangle me-2"></i>
                Yedekler yüklenirken bir hata oluştu: ${error.message}
            </div>
        `;
    } finally {
        isLoading = false;
    }
}

// Display backups in the UI
function displayBackups(backups) {
    const container = document.getElementById('backupsListContainer');
    
    if (backups.length === 0) {
        container.innerHTML = `
            <div class="empty-state">
                <i class="fas fa-inbox"></i>
                <h5>Henüz yedek bulunmuyor</h5>
                <p class="text-muted">İlk yedeği almak için "Yeni Yedek Al" butonuna tıklayın.</p>
            </div>
        `;
        return;
    }
    
    const backupsHTML = backups.map(backup => `
        <div class="backup-item">
            <div class="backup-info">
                <div class="backup-details">
                    <div class="backup-filename">
                        <i class="fas fa-file-archive text-primary me-2"></i>
                        ${backup.filename}
                    </div>
                    <div class="backup-meta">
                        <div class="backup-meta-item">
                            <i class="fas fa-calendar"></i>
                            <span>${backup.modifiedAtFormatted || 'Tarih bilgisi yok'}</span>
                        </div>
                        <div class="backup-meta-item">
                            <i class="fas fa-hdd"></i>
                            <span>${backup.sizeMB} MB</span>
                        </div>
                    </div>
                </div>
                <div class="backup-actions">
                    <a href="/admin/api/backup/download/${encodeURIComponent(backup.filename)}" 
                       class="btn btn-primary btn-sm"
                       download>
                        <i class="fas fa-download me-2"></i>İndir
                    </a>
                </div>
            </div>
        </div>
    `).join('');
    
    container.innerHTML = `
        <div class="mb-3">
            <strong>Toplam ${backups.length} yedek bulundu</strong>
        </div>
        ${backupsHTML}
    `;
}

// Refresh backups list
function refreshBackups() {
    loadBackups();
}

// Run manual backup
async function runBackup() {
    if (!confirm('Yeni yedek oluşturulacak. Devam etmek istiyor musunuz?')) {
        return;
    }
    
    const btn = event.target.closest('button');
    const originalHTML = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Yedekleniyor...';
    
    try {
        const response = await fetch('/admin/api/backup/run', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            }
        });
        
        const data = await response.json();
        
        if (data.success) {
            alert('Yedekleme başlatıldı! Arka planda çalışıyor. Birkaç dakika sonra listeyi yenileyin.');
            // Refresh list after 5 seconds
            setTimeout(() => {
                refreshBackups();
            }, 5000);
        } else {
            alert('Yedekleme başlatılamadı: ' + data.message);
        }
    } catch (error) {
        console.error('Backup error:', error);
        alert('Yedekleme başlatılırken bir hata oluştu: ' + error.message);
    } finally {
        btn.disabled = false;
        btn.innerHTML = originalHTML;
    }
}

// Auto-refresh every 30 seconds (optional)
// setInterval(refreshBackups, 30000);
</script>
