<!-- Admin Dashboard Content -->
<div class="admin-container">
    <!-- Sidebar -->
    <div class="admin-sidebar">
        <div class="sidebar-header">
            <h6 class="mb-0"><i class="fas fa-cog me-2"></i>Yönetim Paneli</h6>
        </div>
        <nav class="sidebar-nav">
            <a href="/admin/dashboard" class="nav-item active">
                <i class="fas fa-tachometer-alt"></i>
                <span>Dashboard</span>
            </a>
            <a href="/admin/users" class="nav-item">
                <i class="fas fa-users"></i>
                <span>Öğrenciler</span>
                <span class="badge bg-primary ms-auto"><%= userCount %></span>
            </a>
            <a href="/admin/applications" class="nav-item">
                <i class="fas fa-file-alt"></i>
                <span>Başvurular</span>
                <span class="badge bg-success ms-auto"><%= applicationCount %></span>
            </a>
            <a href="/admin/universities" class="nav-item">
                <i class="fas fa-university"></i>
                <span>Üniversiteler</span>
            </a>
            <a href="/admin/backups" class="nav-item">
                <i class="fas fa-database"></i>
                <span>Yedekleme</span>
            </a>
        </nav>
    </div>

    <!-- Main Content Area -->
    <div class="admin-main">
        <!-- Dashboard Section -->
        <div class="section-header">
            <h2><i class="fas fa-tachometer-alt me-2"></i>Dashboard</h2>
            <p class="text-muted">Sistem genel durumu ve istatistikler</p>
        </div>

        <!-- Statistics Cards -->
        <div class="stats-grid">
            <div class="stat-card primary">
                <div class="stat-icon">
                    <i class="fas fa-users"></i>
                </div>
                <div class="stat-content">
                    <h3><%= userCount %></h3>
                    <p>Toplam Öğrenci</p>
                    <div class="stat-trend positive">
                        <i class="fas fa-arrow-up"></i>
                        <span>+0%</span>
                    </div>
                </div>
            </div>

            <div class="stat-card success">
                <div class="stat-icon">
                    <i class="fas fa-file-alt"></i>
                </div>
                <div class="stat-content">
                    <h3><%= applicationCount %></h3>
                    <p>Toplam Başvuru</p>
                    <div class="stat-trend positive">
                        <i class="fas fa-arrow-up"></i>
                        <span>+0%</span>
                    </div>
                </div>
            </div>

            <div class="stat-card warning">
                <div class="stat-icon">
                    <i class="fas fa-clock"></i>
                </div>
                <div class="stat-content">
                    <h3><%= typeof pendingApplicationCount !== 'undefined' ? pendingApplicationCount : applicationCount %></h3>
                    <p>Bekleyen Başvuru</p>
                    <div class="stat-trend neutral">
                        <i class="fas fa-minus"></i>
                        <span>0%</span>
                    </div>
                </div>
            </div>

            <div class="stat-card info">
                <div class="stat-icon">
                    <i class="fas fa-check-circle"></i>
                </div>
                <div class="stat-content">
                    <h3><%= typeof approvedApplicationCount !== 'undefined' ? approvedApplicationCount : 0 %></h3>
                    <p>Onaylanan Başvuru</p>
                    <div class="stat-trend positive">
                        <i class="fas fa-arrow-up"></i>
                        <span>+0%</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Net Profit Card -->
        <div class="row mt-4">
            <div class="col-12">
                <div class="card financial-card profit-card" id="netProfitCard">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-calculator me-2"></i>
                            Net Kar Hesaplama
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4">
                                <div class="financial-stat">
                                    <h6 class="text-muted mb-2">Toplam Gelir</h6>
                                    <h4 class="mb-0 text-success" id="totalRevenue">0.00 EUR</h4>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="financial-stat">
                                    <h6 class="text-muted mb-2">Toplam Alacaklar</h6>
                                    <h4 class="mb-0 text-warning" id="totalReceivables">0.00 EUR</h4>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="financial-stat">
                                    <h6 class="text-muted mb-2">Net Kar</h6>
                                    <h4 class="mb-0 text-primary" id="netProfit">0.00 EUR</h4>
                                </div>
                            </div>
                        </div>
                        <div class="row mt-3">
                            <div class="col-md-12">
                                <label class="form-label">Zaman Aralığı:</label>
                                <select class="form-select form-select-sm" id="profitPeriodFilter">
                                    <option value="7days">Son 7 Gün</option>
                                    <option value="30days">Son 30 Gün</option>
                                    <option value="90days">Son 90 Gün</option>
                                    <option value="1year">Son 1 Yıl</option>
                                    <option value="all" selected>Tüm Zamanlar</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Financial Filters and Controls -->
        <div class="row mt-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-filter me-2"></i>Finansal Filtreler</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <label class="form-label">Zaman Aralığı:</label>
                                <select class="form-select" id="periodFilter">
                                    <option value="7days">Son 7 Gün</option>
                                    <option value="30days" selected>Son 30 Gün</option>
                                    <option value="90days">Son 90 Gün</option>
                                    <option value="1year">Son 1 Yıl</option>
                                    <option value="all">Tüm Zamanlar</option>
                                </select>
                            </div>
                            <div class="col-md-6 d-flex align-items-end">
                                <button class="btn btn-primary w-100" onclick="refreshFinancialData()">
                                    <i class="fas fa-sync-alt me-2"></i>Yenile
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Financial Overview -->
        <div class="row mt-4">
            <div class="col-lg-6">
                <div class="card financial-card receivables-card">
                    <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="fas fa-money-bill-wave me-2"></i>
                            Alacaklar (Ödenmemiş)
                        </h5>
                        <button class="btn btn-sm btn-outline-dark" onclick="exportFinancialData('receivables')" title="CSV Olarak İndir">
                            <i class="fas fa-download"></i>
                        </button>
                    </div>
                    <div class="card-body">
                        <div class="financial-total">
                            <h3 class="mb-0" id="receivablesTotal">0.00 EUR</h3>
                            <p class="text-muted mb-3">Toplam Alacak</p>
                        </div>
                        <div class="financial-list">
                            <h6 class="mb-3">
                                <i class="fas fa-list me-2"></i>
                                Öğrenci Listesi (<span id="receivablesCount">0</span> öğrenci)
                            </h6>
                            <div id="receivablesListContainer">
                                <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                                    <table class="table table-sm table-hover" id="receivablesTable">
                                        <thead class="table-light sticky-top">
                                            <tr>
                                                <th>Öğrenci</th>
                                                <th>Hizmet</th>
                                                <th>Tutar</th>
                                                <th>Vade Tarihi</th>
                                            </tr>
                                        </thead>
                                        <tbody id="receivablesTableBody">
                                            <tr>
                                                <td colspan="4" class="text-center text-muted py-3">
                                                    <i class="fas fa-spinner fa-spin me-2"></i>Yükleniyor...
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card financial-card revenue-card">
                    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="fas fa-chart-line me-2"></i>
                            Gelirler
                        </h5>
                        <button class="btn btn-sm btn-outline-light" onclick="exportFinancialData('revenue')" title="CSV Olarak İndir">
                            <i class="fas fa-download"></i>
                        </button>
                    </div>
                    <div class="card-body">
                        <div class="financial-total">
                            <h3 class="mb-0" id="revenueTotal">0.00 EUR</h3>
                            <p class="text-muted mb-3" id="revenuePeriodLabel">Son 30 Günlük Ciro</p>
                        </div>
                        <div class="financial-list">
                            <h6 class="mb-3">
                                <i class="fas fa-list me-2"></i>
                                Öğrenci Listesi (<span id="revenueCount">0</span> öğrenci)
                            </h6>
                            <div id="revenueListContainer">
                                <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                                    <table class="table table-sm table-hover" id="revenueTable">
                                        <thead class="table-light sticky-top">
                                            <tr>
                                                <th>Öğrenci</th>
                                                <th>Hizmet</th>
                                                <th>Tutar</th>
                                                <th>Ödeme Tarihi</th>
                                            </tr>
                                        </thead>
                                        <tbody id="revenueTableBody">
                                            <tr>
                                                <td colspan="4" class="text-center text-muted py-3">
                                                    <i class="fas fa-spinner fa-spin me-2"></i>Yükleniyor...
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Activity -->
        <div class="row mt-4">
            <div class="col-lg-6">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-users me-2"></i>Son Öğrenciler</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Öğrenci</th>
                                        <th>E-posta</th>
                                        <th>Kayıt Tarihi</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% users.slice(0, 5).forEach(user => { %>
                                    <tr>
                                        <td><%= user.first_name %> <%= user.last_name %></td>
                                        <td><%= user.email %></td>
                                        <td><%= new Date(user.created_at).toLocaleDateString('tr-TR') %></td>
                                    </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-6">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-file-alt me-2"></i>Son Başvurular</h5>
                    </div>
                    <div class="card-body">
                        <% if (applications.length > 0) { %>
                            <div class="table-responsive">
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>Öğrenci</th>
                                            <th>Ülke</th>
                                            <th>Durum</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% applications.slice(0, 5).forEach(app => { %>
                                        <tr>
                                            <td><%= app.first_name %> <%= app.last_name %></td>
                                            <td><%= app.country %></td>
                                            <td>
                                                <% if (app.status === 'pending') { %>
                                                    <span class="badge bg-warning">Beklemede</span>
                                                <% } else if (app.status === 'approved') { %>
                                                    <span class="badge bg-success">Onaylandı</span>
                                                <% } else if (app.status === 'rejected') { %>
                                                    <span class="badge bg-danger">Reddedildi</span>
                                                <% } %>
                                            </td>
                                        </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        <% } else { %>
                            <p class="text-muted mb-0">Henüz başvuru bulunmuyor.</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div> 

<script>
// Financial Dashboard JavaScript
let currentFilters = {
    period: '30days'
};

// Initialize on page load
document.addEventListener('DOMContentLoaded', function() {
    loadFinancialData();
    loadNetProfit();
    
    // Add event listeners for filters
    document.getElementById('periodFilter').addEventListener('change', function() {
        currentFilters.period = this.value;
        loadFinancialData();
        loadNetProfit();
    });
    
    // Net profit filter
    document.getElementById('profitPeriodFilter').addEventListener('change', function() {
        loadNetProfit();
    });
});

// Load financial data (receivables and revenue)
async function loadFinancialData() {
    const period = document.getElementById('periodFilter').value;
    
    // Load receivables (all currencies)
    try {
        const receivablesResponse = await fetch(`/admin/api/financial-data?type=receivables`);
        const receivablesData = await receivablesResponse.json();
        
        if (receivablesData.success) {
            updateReceivablesDisplay(receivablesData.data);
        }
    } catch (error) {
        console.error('Error loading receivables:', error);
    }
    
    // Load revenue (all currencies)
    try {
        const revenueResponse = await fetch(`/admin/api/financial-data?type=revenue&period=${period}`);
        const revenueData = await revenueResponse.json();
        
        if (revenueData.success) {
            updateRevenueDisplay(revenueData.data, period);
        }
    } catch (error) {
        console.error('Error loading revenue:', error);
    }
}

// Update receivables display
function updateReceivablesDisplay(data) {
    // Show totals by currency
    let totalText = '';
    if (data.totalsByCurrency && data.totalsByCurrency.length > 0) {
        totalText = data.totalsByCurrency.map(item => 
            `${parseFloat(item.amount).toFixed(2)} ${item.currency}`
        ).join(' + ');
    } else {
        totalText = '0.00 EUR';
    }
    document.getElementById('receivablesTotal').textContent = totalText;
    document.getElementById('receivablesCount').textContent = data.count;
    
    const tbody = document.getElementById('receivablesTableBody');
    
    if (data.services.length === 0) {
        tbody.innerHTML = `
            <tr>
                <td colspan="4" class="text-center text-muted py-3">
                    <i class="fas fa-inbox me-2"></i>Henüz ödenmemiş hizmet bulunmuyor.
                </td>
            </tr>
        `;
        return;
    }
    
    tbody.innerHTML = data.services.map(service => `
        <tr>
            <td>
                <div>
                    <strong>
                        <a href="/admin/users/${service.user_id}" class="text-decoration-none" style="color: inherit;">
                            ${service.first_name} ${service.last_name}
                        </a>
                    </strong>
                    <br>
                    <small class="text-muted">${service.email}</small>
                </div>
            </td>
            <td>
                <span class="badge bg-secondary">${service.service_name}</span>
            </td>
            <td>
                <strong>${parseFloat(service.amount).toFixed(2)} ${service.currency || 'EUR'}</strong>
            </td>
            <td>
                ${service.due_date ? new Date(service.due_date).toLocaleDateString('tr-TR') : '<span class="text-muted">Belirtilmemiş</span>'}
            </td>
        </tr>
    `).join('');
}

// Update revenue display
function updateRevenueDisplay(data, period) {
    const periodLabels = {
        '7days': 'Son 7 Günlük Ciro',
        '30days': 'Son 30 Günlük Ciro',
        '90days': 'Son 90 Günlük Ciro',
        '1year': 'Son 1 Yıllık Ciro',
        'all': 'Tüm Zamanlar - Toplam Ciro'
    };
    
    // Show totals by currency
    let totalText = '';
    if (data.totalsByCurrency && data.totalsByCurrency.length > 0) {
        totalText = data.totalsByCurrency.map(item => 
            `${parseFloat(item.amount).toFixed(2)} ${item.currency}`
        ).join(' + ');
    } else {
        totalText = '0.00 EUR';
    }
    document.getElementById('revenueTotal').textContent = totalText;
    document.getElementById('revenuePeriodLabel').textContent = periodLabels[period] || 'Toplam Ciro';
    document.getElementById('revenueCount').textContent = data.count;
    
    const tbody = document.getElementById('revenueTableBody');
    
    if (data.services.length === 0) {
        tbody.innerHTML = `
            <tr>
                <td colspan="4" class="text-center text-muted py-3">
                    <i class="fas fa-inbox me-2"></i>Seçilen dönemde tahsil edilen hizmet bulunmuyor.
                </td>
            </tr>
        `;
        return;
    }
    
    tbody.innerHTML = data.services.map(service => `
        <tr>
            <td>
                <div>
                    <strong>
                        <a href="/admin/users/${service.user_id}" class="text-decoration-none" style="color: inherit;">
                            ${service.first_name} ${service.last_name}
                        </a>
                    </strong>
                    <br>
                    <small class="text-muted">${service.email}</small>
                </div>
            </td>
            <td>
                <span class="badge bg-success">${service.service_name}</span>
            </td>
            <td>
                <strong>${parseFloat(service.amount).toFixed(2)} ${service.currency || 'EUR'}</strong>
            </td>
            <td>
                ${service.payment_date ? new Date(service.payment_date).toLocaleDateString('tr-TR') : '<span class="text-muted">Belirtilmemiş</span>'}
            </td>
        </tr>
    `).join('');
}

// Load net profit
async function loadNetProfit() {
    const period = document.getElementById('profitPeriodFilter').value;
    
    try {
        const response = await fetch(`/admin/api/net-profit?period=${period}`);
        const data = await response.json();
        
        if (data.success && data.data.byCurrency) {
            // Show totals by currency
            const revenueText = data.data.byCurrency.map(item => 
                `${item.revenue.toFixed(2)} ${item.currency}`
            ).join(' + ') || '0.00 EUR';
            
            const receivablesText = data.data.byCurrency.map(item => 
                `${item.receivables.toFixed(2)} ${item.currency}`
            ).join(' + ') || '0.00 EUR';
            
            // Net profit = revenue only (alacaklar borç değil, sadece henüz zamanı gelmemiş)
            const netProfitText = data.data.byCurrency
                .filter(item => item.revenue > 0) // Sadece geliri olan para birimleri
                .map(item => 
                    `${item.revenue.toFixed(2)} ${item.currency}`
                ).join(' + ') || '0.00 EUR';
            
            document.getElementById('totalRevenue').textContent = revenueText;
            document.getElementById('totalReceivables').textContent = receivablesText;
            document.getElementById('netProfit').textContent = netProfitText;
        }
    } catch (error) {
        console.error('Error loading net profit:', error);
    }
}

// Export financial data
function exportFinancialData(type) {
    const period = document.getElementById('periodFilter').value;
    
    window.location.href = `/admin/api/financial-export?type=${type}&period=${period}`;
}

// Refresh all financial data
function refreshFinancialData() {
    loadFinancialData();
    loadNetProfit();
}
</script> 