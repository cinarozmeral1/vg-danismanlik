<!-- Admin Dashboard Content -->
<div class="admin-container">
    <%- include('partials/sidebar') %>

    <!-- Main Content Area -->
    <div class="admin-main">
        <!-- Dashboard Section -->
        <div class="section-header">
            <h2><i class="fas fa-tachometer-alt me-2"></i>Dashboard</h2>
            <p class="text-muted">Sistem genel durumu ve istatistikler</p>
        </div>

        <!-- Statistics Cards -->
        <div class="stats-grid">
            <div class="stat-card primary">
                <div class="stat-icon">
                    <i class="fas fa-users"></i>
                </div>
                <div class="stat-content">
                    <h3><%= userCount %></h3>
                    <p>Toplam Öğrenci</p>
                    <% const userPct = typeof percentChanges !== 'undefined' ? percentChanges.users : 0; %>
                    <div class="stat-trend <%= userPct > 0 ? 'positive' : (userPct < 0 ? 'negative' : 'neutral') %>">
                        <i class="fas fa-arrow-<%= userPct >= 0 ? 'up' : 'down' %>"></i>
                        <span><%= userPct >= 0 ? '+' : '' %><%= userPct %>%</span>
                    </div>
                </div>
            </div>

            <div class="stat-card success">
                <div class="stat-icon">
                    <i class="fas fa-file-alt"></i>
                </div>
                <div class="stat-content">
                    <h3><%= applicationCount %></h3>
                    <p>Toplam Başvuru</p>
                    <% const appPct = typeof percentChanges !== 'undefined' ? percentChanges.applications : 0; %>
                    <div class="stat-trend <%= appPct > 0 ? 'positive' : (appPct < 0 ? 'negative' : 'neutral') %>">
                        <i class="fas fa-arrow-<%= appPct >= 0 ? 'up' : 'down' %>"></i>
                        <span><%= appPct >= 0 ? '+' : '' %><%= appPct %>%</span>
                    </div>
                </div>
            </div>

            <div class="stat-card warning">
                <div class="stat-icon">
                    <i class="fas fa-clock"></i>
                </div>
                <div class="stat-content">
                    <h3><%= typeof pendingApplicationCount !== 'undefined' ? pendingApplicationCount : applicationCount %></h3>
                    <p>Bekleyen Başvuru</p>
                    <% const pendPct = typeof percentChanges !== 'undefined' ? percentChanges.pending : 0; %>
                    <div class="stat-trend <%= pendPct > 0 ? 'negative' : (pendPct < 0 ? 'positive' : 'neutral') %>">
                        <i class="fas fa-arrow-<%= pendPct >= 0 ? 'up' : 'down' %>"></i>
                        <span><%= pendPct >= 0 ? '+' : '' %><%= pendPct %>%</span>
                    </div>
                </div>
            </div>

            <div class="stat-card info">
                <div class="stat-icon">
                    <i class="fas fa-check-circle"></i>
                </div>
                <div class="stat-content">
                    <h3><%= typeof approvedApplicationCount !== 'undefined' ? approvedApplicationCount : 0 %></h3>
                    <p>Onaylanan Başvuru</p>
                    <% const apprPct = typeof percentChanges !== 'undefined' ? percentChanges.approved : 0; %>
                    <div class="stat-trend <%= apprPct > 0 ? 'positive' : (apprPct < 0 ? 'negative' : 'neutral') %>">
                        <i class="fas fa-arrow-<%= apprPct >= 0 ? 'up' : 'down' %>"></i>
                        <span><%= apprPct >= 0 ? '+' : '' %><%= apprPct %>%</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- AI Recommendations Stats -->
        <div class="row mt-4">
            <div class="col-md-6">
                <div class="card shadow-sm" style="border-left: 4px solid #6f42c1;">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">AI Önerileri</h6>
                                <h3 class="mb-0 text-dark" id="aiRecommendationCount">0</h3>
                                <small class="text-muted">Bu ay: <span id="aiRecommendationThisMonth">0</span></small>
                            </div>
                            <div class="rounded-circle p-3" style="background: rgba(111, 66, 193, 0.1);">
                                <i class="fas fa-magic fa-2x" style="color: #6f42c1;"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card shadow-sm" style="border-left: 4px solid #fd7e14;">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Hazırlık Gerekli</h6>
                                <h3 class="mb-0" id="prepSchoolNeededCount">0</h3>
                                <small class="text-muted">öğrenciye hazırlık programı önerildi</small>
                            </div>
                            <div class="rounded-circle p-3" style="background: rgba(253, 126, 20, 0.1);">
                                <i class="fas fa-book-reader fa-2x" style="color: #fd7e14;"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin) { %>
        <!-- Student-Based Profitability Card -->
        <div class="row mt-4">
            <div class="col-12">
                <div class="card financial-card profit-card" id="netProfitCard">
                    <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="fas fa-calculator me-2"></i>
                            Öğrenci Bazlı Karlılık
                        </h5>
                        <select class="form-select form-select-sm" id="profitPeriodFilter" style="width: auto; min-width: 160px; color: #333;">
                            <option value="all" selected>Tüm Zamanlar</option>
                            <option value="7days">Son 7 Gün</option>
                            <option value="30days">Son 30 Gün</option>
                            <option value="90days">Son 3 Ay</option>
                            <option value="1year">Son 1 Yıl</option>
                        </select>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <div class="financial-stat">
                                    <h6 class="text-muted mb-2">Toplam Gelir</h6>
                                    <h4 class="mb-0 text-success" id="totalRevenue">0.00 EUR</h4>
                                </div>
                            </div>
                            <div class="col-md-4" id="expenseStatCard">
                                <div class="financial-stat">
                                    <h6 class="text-muted mb-2">Toplam Gider</h6>
                                    <h4 class="mb-0 text-danger" id="totalExpenses">0.00 EUR</h4>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="financial-stat">
                                    <h6 class="text-muted mb-2">Net Kar</h6>
                                    <h4 class="mb-0 text-primary" id="netProfit">0.00 EUR</h4>
                                </div>
                            </div>
                        </div>
                        <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                            <table class="table table-sm table-hover" id="profitabilityTable">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>Öğrenci</th>
                                        <th class="text-end">Gelir</th>
                                        <th class="text-end expense-col">Gider</th>
                                        <th class="text-end">Net Kar</th>
                                    </tr>
                                </thead>
                                <tbody id="profitabilityTableBody">
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-3">
                                            <i class="fas fa-spinner fa-spin me-2"></i>Yükleniyor...
                                        </td>
                                    </tr>
                                </tbody>
                                <tfoot class="table-light" id="profitabilityFooter">
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Financial Filters and Controls (Sadece Super Admin) -->
        <div class="row mt-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-filter me-2"></i>Finansal Filtreler</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <label class="form-label">Zaman Aralığı:</label>
                                <select class="form-select" id="periodFilter">
                                    <option value="7days">Son 7 Gün</option>
                                    <option value="30days">Son 30 Gün</option>
                                    <option value="90days" selected>Son 3 Ay</option>
                                    <option value="1year">Son 1 Yıl</option>
                                    <option value="all">Tüm Zamanlar</option>
                                </select>
                            </div>
                            <div class="col-md-6 d-flex align-items-end">
                                <button class="btn btn-primary w-100" onclick="refreshFinancialData()">
                                    <i class="fas fa-sync-alt me-2"></i>Yenile
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Financial Overview -->
        <div class="row mt-4">
            <div class="col-lg-6">
                <div class="card financial-card receivables-card">
                    <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="fas fa-money-bill-wave me-2"></i>
                            Alacaklar (Ödenmemiş)
                        </h5>
                        <button class="btn btn-sm btn-outline-dark" onclick="exportFinancialData('receivables')" title="CSV Olarak İndir">
                            <i class="fas fa-download"></i>
                        </button>
                    </div>
                    <div class="card-body">
                        <div class="financial-total">
                            <h3 class="mb-0" id="receivablesTotal">0.00 EUR</h3>
                            <p class="text-muted mb-3">Toplam Alacak</p>
                        </div>
                        <div class="financial-list">
                            <h6 class="mb-3">
                                <i class="fas fa-list me-2"></i>
                                Öğrenci Listesi (<span id="receivablesCount">0</span> öğrenci)
                            </h6>
                            <div id="receivablesListContainer">
                                <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                                    <table class="table table-sm table-hover" id="receivablesTable">
                                        <thead class="table-light sticky-top">
                                            <tr>
                                                <th>Öğrenci</th>
                                                <th>Hizmet</th>
                                                <th>Tutar</th>
                                                <th>Vade Tarihi</th>
                                            </tr>
                                        </thead>
                                        <tbody id="receivablesTableBody">
                                            <tr>
                                                <td colspan="4" class="text-center text-muted py-3">
                                                    <i class="fas fa-spinner fa-spin me-2"></i>Yükleniyor...
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card financial-card revenue-card">
                    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="fas fa-chart-line me-2"></i>
                            Gelirler
                        </h5>
                        <button class="btn btn-sm btn-outline-light" onclick="exportFinancialData('revenue')" title="CSV Olarak İndir">
                            <i class="fas fa-download"></i>
                        </button>
                    </div>
                    <div class="card-body">
                        <div class="financial-total">
                            <h3 class="mb-0" id="revenueTotal">0.00 EUR</h3>
                            <p class="text-muted mb-3" id="revenuePeriodLabel">Son 30 Günlük Ciro</p>
                        </div>
                        <div class="financial-list">
                            <h6 class="mb-3">
                                <i class="fas fa-list me-2"></i>
                                Öğrenci Listesi (<span id="revenueCount">0</span> öğrenci)
                            </h6>
                            <div id="revenueListContainer">
                                <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                                    <table class="table table-sm table-hover" id="revenueTable">
                                        <thead class="table-light sticky-top">
                                            <tr>
                                                <th>Öğrenci</th>
                                                <th>Hizmet</th>
                                                <th>Tutar</th>
                                                <th>Ödeme Tarihi</th>
                                            </tr>
                                        </thead>
                                        <tbody id="revenueTableBody">
                                            <tr>
                                                <td colspan="4" class="text-center text-muted py-3">
                                                    <i class="fas fa-spinner fa-spin me-2"></i>Yükleniyor...
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Giderler section removed - merged into student profitability above -->
        <% } %>

        <!-- Recent Activity -->
        <div class="row mt-4">
            <div class="col-lg-6">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-users me-2"></i>Son Öğrenciler</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Öğrenci</th>
                                        <th>E-posta</th>
                                        <th>Kayıt Tarihi</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% users.slice(0, 5).forEach(user => { %>
                                    <tr>
                                        <td><%= user.first_name %> <%= user.last_name %></td>
                                        <td><%= user.email %></td>
                                        <td><%= new Date(user.created_at).toLocaleDateString('tr-TR') %></td>
                                    </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-6">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-file-alt me-2"></i>Son Başvurular</h5>
                    </div>
                    <div class="card-body">
                        <% if (applications.length > 0) { %>
                            <div class="table-responsive">
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>Öğrenci</th>
                                            <th>Ülke</th>
                                            <th>Durum</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% applications.slice(0, 5).forEach(app => { %>
                                        <tr>
                                            <td><%= app.first_name %> <%= app.last_name %></td>
                                            <td><%= app.country %></td>
                                            <td>
                                                <% if (app.status === 'pending') { %>
                                                    <span class="badge bg-warning">Beklemede</span>
                                                <% } else if (app.status === 'approved') { %>
                                                    <span class="badge bg-success">Onaylandı</span>
                                                <% } else if (app.status === 'rejected') { %>
                                                    <span class="badge bg-danger">Reddedildi</span>
                                                <% } %>
                                            </td>
                                        </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        <% } else { %>
                            <p class="text-muted mb-0">Henüz başvuru bulunmuyor.</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div> 

<script>
// Financial Dashboard JavaScript
let currentFilters = {
    period: '30days'
};

// Initialize on page load
document.addEventListener('DOMContentLoaded', function() {
    loadFinancialData();
    loadStudentProfitability();
    loadAIRecommendationStats();
    
    // Add event listeners for filters
    document.getElementById('periodFilter').addEventListener('change', function() {
        currentFilters.period = this.value;
        loadFinancialData();
    });
    
    // Student profitability filter (revenue period only)
    const profitFilter = document.getElementById('profitPeriodFilter');
    if (profitFilter) {
        profitFilter.addEventListener('change', function() {
            loadStudentProfitability();
        });
    }
});

// Load AI Recommendation Statistics
async function loadAIRecommendationStats() {
    try {
        const response = await fetch('/api/wizard/admin/stats');
        const result = await response.json();
        
        if (result.success) {
            document.getElementById('aiRecommendationCount').textContent = result.data.total || 0;
            document.getElementById('aiRecommendationThisMonth').textContent = result.data.thisMonth || 0;
            document.getElementById('prepSchoolNeededCount').textContent = result.data.prepSchoolNeeded || 0;
        }
    } catch (error) {
        console.error('AI stats load error:', error);
    }
}

// Load financial data (receivables and revenue)
async function loadFinancialData() {
    const period = document.getElementById('periodFilter').value;
    
    // Load receivables (all currencies)
    try {
        const receivablesResponse = await fetch(`/admin/api/financial-data?type=receivables`);
        const receivablesData = await receivablesResponse.json();
        
        if (receivablesData.success) {
            updateReceivablesDisplay(receivablesData.data);
        }
    } catch (error) {
        console.error('Error loading receivables:', error);
    }
    
    // Load revenue (all currencies)
    try {
        const revenueResponse = await fetch(`/admin/api/financial-data?type=revenue&period=${period}`);
        const revenueData = await revenueResponse.json();
        
        if (revenueData.success) {
            updateRevenueDisplay(revenueData.data, period);
        }
    } catch (error) {
        console.error('Error loading revenue:', error);
    }
}

// Update receivables display
function updateReceivablesDisplay(data) {
    // Show totals by currency
    let totalText = '';
    if (data.totalsByCurrency && data.totalsByCurrency.length > 0) {
        totalText = data.totalsByCurrency.map(item => 
            `${parseFloat(item.amount).toFixed(2)} ${item.currency}`
        ).join(' + ');
    } else {
        totalText = '0.00 EUR';
    }
    document.getElementById('receivablesTotal').textContent = totalText;
    document.getElementById('receivablesCount').textContent = data.count;
    
    const tbody = document.getElementById('receivablesTableBody');
    
    if (data.services.length === 0) {
        tbody.innerHTML = `
            <tr>
                <td colspan="4" class="text-center text-muted py-3">
                    <i class="fas fa-inbox me-2"></i>Henüz ödenmemiş hizmet bulunmuyor.
                </td>
            </tr>
        `;
        return;
    }
    
    tbody.innerHTML = data.services.map(service => `
        <tr>
            <td>
                <div>
                    <strong>
                        <a href="/admin/users/${service.user_id}" class="text-decoration-none" style="color: inherit;">
                            ${service.first_name} ${service.last_name}
                        </a>
                    </strong>
                    <br>
                    <small class="text-muted">${service.email}</small>
                </div>
            </td>
            <td>
                <span class="badge bg-secondary">${service.service_name}</span>
            </td>
            <td>
                <strong>${parseFloat(service.amount).toFixed(2)} ${service.currency || 'EUR'}</strong>
            </td>
            <td>
                ${service.due_date ? new Date(service.due_date).toLocaleDateString('tr-TR') : '<span class="text-muted">Belirtilmemiş</span>'}
            </td>
        </tr>
    `).join('');
}

// Update revenue display
function updateRevenueDisplay(data, period) {
    const periodLabels = {
        '7days': 'Son 7 Günlük Ciro',
        '30days': 'Son 30 Günlük Ciro',
        '90days': 'Son 90 Günlük Ciro',
        '1year': 'Son 1 Yıllık Ciro',
        'all': 'Tüm Zamanlar - Toplam Ciro'
    };
    
    // Show totals by currency
    let totalText = '';
    if (data.totalsByCurrency && data.totalsByCurrency.length > 0) {
        totalText = data.totalsByCurrency.map(item => 
            `${parseFloat(item.amount).toFixed(2)} ${item.currency}`
        ).join(' + ');
    } else {
        totalText = '0.00 EUR';
    }
    document.getElementById('revenueTotal').textContent = totalText;
    document.getElementById('revenuePeriodLabel').textContent = periodLabels[period] || 'Toplam Ciro';
    document.getElementById('revenueCount').textContent = data.count;
    
    const tbody = document.getElementById('revenueTableBody');
    
    if (data.services.length === 0) {
        tbody.innerHTML = `
            <tr>
                <td colspan="4" class="text-center text-muted py-3">
                    <i class="fas fa-inbox me-2"></i>Seçilen dönemde tahsil edilen hizmet bulunmuyor.
                </td>
            </tr>
        `;
        return;
    }
    
    tbody.innerHTML = data.services.map(service => `
        <tr>
            <td>
                <div>
                    <strong>
                        <a href="/admin/users/${service.user_id}" class="text-decoration-none" style="color: inherit;">
                            ${service.first_name} ${service.last_name}
                        </a>
                    </strong>
                    <br>
                    <small class="text-muted">${service.email}</small>
                </div>
            </td>
            <td>
                <span class="badge bg-success">${service.service_name}</span>
            </td>
            <td>
                <strong>${parseFloat(service.amount).toFixed(2)} ${service.currency || 'EUR'}</strong>
            </td>
            <td>
                ${service.payment_date ? new Date(service.payment_date).toLocaleDateString('tr-TR') : '<span class="text-muted">Belirtilmemiş</span>'}
            </td>
        </tr>
    `).join('');
}

// Load student-based profitability
async function loadStudentProfitability() {
    const profitFilter = document.getElementById('profitPeriodFilter');
    const period = profitFilter ? profitFilter.value : 'all';
    
    try {
        const response = await fetch(`/admin/api/student-profitability?period=${period}`);
        const data = await response.json();
        
        if (data.success) {
            updateProfitabilityDisplay(data.data);
        }
    } catch (error) {
        console.error('Error loading student profitability:', error);
    }
}

function formatCurrencyMap(currencyMap) {
    const entries = Object.entries(currencyMap).filter(([, v]) => v !== 0);
    if (entries.length === 0) return '0.00 EUR';
    return entries.map(([cur, amount]) => `${parseFloat(amount).toFixed(2)} ${cur}`).join(' + ');
}

function updateProfitabilityDisplay(data) {
    const profitFilter = document.getElementById('profitPeriodFilter');
    const isAllTime = profitFilter ? profitFilter.value === 'all' : true;
    const colSpan = isAllTime ? 4 : 3;
    
    // Show/hide expense elements based on period
    document.getElementById('expenseStatCard').style.display = isAllTime ? '' : 'none';
    document.querySelectorAll('.expense-col').forEach(el => el.style.display = isAllTime ? '' : 'none');

    // Update summary totals
    document.getElementById('totalRevenue').textContent = formatCurrencyMap(data.totals.revenue);
    if (isAllTime) {
        document.getElementById('totalExpenses').textContent = formatCurrencyMap(data.totals.expenses);
        document.getElementById('netProfit').textContent = formatCurrencyMap(data.totals.netProfit);
    } else {
        document.getElementById('netProfit').textContent = formatCurrencyMap(data.totals.revenue);
    }
    
    const tbody = document.getElementById('profitabilityTableBody');
    const tfoot = document.getElementById('profitabilityFooter');
    
    if (!data.students || data.students.length === 0) {
        tbody.innerHTML = `
            <tr>
                <td colspan="${colSpan}" class="text-center text-muted py-3">
                    <i class="fas fa-inbox me-2"></i>Henüz gelir veya gider kaydı bulunan öğrenci yok.
                </td>
            </tr>
        `;
        tfoot.innerHTML = '';
        return;
    }
    
    tbody.innerHTML = data.students.map(student => {
        const revText = student.byCurrency.map(c => `${c.revenue.toFixed(2)} ${c.currency}`).join(' + ') || '0.00';
        const expText = student.byCurrency.map(c => `${c.expense.toFixed(2)} ${c.currency}`).join(' + ') || '0.00';
        const netText = student.byCurrency.map(c => {
            const val = isAllTime ? c.netProfit : c.revenue;
            const cls = val >= 0 ? 'text-success' : 'text-danger';
            return `<span class="${cls}">${val.toFixed(2)} ${c.currency}</span>`;
        }).join(' + ') || '0.00';
        
        const expCol = isAllTime ? `<td class="text-end text-danger expense-col"><strong>${expText}</strong></td>` : '';
        
        return `
            <tr>
                <td>
                    <a href="/admin/users/${student.user_id}" class="text-decoration-none" style="color: inherit;">
                        <strong>${student.first_name} ${student.last_name}</strong>
                    </a>
                </td>
                <td class="text-end text-success"><strong>${revText}</strong></td>
                ${expCol}
                <td class="text-end"><strong>${netText}</strong></td>
            </tr>
        `;
    }).join('');
    
    // Footer totals
    const totalRevText = formatCurrencyMap(data.totals.revenue);
    const totalExpText = formatCurrencyMap(data.totals.expenses);
    const totalNetText = isAllTime ? formatCurrencyMap(data.totals.netProfit) : formatCurrencyMap(data.totals.revenue);
    const expFootCol = isAllTime ? `<td class="text-end text-danger expense-col">${totalExpText}</td>` : '';
    
    tfoot.innerHTML = `
        <tr class="fw-bold">
            <td>TOPLAM (${data.studentCount} öğrenci)</td>
            <td class="text-end text-success">${totalRevText}</td>
            ${expFootCol}
            <td class="text-end text-primary">${totalNetText}</td>
        </tr>
    `;
}

// Export financial data
function exportFinancialData(type) {
    const period = document.getElementById('periodFilter').value;
    
    window.location.href = `/admin/api/financial-export?type=${type}&period=${period}`;
}

// Refresh all financial data
function refreshFinancialData() {
    loadFinancialData();
    loadStudentProfitability();
}
</script> 