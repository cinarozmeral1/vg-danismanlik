<!-- Admin Edit Application Content -->
<div class="admin-container">
    <%- include('partials/sidebar') %>

    <!-- Main Content Area -->
    <div class="admin-main">
        <!-- Header -->
        <div class="section-header">
            <h2><i class="fas fa-edit me-2"></i>Başvuru Düzenle</h2>
            <p class="text-muted">Mevcut başvuru bilgilerini güncelleyin</p>
        </div>

        <!-- Application Form -->
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-edit me-2"></i>Başvuru Düzenle</h5>
            </div>
            <div class="card-body">
                <form id="editApplicationForm">
                    <!-- User Information (Read-only) -->
                    <div class="mb-4">
                        <h6 class="mb-3"><i class="fas fa-user me-2"></i>Öğrenci Bilgileri</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="userInfo" class="form-label">Öğrenci</label>
                                    <input type="text" class="form-control" id="userInfo" 
                                           value="<%= application.first_name %> <%= application.last_name %> (<%= application.email %>)" 
                                           readonly>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="applicationDate" class="form-label">Başvuru Tarihi</label>
                                    <input type="text" class="form-control" id="applicationDate" 
                                           value="<%= new Date(application.created_at).toLocaleDateString('tr-TR') %>" 
                                           readonly>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Application Details -->
                    <div class="mb-4">
                        <h6 class="mb-3"><i class="fas fa-file-alt me-2"></i>Başvuru Bilgileri</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="country" class="form-label">Hedef Ülke *</label>
                                    <select class="form-select" id="country" name="country" required>
                                        <option value="">Ülke Seçin</option>
                                        <option value="Germany" <%= application.country === 'Germany' ? 'selected' : '' %>>Almanya</option>
                                        <option value="Czech Republic" <%= application.country === 'Czech Republic' ? 'selected' : '' %>>Çek Cumhuriyeti</option>
                                        <option value="Italy" <%= application.country === 'Italy' ? 'selected' : '' %>>İtalya</option>
                                        <option value="Austria" <%= application.country === 'Austria' ? 'selected' : '' %>>Avusturya</option>
                                        <option value="UK" <%= application.country === 'UK' ? 'selected' : '' %>>İngiltere</option>
                                        <option value="Poland" <%= application.country === 'Poland' ? 'selected' : '' %>>Polonya</option>
                                        <option value="Hungary" <%= application.country === 'Hungary' ? 'selected' : '' %>>Macaristan</option>
                                        <option value="Netherlands" <%= application.country === 'Netherlands' ? 'selected' : '' %>>Hollanda</option>
                                        <option value="Spain" <%= application.country === 'Spain' ? 'selected' : '' %>>İspanya</option>
                                        <option value="France" <%= application.country === 'France' ? 'selected' : '' %>>Fransa</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="universitySelect" class="form-label">Üniversite</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                                        <input type="text" class="form-control" id="universitySearchInput" placeholder="Üniversite ara...">
                                    </div>
                                    <select class="form-select mt-2" id="universitySelect">
                                        <option value="">Üniversite Seçin</option>
                                        <option value="__custom__" <%= application.university_name ? '' : 'selected' %>>-- Listede Yok (Manuel Giriş) --</option>
                                    </select>
                                    <input type="hidden" id="university" name="university" value="<%= application.university_name %>">
                                    <div id="customUniversityContainer" class="mt-2" style="display: block;">
                                        <input type="text" class="form-control" id="customUniversity" 
                                               value="<%= application.university_name %>" placeholder="Üniversite adını manuel girin...">
                                        <small class="text-muted">Mevcut: <%= application.university_name %></small>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="program" class="form-label">Program</label>
                                    <input type="text" class="form-control" id="program" name="program" 
                                           value="<%= application.program_name %>" placeholder="Eğitim programı">
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="notes" class="form-label">Notlar</label>
                            <textarea class="form-control" id="notes" name="notes" rows="3" 
                                      placeholder="Başvuru hakkında ek notlar..."><%= application.required_documents || '' %></textarea>
                        </div>

                        <div class="mb-3">
                            <label for="status" class="form-label">Durum *</label>
                            <select class="form-select" id="status" name="status" required>
                                <option value="pending" <%= application.status === 'pending' ? 'selected' : '' %>>Beklemede</option>
                                <option value="approved" <%= application.status === 'approved' ? 'selected' : '' %>>Onaylandı</option>
                                <option value="rejected" <%= application.status === 'rejected' ? 'selected' : '' %>>Reddedildi</option>
                            </select>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="d-flex justify-content-between">
                        <button type="button" class="btn btn-secondary" onclick="goBack()">
                            <i class="fas fa-arrow-left me-2"></i>Geri Dön
                        </button>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-2"></i>Başvuru Güncelle
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    // Universities data cache
    let universitiesData = [];
    const currentUniversityName = '<%= application.university_name %>';
    
    // Ülke eşleştirme tablosu
    const countryMapping = {
        'Germany': 'Germany', 'Almanya': 'Germany',
        'Czech Republic': 'Czech Republic', 'Czechia': 'Czech Republic',
        'Italy': 'Italy', 'İtalya': 'Italy',
        'Austria': 'Austria', 'Avusturya': 'Austria',
        'United Kingdom': 'UK', 'UK': 'UK', 'England': 'UK',
        'Poland': 'Poland', 'Polonya': 'Poland',
        'Hungary': 'Hungary', 'Macaristan': 'Hungary',
        'Netherlands': 'Netherlands', 'Hollanda': 'Netherlands'
    };
    
    document.addEventListener('DOMContentLoaded', function() {
        // Üniversiteleri yükle
        loadUniversities();
        
        // Üniversite arama
        document.getElementById('universitySearchInput').addEventListener('input', function() {
            filterUniversities(this.value);
        });
        
        // Üniversite seçimi
        document.getElementById('universitySelect').addEventListener('change', function() {
            handleUniversitySelection(this.value);
        });
        
        // Manuel giriş
        document.getElementById('customUniversity').addEventListener('input', function() {
            document.getElementById('university').value = this.value;
        });
        
        // Ülke seçimi değiştiğinde üniversiteleri filtrele
        document.getElementById('country').addEventListener('change', function() {
            filterUniversitiesByCountry(this.value);
        });
    });
    
    // Üniversiteleri API'den yükle
    async function loadUniversities() {
        try {
            const response = await fetch('/api/admin/universities-for-selection', { credentials: 'include' });
            const data = await response.json();
            
            if (data.success && data.universities) {
                universitiesData = data.universities;
                populateUniversityDropdown(data.universities);
            }
        } catch (error) {
            console.error('Üniversiteler yüklenemedi:', error);
        }
    }
    
    // Üniversite dropdown'unu doldur
    function populateUniversityDropdown(universities) {
        const select = document.getElementById('universitySelect');
        
        // Mevcut seçenekleri temizle (ilk 2'si hariç)
        while (select.options.length > 2) {
            select.remove(2);
        }
        
        // Üniversiteleri ekle ve mevcut olanı seç
        let foundMatch = false;
        universities.forEach(uni => {
            const option = document.createElement('option');
            option.value = uni.id;
            option.textContent = `${uni.name} (${uni.city}, ${uni.country})`;
            option.setAttribute('data-name', uni.name);
            option.setAttribute('data-country', uni.country);
            option.setAttribute('data-city', uni.city);
            
            // Mevcut üniversite ile eşleşme kontrolü
            if (uni.name === currentUniversityName) {
                option.selected = true;
                foundMatch = true;
                // Manuel giriş alanını gizle
                document.getElementById('customUniversityContainer').style.display = 'none';
            }
            
            select.appendChild(option);
        });
        
        // Eşleşme bulunamadıysa manuel giriş modunu göster
        if (!foundMatch && currentUniversityName) {
            select.value = '__custom__';
            document.getElementById('customUniversityContainer').style.display = 'block';
        }
    }
    
    // Ülkeye göre üniversiteleri filtrele
    function filterUniversitiesByCountry(selectedCountry) {
        const select = document.getElementById('universitySelect');
        
        // Dropdown'u sıfırla
        select.value = '';
        document.getElementById('university').value = '';
        document.getElementById('customUniversityContainer').style.display = 'none';
        document.getElementById('universitySearchInput').value = '';
        
        // Mevcut seçenekleri temizle (ilk 2'si hariç)
        while (select.options.length > 2) {
            select.remove(2);
        }
        
        if (!selectedCountry) {
            // Ülke seçilmediyse tüm üniversiteleri göster
            populateUniversityDropdown(universitiesData);
            return;
        }
        
        // Seçilen ülkeye göre filtrele
        const filteredUniversities = universitiesData.filter(uni => {
            const uniCountryMapped = countryMapping[uni.country] || uni.country;
            return uniCountryMapped === selectedCountry;
        });
        
        // Filtrelenmiş üniversiteleri dropdown'a ekle
        filteredUniversities.forEach(uni => {
            const option = document.createElement('option');
            option.value = uni.id;
            option.textContent = `${uni.name} (${uni.city})`;
            option.setAttribute('data-name', uni.name);
            option.setAttribute('data-country', uni.country);
            option.setAttribute('data-city', uni.city);
            select.appendChild(option);
        });
    }
    
    // Üniversite arama fonksiyonu
    function filterUniversities(searchTerm) {
        const select = document.getElementById('universitySelect');
        const options = select.querySelectorAll('option');
        const term = searchTerm.toLowerCase().trim();
        
        if (term === '') {
            options.forEach(option => option.style.display = '');
            return;
        }
        
        options.forEach(option => {
            if (option.value === '' || option.value === '__custom__') {
                option.style.display = '';
                return;
            }
            
            const name = option.getAttribute('data-name') || '';
            const country = option.getAttribute('data-country') || '';
            const text = option.textContent.toLowerCase();
            
            if (name.toLowerCase().includes(term) || country.toLowerCase().includes(term) || text.includes(term)) {
                option.style.display = '';
            } else {
                option.style.display = 'none';
            }
        });
    }
    
    // Üniversite seçimi işlemi
    function handleUniversitySelection(value) {
        const customContainer = document.getElementById('customUniversityContainer');
        const universityInput = document.getElementById('university');
        const countrySelect = document.getElementById('country');
        
        if (value === '__custom__') {
            customContainer.style.display = 'block';
            document.getElementById('customUniversity').focus();
        } else if (value) {
            customContainer.style.display = 'none';
            const selectedOption = document.getElementById('universitySelect').selectedOptions[0];
            const uniName = selectedOption.getAttribute('data-name');
            const uniCountry = selectedOption.getAttribute('data-country');
            
            universityInput.value = uniName;
            document.getElementById('customUniversity').value = uniName;
            
            // Ülkeyi otomatik ayarla (global countryMapping kullanılıyor)
            if (uniCountry) {
                const mappedCountry = countryMapping[uniCountry] || uniCountry;
                if (countrySelect.querySelector(`option[value="${mappedCountry}"]`)) {
                    countrySelect.value = mappedCountry;
                }
            }
        } else {
            customContainer.style.display = 'none';
            universityInput.value = '';
        }
    }

    document.getElementById('editApplicationForm').addEventListener('submit', function(e) {
        e.preventDefault();
        
        const formData = new FormData(this);
        const data = Object.fromEntries(formData);
        
        // API'ye gönder
        fetch(`/api/admin/applications/<%= application.id %>`, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(data)
        })
        .then(response => response.json())
        .then(result => {
            if (result.success) {
                alert('Başvuru başarıyla güncellendi!');
                window.location.href = '/admin/applications';
            } else {
                alert('Hata: ' + result.message);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Bir hata oluştu. Lütfen tekrar deneyin.');
        });
    });

    function goBack() {
        window.location.href = '/admin/applications';
    }
</script>
