<!-- Admin New Application Content -->
<div class="admin-container">
    <%- include('partials/sidebar') %>

    <!-- Main Content Area -->
    <div class="admin-main">
        <!-- Header -->
        <div class="section-header">
            <h2><i class="fas fa-plus me-2"></i>Yeni Başvuru Oluştur</h2>
            <p class="text-muted">Yeni bir başvuru kaydı oluşturun</p>
        </div>

        <!-- Application Form -->
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-edit me-2"></i>Yeni Başvuru Oluştur</h5>
            </div>
            <div class="card-body">
                <form id="newApplicationForm">
                    <!-- User Selection -->
                    <div class="mb-4">
                        <h6 class="mb-3"><i class="fas fa-user me-2"></i>Öğrenci Seçimi</h6>
                        <div class="mb-3">
                            <label for="userId" class="form-label">Öğrenci *</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-search"></i></span>
                                <input type="text" class="form-control" id="userSearchInput" placeholder="Öğrenci ara (ad, soyad, e-posta)...">
                            </div>
                            <select class="form-select mt-2" id="userId" name="userId" required>
                                <option value="">Öğrenci Seçin</option>
                                <% if (typeof users !== 'undefined' && users) { %>
                                    <% users.forEach(user => { %>
                                        <option value="<%= user.id %>" data-email="<%= user.email %>" data-name="<%= user.first_name %> <%= user.last_name %>">
                                            <%= user.first_name %> <%= user.last_name %> (<%= user.email %>)
                                        </option>
                                    <% }); %>
                                <% } else { %>
                                    <option value="">Kullanıcı verisi bulunamadı</option>
                                <% } %>
                            </select>
                        </div>
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle me-2"></i>
                            <strong>Seçilen Öğrenci:</strong> <span id="selectedUserInfo">Henüz öğrenci seçilmedi</span>
                        </div>
                    </div>

                    <!-- Application Details -->
                    <div class="mb-4">
                        <h6 class="mb-3"><i class="fas fa-file-alt me-2"></i>Başvuru Bilgileri</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="country" class="form-label">Hedef Ülke *</label>
                                    <select class="form-select" id="country" name="country" required>
                                        <option value="">Ülke Seçin</option>
                                        <option value="Germany">Almanya</option>
                                        <option value="Czech Republic">Çek Cumhuriyeti</option>
                                        <option value="Italy">İtalya</option>
                                        <option value="Austria">Avusturya</option>
                                        <option value="UK">İngiltere</option>
                                        <option value="Poland">Polonya</option>
                                        <option value="Hungary">Macaristan</option>
                                        <option value="Netherlands">Hollanda</option>
                                        <option value="Spain">İspanya</option>
                                        <option value="France">Fransa</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="universitySelect" class="form-label">Üniversite</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                                        <input type="text" class="form-control" id="universitySearchInput" placeholder="Üniversite ara...">
                                    </div>
                                    <select class="form-select mt-2" id="universitySelect">
                                        <option value="">Üniversite Seçin</option>
                                        <option value="__custom__">-- Listede Yok (Manuel Giriş) --</option>
                                    </select>
                                    <input type="hidden" id="university" name="university">
                                    <div id="customUniversityContainer" class="mt-2" style="display: none;">
                                        <input type="text" class="form-control" id="customUniversity" placeholder="Üniversite adını manuel girin...">
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="program" class="form-label">Program</label>
                                    <input type="text" class="form-control" id="program" name="program" placeholder="Eğitim programı">
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="notes" class="form-label">Notlar</label>
                            <textarea class="form-control" id="notes" name="notes" rows="3" placeholder="Başvuru hakkında ek notlar..."></textarea>
                        </div>

                        <div class="mb-3">
                            <label for="status" class="form-label">Durum *</label>
                            <select class="form-select" id="status" name="status" required>
                                <option value="pending">Beklemede</option>
                                <option value="approved">Onaylandı</option>
                                <option value="rejected">Reddedildi</option>
                            </select>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <button type="button" class="btn btn-secondary" id="goBackBtn">
                            <i class="fas fa-arrow-left me-2"></i>Geri Dön
                        </button>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-2"></i>Başvuru Oluştur
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    // Universities data cache
    let universitiesData = [];
    
    // Event listeners
    document.addEventListener('DOMContentLoaded', function() {
        // Go back button
        document.getElementById('goBackBtn').addEventListener('click', goBack);
        
        // Load universities from API
        loadUniversities();
        
        // Sayfa yüklendiğinde URL'den userId parametresini kontrol et
        const urlParams = new URLSearchParams(window.location.search);
        const userId = urlParams.get('userId');
        
        if (userId) {
            const selectElement = document.getElementById('userId');
            selectElement.value = userId;
            
            // Öğrenci bilgisini güncelle
            const selectedOption = selectElement.options[selectElement.selectedIndex];
            if (selectedOption) {
                const userName = selectedOption.getAttribute('data-name');
                const userEmail = selectedOption.getAttribute('data-email');
                document.getElementById('selectedUserInfo').textContent = `${userName} (${userEmail})`;
            }
        }
        
        // Öğrenci arama fonksiyonu
        document.getElementById('userSearchInput').addEventListener('input', function() {
            filterUsers(this.value);
        });
        
        // Öğrenci seçimi değiştiğinde bilgi güncelle
        document.getElementById('userId').addEventListener('change', function() {
            const selectedOption = this.options[this.selectedIndex];
            if (selectedOption && selectedOption.value) {
                const userName = selectedOption.getAttribute('data-name');
                const userEmail = selectedOption.getAttribute('data-email');
                document.getElementById('selectedUserInfo').textContent = `${userName} (${userEmail})`;
            } else {
                document.getElementById('selectedUserInfo').textContent = 'Henüz öğrenci seçilmedi';
            }
        });
        
        // Üniversite arama fonksiyonu
        document.getElementById('universitySearchInput').addEventListener('input', function() {
            filterUniversitiesBySearch(this.value);
        });
        
        // Üniversite seçimi değiştiğinde
        document.getElementById('universitySelect').addEventListener('change', function() {
            handleUniversitySelection(this.value);
        });
        
        // Manuel üniversite girişi değiştiğinde
        document.getElementById('customUniversity').addEventListener('input', function() {
            document.getElementById('university').value = this.value;
        });
        
        // Ülke seçimi değiştiğinde üniversiteleri filtrele
        document.getElementById('country').addEventListener('change', function() {
            filterUniversitiesByCountry(this.value);
        });
    });
    
    // Üniversiteleri API'den yükle
    async function loadUniversities() {
        try {
            const response = await fetch('/api/admin/universities-for-selection', { credentials: 'include' });
            const data = await response.json();
            
            if (data.success && data.universities) {
                universitiesData = data.universities;
                populateUniversityDropdown(data.universities);
            }
        } catch (error) {
            console.error('Üniversiteler yüklenemedi:', error);
        }
    }
    
    // Üniversite dropdown'unu doldur
    function populateUniversityDropdown(universities) {
        const select = document.getElementById('universitySelect');
        
        // Mevcut seçenekleri temizle (ilk 2'si hariç)
        while (select.options.length > 2) {
            select.remove(2);
        }
        
        // Üniversiteleri ekle
        universities.forEach(uni => {
            const option = document.createElement('option');
            option.value = uni.id;
            option.textContent = `${uni.name} (${uni.city}, ${uni.country})`;
            option.setAttribute('data-name', uni.name);
            option.setAttribute('data-country', uni.country);
            option.setAttribute('data-city', uni.city);
            select.appendChild(option);
        });
    }
    
    // Ülke eşleştirme tablosu (veritabanındaki ülke adı -> form değeri)
    const countryMapping = {
        'Germany': 'Germany', 'Almanya': 'Germany',
        'Czech Republic': 'Czech Republic', 'Czechia': 'Czech Republic',
        'Italy': 'Italy', 'İtalya': 'Italy',
        'Austria': 'Austria', 'Avusturya': 'Austria',
        'United Kingdom': 'UK', 'UK': 'UK', 'England': 'UK',
        'Poland': 'Poland', 'Polonya': 'Poland',
        'Hungary': 'Hungary', 'Macaristan': 'Hungary',
        'Netherlands': 'Netherlands', 'Hollanda': 'Netherlands'
    };
    
    // Ülkeye göre üniversiteleri filtrele
    function filterUniversitiesByCountry(selectedCountry) {
        const select = document.getElementById('universitySelect');
        
        // Dropdown'u sıfırla
        select.value = '';
        document.getElementById('university').value = '';
        document.getElementById('customUniversityContainer').style.display = 'none';
        document.getElementById('universitySearchInput').value = '';
        
        // Mevcut seçenekleri temizle (ilk 2'si hariç)
        while (select.options.length > 2) {
            select.remove(2);
        }
        
        if (!selectedCountry) {
            // Ülke seçilmediyse tüm üniversiteleri göster
            populateUniversityDropdown(universitiesData);
            return;
        }
        
        // Seçilen ülkeye göre filtrele
        const filteredUniversities = universitiesData.filter(uni => {
            const uniCountryMapped = countryMapping[uni.country] || uni.country;
            return uniCountryMapped === selectedCountry;
        });
        
        // Filtrelenmiş üniversiteleri dropdown'a ekle
        filteredUniversities.forEach(uni => {
            const option = document.createElement('option');
            option.value = uni.id;
            option.textContent = `${uni.name} (${uni.city})`;
            option.setAttribute('data-name', uni.name);
            option.setAttribute('data-country', uni.country);
            option.setAttribute('data-city', uni.city);
            select.appendChild(option);
        });
    }
    
    // Üniversite arama fonksiyonu (metin bazlı)
    function filterUniversitiesBySearch(searchTerm) {
        const select = document.getElementById('universitySelect');
        const options = select.querySelectorAll('option');
        const term = searchTerm.toLowerCase().trim();
        
        if (term === '') {
            options.forEach(option => {
                option.style.display = '';
            });
            return;
        }
        
        options.forEach(option => {
            if (option.value === '' || option.value === '__custom__') {
                option.style.display = '';
                return;
            }
            
            const name = option.getAttribute('data-name') || '';
            const country = option.getAttribute('data-country') || '';
            const city = option.getAttribute('data-city') || '';
            const text = option.textContent.toLowerCase();
            
            if (name.toLowerCase().includes(term) || 
                country.toLowerCase().includes(term) || 
                city.toLowerCase().includes(term) ||
                text.includes(term)) {
                option.style.display = '';
            } else {
                option.style.display = 'none';
            }
        });
    }
    
    // Üniversite seçimi işlemi
    function handleUniversitySelection(value) {
        const customContainer = document.getElementById('customUniversityContainer');
        const universityInput = document.getElementById('university');
        const countrySelect = document.getElementById('country');
        
        if (value === '__custom__') {
            // Manuel giriş göster
            customContainer.style.display = 'block';
            universityInput.value = '';
            document.getElementById('customUniversity').value = '';
            document.getElementById('customUniversity').focus();
        } else if (value) {
            // Veritabanından seçildi
            customContainer.style.display = 'none';
            const selectedOption = document.getElementById('universitySelect').selectedOptions[0];
            const uniName = selectedOption.getAttribute('data-name');
            const uniCountry = selectedOption.getAttribute('data-country');
            
            universityInput.value = uniName;
            
            // Ülkeyi otomatik ayarla
            if (uniCountry) {
                const countryMapping = {
                    'Germany': 'Germany',
                    'Almanya': 'Germany',
                    'Czech Republic': 'Czech Republic',
                    'Czechia': 'Czech Republic',
                    'Çek Cumhuriyeti': 'Czech Republic',
                    'Italy': 'Italy',
                    'İtalya': 'Italy',
                    'Austria': 'Austria',
                    'Avusturya': 'Austria',
                    'United Kingdom': 'UK',
                    'UK': 'UK',
                    'İngiltere': 'UK',
                    'Poland': 'Poland',
                    'Polonya': 'Poland',
                    'Hungary': 'Hungary',
                    'Macaristan': 'Hungary',
                    'Netherlands': 'Netherlands',
                    'Hollanda': 'Netherlands'
                };
                
                const mappedCountry = countryMapping[uniCountry] || uniCountry;
                if (countrySelect.querySelector(`option[value="${mappedCountry}"]`)) {
                    countrySelect.value = mappedCountry;
                }
            }
        } else {
            // Seçim kaldırıldı
            customContainer.style.display = 'none';
            universityInput.value = '';
        }
    }

    // Öğrenci arama fonksiyonu
    function filterUsers(searchTerm) {
        const selectElement = document.getElementById('userId');
        const options = selectElement.querySelectorAll('option');
        const term = searchTerm.toLowerCase().trim();
        
        if (term === '') {
            // Arama terimi boşsa tüm seçenekleri göster
            options.forEach(option => {
                option.style.display = '';
            });
            return;
        }
        
        let visibleCount = 0;
        options.forEach(option => {
            if (option.value === '') {
                // İlk seçenek (Öğrenci Seçin) her zaman görünür olsun
                option.style.display = '';
                return;
            }
            
            const name = option.getAttribute('data-name') || '';
            const email = option.getAttribute('data-email') || '';
            const text = option.textContent.toLowerCase();
            
            // Daha kapsamlı arama
            const nameMatch = name.toLowerCase().includes(term);
            const emailMatch = email.toLowerCase().includes(term);
            const textMatch = text.includes(term);
            
            if (nameMatch || emailMatch || textMatch) {
                option.style.display = '';
                visibleCount++;
            } else {
                option.style.display = 'none';
            }
        });
    }

    // Öğrenci seçimi değiştiğinde bilgi güncelle
    document.getElementById('userId').addEventListener('change', function() {
        const selectedOption = this.options[this.selectedIndex];
        const userInfo = document.getElementById('selectedUserInfo');
        
        if (this.value) {
            const userName = selectedOption.getAttribute('data-name');
            const userEmail = selectedOption.getAttribute('data-email');
            userInfo.textContent = `${userName} (${userEmail})`;
        } else {
            userInfo.textContent = 'Henüz kullanıcı seçilmedi';
        }
    });

    document.getElementById('newApplicationForm').addEventListener('submit', function(e) {
        e.preventDefault();
        
        const formData = new FormData(this);
        const data = Object.fromEntries(formData);
        
        // Öğrenci seçimi kontrolü
        if (!data.userId) {
            alert('Lütfen bir kullanıcı seçin!');
            return;
        }
        
        // API'ye gönder
        fetch('/api/admin/applications', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(data)
        })
        .then(response => response.json())
        .then(result => {
            if (result.success) {
                alert('Başvuru başarıyla oluşturuldu!');
                window.location.href = '/admin/applications';
            } else {
                alert('Hata: ' + result.message);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Bir hata oluştu. Lütfen tekrar deneyin.');
        });
    });

    function goBack() {
        window.location.href = '/admin/applications';
    }
</script>
