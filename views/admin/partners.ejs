<!-- Admin Partners Content -->
<div class="admin-container">
    <%- include('partials/sidebar') %>

    <!-- Main Content Area -->
    <div class="admin-main">
        <div class="section-header">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2><i class="fas fa-handshake me-2"></i>Partnerler</h2>
                    <p class="text-muted mb-0">Partner yönetimi ve kazanç takibi</p>
                </div>
                <button class="btn btn-primary" onclick="showAddPartnerModal()">
                    <i class="fas fa-plus me-2"></i>Yeni Partner Ekle
                </button>
            </div>
        </div>

        <!-- Stats Grid -->
        <div class="stats-grid">
            <div class="stat-card primary">
                <div class="stat-icon">
                    <i class="fas fa-handshake"></i>
                </div>
                <div class="stat-content">
                    <h3><%= partners.length %></h3>
                    <p>Toplam Partner</p>
                </div>
            </div>
            <div class="stat-card success">
                <div class="stat-icon">
                    <i class="fas fa-check-circle"></i>
                </div>
                <div class="stat-content">
                    <h3><%= partners.filter(p => p.is_active && p.email_verified).length %></h3>
                    <p>Aktif Partner</p>
                </div>
            </div>
            <div class="stat-card warning">
                <div class="stat-icon">
                    <i class="fas fa-clock"></i>
                </div>
                <div class="stat-content">
                    <h3><%= partners.filter(p => !p.email_verified).length %></h3>
                    <p>Doğrulama Bekleyen</p>
                </div>
            </div>
            <div class="stat-card info">
                <div class="stat-icon">
                    <i class="fas fa-users"></i>
                </div>
                <div class="stat-content">
                    <h3><%= partners.reduce((sum, p) => sum + parseInt(p.student_count || 0), 0) %></h3>
                    <p>Partner Öğrencileri</p>
                </div>
            </div>
        </div>

        <!-- Partners Table -->
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Partner Listesi (<%= partners.length %>)</h5>
                <div class="search-box">
                    <div class="input-group" style="width: 300px;">
                        <span class="input-group-text">
                            <i class="fas fa-search"></i>
                        </span>
                        <input type="text" class="form-control" id="partnerSearchInput" placeholder="Partner ara...">
                    </div>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover" id="partnersTable">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>İsim Soyisim</th>
                                <th>E-posta</th>
                                <th>Öğrenci</th>
                                <th>Ödenen</th>
                                <th>Bekleyen</th>
                                <th>IBAN</th>
                                <th>Durum</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% partners.forEach(partner => { %>
                            <tr data-partner-id="<%= partner.id %>" style="cursor: pointer;" onclick="showPartnerStudents(<%= partner.id %>, '<%= partner.first_name %> <%= partner.last_name %>')">
                                <td><%= partner.id %></td>
                                <td>
                                    <strong><%= partner.first_name %> <%= partner.last_name %></strong>
                                    <% if (partner.company_name) { %>
                                    <br><small class="text-muted"><%= partner.company_name %></small>
                                    <% } %>
                                </td>
                                <td><small><%= partner.email %></small></td>
                                <td><span class="badge bg-info" title="Öğrencileri göster"><%= partner.student_count || 0 %></span></td>
                                <td><span class="text-success fw-bold"><%= parseFloat(partner.paid_earnings || 0).toFixed(2) %> €</span></td>
                                <td>
                                    <% if (parseFloat(partner.pending_earnings || 0) > 0) { %>
                                        <span class="text-warning fw-bold"><%= parseFloat(partner.pending_earnings || 0).toFixed(2) %> €</span>
                                    <% } else { %>
                                        <span class="text-muted">0.00 €</span>
                                    <% } %>
                                </td>
                                <td>
                                    <% if (partner.iban) { %>
                                        <span class="badge bg-success" title="<%= partner.iban %>"><i class="fas fa-check me-1"></i>Mevcut</span>
                                    <% } else { %>
                                        <span class="badge bg-danger"><i class="fas fa-times me-1"></i>Eksik</span>
                                    <% } %>
                                </td>
                                <td>
                                    <% if (partner.email_verified && partner.is_active) { %>
                                        <span class="badge bg-success">Aktif</span>
                                    <% } else if (!partner.email_verified) { %>
                                        <span class="badge bg-warning text-dark">Doğrulama Bekliyor</span>
                                    <% } else { %>
                                        <span class="badge bg-secondary">Pasif</span>
                                    <% } %>
                                </td>
                                <td onclick="event.stopPropagation();">
                                    <div class="btn-group" role="group">
                                        <button class="btn btn-sm btn-outline-primary" onclick="editPartner(<%= partner.id %>)" title="Düzenle">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <% if (!partner.email_verified) { %>
                                        <button class="btn btn-sm btn-outline-info" onclick="resendVerification(<%= partner.id %>)" title="Doğrulama Maili Gönder">
                                            <i class="fas fa-envelope"></i>
                                        </button>
                                        <% } %>
                                        <button class="btn btn-sm btn-outline-danger" onclick="deletePartner(<%= partner.id %>, '<%= partner.first_name %> <%= partner.last_name %>')" title="Sil">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                    
                    <% if (partners.length === 0) { %>
                    <div class="text-center py-5">
                        <i class="fas fa-handshake fa-3x text-muted mb-3"></i>
                        <h5 class="text-muted">Henüz partner bulunmuyor</h5>
                        <p class="text-muted">Yeni partner eklemek için yukarıdaki butonu kullanın.</p>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Partner Modal -->
<div class="modal fade" id="addPartnerModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="fas fa-user-plus me-2"></i>Yeni Partner Ekle</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="addPartnerForm">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="partnerFirstName" class="form-label">Ad *</label>
                            <input type="text" class="form-control" id="partnerFirstName" required placeholder="Ad">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="partnerLastName" class="form-label">Soyad *</label>
                            <input type="text" class="form-control" id="partnerLastName" required placeholder="Soyad">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="partnerEmail" class="form-label">E-posta *</label>
                        <input type="email" class="form-control" id="partnerEmail" required placeholder="partner@email.com">
                        <small class="text-muted">Bu adrese doğrulama e-postası gönderilecek</small>
                    </div>
                    <div class="mb-3">
                        <label for="partnerCompany" class="form-label">Şirket Adı</label>
                        <input type="text" class="form-control" id="partnerCompany" placeholder="Şirket adı (opsiyonel)">
                    </div>
                    <div class="mb-3">
                        <label for="partnerPhone" class="form-label">Telefon</label>
                        <input type="tel" class="form-control" id="partnerPhone" placeholder="+90 xxx xxx xx xx">
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-primary" onclick="addPartner()">
                    <i class="fas fa-plus me-2"></i>Partner Ekle
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Partner Modal -->
<div class="modal fade" id="editPartnerModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title"><i class="fas fa-edit me-2"></i>Partner Düzenle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="editPartnerForm">
                    <input type="hidden" id="editPartnerId">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="editPartnerFirstName" class="form-label">Ad *</label>
                            <input type="text" class="form-control" id="editPartnerFirstName" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="editPartnerLastName" class="form-label">Soyad *</label>
                            <input type="text" class="form-control" id="editPartnerLastName" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="editPartnerEmail" class="form-label">E-posta</label>
                        <input type="email" class="form-control" id="editPartnerEmail" readonly disabled>
                        <small class="text-muted">E-posta adresi değiştirilemez</small>
                    </div>
                    <div class="mb-3">
                        <label for="editPartnerCompany" class="form-label">Şirket Adı</label>
                        <input type="text" class="form-control" id="editPartnerCompany">
                    </div>
                    <div class="mb-3">
                        <label for="editPartnerPhone" class="form-label">Telefon</label>
                        <input type="tel" class="form-control" id="editPartnerPhone">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">IBAN</label>
                        <div id="editPartnerIbanDisplay" class="form-control-plaintext" style="font-family: monospace; letter-spacing: 1px; background: #f8f9fa; padding: 8px 12px; border-radius: 6px; font-size: 13px;"></div>
                        <small class="text-muted">IBAN sadece partner tarafından güncellenebilir</small>
                    </div>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="editPartnerActive">
                            <label class="form-check-label" for="editPartnerActive">Aktif</label>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-warning" onclick="updatePartner()">
                    <i class="fas fa-save me-2"></i>Kaydet
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Partner Students Modal -->
<div class="modal fade" id="partnerStudentsModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header" style="background: linear-gradient(135deg, #005A9E 0%, #003d6b 100%); color: white;">
                <h5 class="modal-title"><i class="fas fa-users me-2"></i><span id="psModalTitle">Partner Öğrencileri</span></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="psModalBody">
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2 text-muted">Yükleniyor...</p>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Search functionality
    document.getElementById('partnerSearchInput').addEventListener('input', function() {
        const searchTerm = this.value.toLowerCase();
        const rows = document.querySelectorAll('#partnersTable tbody tr');
        
        rows.forEach(row => {
            const text = row.textContent.toLowerCase();
            row.style.display = text.includes(searchTerm) ? '' : 'none';
        });
    });

    // Show add partner modal
    function showAddPartnerModal() {
        document.getElementById('addPartnerForm').reset();
        const modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('addPartnerModal'));
        modal.show();
    }

    // Add partner
    async function addPartner() {
        const first_name = document.getElementById('partnerFirstName').value;
        const last_name = document.getElementById('partnerLastName').value;
        const email = document.getElementById('partnerEmail').value;
        const company_name = document.getElementById('partnerCompany').value;
        const phone = document.getElementById('partnerPhone').value;
        
        if (!first_name || !last_name || !email) {
            alert('Ad, soyad ve e-posta adresi gerekli!');
            return;
        }
        
        try {
            const response = await fetch('/admin/partners', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({ first_name, last_name, email, company_name, phone })
            });
            
            const data = await response.json();
            
            if (data.success) {
                alert(data.message);
                const addModal = bootstrap.Modal.getInstance(document.getElementById('addPartnerModal'));
                if (addModal) addModal.hide();
                window.location.reload();
            } else {
                alert(data.message || 'Partner eklenemedi!');
            }
        } catch (error) {
            console.error('Add partner error:', error);
            alert('Partner eklenirken bir hata oluştu!');
        }
    }

    // Edit partner
    async function editPartner(id) {
        try {
            const response = await fetch('/admin/api/partners', {
                credentials: 'include'
            });
            const data = await response.json();
            
            if (data.success) {
                const partner = data.partners.find(p => p.id === id);
                if (partner) {
                    document.getElementById('editPartnerId').value = partner.id;
                    document.getElementById('editPartnerFirstName').value = partner.first_name;
                    document.getElementById('editPartnerLastName').value = partner.last_name;
                    document.getElementById('editPartnerEmail').value = partner.email;
                    document.getElementById('editPartnerCompany').value = partner.company_name || '';
                    document.getElementById('editPartnerPhone').value = partner.phone || '';
                    document.getElementById('editPartnerActive').checked = partner.is_active;
                    const ibanEl = document.getElementById('editPartnerIbanDisplay');
                    if (partner.iban) {
                        ibanEl.innerHTML = `<span class="text-success"><i class="fas fa-check-circle me-1"></i>${partner.iban}</span>` + (partner.account_holder_name ? `<br><small class="text-muted">${partner.account_holder_name}</small>` : '');
                    } else {
                        ibanEl.innerHTML = '<span class="text-danger"><i class="fas fa-times-circle me-1"></i>Henüz girilmemiş</span>';
                    }
                    
                    const modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('editPartnerModal'));
                    modal.show();
                }
            }
        } catch (error) {
            console.error('Edit partner error:', error);
            alert('Partner bilgileri yüklenemedi!');
        }
    }

    // Update partner
    async function updatePartner() {
        const id = document.getElementById('editPartnerId').value;
        const first_name = document.getElementById('editPartnerFirstName').value;
        const last_name = document.getElementById('editPartnerLastName').value;
        const company_name = document.getElementById('editPartnerCompany').value;
        const phone = document.getElementById('editPartnerPhone').value;
        const is_active = document.getElementById('editPartnerActive').checked;
        
        try {
            const response = await fetch(`/admin/partners/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({ first_name, last_name, company_name, phone, is_active })
            });
            
            const data = await response.json();
            
            if (data.success) {
                alert('Partner başarıyla güncellendi!');
                const editModal = bootstrap.Modal.getInstance(document.getElementById('editPartnerModal'));
                if (editModal) editModal.hide();
                window.location.reload();
            } else {
                alert(data.message || 'Partner güncellenemedi!');
            }
        } catch (error) {
            console.error('Update partner error:', error);
            alert('Partner güncellenirken bir hata oluştu!');
        }
    }

    // Delete partner
    async function deletePartner(id, name) {
        if (!confirm(`"${name}" adlı partneri silmek istediğinizden emin misiniz?\n\nBu işlem geri alınamaz ve partner ile ilişkili tüm kazanç kayıtları silinecektir.`)) {
            return;
        }
        
        try {
            const response = await fetch(`/admin/partners/${id}`, {
                method: 'DELETE',
                credentials: 'include'
            });
            
            const data = await response.json();
            
            if (data.success) {
                alert(data.message);
                const row = document.querySelector(`tr[data-partner-id="${id}"]`);
                if (row) row.remove();
            } else {
                alert(data.message || 'Partner silinemedi!');
            }
        } catch (error) {
            console.error('Delete partner error:', error);
            alert('Partner silinirken bir hata oluştu!');
        }
    }

    // Resend verification email
    async function resendVerification(id) {
        try {
            const response = await fetch(`/admin/partners/${id}/resend-verification`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include'
            });
            
            const data = await response.json();
            
            if (data.success) {
                alert(data.message);
            } else {
                alert(data.message || 'E-posta gönderilemedi!');
            }
        } catch (error) {
            console.error('Resend verification error:', error);
            alert('E-posta gönderilirken bir hata oluştu!');
        }
    }

    // Show partner students
    async function showPartnerStudents(partnerId, partnerName) {
        const modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('partnerStudentsModal'));
        document.getElementById('psModalTitle').textContent = partnerName + ' - Öğrenciler';
        document.getElementById('psModalBody').innerHTML = '<div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div><p class="mt-2 text-muted">Yükleniyor...</p></div>';
        modal.show();

        try {
            const response = await fetch(`/admin/partners/${partnerId}/students`, { credentials: 'include' });
            const data = await response.json();

            if (!data.success) {
                document.getElementById('psModalBody').innerHTML = '<div class="alert alert-danger">Veriler yüklenemedi.</div>';
                return;
            }

            const students = data.students;

            if (students.length === 0) {
                document.getElementById('psModalBody').innerHTML = `
                    <div class="text-center py-5">
                        <i class="fas fa-user-slash fa-3x text-muted mb-3"></i>
                        <h6 class="text-muted">Bu partnere atanmış öğrenci bulunmuyor</h6>
                    </div>`;
                return;
            }

            let html = `
                <div class="mb-3">
                    <span class="badge bg-primary">${students.length} öğrenci</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover table-sm align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Ad Soyad</th>
                                <th>E-posta</th>
                                <th>Telefon</th>
                                <th>Sınıf</th>
                                <th>Kazanç</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>`;

            students.forEach(s => {
                const total = parseFloat(s.total_earning || 0);
                const paid = parseFloat(s.paid_earning || 0);
                const pending = parseFloat(s.pending_earning || 0);
                const cur = s.earning_currency || 'EUR';
                let earningCell = '<span class="text-muted">-</span>';
                if (total > 0) {
                    earningCell = '';
                    if (paid > 0) earningCell += `<span class="badge bg-success me-1">${paid.toFixed(0)} ${cur}</span>`;
                    if (pending > 0) earningCell += `<span class="badge bg-warning text-dark">${pending.toFixed(0)} ${cur}</span>`;
                }

                html += `
                    <tr>
                        <td><strong>${s.first_name} ${s.last_name}</strong></td>
                        <td><small>${s.email || '-'}</small></td>
                        <td><small>${s.phone || '-'}</small></td>
                        <td>${s.active_class || '-'}</td>
                        <td>${earningCell}</td>
                        <td>
                            <a href="/admin/users/${s.id}/details#partner-section" class="btn btn-sm btn-outline-primary" title="Partner Yönetimi">
                                <i class="fas fa-eye"></i>
                            </a>
                        </td>
                    </tr>`;
            });

            html += '</tbody></table></div>';
            document.getElementById('psModalBody').innerHTML = html;
        } catch (error) {
            console.error('Partner students error:', error);
            document.getElementById('psModalBody').innerHTML = '<div class="alert alert-danger">Bir hata oluştu.</div>';
        }
    }
</script>
