

<!-- Admin Program Edit -->
<div class="admin-container">
	<!-- Sidebar -->
	<div class="admin-sidebar">
		<div class="sidebar-header">
			<h6 class="mb-0"><i class="fas fa-cog me-2"></i>Yönetim Paneli</h6>
		</div>
		<nav class="sidebar-nav">
			<a href="/admin/dashboard" class="nav-item">
				<i class="fas fa-tachometer-alt"></i>
				<span>Dashboard</span>
			</a>
		<a href="/admin/users" class="nav-item">
			<i class="fas fa-users"></i>
                <span>Öğrenciler</span>
                <span class="badge bg-primary ms-auto"><%= userCount %></span>
		</a>
		<a href="/admin/applications" class="nav-item">
			<i class="fas fa-file-alt"></i>
			<span>Başvurular</span>
            <span class="badge bg-success ms-auto"><%= applicationCount %></span>
		</a>
		<a href="/admin/partners" class="nav-item">
			<i class="fas fa-handshake"></i>
			<span>Partnerler</span>
			<% if (typeof partnerCount !== 'undefined' && partnerCount > 0) { %>
				<span class="badge bg-info ms-auto"><%= partnerCount %></span>
			<% } %>
		</a>
		<a href="/admin/universities" class="nav-item">
			<i class="fas fa-university"></i>
			<span>Üniversiteler</span>
		</a>
		<a href="/admin/backups" class="nav-item">
			<i class="fas fa-database"></i>
			<span>Yedekleme</span>
		</a>
	</nav>
</div>

	<!-- Main Content -->
	<div class="admin-main">
		<div class="section-header d-flex align-items-center justify-content-between">
			<div>
				<h2><i class="fas fa-edit me-2"></i>Program Düzenle</h2>
				<p class="text-muted mb-0"><%= program.university_name %> • <strong><%= program.name %></strong></p>
			</div>
			<div>
				<a href="/admin/universities/<%= program.university_id %>" class="btn btn-outline-secondary btn-sm">
					<i class="fas fa-arrow-left me-2"></i>Geri Dön
				</a>
			</div>
		</div>

		<div class="card">
			<div class="card-header">
				<h5 class="mb-0">Temel Bilgiler</h5>
			</div>
			<div class="card-body">
				<form id="programEditForm">
					<div class="row g-3">
						<div class="col-md-6">
							<label class="form-label">Program Adı</label>
							<input type="text" class="form-control" name="name" value="<%= program.name %>" required>
						</div>
						<div class="col-md-6">
							<label class="form-label">Program Adı (İngilizce)</label>
							<input type="text" class="form-control" name="name_en" value="<%= program.name_en || '' %>">
						</div>
						<div class="col-md-4">
							<label class="form-label">Seviye</label>
							<select class="form-select" name="level" required>
										<% const levels = ['Bachelor', 'Master', 'PhD', 'Diploma', 'Certificate']; %>
		<% levels.forEach(function(l){ %>
			<option value="<%= l %>" <%= program.level === l ? 'selected' : '' %>><%= l %></option>
		<% }) %>
							</select>
						</div>
						<div class="col-md-4">
							<label class="form-label">Alan</label>
							<input type="text" class="form-control" name="field_of_study" value="<%= program.field_of_study %>" required>
						</div>
						<div class="col-md-4">
							<label class="form-label">Süre (Sömestr)</label>
							<input type="number" class="form-control" name="duration_months" value="<%= program.duration_months %>" min="1" required>
						</div>
						<div class="col-md-4">
							<label class="form-label">Ücret</label>
							<input type="number" class="form-control" name="tuition_fee" value="<%= Math.round(program.tuition_fee || 0) %>" min="0">
						</div>
						<div class="col-md-4">
							<label class="form-label">Para Birimi</label>
							<select class="form-select" name="currency">
								<% const currencies = ['EUR','GBP','USD']; %>
								<% currencies.forEach(function(c){ %>
									<option value="<%= c %>" <%= (program.currency || 'EUR') === c ? 'selected' : '' %>><%= c %></option>
								<% }) %>
							</select>
						</div>
						<div class="col-md-4">
							<label class="form-label">Dil</label>
							<input type="text" class="form-control" name="language" value="<%= program.language %>" required>
						</div>

						<div class="col-md-4">
							<label class="form-label">Durum</label>
							<select class="form-select" name="is_active">
								<option value="true" <%= program.is_active ? 'selected' : '' %>>Aktif</option>
								<option value="false" <%= !program.is_active ? 'selected' : '' %>>Pasif</option>
							</select>
						</div>
					</div>

					<div class="d-flex justify-content-end mt-4 gap-2">
											<a href="/admin/universities/<%= program.university_id %>" class="btn btn-secondary">
						<i class="fas fa-times me-2"></i>İptal
					</a>
						<button type="submit" class="btn btn-primary">
							<i class="fas fa-save me-2"></i>Kaydet
						</button>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>

<script>
(function(){
	const form = document.getElementById('programEditForm');
	form.addEventListener('submit', async function(e){
		e.preventDefault();
		const formData = new FormData(form);
		const payload = {};
		for (const [k,v] of formData.entries()) payload[k] = v;
		try {
			const res = await fetch('/api/admin/programs/<%= program.id %>', {
				method: 'PUT',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify(payload)
			});
			const result = await res.json();
			if (result.success) {
				alert('Program başarıyla güncellendi');
				window.location.href = '/admin/universities/<%= program.university_id %>';
			} else {
				alert('Hata: ' + (result.message || 'Güncelleme başarısız'));
			}
		} catch(err) {
			console.error(err);
			alert('Sunucu hatası');
		}
	});
})();
</script>
