    // Add/Edit service
    window.addService = async function() {
        try {
            // Get service name from dropdown or text input
            const serviceNameSelect = document.getElementById('serviceNameSelect');
            const serviceNameInput = document.getElementById('serviceName');
            let serviceName = '';
            
            if (serviceNameSelect.style.display !== 'none') {
                serviceName = serviceNameSelect.value;
            } else {
                serviceName = serviceNameInput.value;
            }
            
            const amount = parseFloat(document.getElementById('serviceAmount').value);
            const currency = document.getElementById('serviceCurrency').value;
            
            // Convert Turkish date format (DD.MM.YYYY) to ISO (YYYY-MM-DD)
            const dueDateRaw = document.getElementById('serviceDueDate').value || '';
            const paymentDateRaw = document.getElementById('servicePaymentDate').value || '';
            const dueDate = parseTurkishDate(dueDateRaw) || null;
            const paymentDate = parseTurkishDate(paymentDateRaw) || null;
            
            const isPaid = document.getElementById('serviceIsPaid').checked;
            const notes = document.getElementById('serviceNotes').value;
            
            if (!serviceName || !amount) {
                showAlert('warning', 'Lütfen tüm gerekli alanları doldurun');
                return;
            }
            
            const serviceData = {
                service_name: serviceName,
                amount: amount,
                currency: currency,
                due_date: dueDate,
                payment_date: paymentDate,
                is_paid: isPaid,
                notes: notes
            };
            
            // Check if we're editing an existing service
            const editId = document.getElementById('addServiceForm').getAttribute('data-edit-id');
            let response;
            
            if (editId) {
                // Update existing service
                console.log('Updating service with data:', serviceData);
                response = await fetch(`/api/admin/users/<%= user.id %>/services/${editId}`, {
                    method: 'PUT',
                    credentials: 'include',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(serviceData)
                });
            } else {
                // Add new service
                console.log('Adding service with data:', serviceData);
                response = await fetch(`/api/admin/users/<%= user.id %>/services`, {
                method: 'POST',
                credentials: 'include',
                headers: {
                    'Content-Type': 'application/json'
                },
                    body: JSON.stringify(serviceData)
                });
            }

            if (!response.ok) {
                throw new Error(`HTTP error! status: ${response.status}`);
            }

            const result = await response.json();
            
            if (result.success) {
                showAlert('success', editId ? 'Hizmet başarıyla güncellendi' : 'Hizmet başarıyla eklendi');
                loadServices();
                cancelAddService();
            } else {
                throw new Error(result.message);
            }
        } catch (error) {
            console.error('Error adding/updating service:', error);
            showAlert('danger', 'Hizmet işlemi sırasında hata oluştu: ' + error.message);
        }
    };

