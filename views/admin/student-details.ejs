// Save guardians information
async function adminSaveGuardians() {
    try {
        const guardians = adminCollectGuardianData();
        const required = guardians.filter(g => g.is_required);
        const filled = required.filter(g => g.full_name !== '');
        if (filled.length < 2) {
            document.getElementById('adminGuardiansAlertContainer').innerHTML = `
                <div class="alert alert-danger">En az 2 veli bilgisi (Anne ve Baba) doldurulmalıdır.</div>`;
            return;
        }

        const response = await fetch(`/api/admin/users/<%= user.id %>/guardians`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ guardians })
        });
        
        const result = await response.json();
        
        if (result.success) {
            adminGuardiansList = result.guardians;
            adminRenderGuardiansDisplay(adminGuardiansList);
            
            const modal = bootstrap.Modal.getInstance(document.getElementById('editGuardiansModal'));
            modal.hide();
            
            alert('Veli bilgileri başarıyla güncellendi!');
        } else {
            alert('Hata: ' + result.message);
        }
    } catch (error) {
        console.error('Error updating guardians:', error);
        alert('Veli bilgileri güncellenirken bir hata oluştu.');
    }
}

