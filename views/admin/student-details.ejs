    // Calculate installments - UPDATED VERSION
    window.calculateInstallments = function() {
        console.log('🔧 calculateInstallments called - NEW VERSION');
        
        const totalAmount = parseFloat(document.getElementById('serviceAmount').value) || 0;
        const installmentCount = parseInt(document.getElementById('installmentCount').value) || 1;
        
        console.log('📊 Calculation data:', { totalAmount, installmentCount });
        
        if (totalAmount > 0 && installmentCount > 0) {
            const installmentAmount = totalAmount / installmentCount;
            document.getElementById('installmentAmount').value = installmentAmount.toFixed(2);
            console.log('✅ Calculated installment amount:', installmentAmount.toFixed(2));
            
            // Show installment preview if due date is set
            const dueDate = document.getElementById('serviceDueDate').value;
            if (dueDate) {
                console.log('📅 Due date found, showing preview...');
                showInstallmentPreview();
            } else {
                console.log('❌ No due date, skipping preview');
            }
        } else {
            console.log('❌ Invalid data for calculation');
        }
    };

    // Show installment preview - UPDATED VERSION
    window.showInstallmentPreview = function() {
        console.log('🔧 showInstallmentPreview called - NEW VERSION');
        
        const dueDate = document.getElementById('serviceDueDate').value;
        const installmentCount = parseInt(document.getElementById('installmentCount').value) || 1;
        const installmentInterval = document.getElementById('installmentInterval').value;
        const installmentAmount = document.getElementById('installmentAmount').value;
        const currency = document.getElementById('serviceCurrency').value;
        
        console.log('📊 Preview data:', {
            dueDate, installmentCount, installmentInterval, installmentAmount, currency
        });
        
        if (!dueDate || !installmentAmount) {
            console.log('❌ Missing dueDate or installmentAmount, returning');
            return;
        }
        
        const previewContainer = document.getElementById('installmentPreview');
        if (!previewContainer) {
            console.log('❌ installmentPreview container not found');
            return;
        }
        
        console.log('✅ Creating installment preview table...');
        
        let html = '<h6 class="text-success">📋 Taksit Önizlemesi:</h6><div class="table-responsive"><table class="table table-sm table-bordered table-striped">';
        html += '<thead class="table-dark"><tr><th>Taksit No</th><th>Tutar</th><th>Vade Tarihi</th><th>Durum</th></tr></thead><tbody>';
        
        const startDate = new Date(dueDate);
        
        for (let i = 1; i <= installmentCount; i++) {
            let installmentDate = new Date(startDate);
            
            switch (installmentInterval) {
                case 'weekly':
                    installmentDate.setDate(startDate.getDate() + (i - 1) * 7);
                    break;
                case 'monthly':
                    installmentDate.setMonth(startDate.getMonth() + (i - 1));
                    break;
                case 'quarterly':
                    installmentDate.setMonth(startDate.getMonth() + (i - 1) * 3);
                    break;
            }
            
            html += `<tr>
                <td><strong>${i}</strong></td>
                <td><span class="text-primary">${installmentAmount} ${currency}</span></td>
                <td>${installmentDate.toLocaleDateString('tr-TR')}</td>
                <td><span class="badge bg-warning">Bekliyor</span></td>
            </tr>`;
        }
        
        html += '</tbody></table></div>';
        previewContainer.innerHTML = html;
        console.log('✅ Installment preview HTML set successfully!');
        console.log('📋 Preview HTML:', html);
    };

