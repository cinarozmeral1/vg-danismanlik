<!-- Admin Student Details Content -->
<div class="admin-container">
    <!-- Sidebar -->
    <div class="admin-sidebar">
        <div class="sidebar-header">
            <h6 class="mb-0"><i class="fas fa-cog me-2"></i>Yönetim Paneli</h6>
        </div>
        <nav class="sidebar-nav">
            <a href="/admin/dashboard" class="nav-item">
                <i class="fas fa-tachometer-alt"></i>
                <span>Dashboard</span>
            </a>
            <a href="/admin/users" class="nav-item active">
                <i class="fas fa-users"></i>
                <span>Öğrenciler</span>
                <span class="badge bg-primary ms-auto"><%= userCount %></span>
            </a>
            <a href="/admin/applications" class="nav-item">
                <i class="fas fa-file-alt"></i>
                <span>Başvurular</span>
                <span class="badge bg-success ms-auto"><%= applicationCount %></span>
            </a>
            <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin) { %>
            <a href="/admin/partners" class="nav-item">
                <i class="fas fa-handshake"></i>
                <span>Partnerler</span>
                <% if (typeof partnerCount !== 'undefined' && partnerCount > 0) { %>
                    <span class="badge bg-info ms-auto"><%= partnerCount %></span>
                <% } %>
            </a>
            <% } %>
            <a href="/admin/universities" class="nav-item">
                <i class="fas fa-university"></i>
                <span>Üniversiteler</span>
            </a>
            <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin) { %>
            <a href="/admin/backups" class="nav-item">
                <i class="fas fa-database"></i>
                <span>Yedekleme</span>
            </a>
            <a href="/admin/admins" class="nav-item">
                <i class="fas fa-user-shield"></i>
                <span>Adminler</span>
            </a>
            <% } %>
        </nav>
    </div>

    <!-- Main Content Area -->
    <div class="admin-main">
        <!-- Header -->
        <div class="section-header">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2><i class="fas fa-user me-2"></i>Öğrenci Detayları</h2>
                    <p class="text-muted">Öğrenci bilgilerini görüntüleyin ve düzenleyin</p>
                </div>
                <div>
                    <a href="/admin/users" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left me-2"></i>Geri Dön
                    </a>
                </div>
            </div>
        </div>

        <!-- Student Profile Header -->
        <div class="card mb-4">
            <div class="card-body bg-primary text-white">
                <div class="row align-items-center">
                    <div class="col-md-2 text-center">
                        <img src="<%= user.avatar_url || '/images/default-avatar.png' %>" alt="Avatar" class="avatar-img" id="userAvatar" onerror="this.src='data:image/svg+xml;base64,';">
                    </div>
                    <div class="col-md-6">
                        <h3 class="mb-1"><%= user.first_name %> <%= user.last_name %></h3>
                        <p class="mb-0 opacity-75">DOSYA NO: VG<%= user.id.toString().padStart(6, '0') %></p>
                    </div>
                    <div class="col-md-4 text-end">
                        <button class="btn btn-light btn-sm" onclick="changeAvatar()">
                            <i class="fas fa-camera me-1"></i>Avatar Değiştir
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Navigation Tabs -->
        <div class="card">
            <div class="card-header p-0">
                <div class="d-flex justify-content-center">
                    <ul class="nav nav-tabs nav-fill student-tabs" id="studentTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="student-info-tab" data-bs-toggle="tab" data-bs-target="#student-info" type="button" role="tab">
                                <i class="fas fa-user me-2"></i>ÖĞRENCİ
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="grades-tab" data-bs-toggle="tab" data-bs-target="#grades" type="button" role="tab">
                                <i class="fas fa-star me-2"></i>NOTLAR
                            </button>
                        </li>
                        <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin) { %>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="services-tab" data-bs-toggle="tab" data-bs-target="#services" type="button" role="tab">
                                <i class="fas fa-cogs me-2"></i>HİZMETLER
                            </button>
                        </li>
                        <% } %>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="files-tab" data-bs-toggle="tab" data-bs-target="#files" type="button" role="tab">
                                <i class="fas fa-file me-2"></i>DOSYALAR
                            </button>
                        </li>
                        <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin) { %>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="partner-tab" data-bs-toggle="tab" data-bs-target="#partner" type="button" role="tab">
                                <i class="fas fa-handshake me-2"></i>PARTNER
                            </button>
                        </li>
                        <% } %>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="ai-recommendation-tab" data-bs-toggle="tab" data-bs-target="#ai-recommendation" type="button" role="tab" style="white-space: nowrap;">
                                <i class="fas fa-magic me-2"></i>AI
                            </button>
                        </li>
                    </ul>
                </div>
            </div>
            <div class="tab-content" id="studentTabsContent" style="overflow: visible; max-height: none;">
                    <!-- Student Information Tab -->
                    <div class="tab-pane fade show active" id="student-info" role="tabpanel" style="overflow: visible; max-height: none;">
                        <div class="container-fluid px-0">
                            <h5 class="mb-4 text-center"><strong>Öğrenci Bilgileri</strong></h5>
                            <form id="studentForm">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label for="first_name" class="form-label">Ad *</label>
                                        <input type="text" class="form-control" id="first_name" name="first_name" value="<%= user.first_name || '' %>" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="last_name" class="form-label">Soyad *</label>
                                        <input type="text" class="form-control" id="last_name" name="last_name" value="<%= user.last_name || '' %>" required>
                                    </div>

                                    <div class="col-md-6">
                                        <label for="tc_number" class="form-label">TC Kimlik No *</label>
                                        <input type="text" class="form-control" id="tc_number" name="tc_number" value="<%= user.tc_number || '' %>" maxlength="11" pattern="[0-9]{11}" oninput="this.value = this.value.replace(/[^0-9]/g, '')" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="email" class="form-label">E-posta *</label>
                                        <input type="email" class="form-control" id="email" name="email" value="<%= user.email || '' %>" readonly>
                                    </div>

                                    <div class="col-md-6">
                                        <label for="phone" class="form-label">Telefon *</label>
                                        <input type="tel" class="form-control" id="phone" name="phone" value="<%= user.phone || '' %>" placeholder="Örn: +90 555 123 45 67" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="english_level" class="form-label">İngilizce Seviyesi *</label>
                                        <select class="form-select" id="english_level" name="english_level" required>
                                            <option value="">Seçiniz</option>
                                            <option value="A1" <%= user.english_level === 'A1' ? 'selected' : '' %>>A1</option>
                                            <option value="A2" <%= user.english_level === 'A2' ? 'selected' : '' %>>A2</option>
                                            <option value="B1" <%= user.english_level === 'B1' ? 'selected' : '' %>>B1</option>
                                            <option value="B2" <%= user.english_level === 'B2' ? 'selected' : '' %>>B2</option>
                                            <option value="C1" <%= user.english_level === 'C1' ? 'selected' : '' %>>C1</option>
                                            <option value="C2" <%= user.english_level === 'C2' ? 'selected' : '' %>>C2</option>
                                        </select>
                                    </div>

                                    <div class="col-md-6">
                                        <label for="high_school_graduation_date" class="form-label">Lise Mezuniyet Tarihi *</label>
                                        <input type="text" class="form-control" id="high_school_graduation_date" name="high_school_graduation_date" value="<%= user.high_school_graduation_date ? new Date(user.high_school_graduation_date).toLocaleDateString('tr-TR').replace(/\./g, '/') : '' %>" placeholder="GG/AA/YYYY" required>
                                        <small class="text-muted">GG/AA/YYYY formatında slash (/) kullanarak giriniz.</small>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="birth_date" class="form-label">Doğum Tarihi *</label>
                                        <input type="text" class="form-control" id="birth_date" name="birth_date" value="<%= user.birth_date ? new Date(user.birth_date).toLocaleDateString('tr-TR').replace(/\./g, '/') : '' %>" placeholder="GG/AA/YYYY" required>
                                        <small class="text-muted">GG/AA/YYYY formatında slash (/) kullanarak giriniz.</small>
                                    </div>

                                    <div class="col-md-6">
                                        <label for="passport_type" class="form-label">Pasaport Türü *</label>
                                        <input type="text" class="form-control" id="passport_type" name="passport_type" value="<%= user.passport_type || '' %>" placeholder="Örn: Bordo, Yeşil, Gri, Siyah" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="passport_number" class="form-label">Pasaport Numarası *</label>
                                        <input type="text" class="form-control" id="passport_number" name="passport_number" value="<%= user.passport_number || '' %>" placeholder="Örn: P1234567" required>
                                    </div>

                                    <div class="col-md-6">
                                        <label for="desired_country" class="form-label">Gitmek İstediği Ülke *</label>
                                        <input type="text" class="form-control" id="desired_country" name="desired_country" value="<%= user.desired_country || '' %>" placeholder="Örn: Almanya" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="active_class" class="form-label">Aktif Sınıf *</label>
                                        <input type="text" class="form-control" id="active_class" name="active_class" value="<%= user.active_class || '' %>" placeholder="Örn: 11" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="current_school" class="form-label">Aktif Olarak Okuduğu Okul</label>
                                        <input type="text" class="form-control" id="current_school" name="current_school" value="<%= user.current_school || '' %>" placeholder="Örn: Galatasaray Lisesi">
                                    </div>
                                    <div class="col-12">
                                        <label for="home_address" class="form-label">Ev Adresi</label>
                                        <textarea class="form-control" id="home_address" name="home_address" rows="2" placeholder="Tam ev adresi"><%= user.home_address || '' %></textarea>
                                    </div>
                                </div>

                                <div class="text-end mt-3">
                                    <button type="button" class="btn btn-primary" onclick="showUpdateModal()">
                                        <i class="fas fa-save me-2"></i>Değişiklikleri Kaydet
                                    </button>
                                </div>
                            </form>

                            <!-- Inline Guardian Section -->
                            <hr class="my-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h5 class="mb-0"><i class="fas fa-user-friends me-2"></i><strong>VELİ BİLGİLERİ</strong></h5>
                                <button type="button" class="btn btn-sm btn-primary" onclick="showEditGuardiansModal()">
                                    <i class="fas fa-edit me-1"></i>Düzenle
                                </button>
                            </div>
                            <div id="adminGuardiansDisplay">
                                <!-- Guardians will be rendered dynamically -->
                                <p class="text-muted">Yükleniyor...</p>
                            </div>
                        </div>
                    </div>
                    
                    
                    <!-- Grades Tab -->
                    <div class="tab-pane fade" id="grades" role="tabpanel" style="overflow: visible; max-height: none;">
                        <div class="container-fluid px-0">
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <h5 class="mb-0 text-center"><strong>NOTLAR</strong></h5>
                                <button type="button" class="btn btn-primary" onclick="showAddNoteModal()">
                                    <i class="fas fa-plus me-2"></i>YENİ NOT EKLE
                                </button>
                            </div>

                        <!-- Filters -->
                        <div class="card mb-3">
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-3">
                                        <label for="noteCategoryFilter" class="form-label">Kategori</label>
                                        <select class="form-select" id="noteCategoryFilter" onchange="loadStudentNotes()">
                                            <option value="">Tüm Kategoriler</option>
                                            <option value="general">Genel</option>
                                            <option value="academic">Akademik</option>
                                            <option value="personal">Kişisel</option>
                                            <option value="important">Önemli</option>
                                            <option value="reminder">Hatırlatıcı</option>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="notePriorityFilter" class="form-label">Öncelik</label>
                                        <select class="form-select" id="notePriorityFilter" onchange="loadStudentNotes()">
                                            <option value="">Tüm Öncelikler</option>
                                            <option value="low">Düşük</option>
                                            <option value="medium">Orta</option>
                                            <option value="high">Yüksek</option>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="noteImportantFilter" class="form-label">Önemli Notlar</label>
                                        <select class="form-select" id="noteImportantFilter" onchange="loadStudentNotes()">
                                            <option value="">Tümü</option>
                                            <option value="true">Sadece Önemliler</option>
                                            <option value="false">Normal Notlar</option>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">&nbsp;</label>
                                        <div class="d-grid">
                                            <button type="button" class="btn btn-outline-secondary" onclick="clearNoteFilters()">
                                                <i class="fas fa-times me-1"></i>Filtreleri Temizle
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                            <!-- Notes List -->
                            <div id="studentNotesList" class="row">
                                <!-- Notes will be loaded here -->
                            </div>
                        </div>
                    </div>
                    
                    <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin) { %>
                    <!-- Services Tab (Sadece Super Admin) -->
                    <div class="tab-pane fade" id="services" role="tabpanel" style="overflow: visible; max-height: none;">
                        <div class="container-fluid px-0">
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <h5 class="mb-0 text-center"><strong>HİZMETLER</strong></h5>
                                <button type="button" class="btn btn-success" onclick="toggleAddServiceForm()">
                                    <i class="fas fa-plus me-2"></i>YENİ HİZMET EKLE
                                </button>
                            </div>
                        
                        <!-- Add Service Form (Initially Hidden) -->
                        <div id="addServiceFormContainer" class="card mb-4" style="display: none;">
                            <div class="card-header" style="background: #1e40af !important; background-color: #1e40af !important; border-bottom: 1px solid #1d4ed8 !important;">
                                <h6 class="mb-0" style="color: white !important;">Yeni Hizmet Ekle</h6>
                            </div>
                            <div class="card-body">
                                <form id="addServiceForm">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label for="serviceName" class="form-label">Hizmet Adı *</label>
                                                <!-- Dropdown for new service, will be changed to text input when editing -->
                                                <select class="form-select" id="serviceNameSelect" required>
                                                    <option value="">Hizmet Seçin</option>
                                                    <option value="Danismanlik Ucreti (Kabul Oncesi)">Danışmanlık Ücreti (Kabul Öncesi)</option>
                                                    <option value="Danismanlik Ucreti (Kabul Sonrasi)">Danışmanlık Ücreti (Kabul Sonrası)</option>
                                                </select>
                                                <input type="text" class="form-control" id="serviceName" placeholder="Hizmet adını girin" style="display: none;">
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="mb-3">
                                                <label for="serviceAmount" class="form-label">Tutar *</label>
                                                <input type="number" class="form-control" id="serviceAmount" step="0.01" min="0" placeholder="0.00" required>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="mb-3">
                                                <label for="serviceCurrency" class="form-label">Para Birimi *</label>
                                                <select class="form-select" id="serviceCurrency" required>
                                                    <option value="EUR">EUR (Euro)</option>
                                                    <option value="USD">USD (Dolar)</option>
                                                    <option value="TRY">TRY (Türk Lirası)</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-4">
                                            <div class="mb-3">
                                                <label for="serviceDueDate" class="form-label">Vade Tarihi</label>
                                                <input type="text" class="form-control date-turkish" id="serviceDueDate" placeholder="GG.AA.YYYY">
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="mb-3" id="paymentDateContainer" style="display: none;">
                                                <label for="servicePaymentDate" class="form-label">Ödeme Tarihi</label>
                                                <input type="text" class="form-control date-turkish" id="servicePaymentDate" placeholder="GG.AA.YYYY">
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="mb-3 form-check mt-4">
                                                <input type="checkbox" class="form-check-input" id="serviceIsPaid" onchange="togglePaymentDate()">
                                                <label class="form-check-label" for="serviceIsPaid">
                                                    <strong>Ödendi</strong>
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-12">
                                            <div class="mb-3">
                                                <label for="serviceNotes" class="form-label">Notlar</label>
                                                <textarea class="form-control" id="serviceNotes" rows="3" placeholder="Hizmet hakkında ek bilgiler..."></textarea>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <button type="button" class="btn btn-success" onclick="addService()">
                                            <i class="fas fa-save me-2"></i>Hizmet Ekle
                                        </button>
                                        <button type="button" class="btn btn-secondary" onclick="cancelAddService()">
                                            <i class="fas fa-times me-2"></i>İptal
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                        
                        <!-- Services List -->
                        <div id="servicesList" class="row">
                                <!-- Services will be loaded here -->
                            </div>
                        </div>
                    </div>
                    <% } %>
                    
                    <!-- Files Tab -->
                    <div class="tab-pane fade" id="files" role="tabpanel" style="overflow: visible; max-height: none;">
                        <div class="container-fluid px-0">
                            <!-- File Management -->
                            <div class="col-12">
                                <!-- File Upload Area -->
                                <div class="card mb-4">
                                    <div class="card-body">
                                        <div class="file-upload-area" id="fileUploadArea">
                                            <div class="upload-icon">
                                                <i class="fas fa-cloud-upload-alt fa-3x text-primary"></i>
                                            </div>
                                            <h5 class="mt-3">Yüklemek istediğiniz dosya veya resimleri sürükleyip bırakın</h5>
                                            <p class="text-muted">Desteklenen formatlar: PDF, JPG, JPEG, PNG, HEIC</p>
                                            <input type="file" id="fileInput" multiple accept=".pdf,.jpg,.jpeg,.png,.heic" style="display: none;">
                                            <button type="button" class="btn btn-primary mt-3" onclick="document.getElementById('fileInput').click()">
                                                <i class="fas fa-plus me-2"></i>Dosya Seç
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Contract Generation -->
                                <div class="card mb-4">
                                    <div class="card-header text-white" style="background: linear-gradient(135deg, #1a365d 0%, #2563eb 100%) !important;">
                                        <h6 class="mb-0" style="color: white !important;"><i class="fas fa-file-contract me-2"></i>Sözleşme Oluştur</h6>
                                    </div>
                                    <div class="card-body">
                                        <p class="text-muted mb-3">Öğrencinin mevcut bilgileri kullanılarak otomatik danışmanlık sözleşmesi PDF'i oluşturulur ve dosyalara eklenir.</p>
                                        <button type="button" class="btn btn-primary btn-lg w-100" id="generateContractBtn" onclick="generateContract()">
                                            <i class="fas fa-file-pdf me-2"></i>Danışmanlık Sözleşmesi Oluştur
                                        </button>
                                        <div id="contractProgress" style="display: none;" class="mt-3">
                                            <div class="d-flex align-items-center justify-content-center">
                                                <div class="spinner-border spinner-border-sm text-primary me-2" role="status">
                                                    <span class="visually-hidden">Oluşturuluyor...</span>
                                                </div>
                                                <span class="text-muted">Sözleşme oluşturuluyor, lütfen bekleyin...</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- File List -->
                                <div class="card">
                                    <div class="card-header bg-primary text-white" style="background-color: #2563eb !important; color: white !important; background: #2563eb !important;">
                                        <h6 class="mb-0" style="color: white !important;">Dosya Listesi</h6>
                                    </div>
                                    <div class="card-body">
                                        <div id="filesList">
                                            <!-- Files will be loaded here -->
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin) { %>
                    <!-- Partner Tab (Sadece Super Admin) -->
                    <div class="tab-pane fade" id="partner" role="tabpanel" style="overflow: visible; max-height: none;">
                        <div class="container-fluid px-0">
                            <h5 class="mb-4 text-center"><strong>Partner Kazançları</strong></h5>
                            <p class="text-muted text-center mb-4">Bir partnere tıklayarak kazanç ekleyebilirsiniz. Birden fazla partnere kazanç atanabilir.</p>
                            
                            <!-- Partner Search -->
                            <div class="mb-4">
                                <div class="input-group">
                                            <span class="input-group-text bg-primary text-white"><i class="fas fa-search"></i></span>
                                            <input type="text" class="form-control" id="partnerSearchInput" placeholder="Partner ara...">
                                        </div>
                                        </div>
                            
                            <!-- Partners Grid -->
                            <div class="row g-3 mb-4" id="partnersGrid">
                                <div class="col-12 text-center py-4">
                                    <div class="spinner-border text-primary" role="status">
                                        <span class="visually-hidden">Yükleniyor...</span>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Selected Partner Earnings Section -->
                            <div id="selectedPartnerSection" style="display: none;">
                                <div class="card">
                                <div class="card-header text-white" style="background: linear-gradient(135deg, #0078D7 0%, #005A9E 100%);">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <h6 class="mb-0"><i class="fas fa-user-tie me-2"></i><span id="selectedPartnerName">Partner</span> - Kazançlar</h6>
                                            <button class="btn btn-sm btn-light" onclick="closePartnerSection()">
