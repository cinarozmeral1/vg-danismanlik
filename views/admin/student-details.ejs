    };

    function getTimeAgo(dateString) {
        const date = new Date(dateString);
        const now = new Date();
        const diffInSeconds = Math.floor((now - date) / 1000);
        
        if (diffInSeconds < 60) return 'Az önce';
        if (diffInSeconds < 3600) return `${Math.floor(diffInSeconds / 60)} dakika önce`;
        if (diffInSeconds < 86400) return `${Math.floor(diffInSeconds / 3600)} saat önce`;
        if (diffInSeconds < 2592000) return `${Math.floor(diffInSeconds / 86400)} gün önce`;
        if (diffInSeconds < 31536000) return `${Math.floor(diffInSeconds / 2592000)} ay önce`;
        return `${Math.floor(diffInSeconds / 31536000)} yıl önce`;
    }

    // File upload functions
    function handleFileUpload(event) {
        const files = event.target.files;
        if (files.length > 0) {
            uploadFiles(files);
        }
    }

    async function uploadFiles(files) {

        const allowedTypes = ['application/pdf', 'image/jpeg', 'image/jpg', 'image/png', 'image/heic'];
        const maxSize = 10 * 1024 * 1024; // 10MB

        for (let file of files) {
            // Validate file type
            if (!allowedTypes.includes(file.type)) {
                showAlert('danger', `Dosya türü desteklenmiyor: ${file.name}. Sadece PDF, JPG, JPEG, PNG, HEIC dosyaları yüklenebilir.`);
                continue;
            }

            // Validate file size
            if (file.size > maxSize) {
                showAlert('danger', `Dosya boyutu çok büyük: ${file.name}. Maksimum 10MB yüklenebilir.`);
                continue;
            }

            await uploadSingleFile(file);
        }

        // Clear file input
        document.getElementById('fileInput').value = '';
    }

    async function uploadSingleFile(file) {
        try {
            console.log('Uploading file:', file.name);
            
            // Get title and description from user input
            const title = prompt('Belge başlığını girin:', file.name);
            if (!title) {
                showAlert('warning', 'Belge başlığı gereklidir');
                return;
            }
            
            const description = prompt('Belge açıklamasını girin (isteğe bağlı):', '');
            
            const formData = new FormData();
            formData.append('file', file);
            formData.append('title', title);
            formData.append('description', description || '');

            const response = await fetch(`/api/admin/users/<%= user.id %>/files/upload`, {
                method: 'POST',
                credentials: 'include',
                body: formData
            });

            console.log('Upload response status:', response.status);

            if (!response.ok) {
                const errorData = await response.json();
                throw new Error(errorData.message || `HTTP error! status: ${response.status}`);
            }

            const result = await response.json();
            console.log('Upload result:', result);

            if (result.success) {
                showAlert('success', `Dosya başarıyla yüklendi: ${file.name}`);
                // Reload files
                loadFiles();
            } else {
                throw new Error(result.message);
            }
        } catch (error) {
            console.error('Error uploading file:', error);
            showAlert('danger', `Dosya yüklenirken hata oluştu: ${file.name} - ${error.message}`);
        }
    }







