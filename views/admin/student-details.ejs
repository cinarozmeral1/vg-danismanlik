    // Make toggleChecklistItem globally accessible
    window.toggleChecklistItem = async function(itemId, isCompleted) {
        console.log('Toggling checklist item:', itemId, 'to:', isCompleted);
        try {
            const response = await fetch(`/api/admin/users/<%= user.id %>/checklist/${itemId}`, {
                method: 'PUT',
                credentials: 'include',
                headers: {
                    'Content-Type': 'application/json'
                },
