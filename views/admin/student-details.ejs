    window.addService = async function() {
        try {
            const serviceName = document.getElementById('serviceName').value;
            const amount = parseFloat(document.getElementById('serviceAmount').value);
            const currency = document.getElementById('serviceCurrency').value;
            const dueDate = document.getElementById('serviceDueDate').value || null;
            const paymentDate = document.getElementById('servicePaymentDate').value || null;
            const isPaid = document.getElementById('serviceIsPaid').checked;
            const notes = document.getElementById('serviceNotes').value;
            
            if (!serviceName || !amount) {
                showAlert('warning', 'Lütfen tüm gerekli alanları doldurun');
                return;
            }
            
            console.log('Adding service with data:', {
                serviceName, amount, currency, dueDate, paymentDate, isPaid, notes
            });
            
            const response = await fetch(`/api/admin/users/<%= user.id %>/services`, {
                method: 'POST',
                credentials: 'include',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    service_name: serviceName,
                    amount: amount,
                    currency: currency,
                    due_date: dueDate,
                    payment_date: paymentDate,
                    is_paid: isPaid,
                    notes: notes
                })
            });

            if (!response.ok) {
                throw new Error(`HTTP error! status: ${response.status}`);
            }

            const result = await response.json();
            
            if (result.success) {
                showAlert('success', 'Hizmet başarıyla eklendi');
                loadServices();
                cancelAddService();
            } else {
                throw new Error(result.message);
            }
        } catch (error) {
            console.error('Error adding service:', error);
            showAlert('danger', 'Hizmet eklenirken hata oluştu: ' + error.message);
        }
    };

    // Delete service
    window.deleteService = async function(serviceId) {
        if (!confirm('Bu hizmeti silmek istediğinizden emin misiniz?')) {
            return;
        }

        try {
            console.log('Deleting service:', serviceId);
            const response = await fetch(`/api/admin/users/<%= user.id %>/services/${serviceId}`, {
                method: 'DELETE',
                credentials: 'include',
                headers: {
                    'Content-Type': 'application/json'
                }
            });

            if (!response.ok) {
                throw new Error(`HTTP error! status: ${response.status}`);
            }

            const result = await response.json();
            
            if (result.success) {
                showAlert('success', 'Hizmet başarıyla silindi');
                loadServices();
            } else {
                throw new Error(result.message);
            }
        } catch (error) {
            console.error('Error deleting service:', error);
            showAlert('danger', 'Hizmet silinirken hata oluştu: ' + error.message);
        }
    };

    // Mark installment as paid
    window.markInstallmentPaid = async function(installmentId) {
        try {
            const response = await fetch(`/api/admin/installments/${installmentId}`, {
                method: 'PATCH',
                headers: {
                    'Content-Type': 'application/json',
                },
                credentials: 'include',
                body: JSON.stringify({
                    is_paid: true,
                    payment_date: new Date().toISOString().split('T')[0]
                })
            });

            const result = await response.json();
            
            if (result.success) {
                showAlert('success', 'Taksit ödendi olarak işaretlendi');
                loadServices();
            } else {
                throw new Error(result.message);
            }
        } catch (error) {
            console.error('Error marking installment paid:', error);
            showAlert('error', 'Taksit güncellenirken hata oluştu: ' + error.message);
        }
    };

    // Mark installment as unpaid
    window.markInstallmentUnpaid = async function(installmentId) {
        try {
            const response = await fetch(`/api/admin/installments/${installmentId}`, {
                method: 'PATCH',
                headers: {
                    'Content-Type': 'application/json',
                },
                credentials: 'include',
                body: JSON.stringify({
                    is_paid: false,
                    payment_date: null
                })
            });

            const result = await response.json();
            
            if (result.success) {
                showAlert('success', 'Taksit ödenmedi olarak işaretlendi');
                loadServices();
            } else {
                throw new Error(result.message);
            }
        } catch (error) {
            console.error('Error marking installment unpaid:', error);
            showAlert('error', 'Taksit güncellenirken hata oluştu: ' + error.message);
        }
    };

});

function showUpdateModal(){
    const modalHtml = `
        <div class="modal fade" id="confirmStudentUpdateModal" tabindex="-1" aria-labelledby="confirmStudentUpdateModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="confirmStudentUpdateModalLabel">Öğrenci Bilgilerini Güncelle</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        Değişiklikleri kaydetmek istediğinize emin misiniz?
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                        <button type="button" class="btn btn-primary" id="confirmStudentUpdateBtn">
                            <i class="fas fa-save me-2"></i>Kaydet
                        </button>
                    </div>
                </div>
            </div>
        </div>`;

    const existingModal = document.getElementById('confirmStudentUpdateModal');
    if (existingModal) {
        existingModal.remove();
    }

    const modalContainer = document.getElementById('studentNoteModalContainer') || document.body;
    modalContainer.insertAdjacentHTML('beforeend', modalHtml);
    const modalElement = document.getElementById('confirmStudentUpdateModal');
    const modalInstance = new bootstrap.Modal(modalElement);

    modalElement.addEventListener('shown.bs.modal', () => {
        const confirmBtn = document.getElementById('confirmStudentUpdateBtn');
        if (confirmBtn) {
            confirmBtn.focus();
            confirmBtn.addEventListener('click', () => {
                modalInstance.hide();
                saveStudent();
            }, { once: true });
        }
    });

    modalElement.addEventListener('hidden.bs.modal', () => {
        modalElement.remove();
    });

    modalInstance.show();
}

function saveStudent(){
    let loadingToastId = null;
    if (typeof showToast === 'function') {
        loadingToastId = showToast({
            title: 'Güncelleniyor',
            message: 'Öğrenci bilgileri kaydediliyor...',
            type: 'info'
        });
    }

    const formatDate = (value) => {
        if (!value) return null;
        const parts = value.split(/[\.\/]/);
        if (parts.length === 3) {
            const [day, month, year] = parts;
            if (year.length === 4) {
                return `${year.padStart(4, '0')}-${month.padStart(2, '0')}-${day.padStart(2, '0')}`;
            }
        }
        return value;
    };

    const payload = {
        first_name: document.getElementById('first_name').value,
        last_name: document.getElementById('last_name').value,
        email: document.getElementById('email').value,
        phone: document.getElementById('phone').value,
        english_level: document.getElementById('english_level').value,
        high_school_graduation_date: formatDate(document.getElementById('high_school_graduation_date').value),
        birth_date: formatDate(document.getElementById('birth_date').value),
        tc_number: document.getElementById('tc_number').value,
        passport_type: document.getElementById('passport_type').value,
        passport_number: document.getElementById('passport_number').value,
        desired_country: document.getElementById('desired_country').value,
        active_class: document.getElementById('active_class').value,
    };

    fetch('/api/admin/users/<%= user.id %>/details', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    })
    .then(res => res.json())
    .then(result => {
        if (typeof hideToast === 'function' && loadingToastId) {
            hideToast(loadingToastId);
        }
        if (result.success) {
            if (typeof showToast === 'function') {
                showToast({
                    title: 'Başarılı',
                    message: 'Öğrenci bilgileri güncellendi.',
                    type: 'success'
                });
            } else {
                showAlert('success', 'Öğrenci bilgileri güncellendi.');
            }
            setTimeout(() => {
                window.location.reload();
            }, 1200);
        } else {
            if (typeof showToast === 'function') {
                showToast({
                    title: 'Hata',
                    message: result.message || 'Öğrenci bilgileri kaydedilemedi.',
                    type: 'danger'
                });
            } else {
                showAlert('danger', result.message || 'Öğrenci bilgileri kaydedilemedi.');
            }
        }
    })
    .catch(err => {
        console.error(err);
        if (typeof hideToast === 'function' && loadingToastId) {
            hideToast(loadingToastId);
        }
        if (typeof showToast === 'function') {
            showToast({
                title: 'Sunucu Hatası',
                message: 'İşlem sırasında beklenmedik bir hata oluştu.',
                type: 'danger'
            });
        } else {
            showAlert('danger', 'İşlem sırasında beklenmedik bir hata oluştu.');
        }
    });
}

async function changeAvatar() {
    console.log('🔧 Changing avatar...');
    
    // Create file input for avatar upload
    const fileInput = document.createElement('input');
    fileInput.type = 'file';
    fileInput.accept = 'image/jpeg,image/jpg,image/png,image/gif,image/webp';
    fileInput.style.display = 'none';
    
    fileInput.addEventListener('change', async function(e) {
        const file = e.target.files[0];
        if (file) {
            // Validate file type
            if (!file.type.startsWith('image/')) {
                showAlert('danger', 'Lütfen sadece resim dosyası seçin!');
                return;
            }
            
            // Validate specific image formats (exclude HEIC)
            const allowedFormats = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif', 'image/webp'];
            if (!allowedFormats.includes(file.type)) {
                showAlert('danger', 'Desteklenmeyen resim formatı! Lütfen JPG, PNG, GIF veya WebP formatında resim yükleyin.');
                return;
            }
            
            // Validate file size (max 5MB)
            if (file.size > 5 * 1024 * 1024) {
                showAlert('danger', 'Dosya boyutu çok büyük! Maksimum 5MB yüklenebilir.');
                return;
            }
            
            try {
                // Show loading
                showAlert('info', 'Avatar yükleniyor...');
                console.log('📤 Uploading avatar for user:', '<%= user.id %>');
                console.log('📤 Upload URL:', `/admin/users/<%= user.id %>/avatar`);
                
                // Create FormData
                const formData = new FormData();
                formData.append('avatar', file);
                console.log('📁 File details:', { name: file.name, size: file.size, type: file.type });
                console.log('📁 FormData entries:', Array.from(formData.entries()));
                
                // Upload to server
                const response = await fetch(`/admin/users/<%= user.id %>/avatar`, {
                    method: 'POST',
                    credentials: 'include',
                    body: formData
                });
                
                console.log('📡 Response status:', response.status);
                
                if (!response.ok) {
                    const errorText = await response.text();
                    console.error('❌ Server error response:', errorText);
                    throw new Error(`HTTP error! status: ${response.status} - ${errorText}`);
                }
                
                const result = await response.json();
                console.log('📡 Response result:', result);
                
                if (result.success) {
                    // Update avatar image
                    const avatarImg = document.getElementById('userAvatar');
                    console.log('🖼️ Avatar element found:', avatarImg);
                    console.log('🖼️ New avatar URL:', result.avatar_url);
                    console.log('🖼️ Avatar URL length:', result.avatar_url ? result.avatar_url.length : 'null');
                    
                    if (avatarImg) {
                        // Direct base64 data URL, no caching needed
                        avatarImg.src = result.avatar_url;
                        console.log('🖼️ Avatar src updated to:', avatarImg.src.substring(0, 50) + '...');
                        
                        // Force image reload
                        avatarImg.onload = function() {
                            console.log('🖼️ Avatar image loaded successfully');
                        };
                        avatarImg.onerror = function() {
                            console.error('🖼️ Avatar image failed to load');
                        };
                    } else {
                        console.error('🖼️ Avatar element not found!');
                    }
                    
                    showAlert('success', 'Avatar başarıyla değiştirildi!');
                } else {
                    throw new Error(result.message);
                }
            } catch (error) {
                console.error('❌ Error uploading avatar:', error);
                showAlert('danger', 'Avatar yüklenirken hata oluştu: ' + error.message);
            }
        }
    });
    
    document.body.appendChild(fileInput);
    fileInput.click();
    document.body.removeChild(fileInput);
}

// Notes functionality
let currentNoteId = null;

// Load student notes
async function loadStudentNotes() {
    try {
        console.log('🔧 Loading student notes...');
        
        // Show loading state
        const notesList = document.getElementById('studentNotesList');
        notesList.innerHTML = `
            <div class="col-12">
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Yükleniyor...</span>
                    </div>
                    <p class="mt-2 text-muted">Notlar yükleniyor...</p>
                </div>
            </div>
        `;
        
        const category = document.getElementById('noteCategoryFilter').value;
        const priority = document.getElementById('notePriorityFilter').value;
        const isImportant = document.getElementById('noteImportantFilter').value;

        let url = `/api/admin/users/<%= user.id %>/notes`;

        const params = new URLSearchParams();
        if (category) params.append('category', category);
        if (priority) params.append('priority', priority);
        if (isImportant) params.append('is_important', isImportant);

        if (params.toString()) {
            url += '?' + params.toString();
        }

        console.log('📡 Notes API URL:', url);

        const response = await fetch(url, {
            credentials: 'include',
            headers: {
                'Content-Type': 'application/json'
            }
        });

        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }

        const result = await response.json();
        console.log('📊 Notes result:', result);
        
        if (result.success) {
            displayStudentNotes(result.notes || []);
        } else {
            throw new Error(result.message || 'Notlar yüklenemedi');
        }
    } catch (error) {
        console.error('❌ Error loading student notes:', error);
        const notesList = document.getElementById('studentNotesList');
        notesList.innerHTML = `
            <div class="col-12">
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    Notlar yüklenirken hata oluştu: ${error.message}
                </div>
            </div>
        `;
    }
}

// Display student notes
function displayStudentNotes(notes) {
    console.log('🔧 Displaying student notes:', notes);
    const notesList = document.getElementById('studentNotesList');
    
    if (notes.length === 0) {
        notesList.innerHTML = `
            <div class="col-12">
                <div class="text-center py-5">
                    <i class="fas fa-sticky-note fa-3x text-muted mb-3"></i>
                    <h5 class="text-muted">Henüz not bulunmuyor</h5>
                    <p class="text-muted">Bu öğrenci için henüz not eklenmemiş.</p>
                </div>
            </div>
        `;
        return;
    }

    let html = '';
    notes.forEach(note => {
        const priorityClass = getNotePriorityClass(note.priority);
        const categoryClass = getNoteCategoryClass(note.category);
        const importantIcon = note.is_important ? '<i class="fas fa-star text-warning"></i>' : '';
        
        html += `
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 ${note.is_important ? 'border-warning' : ''}">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <div>
                            <span class="badge ${categoryClass} me-2">${getNoteCategoryName(note.category)}</span>
                            <span class="badge ${priorityClass}">${getNotePriorityName(note.priority)}</span>
                        </div>
                        <div>
                            ${importantIcon}
                            <div class="btn-group btn-group-sm">
                                <button class="btn btn-outline-primary" onclick="editStudentNote(${note.id})" title="Düzenle">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="btn btn-outline-danger" onclick="deleteStudentNote(${note.id})" title="Sil">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="card-body">
                        <h6 class="card-title">${note.title}</h6>
                        <p class="card-text">${note.content}</p>
                    </div>
                    <div class="card-footer">
                        <small class="text-muted">
                            <i class="fas fa-clock me-1"></i>
                            ${new Date(note.created_at).toLocaleDateString('tr-TR')}
                        </small>
                    </div>
                </div>
            </div>
        `;
    });

    notesList.innerHTML = html;
    console.log('✅ Student notes displayed successfully');
}

