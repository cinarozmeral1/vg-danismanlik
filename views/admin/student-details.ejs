function showUpdateModal(){
    const modalHtml = `
        <div class="modal fade" id="confirmStudentUpdateModal" tabindex="-1" aria-labelledby="confirmStudentUpdateModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="confirmStudentUpdateModalLabel">Öğrenci Bilgilerini Güncelle</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        Değişiklikleri kaydetmek istediğinize emin misiniz?
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                        <button type="button" class="btn btn-primary" id="confirmStudentUpdateBtn">
                            <i class="fas fa-save me-2"></i>Kaydet
                        </button>
                    </div>
                </div>
            </div>
        </div>`;

    const existingModal = document.getElementById('confirmStudentUpdateModal');
    if (existingModal) {
        existingModal.remove();
    }

    const modalContainer = document.getElementById('studentNoteModalContainer') || document.body;
    modalContainer.insertAdjacentHTML('beforeend', modalHtml);
    const modalElement = document.getElementById('confirmStudentUpdateModal');
    const modalInstance = new bootstrap.Modal(modalElement);

    modalElement.addEventListener('shown.bs.modal', () => {
        const confirmBtn = document.getElementById('confirmStudentUpdateBtn');
        if (confirmBtn) {
            confirmBtn.focus();
            confirmBtn.addEventListener('click', () => {
                modalInstance.hide();
                saveStudent();
            }, { once: true });
        }
    });

    modalElement.addEventListener('hidden.bs.modal', () => {
        modalElement.remove();
    });

    modalInstance.show();
}

function saveStudent(){
    let loadingToastId = null;
    if (typeof showToast === 'function') {
        loadingToastId = showToast({
            title: 'Güncelleniyor',
            message: 'Öğrenci bilgileri kaydediliyor...',
            type: 'info'
        });
    }

    const formatDate = (value) => {
        if (!value) return null;
        const parts = value.split(/[\.\/]/);
        if (parts.length === 3) {
            const [day, month, year] = parts;
            if (year.length === 4) {
                return `${year.padStart(4, '0')}-${month.padStart(2, '0')}-${day.padStart(2, '0')}`;
            }
        }
        return value;
    };

    const payload = {
        first_name: document.getElementById('first_name').value,
        last_name: document.getElementById('last_name').value,
        email: document.getElementById('email').value,
        phone: document.getElementById('phone').value,
        english_level: document.getElementById('english_level').value,
        high_school_graduation_date: formatDate(document.getElementById('high_school_graduation_date').value),
        birth_date: formatDate(document.getElementById('birth_date').value),
        tc_number: document.getElementById('tc_number').value,
        passport_type: document.getElementById('passport_type').value,
        passport_number: document.getElementById('passport_number').value,
        desired_country: document.getElementById('desired_country').value,
        active_class: document.getElementById('active_class').value,
        current_school: document.getElementById('current_school') ? document.getElementById('current_school').value : null,
        home_address: document.getElementById('home_address') ? document.getElementById('home_address').value : null,
    };

    fetch('/api/admin/users/<%= user.id %>/details', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    })
    .then(res => res.json())
    .then(result => {
        if (typeof hideToast === 'function' && loadingToastId) {
            hideToast(loadingToastId);
        }
        if (result.success) {
            if (typeof showToast === 'function') {
                showToast({
                    title: 'Başarılı',
                    message: 'Öğrenci bilgileri güncellendi.',
                    type: 'success'
                });
            } else {
                showAlert('success', 'Öğrenci bilgileri güncellendi.');
            }
            setTimeout(() => {
                window.location.reload();
            }, 1200);
        } else {
            if (typeof showToast === 'function') {
                showToast({
                    title: 'Hata',
                    message: result.message || 'Öğrenci bilgileri kaydedilemedi.',
                    type: 'danger'
                });
            } else {
                showAlert('danger', result.message || 'Öğrenci bilgileri kaydedilemedi.');
            }
        }
    })
    .catch(err => {
        console.error(err);
        if (typeof hideToast === 'function' && loadingToastId) {
            hideToast(loadingToastId);
        }
        if (typeof showToast === 'function') {
            showToast({
                title: 'Sunucu Hatası',
                message: 'İşlem sırasında beklenmedik bir hata oluştu.',
                type: 'danger'
            });
        } else {
            showAlert('danger', 'İşlem sırasında beklenmedik bir hata oluştu.');
        }
    });
}

async function changeAvatar() {
    console.log('🔧 Changing avatar...');
    
    // Create file input for avatar upload
    const fileInput = document.createElement('input');
    fileInput.type = 'file';
    fileInput.accept = 'image/jpeg,image/jpg,image/png,image/gif,image/webp';
    fileInput.style.display = 'none';
    
    fileInput.addEventListener('change', async function(e) {
        const file = e.target.files[0];
        if (file) {
            // Validate file type
            if (!file.type.startsWith('image/')) {
                showAlert('danger', 'Lütfen sadece resim dosyası seçin!');
                return;
            }
            
            // Validate specific image formats (exclude HEIC)
            const allowedFormats = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif', 'image/webp'];
            if (!allowedFormats.includes(file.type)) {
                showAlert('danger', 'Desteklenmeyen resim formatı! Lütfen JPG, PNG, GIF veya WebP formatında resim yükleyin.');
                return;
            }
            
            // Validate file size (max 5MB)
            if (file.size > 5 * 1024 * 1024) {
                showAlert('danger', 'Dosya boyutu çok büyük! Maksimum 5MB yüklenebilir.');
                return;
            }
            
            try {
                // Show loading
                showAlert('info', 'Avatar yükleniyor...');
                console.log('📤 Uploading avatar for user:', '<%= user.id %>');
                console.log('📤 Upload URL:', `/admin/users/<%= user.id %>/avatar`);
                
                // Create FormData
                const formData = new FormData();
                formData.append('avatar', file);
                console.log('📁 File details:', { name: file.name, size: file.size, type: file.type });
                console.log('📁 FormData entries:', Array.from(formData.entries()));
                
                // Upload to server
                const response = await fetch(`/admin/users/<%= user.id %>/avatar`, {
                    method: 'POST',
                    credentials: 'include',
                    body: formData
                });
                
                console.log('📡 Response status:', response.status);
                
                if (!response.ok) {
                    const errorText = await response.text();
                    console.error('❌ Server error response:', errorText);
                    throw new Error(`HTTP error! status: ${response.status} - ${errorText}`);
                }
                
                const result = await response.json();
                console.log('📡 Response result:', result);
                
                if (result.success) {
                    // Update avatar image
                    const avatarImg = document.getElementById('userAvatar');
                    console.log('🖼️ Avatar element found:', avatarImg);
                    console.log('🖼️ New avatar URL:', result.avatar_url);
                    console.log('🖼️ Avatar URL length:', result.avatar_url ? result.avatar_url.length : 'null');
                    
                    if (avatarImg) {
                        // Direct base64 data URL, no caching needed
                        avatarImg.src = result.avatar_url;
                        console.log('🖼️ Avatar src updated to:', avatarImg.src.substring(0, 50) + '...');
                        
                        // Force image reload
                        avatarImg.onload = function() {
                            console.log('🖼️ Avatar image loaded successfully');
                        };
                        avatarImg.onerror = function() {
                            console.error('🖼️ Avatar image failed to load');
                        };
                    } else {
                        console.error('🖼️ Avatar element not found!');
                    }
                    
                    showAlert('success', 'Avatar başarıyla değiştirildi!');
                } else {
                    throw new Error(result.message);
                }
            } catch (error) {
                console.error('❌ Error uploading avatar:', error);
                showAlert('danger', 'Avatar yüklenirken hata oluştu: ' + error.message);
            }
        }
    });
    
    document.body.appendChild(fileInput);
    fileInput.click();
    document.body.removeChild(fileInput);
}

