<script>
document.addEventListener('DOMContentLoaded', function() {
    // Load checklist when checklist tab is shown
    const checklistTab = document.getElementById('checklist-tab');
    console.log('Checklist tab element:', checklistTab);
    
    if (checklistTab) {
        checklistTab.addEventListener('shown.bs.tab', function() {
            console.log('🔧 Checklist tab shown, refreshing checklist...');
            loadChecklist();
            hideRemainingButtonsKaydetButtons();
        });
    }
    
    // Also load initially if checklist tab is active
    if (checklistTab && checklistTab.classList.contains('active')) {
        console.log('Checklist tab is initially active, loading checklist...');
        loadChecklist();
    }

    // Load files when files tab is shown
    const filesTab = document.getElementById('files-tab');
    if (filesTab) {
        filesTab.addEventListener('shown.bs.tab', function() {
            console.log('Files tab shown, loading files...');
            try {
                loadFiles();
            } catch (error) {
                console.error('Error loading files:', error);
            }
        });
        
        filesTab.addEventListener('click', function() {
            console.log('Files tab clicked, loading files...');
            setTimeout(() => {
                try {
                    loadFiles();
                } catch (error) {
                    console.error('Error loading files:', error);
                }
            }, 100);
        });
    }
    
    // Also load initially if files tab is active
    if (filesTab && filesTab.classList.contains('active')) {
        console.log('Files tab is initially active, loading files...');
        try {
            loadFiles();
        } catch (error) {
            console.error('Error loading files:', error);
        }
    }




    // File upload functionality
    const fileInput = document.getElementById('fileInput');
    const fileUploadArea = document.getElementById('fileUploadArea');

    if (fileInput) {
        fileInput.addEventListener('change', handleFileUpload);
    }

    if (fileUploadArea) {
        // Drag and drop functionality
        fileUploadArea.addEventListener('dragover', function(e) {
            e.preventDefault();
            fileUploadArea.classList.add('dragover');
        });

        fileUploadArea.addEventListener('dragleave', function(e) {
            e.preventDefault();
            fileUploadArea.classList.remove('dragover');
        });

        fileUploadArea.addEventListener('drop', function(e) {
            e.preventDefault();
            fileUploadArea.classList.remove('dragover');
            
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                uploadFiles(files);
            }
        });
    }

    // Form submission
    document.getElementById('studentForm').addEventListener('submit', function(e) {
        e.preventDefault();
        
        const formData = new FormData(this);
        const data = Object.fromEntries(formData.entries());
        
        // Convert empty strings to null for optional fields
        Object.keys(data).forEach(key => {
            if (data[key] === '') {
                data[key] = null;
            }
        });
        
        fetch(`/api/admin/users/<%= user.id %>/details`, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(data)
        })
        .then(response => response.json())
        .then(result => {
            if (result.success) {
                // Show success message
                const alertDiv = document.createElement('div');
                alertDiv.className = 'alert alert-success alert-dismissible fade show';
                alertDiv.innerHTML = `
                    <i class="fas fa-check-circle me-2"></i>${result.message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                `;
                document.querySelector('.section-header').appendChild(alertDiv);
                
                // Auto-hide after 3 seconds
                setTimeout(() => {
                    alertDiv.remove();
                }, 3000);
            } else {
                throw new Error(result.message);
            }
        })
        .catch(error => {
            console.error('Update error:', error);
            const alertDiv = document.createElement('div');
            alertDiv.className = 'alert alert-danger alert-dismissible fade show';
            alertDiv.innerHTML = `
                <i class="fas fa-exclamation-circle me-2"></i>Hata: ${error.message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            document.querySelector('.section-header').appendChild(alertDiv);
        });
    });

    // Checklist functions
    async function loadChecklist() {
        console.log('Loading checklist for user:', <%= user.id %>);
        try {
            const response = await fetch(`/api/admin/users/<%= user.id %>/checklist`, {
                method: 'GET',
                credentials: 'include',
                headers: {
                    'Content-Type': 'application/json'
                }
            });

            console.log('Checklist response status:', response.status);
            
            if (!response.ok) {
                throw new Error(`HTTP error! status: ${response.status}`);
            }

            const data = await response.json();
            console.log('Checklist data:', data);
            if (data.checklist && data.checklist.length > 0) {
                displayChecklist(data.checklist);
            } else {
                console.log('Checklist empty, initializing defaults...');
                await initializeChecklist();
            }
        } catch (error) {
            console.error('Error loading checklist:', error);
            // Show default checklist if API fails
            showDefaultChecklist();
        }
    }

    async function initializeChecklist() {
        try {
            const response = await fetch(`/api/admin/users/<%= user.id %>/checklist/initialize`, {
                method: 'POST',
                credentials: 'include',
                headers: {
                    'Content-Type': 'application/json'
                }
            });

            if (!response.ok) {
                throw new Error(`Initialize checklist failed: ${response.status}`);
            }

            await loadChecklist();
        } catch (error) {
            console.error('Checklist initialize error:', error);
            showDefaultChecklist();
        }
    }

    function displayChecklist(checklist) {
        console.log('Displaying checklist:', checklist);
        const container = document.getElementById('checklistContainer');
        console.log('Checklist container:', container);
        
        if (!checklist || checklist.length === 0) {
            console.log('No checklist data, showing default');
            showDefaultChecklist();
            return;
        }

        // Calculate progress
        const completedCount = checklist.filter(item => item.is_completed).length;
        const totalCount = checklist.length;
        const progressPercentage = (completedCount / totalCount) * 100;

        let html = `
            <div class="checklist-progress mb-4">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="text-muted">İlerleme: <span id="progressCount">${completedCount}</span>/${totalCount}</span>
                    <span class="text-muted">%<span id="progressPercentage">${Math.round(progressPercentage)}</span></span>
                </div>
                <div class="progress" style="height: 8px;">
                    <div class="progress-bar" id="progressBar" style="width: ${progressPercentage}%"></div>
                </div>
            </div>
        `;

        checklist.forEach(item => {
            html += `
                <div class="checklist-item ${item.is_completed ? 'completed' : ''}" data-item-id="${item.id}">
                    <label class="toggle-switch">
                        <input type="checkbox" ${item.is_completed ? 'checked' : ''} 
                               onchange="toggleChecklistItem(${item.id}, this.checked)">
                        <span class="slider"></span>
                    </label>
                    <div class="checklist-text ${item.is_completed ? 'completed' : ''}">
                        ${item.item_name}
                    </div>
                </div>
            `;
        });

        container.innerHTML = html;
    }

    function showDefaultChecklist() {
        const container = document.getElementById('checklistContainer');
        if (!container) {
            console.error('Checklist container not found!');
            return;
        }

        container.innerHTML = `
            <div class="alert alert-info">
                <i class="fas fa-info-circle me-2"></i>
                Kontrol listesi oluşturulmamış. Varsayılan maddeler ekleniyor...
            </div>
        `;

        initializeChecklist().catch(err => {
            console.error('Default checklist initialization failed:', err);
            document.getElementById('checklistContainer').innerHTML = getDefaultChecklistHTML();
        });
    }

    async function loadChecklistFromDatabase() {
        try {
            console.log('Loading checklist from database for user:', <%= user.id %>);
            const response = await fetch(`/api/admin/users/<%= user.id %>/checklist`, {
                method: 'GET',
                credentials: 'include',
                headers: {
                    'Content-Type': 'application/json'
                }
            });

            console.log('Database checklist response status:', response.status);
            
            if (!response.ok) {
                throw new Error(`HTTP error! status: ${response.status}`);
            }

            const data = await response.json();
            console.log('Database checklist data:', data);
            
            if (data.checklist && data.checklist.length > 0) {
                displayChecklist(data.checklist);
            } else {
                // If no checklist exists, create it
                await createChecklistForUser();
            }
        } catch (error) {
            console.error('Error loading checklist from database:', error);
            showDefaultChecklistFallback();
        }
    }

    async function createChecklistForUser() {
        try {
            console.log('Creating checklist for user:', <%= user.id %>);
            const response = await fetch(`/api/admin/users/<%= user.id %>/checklist/initialize`, {
                method: 'POST',
                credentials: 'include',
                headers: {
                    'Content-Type': 'application/json'
                }
            });

            console.log('Create checklist response status:', response.status);
            
            if (!response.ok) {
                throw new Error(`HTTP error! status: ${response.status}`);
            }

