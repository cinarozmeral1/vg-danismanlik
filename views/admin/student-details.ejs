function adminAddGuardianCard() {
    const container = document.getElementById('adminGuardiansContainer');
    container.insertAdjacentHTML('beforeend', adminCreateGuardianCardHTML(
        { full_name: '', relationship: 'Diger' }, adminGuardianCounter, false
    ));
    adminGuardianCounter++;
}

function adminRemoveGuardianCard(btn) {
    const card = btn.closest('.admin-guardian-card');
    if (card && card.dataset.required !== 'true') card.remove();
}

function adminCollectGuardianData() {
    const cards = document.querySelectorAll('.admin-guardian-card');
    const guardians = [];
    cards.forEach((card, i) => {
        guardians.push({
            full_name: card.querySelector('.admin-g-fullname').value.trim(),
            relationship: card.querySelector('.admin-g-relationship').value,
            tc_number: card.querySelector('.admin-g-tc').value.trim(),
            phone: card.querySelector('.admin-g-phone').value.trim(),
            email: card.querySelector('.admin-g-email').value.trim(),
            address: card.querySelector('.admin-g-address').value.trim(),
            is_required: i < 2,
            sort_order: i + 1
        });
    });
    return guardians;
}

// Load guardians from API
async function loadGuardians() {
    try {
        const response = await fetch(`/api/admin/users/<%= user.id %>/guardians`, {
            method: 'GET', credentials: 'include',
            headers: { 'Content-Type': 'application/json' }
