    // Toggle payment date visibility based on checkbox
    window.togglePaymentDate = function() {
        const isPaid = document.getElementById('serviceIsPaid').checked;
        const paymentDateContainer = document.getElementById('paymentDateContainer');
        if (isPaid) {
            paymentDateContainer.style.display = 'block';
            // Set today's date as default if empty
            const paymentDateInput = document.getElementById('servicePaymentDate');
            if (!paymentDateInput.value) {
                const today = new Date();
                paymentDateInput.value = formatDateTurkish(today);
            }
        } else {
            paymentDateContainer.style.display = 'none';
            document.getElementById('servicePaymentDate').value = '';
        }
    };
    
    // Format date to Turkish format (DD.MM.YYYY)
    window.formatDateTurkish = function(date) {
        if (!date) return '';
        const d = new Date(date);
        const day = String(d.getDate()).padStart(2, '0');
        const month = String(d.getMonth() + 1).padStart(2, '0');
        const year = d.getFullYear();
        return `${day}.${month}.${year}`;
    };
    
    // Parse Turkish date format to ISO
    window.parseTurkishDate = function(dateStr) {
        if (!dateStr) return '';
        // Handle DD.MM.YYYY format
        const parts = dateStr.split('.');
        if (parts.length === 3) {
            return `${parts[2]}-${parts[1]}-${parts[0]}`;
        }
        // If already in ISO format, return as is
        if (dateStr.includes('-')) {
            return dateStr.split('T')[0];
        }
        return dateStr;
    };
    
    // Convert ISO date to Turkish format
    window.isoToTurkish = function(isoDate) {
        if (!isoDate) return '';
        const datePart = isoDate.includes('T') ? isoDate.split('T')[0] : isoDate;
        const parts = datePart.split('-');
        if (parts.length === 3) {
            return `${parts[2]}.${parts[1]}.${parts[0]}`;
        }
        return isoDate;
    };
    
    // Switch to text input for editing
    window.switchToTextInput = function() {
        document.getElementById('serviceNameSelect').style.display = 'none';
        document.getElementById('serviceNameSelect').removeAttribute('required');
        document.getElementById('serviceName').style.display = 'block';
        document.getElementById('serviceName').setAttribute('required', 'required');
    };
    
    // Switch to dropdown for new service
    window.switchToDropdown = function() {
        document.getElementById('serviceName').style.display = 'none';
        document.getElementById('serviceName').removeAttribute('required');
        document.getElementById('serviceName').value = '';
        document.getElementById('serviceNameSelect').style.display = 'block';
        document.getElementById('serviceNameSelect').setAttribute('required', 'required');
        document.getElementById('serviceNameSelect').value = '';
    };

    // Edit service
    window.editService = function(serviceId) {
        // Find the service in the current services array
        const service = window.currentServices.find(s => s.id == serviceId || s.id == parseInt(serviceId));
        
        if (!service) {
            showAlert('danger', 'Hizmet bulunamadı. Lütfen sayfayı yenileyin.');
            return;
        }

        // Switch to text input for editing (allows manual entry)
        switchToTextInput();

        // Fill the add service form with existing data
        document.getElementById('serviceName').value = service.service_name || '';
        document.getElementById('serviceAmount').value = service.amount || '';
        document.getElementById('serviceCurrency').value = service.currency || 'EUR';
        
        // Format dates for Turkish format (DD.MM.YYYY)
        const dueDate = service.due_date ? isoToTurkish(service.due_date) : '';
        const paymentDate = service.payment_date ? isoToTurkish(service.payment_date) : '';
        
        document.getElementById('serviceDueDate').value = dueDate;
        document.getElementById('servicePaymentDate').value = paymentDate;
        
        const isPaid = service.is_paid === true || service.is_paid === 1;
        document.getElementById('serviceIsPaid').checked = isPaid;
        document.getElementById('serviceNotes').value = service.notes || '';
        
        // Show/hide payment date based on checkbox
        document.getElementById('paymentDateContainer').style.display = isPaid ? 'block' : 'none';

        // Show the form if hidden
        const formContainer = document.getElementById('addServiceFormContainer');
        if (formContainer.style.display === 'none' || formContainer.style.display === '') {
            toggleAddServiceForm();
        }

        // Change the form title and button text
        const header = document.querySelector('#addServiceFormContainer .card-header h6');
        if (header) {
            header.textContent = 'Hizmet Düzenle';
        }
        
        const saveButton = document.querySelector('#addServiceForm button[onclick="addService()"]');
        if (saveButton) {
            saveButton.innerHTML = '<i class="fas fa-save me-2"></i>Güncelle';
        }
        
        // Store the service ID for updating
        document.getElementById('addServiceForm').setAttribute('data-edit-id', serviceId);
        
