// =====================================================
// PARTNER TAB FUNCTIONS (Multi-Partner Support)
// =====================================================

const studentId = <%= user.id %>;
let allPartners = [];
let allEarnings = [];
let selectedPartnerId = null;
let assignedPartnerIds = []; // Multiple assigned partners

// Load partner data when partner tab is clicked
document.getElementById('partner-tab')?.addEventListener('shown.bs.tab', function() {
    loadAllPartnerData();
});

// Also load on DOMContentLoaded if partner tab exists
document.addEventListener('DOMContentLoaded', function() {
    // Load partner data initially
    setTimeout(() => {
        loadAllPartnerData();
    }, 500);
    
    // Setup partner search
    document.getElementById('partnerSearchInput')?.addEventListener('input', function() {
        filterPartners(this.value);
    });
});

// Load all partner data for this student
async function loadAllPartnerData() {
    try {
        // Load all partners
        const partnersResponse = await fetch('/admin/api/partners', {
            credentials: 'include'
        });
        const partnersData = await partnersResponse.json();
        
        if (partnersData.success) {
            allPartners = partnersData.partners;
        }
        
        // Load student's partner info and earnings
        const earningsResponse = await fetch(`/admin/users/${studentId}/partner`, {
            credentials: 'include'
        });
        const earningsData = await earningsResponse.json();
        
        if (earningsData.success) {
            allEarnings = earningsData.earnings || [];
            assignedPartnerIds = earningsData.assigned_partner_ids || [];
            // Fallback to legacy partner_id if no new assignments
            if (assignedPartnerIds.length === 0 && earningsData.partner?.id) {
                assignedPartnerIds = [earningsData.partner.id];
            }
        }
        
        // Display partners grid with earnings info
        displayPartnersGrid();
        displayAllEarningsSummary();
        
    } catch (error) {
        console.error('Load partner data error:', error);
        document.getElementById('partnersGrid').innerHTML = `
            <div class="col-12">
                <div class="alert alert-danger">Partner verileri yüklenirken hata oluştu</div>
            </div>
        `;
    }
}

// Display partners as clickable cards
function displayPartnersGrid() {
    const container = document.getElementById('partnersGrid');
    
    if (!allPartners || allPartners.length === 0) {
        container.innerHTML = `
            <div class="col-12">
                <div class="alert alert-warning">
                    <i class="fas fa-info-circle me-2"></i>
                    Henüz partner tanımlanmamış.
                </div>
            </div>
        `;
        return;
    }
    
    let html = '';
    
    allPartners.forEach(partner => {
        // Calculate earnings for this partner
        const partnerEarnings = allEarnings.filter(e => e.partner_id === partner.id);
        const totalEarnings = partnerEarnings.reduce((sum, e) => sum + parseFloat(e.amount), 0);
        const hasEarnings = partnerEarnings.length > 0;
        const isAssigned = assignedPartnerIds.includes(partner.id);
        
        // Card styling based on status
        let cardClass = 'border-secondary';
        let headerStyle = '';
        if (isAssigned) {
            cardClass = 'border-primary border-2';
            headerStyle = 'background: linear-gradient(135deg, #0d6efd 0%, #0056b3 100%);';
        } else if (hasEarnings) {
            cardClass = 'border-success';
        }
        
        const badgeClass = hasEarnings ? 'bg-success' : 'bg-secondary';
        
        html += `
            <div class="col-md-6 col-lg-4">
                <div class="card partner-card ${cardClass}" style="transition: all 0.3s;">
                    ${isAssigned ? `<div class="card-header text-white py-1 text-center" style="${headerStyle}"><small><i class="fas fa-check-circle me-1"></i>Atanmış Partner</small></div>` : ''}
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-2">
                            <div class="avatar-circle me-3" style="width: 45px; height: 45px; border-radius: 50%; background: linear-gradient(135deg, ${isAssigned ? '#0d6efd, #0056b3' : '#667eea, #764ba2'}); display: flex; align-items: center; justify-content: center;">
                                <i class="fas fa-user-tie text-white"></i>
                            </div>
                            <div class="flex-grow-1">
                                <h6 class="mb-0 fw-bold">${partner.first_name} ${partner.last_name}</h6>
                                <small class="text-muted">${partner.company_name || partner.email}</small>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mt-2 mb-3">
                            <span class="badge ${badgeClass}">
                                ${hasEarnings ? partnerEarnings.length + ' Kazanç' : 'Kazanç Yok'}
                            </span>
                            ${hasEarnings ? `<strong class="text-success">${totalEarnings.toFixed(2)} €</strong>` : '<span class="text-muted">-</span>'}
                        </div>
                        <div class="d-flex gap-2">
                            ${isAssigned 
                                ? `<button class="btn btn-sm btn-outline-danger flex-grow-1" onclick="event.stopPropagation(); removePartnerAssignment(${partner.id})">
                                       <i class="fas fa-times me-1"></i>Kaldır
                                   </button>`
                                : `<button class="btn btn-sm btn-primary flex-grow-1" onclick="event.stopPropagation(); assignPartner(${partner.id})">
                                       <i class="fas fa-link me-1"></i>Ata
                                   </button>`
                            }
                            <button class="btn btn-sm btn-outline-success flex-grow-1" onclick="event.stopPropagation(); selectPartner(${partner.id}, '${partner.first_name} ${partner.last_name}')">
                                <i class="fas fa-plus me-1"></i>Kazanç
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        `;
    });
    
    container.innerHTML = html;
    
    // Add hover effect
    document.querySelectorAll('.partner-card').forEach(card => {
        card.addEventListener('mouseenter', function() {
            this.style.transform = 'translateY(-3px)';
            this.style.boxShadow = '0 4px 12px rgba(0,0,0,0.15)';
        });
        card.addEventListener('mouseleave', function() {
            this.style.transform = 'translateY(0)';
            this.style.boxShadow = 'none';
        });
    });
}

// Assign partner to student (without earning) - supports multiple partners
async function assignPartner(partnerId) {
    try {
        const response = await fetch(`/admin/users/${studentId}/partners`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({ partner_id: partnerId })
        });
        
        const data = await response.json();
        
        if (data.success) {
            alert('Partner başarıyla atandı!');
            await loadAllPartnerData();
        } else {
            alert(data.message || 'Partner atanamadı!');
        }
    } catch (error) {
        console.error('Assign partner error:', error);
        alert('Partner atanırken bir hata oluştu!');
    }
}

// Remove specific partner assignment
async function removePartnerAssignment(partnerId) {
    if (!confirm('Bu partnerin atamasını kaldırmak istediğinizden emin misiniz?')) {
        return;
    }
    
    try {
        const response = await fetch(`/admin/users/${studentId}/partners/${partnerId}`, {
            method: 'DELETE',
            credentials: 'include'
        });
        
        const data = await response.json();
        
        if (data.success) {
            alert('Partner ataması kaldırıldı!');
            await loadAllPartnerData();
        } else {
            alert(data.message || 'Partner kaldırılamadı!');
        }
    } catch (error) {
        console.error('Remove partner error:', error);
        alert('Partner kaldırılırken bir hata oluştu!');
    }
}

// Filter partners by search
function filterPartners(searchTerm) {
    const filtered = allPartners.filter(p => {
        const fullName = `${p.first_name} ${p.last_name}`.toLowerCase();
        return fullName.includes(searchTerm.toLowerCase()) ||
            (p.company_name && p.company_name.toLowerCase().includes(searchTerm.toLowerCase())) ||
            p.email.toLowerCase().includes(searchTerm.toLowerCase());
    });
    
    // Temporarily replace allPartners for display
    const originalPartners = allPartners;
    allPartners = filtered;
    displayPartnersGrid();
    allPartners = originalPartners;
}

// Select a partner and show earnings section
function selectPartner(partnerId, partnerName) {
    selectedPartnerId = partnerId;
    document.getElementById('selectedPartnerId').value = partnerId;
    document.getElementById('selectedPartnerName').textContent = partnerName;
    document.getElementById('selectedPartnerSection').style.display = 'block';
    
    // Scroll to the section
    document.getElementById('selectedPartnerSection').scrollIntoView({ behavior: 'smooth', block: 'start' });
    
    // Display earnings for this partner
    displayPartnerEarnings(partnerId);
    
    // Initialize Turkish date pickers for this section
    setTimeout(function() {
        initializeTurkishDatePickersInSection('selectedPartnerSection');
    }, 100);
}

// Initialize Flatpickr for date inputs in a specific section
function initializeTurkishDatePickersInSection(sectionId) {
    const section = document.getElementById(sectionId);
    if (!section) return;
    
    const dateInputs = section.querySelectorAll('input[type="date"]');
    
    dateInputs.forEach(function(input) {
        // Skip if already initialized
        if (input._flatpickr || input.dataset.flatpickrInitialized) return;
        
        // Get current value if exists
        const currentValue = input.value;
        
        // Mark as initialized
        input.dataset.flatpickrInitialized = 'true';
        
        // Change type to text to use Flatpickr
        input.type = 'text';
        input.placeholder = 'GG.AA.YYYY';
        
        // Initialize Flatpickr with Turkish locale
        flatpickr(input, {
            locale: 'tr',
            dateFormat: 'd.m.Y',
            altInput: true,
            altFormat: 'd.m.Y',
            defaultDate: currentValue || null,
            allowInput: true
        });
    });
}

// Close partner section
function closePartnerSection() {
    selectedPartnerId = null;
    document.getElementById('selectedPartnerSection').style.display = 'none';
}

// Display earnings for selected partner
function displayPartnerEarnings(partnerId) {
    const container = document.getElementById('partnerEarningsTable');
    const partnerEarnings = allEarnings.filter(e => e.partner_id === partnerId);
    
    if (!partnerEarnings || partnerEarnings.length === 0) {
        container.innerHTML = `
            <div class="alert alert-info">
                <i class="fas fa-info-circle me-2"></i>
                Bu partner için henüz kazanç kaydı yok.
            </div>
        `;
        return;
    }
    
    let totalAmount = 0;
    let tableRows = '';
    
    partnerEarnings.forEach(earning => {
        totalAmount += parseFloat(earning.amount);
        // Show payment date only when paid
        const paymentDate = (earning.is_paid && earning.earning_date) 
            ? (() => { const d = new Date(earning.earning_date); return String(d.getUTCDate()).padStart(2,'0') + '.' + String(d.getUTCMonth()+1).padStart(2,'0') + '.' + d.getUTCFullYear(); })() 
            : '<span class="text-muted">-</span>';
        
        tableRows += `
            <tr>
                <td><strong>${parseFloat(earning.amount).toFixed(2)} ${earning.currency}</strong></td>
                <td>${paymentDate}</td>
                <td>
                    ${earning.is_paid 
                        ? '<span class="badge bg-success"><i class="fas fa-check me-1"></i>Ödendi</span>' 
                        : '<span class="badge bg-warning text-dark"><i class="fas fa-clock me-1"></i>Beklemede</span>'}
                </td>
                <td>${earning.notes || '-'}</td>
                <td>
                    <button class="btn btn-sm btn-outline-danger" onclick="deleteEarning(${earning.id})">
                        <i class="fas fa-trash"></i>
                    </button>
                </td>
            </tr>
        `;
    });
    
    container.innerHTML = `
        <div class="table-responsive">
            <table class="table table-sm table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Tutar</th>
                        <th>Ödeme Tarihi</th>
                        <th>Durum</th>
                        <th>Not</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    ${tableRows}
                </tbody>
                <tfoot class="table-success">
                    <tr>
                        <th colspan="5">Toplam: <strong>${totalAmount.toFixed(2)} €</strong></th>
                        <th></th>
                    </tr>
                </tfoot>
            </table>
        </div>
    `;
}

// Display all earnings summary
function displayAllEarningsSummary() {
    const container = document.getElementById('allEarningsContent');
    
    if (!allEarnings || allEarnings.length === 0) {
        container.innerHTML = `
            <div class="alert alert-info mb-0">
                <i class="fas fa-info-circle me-2"></i>
                Bu öğrenci için henüz partner kazancı kaydedilmemiş.
            </div>
        `;
        return;
    }
    
    // Group earnings by partner
    const earningsByPartner = {};
    let grandTotal = 0;
    
    allEarnings.forEach(earning => {
        const partnerName = earning.partner_name || 'Bilinmeyen Partner';
        if (!earningsByPartner[partnerName]) {
            earningsByPartner[partnerName] = { total: 0, count: 0, paid: 0, pending: 0 };
        }
        const amount = parseFloat(earning.amount);
        earningsByPartner[partnerName].total += amount;
        earningsByPartner[partnerName].count++;
        if (earning.is_paid) {
            earningsByPartner[partnerName].paid += amount;
        } else {
            earningsByPartner[partnerName].pending += amount;
        }
        grandTotal += amount;
    });
    
    let html = '<div class="table-responsive"><table class="table table-sm mb-0">';
    html += '<thead class="table-light"><tr><th>Partner</th><th>Kazanç Sayısı</th><th>Ödenen</th><th>Bekleyen</th><th>Toplam</th></tr></thead>';
    html += '<tbody>';
    
    for (const [partnerName, data] of Object.entries(earningsByPartner)) {
        html += `
            <tr>
                <td><strong>${partnerName}</strong></td>
                <td>${data.count}</td>
                <td class="text-success">${data.paid.toFixed(2)} €</td>
                <td class="text-warning">${data.pending.toFixed(2)} €</td>
                <td><strong>${data.total.toFixed(2)} €</strong></td>
            </tr>
        `;
    }
    
    html += '</tbody>';
    html += `<tfoot class="table-success"><tr><th colspan="4">Genel Toplam</th><th><strong>${grandTotal.toFixed(2)} €</strong></th></tr></tfoot>`;
    html += '</table></div>';
    
    container.innerHTML = html;
}

// Toggle payment date visibility and auto-fill today's date
function togglePaymentDate() {
    const isPaid = document.getElementById('earningPaid').value === 'true';
    const container = document.getElementById('paymentDateContainer');
    const dateInput = document.getElementById('earningDate');
    
    if (isPaid) {
        container.style.display = 'block';
        // Auto-fill with today's date in Turkish format
        const today = new Date();
        const day = String(today.getDate()).padStart(2, '0');
        const month = String(today.getMonth() + 1).padStart(2, '0');
        const year = today.getFullYear();
        dateInput.value = `${day}.${month}.${year}`;
    } else {
        container.style.display = 'none';
        dateInput.value = '';
    }
}

// Save earning for selected partner
async function saveEarning() {
    const partnerId = document.getElementById('selectedPartnerId').value;
    
    if (!partnerId) {
        alert('Lütfen bir partner seçin!');
        return;
    }
    
    const amount = document.getElementById('earningAmount').value;
    const isPaid = document.getElementById('earningPaid').value === 'true';
    const earningDateInput = document.getElementById('earningDate');
    const earningDateValue = earningDateInput.value;
    
    if (!amount) {
        alert('Tutar zorunludur!');
        return;
    }
    
    // Convert Turkish date format (DD.MM.YYYY) to ISO format (YYYY-MM-DD)
    function convertTurkishDateToISO(dateStr) {
        if (!dateStr) return null;
        // Check if already in ISO format
        if (dateStr.match(/^\d{4}-\d{2}-\d{2}$/)) return dateStr;
        // Convert DD.MM.YYYY to YYYY-MM-DD
        const parts = dateStr.split('.');
        if (parts.length === 3) {
            return `${parts[2]}-${parts[1].padStart(2,'0')}-${parts[0].padStart(2,'0')}`;
        }
        return dateStr;
    }
    
    // Get today's date in ISO format for paid earnings
    function getTodayISO() {
        const today = new Date();
        return today.toISOString().split('T')[0];
    }
    
    const earningData = {
        partner_id: parseInt(partnerId),
        user_id: studentId,
        amount: parseFloat(amount),
        currency: document.getElementById('earningCurrency').value,
        // Only set earning_date if paid, otherwise null
        earning_date: isPaid ? (earningDateValue ? convertTurkishDateToISO(earningDateValue) : getTodayISO()) : null,
        is_paid: isPaid,
        // payment_date is same as earning_date when paid
        payment_date: isPaid ? (earningDateValue ? convertTurkishDateToISO(earningDateValue) : getTodayISO()) : null,
        notes: document.getElementById('earningNotes').value || null
    };
    
    try {
        const response = await fetch('/admin/partner-earnings', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify(earningData)
        });
        
        const data = await response.json();
        
        if (data.success) {
            alert(data.message || 'Kazanç başarıyla eklendi!');
            // Reset form
            document.getElementById('earningForm').reset();
            document.getElementById('paymentDateContainer').style.display = 'none';
            // Reload all data
            await loadAllPartnerData();
            // Re-display selected partner earnings
            if (selectedPartnerId) {
                displayPartnerEarnings(selectedPartnerId);
            }
        } else {
            alert(data.message || 'Kazanç eklenemedi!');
        }
    } catch (error) {
        console.error('Save earning error:', error);
        alert('Kazanç eklenirken bir hata oluştu!');
    }
}

// Delete earning
async function deleteEarning(earningId) {
    if (!confirm('Bu kazanç kaydını silmek istediğinizden emin misiniz?')) {
        return;
    }
    
    try {
        const response = await fetch(`/admin/partner-earnings/${earningId}`, {
            method: 'DELETE',
            credentials: 'include'
        });
        
        const data = await response.json();
        
        if (data.success) {
            alert('Kazanç kaydı silindi!');
            await loadAllPartnerData();
            // Re-display selected partner earnings
            if (selectedPartnerId) {
                displayPartnerEarnings(selectedPartnerId);
            }
        } else {
            alert(data.message || 'Kazanç silinemedi!');
        }
    } catch (error) {
        console.error('Delete earning error:', error);
        alert('Kazanç silinirken bir hata oluştu!');
    }
}

// =============== AI RECOMMENDATION FUNCTIONS ===============

// Load AI recommendation when tab is clicked
document.getElementById('ai-recommendation-tab')?.addEventListener('shown.bs.tab', function() {
    loadAIRecommendation();
});

// Load AI recommendation
async function loadAIRecommendation() {
    const container = document.getElementById('aiRecommendationContent');
    
    try {
        const response = await fetch(`/api/admin/users/${studentId}/ai-recommendation`, {
            credentials: 'include'
        });
        const data = await response.json();
        
        if (data.success && data.recommendation) {
            displayAIRecommendation(data.recommendation);
        } else {
            container.innerHTML = `
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle fa-2x mb-3"></i>
                    <h5>AI Önerisi Bulunamadı</h5>
                    <p class="text-muted mb-0">Bu öğrenci henüz AI sihirbazını kullanmamış.</p>
                </div>
            `;
        }
    } catch (error) {
        console.error('Load AI recommendation error:', error);
        container.innerHTML = `
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle me-2"></i>
                AI önerisi yüklenirken bir hata oluştu.
            </div>
        `;
    }
}

// Display AI recommendation
function displayAIRecommendation(rec) {
    const container = document.getElementById('aiRecommendationContent');
    
    const countryFlags = {
        'Germany': '🇩🇪',
        'Czech Republic': '🇨🇿',
        'Italy': '🇮🇹',
        'Austria': '🇦🇹',
        'UK': '🇬🇧',
        'Poland': '🇵🇱',
        'Hungary': '🇭🇺',
        'Netherlands': '🇳🇱'
    };
    
    // Parse ai_reasoning if it's JSON (new format)
    let rec1 = null, rec2 = null, comparison = null, overall_advice = null, hasCanadianDiploma = false, wcepSummary = null;
    
    if (rec.ai_reasoning) {
        try {
            const fullData = JSON.parse(rec.ai_reasoning);
            rec1 = fullData.recommendation_1;
            rec2 = fullData.recommendation_2;
            comparison = fullData.comparison;
            overall_advice = fullData.overall_advice;
            hasCanadianDiploma = fullData.has_canadian_diploma || false;
            wcepSummary = fullData.wcep_advantage_summary || null;
        } catch (e) {
            // Eski format - düz metin
            console.log('Using legacy format');
        }
    }
    
    // Helper function to render recommendation card (same as wizard)
    function renderRecommendationCard(recData, number, isPrimary) {
        if (!recData) return '';
        
        const flag = countryFlags[recData.country] || '🌍';
        const cardStyle = isPrimary 
            ? 'background: linear-gradient(135deg, #0056b3, #004494);' 
            : 'background: linear-gradient(135deg, #28a745, #20903d);';
        
        return `
            <div class="recommendation-card mb-4" style="${cardStyle} color: white; border-radius: 20px; padding: 25px; box-shadow: 0 10px 30px rgba(0,0,0,0.15);">
                <div class="d-flex align-items-center mb-3">
                    <span class="badge bg-white text-dark me-2" style="font-size: 1rem; padding: 8px 15px;">
                        ${isPrimary ? '⭐ 1. Öneri' : '🔷 2. Öneri'}
                    </span>
                    <span style="font-size: 2rem;">${flag}</span>
                </div>
                
                <h3 class="mb-1">${recData.university_name || 'Üniversite'}</h3>
                <h5 class="mb-3 opacity-75">${recData.program_name || 'Program'}</h5>
                
                <div class="row mb-3">
                    <div class="col-6 col-md-3 mb-2">
                        <small class="opacity-75">Ülke</small>
                        <div class="fw-bold">${recData.country}</div>
                    </div>
                    <div class="col-6 col-md-3 mb-2">
                        <small class="opacity-75">Şehir</small>
                        <div class="fw-bold">${recData.city}</div>
                    </div>
                    <div class="col-6 col-md-3 mb-2">
                        <small class="opacity-75">Yıllık Ücret</small>
                        <div class="fw-bold">${recData.tuition || 'Değişken'}</div>
                    </div>
                    <div class="col-6 col-md-3 mb-2">
                        <small class="opacity-75">Dil</small>
                        <div class="fw-bold">İngilizce</div>
                    </div>
                </div>
            </div>
            
            ${recData.why_this_university ? `
                <div class="info-section mb-3" style="background: #f8f9fa; border-radius: 15px; padding: 20px; border-left: 4px solid ${isPrimary ? '#0056b3' : '#28a745'};">
                    <h6 class="mb-2"><i class="fas fa-university me-2" style="color: ${isPrimary ? '#0056b3' : '#28a745'};"></i>Neden Bu Üniversite?</h6>
                    <p class="mb-0 text-dark">${recData.why_this_university}</p>
                </div>
            ` : ''}
            
            ${recData.why_this_program ? `
                <div class="info-section mb-3" style="background: #f8f9fa; border-radius: 15px; padding: 20px; border-left: 4px solid #6f42c1;">
                    <h6 class="mb-2"><i class="fas fa-book me-2" style="color: #6f42c1;"></i>Neden Bu Program?</h6>
                    <p class="mb-0 text-dark">${recData.why_this_program}</p>
                </div>
            ` : ''}
            
            ${recData.country_info ? `
                <div class="info-section mb-3" style="background: #f8f9fa; border-radius: 15px; padding: 20px; border-left: 4px solid #fd7e14;">
                    <h6 class="mb-2"><i class="fas fa-globe me-2" style="color: #fd7e14;"></i>Ülke Hakkında</h6>
                    <p class="mb-0 text-dark">${recData.country_info}</p>
                </div>
            ` : ''}
            
            ${recData.city_info ? `
                <div class="info-section mb-3" style="background: #f8f9fa; border-radius: 15px; padding: 20px; border-left: 4px solid #17a2b8;">
                    <h6 class="mb-2"><i class="fas fa-city me-2" style="color: #17a2b8;"></i>Şehir Hakkında</h6>
                    <p class="mb-0 text-dark">${recData.city_info}</p>
                </div>
            ` : ''}
            
            ${recData.career_prospects ? `
                <div class="info-section mb-3" style="background: #f8f9fa; border-radius: 15px; padding: 20px; border-left: 4px solid #28a745;">
                    <h6 class="mb-2"><i class="fas fa-briefcase me-2" style="color: #28a745;"></i>Kariyer Fırsatları</h6>
                    <p class="mb-0 text-dark">${recData.career_prospects}</p>
                </div>
            ` : ''}
        `;
    }
    
    let html = `
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <span class="badge bg-primary me-2">${rec.education_level === 'bachelor' ? 'Lisans' : 'Yüksek Lisans'}</span>
                <span class="badge bg-secondary">İngilizce: ${rec.english_level || '-'}</span>
                ${hasCanadianDiploma ? '<span class="badge bg-danger ms-2">🍁 Kanada Diploması</span>' : ''}
            </div>
            <button class="btn btn-outline-danger btn-sm" onclick="deleteAIRecommendation(${rec.id})">
                <i class="fas fa-trash me-1"></i>Sil
            </button>
        </div>
        
        ${hasCanadianDiploma && wcepSummary ? `
            <div class="mb-4" style="background: linear-gradient(135deg, #dc2626, #991b1b); border-radius: 15px; padding: 20px; color: white;">
                <div class="d-flex align-items-center mb-2">
                    <span style="font-size: 2rem; margin-right: 12px;">🍁</span>
                    <div>
                        <h6 class="mb-0"><i class="fas fa-check-circle me-1"></i>Kanada Lise Diploması Avantajı!</h6>
                        <small class="opacity-75">WCEP Ortaklığı</small>
                    </div>
                </div>
                <p class="mb-0" style="font-size: 0.9rem;">${wcepSummary}</p>
            </div>
        ` : ''}
        
        ${rec.prep_school_needed ? `
            <div class="prep-warning mb-4" style="background: linear-gradient(135deg, #fff3cd, #ffe69c); border: none; border-radius: 15px; padding: 20px;">
                <h5 class="text-dark"><i class="fas fa-exclamation-triangle me-2 text-warning"></i>Hazırlık Önerisi</h5>
                <p class="mb-0 text-dark">${rec.prep_school_suggestion || 'İngilizce seviyesine göre hazırlık programı önerilmektedir.'}</p>
            </div>
        ` : `
            <div class="mb-4" style="background: linear-gradient(135deg, #d4edda, #c3e6cb); border: none; border-radius: 15px; padding: 15px;">
                <i class="fas fa-check-circle me-2 text-success"></i>Hazırlık programı gerekli değil
            </div>
        `}
    `;
    
    // Yeni format (JSON) varsa detaylı göster
    if (rec1) {
        html += renderRecommendationCard(rec1, 1, true);
        
        if (rec2) {
            html += `<hr class="my-4">`;
            html += renderRecommendationCard(rec2, 2, false);
        }
        
        if (comparison) {
            html += `
                <div class="info-section mb-3" style="background: linear-gradient(135deg, #e9ecef, #dee2e6); border-radius: 15px; padding: 20px;">
                    <h6 class="mb-2"><i class="fas fa-balance-scale me-2" style="color: #495057;"></i>Karşılaştırma</h6>
                    <p class="mb-0 text-dark">${comparison}</p>
                </div>
            `;
        }
        
        if (overall_advice) {
            html += `
                <div class="info-section mb-3" style="background: linear-gradient(135deg, #d4edda, #c3e6cb); border-radius: 15px; padding: 20px;">
                    <h6 class="mb-2"><i class="fas fa-lightbulb me-2" style="color: #155724;"></i>Genel Tavsiyeler</h6>
                    <p class="mb-0 text-dark">${overall_advice}</p>
                </div>
            `;
        }
        
        // Kanada Diploması Avantajları Detaylı Bölümü
        if (hasCanadianDiploma) {
            html += `
                <div class="info-section mb-3" style="background: linear-gradient(135deg, #fef2f2, #fee2e2); border: 2px solid #dc2626; border-radius: 15px; padding: 20px;">
                    <div class="d-flex align-items-center mb-3">
                        <span style="font-size: 2rem; margin-right: 12px;">🍁</span>
                        <div>
                            <h5 class="mb-0 text-danger"><i class="fas fa-award me-2"></i>Kanada Diploması Avantajları</h5>
                            <small class="text-muted">WCEP ortaklığı kapsamında öğrenciye sağlanan fırsatlar</small>
                        </div>
                    </div>
                    
                    <div class="row g-2">
                        <div class="col-md-6">
                            <div class="p-2" style="background: white; border-radius: 8px; border-left: 3px solid #dc2626;">
                                <strong class="small">🇩🇪 Almanya</strong>
                                <p class="mb-0 small">Studienkolleg'den <strong>muafiyet</strong></p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-2" style="background: white; border-radius: 8px; border-left: 3px solid #dc2626;">
                                <strong class="small">🇬🇧 İngiltere</strong>
                                <p class="mb-0 small">Foundation Year'dan <strong>muafiyet</strong></p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-2" style="background: white; border-radius: 8px; border-left: 3px solid #dc2626;">
                                <strong class="small">🇨🇿 Çekya</strong>
                                <p class="mb-0 small">Charles Üni. Tıp/Diş'e <strong>sınavsız kabul</strong></p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-2" style="background: white; border-radius: 8px; border-left: 3px solid #dc2626;">
                                <strong class="small">🇦🇹 Avusturya</strong>
                                <p class="mb-0 small">Vorstudienlehrgang'dan <strong>muafiyet</strong></p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-2" style="background: white; border-radius: 8px; border-left: 3px solid #dc2626;">
                                <strong class="small">🇮🇹 İtalya</strong>
                                <p class="mb-0 small">Ek sınavlardan <strong>muafiyet</strong></p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-2" style="background: white; border-radius: 8px; border-left: 3px solid #dc2626;">
                                <strong class="small">🇵🇱 🇭🇺 Polonya & Macaristan</strong>
                                <p class="mb-0 small"><strong>Öncelikli değerlendirme</strong></p>
                            </div>
                        </div>
                    </div>
                </div>
            `;
        }
    } else {
        // Eski format (düz metin ai_reasoning)
        html += `
            <div class="card mb-3" style="border-left: 3px solid #28a745;">
                <div class="card-body">
                    <h6 class="card-title"><span class="badge bg-success me-2">Öneri</span></h6>
                    <p class="mb-2"><strong>Ülke:</strong> ${rec.recommended_country || '-'}</p>
                    <p class="mb-2"><strong>Şehir:</strong> ${rec.recommended_city || '-'}</p>
                    <p class="mb-0"><strong>Ücret:</strong> ${rec.recommended_tuition || '-'}</p>
                </div>
            </div>
            
            ${rec.ai_reasoning ? `
                <div class="mt-4">
                    <h6 class="text-info mb-3"><i class="fas fa-brain me-2"></i>AI Açıklaması</h6>
                    <div class="bg-light p-3 rounded">
                        ${rec.ai_reasoning}
                    </div>
                </div>
            ` : ''}
        `;
    }
    
    html += `
        <hr class="my-4">
        <div class="text-muted small">
            <i class="fas fa-calendar me-1"></i>Oluşturulma: ${new Date(rec.created_at).toLocaleString('tr-TR')}
        </div>
    `;
    
    container.innerHTML = html;
}

// Toggle AI reasoning text
let isReasoningExpanded = false;
function toggleAIReasoning() {
    const content = document.getElementById('aiReasoningContent');
    const toggleText = document.getElementById('toggleReasoningText');
    
    if (isReasoningExpanded) {
        content.textContent = window.fullAIReasoning.substring(0, 300) + '...';
        toggleText.textContent = 'Daha fazla göster';
    } else {
        content.textContent = window.fullAIReasoning;
        toggleText.textContent = 'Daha az göster';
    }
    isReasoningExpanded = !isReasoningExpanded;
}

// Delete AI recommendation
async function deleteAIRecommendation(id) {
    if (!confirm('Bu AI önerisini silmek istediğinizden emin misiniz? Bu işlem öğrencinin portalından da silinmesine neden olacaktır.')) {
        return;
    }
    
    try {
        const response = await fetch(`/api/admin/ai-recommendations/${id}`, {
            method: 'DELETE',
            credentials: 'include'
        });
        
        const data = await response.json();
        
        if (data.success) {
            alert('AI önerisi başarıyla silindi!');
            loadAIRecommendation();
        } else {
            alert(data.message || 'AI önerisi silinemedi!');
        }
    } catch (error) {
        console.error('Delete AI recommendation error:', error);
        alert('AI önerisi silinirken bir hata oluştu!');
    }
}

