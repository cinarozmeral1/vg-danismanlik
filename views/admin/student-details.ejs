// Save student note
async function saveStudentNote() {
    try {
        console.log('🔧 Saving student note...');
        
        const title = document.getElementById('studentNoteTitle').value;
        const content = document.getElementById('studentNoteContent').value;
        const category = document.getElementById('studentNoteCategory').value;
        const priority = document.getElementById('studentNotePriority').value;
        const isImportant = document.getElementById('studentNoteImportant').checked;

        if (!title || !content) {
            showAlert('warning', 'Lütfen tüm gerekli alanları doldurun');
            return;
        }

        const url = currentNoteId 
            ? `/api/admin/users/<%= user.id %>/notes/${currentNoteId}`
            : `/api/admin/users/<%= user.id %>/notes`;

        const method = currentNoteId ? 'PUT' : 'POST';

        console.log('📡 Saving to:', url, 'Method:', method);

        const response = await fetch(url, {
            method: method,
            credentials: 'include',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                title,
                content,
                category,
                priority,
                is_important: isImportant
            })
        });

        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }

        const result = await response.json();
        
        if (result.success) {
            showAlert('success', currentNoteId ? 'Not güncellendi' : 'Not eklendi');
            loadStudentNotes();
            
            // Close modal
            const modal = bootstrap.Modal.getInstance(document.getElementById('studentNoteModal'));
            modal.hide();
        } else {
            throw new Error(result.message);
        }
    } catch (error) {
        console.error('❌ Error saving student note:', error);
        showAlert('danger', 'Not kaydedilirken hata oluştu: ' + error.message);
    }
}

// Edit student note
async function editStudentNote(noteId) {
    try {
        console.log('🔧 Editing student note:', noteId);
        const response = await fetch(`/api/admin/users/<%= user.id %>/notes/${noteId}`, {
            credentials: 'include'
        });
        const result = await response.json();

        if (!result.success || !result.note) {
            throw new Error(result.message || 'Not bulunamadı');
        }

        showAddNoteModal(result.note);
        
    } catch (error) {
        console.error('❌ Error editing student note:', error);
        showAlert('danger', 'Not düzenlenirken hata oluştu');
    }
}

// Delete student note
async function deleteStudentNote(noteId) {
    if (!confirm('Bu notu silmek istediğinizden emin misiniz?')) {
        return;
    }

    try {
        console.log('🔧 Deleting student note:', noteId);

        const response = await fetch(`/api/admin/users/<%= user.id %>/notes/${noteId}`, {
            method: 'DELETE',
            credentials: 'include'
        });

        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }

        const result = await response.json();
        
        if (result.success) {
            showAlert('success', 'Not silindi');
            loadStudentNotes();
        } else {
            throw new Error(result.message);
        }
    } catch (error) {
        console.error('❌ Error deleting student note:', error);
        showAlert('danger', 'Not silinirken hata oluştu: ' + error.message);
    }
}

// Helper functions for notes
function getNotePriorityClass(priority) {
    switch (priority) {
        case 'high': return 'bg-danger';
        case 'medium': return 'bg-warning';
        case 'low': return 'bg-success';
        default: return 'bg-secondary';
    }
}

function getNoteCategoryClass(category) {
    switch (category) {
        case 'academic': return 'bg-primary';
        case 'personal': return 'bg-info';
        case 'important': return 'bg-warning';
        case 'reminder': return 'bg-secondary';
        default: return 'bg-light text-dark';
    }
}

function getNotePriorityName(priority) {
    switch (priority) {
        case 'high': return 'Yüksek';
        case 'medium': return 'Orta';
        case 'low': return 'Düşük';
        default: return 'Belirsiz';
    }
}

function getNoteCategoryName(category) {
    switch (category) {
        case 'academic': return 'Akademik';
        case 'personal': return 'Kişisel';
        case 'important': return 'Önemli';
        case 'reminder': return 'Hatırlatıcı';
        default: return 'Genel';
    }
}

