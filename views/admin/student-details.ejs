}

function adminRenderGuardiansInModal(guardiansList) {
    const container = document.getElementById('adminGuardiansContainer');
    container.innerHTML = '';
    adminGuardianCounter = 0;
    
    if (!guardiansList || guardiansList.length === 0) {
        guardiansList = [
            { full_name: '', relationship: 'Anne', is_required: true, sort_order: 1 },
            { full_name: '', relationship: 'Baba', is_required: true, sort_order: 2 }
        ];
    } else if (guardiansList.length === 1) {
        guardiansList.push({ full_name: '', relationship: 'Baba', is_required: true, sort_order: 2 });
    }
    
    guardiansList.forEach((g, i) => {
        const isReq = i < 2;
        container.insertAdjacentHTML('beforeend', adminCreateGuardianCardHTML(g, adminGuardianCounter, isReq));
        adminGuardianCounter++;
    });
}

function adminRenderGuardiansDisplay(guardiansList) {
    const display = document.getElementById('adminGuardiansDisplay');
    if (!guardiansList || guardiansList.length === 0) {
        display.innerHTML = '<p class="text-muted"><i class="fas fa-info-circle me-1"></i>Henüz veli bilgisi girilmemiş.</p>';
        return;
    }
    
    let html = '<div class="row g-3">';
    guardiansList.forEach((g, idx) => {
