    function displayFiles(files) {
        const container = document.getElementById('filesList');
        
        if (!files || files.length === 0) {
            container.innerHTML = '<div class="text-center text-muted py-4">Henüz dosya yüklenmemiş</div>';
            return;
        }

        let html = '';
        files.forEach(file => {
            // Determine file type from mime_type
            const isPdf = file.mime_type && file.mime_type.includes('pdf');
            const isImage = file.mime_type && file.mime_type.startsWith('image/');
            const fileIconClass = isPdf ? 'pdf' : (isImage ? 'image' : 'pdf');
            const fileType = isPdf ? 'PDF' : (isImage ? 'IMG' : 'DOC');
            const timeAgo = getTimeAgo(file.created_at);
            
            html += `
                <div class="file-item">
                    <div class="file-icon ${fileIconClass}">
                        ${fileType}
                    </div>
                    <div class="file-info">
                        <div class="file-name">${file.title || file.original_filename}</div>
                        <div class="file-meta">
                            <i class="fas fa-info-circle me-1"></i>
                            ${file.original_filename} • ${timeAgo}
                        </div>
                    </div>
                    <div class="file-actions">
                        <button class="file-action-btn download" onclick="downloadFile(${file.id})" title="İndir">
                            <i class="fas fa-download"></i>
                        </button>
                        <button class="file-action-btn delete" onclick="deleteFile(${file.id})" title="Sil">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                </div>
            `;
        });

        container.innerHTML = html;
    }


    window.downloadFile = async function(fileId) {
        try {
            console.log('Downloading file:', fileId);
            const response = await fetch(`/api/admin/users/<%= user.id %>/documents/${fileId}/download`, {
                method: 'GET',
                credentials: 'include'
            });

            if (!response.ok) {
                throw new Error(`HTTP error! status: ${response.status}`);
            }

            // Get filename from Content-Disposition header
            const contentDisposition = response.headers.get('Content-Disposition');
            let filename = 'document';
            if (contentDisposition) {
                const filenameMatch = contentDisposition.match(/filename="(.+)"/);
                if (filenameMatch) {
                    filename = filenameMatch[1];
                }
            }

            const blob = await response.blob();
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            window.URL.revokeObjectURL(url);
            document.body.removeChild(a);
            
            showAlert('success', 'Dosya başarıyla indirildi: ' + filename);
        } catch (error) {
            console.error('Error downloading file:', error);
            showAlert('danger', 'Dosya indirilirken hata oluştu: ' + error.message);
        }
    };

