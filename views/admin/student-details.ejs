// Save student note
async function saveStudentNote() {
    try {
        console.log('🔧 Saving student note...');
        
        const title = document.getElementById('studentNoteTitle').value;
        const content = document.getElementById('studentNoteContent').value;
        const category = document.getElementById('studentNoteCategory').value;
        const priority = document.getElementById('studentNotePriority').value;
        const isImportant = document.getElementById('studentNoteImportant').checked;

        if (!title || !content) {
            showAlert('warning', 'Lütfen tüm gerekli alanları doldurun');
            return;
        }

        const url = currentNoteId 
            ? `/api/admin/users/<%= user.id %>/notes/${currentNoteId}`
            : `/api/admin/users/<%= user.id %>/notes`;

        const method = currentNoteId ? 'PUT' : 'POST';

        console.log('📡 Saving to:', url, 'Method:', method);

        const response = await fetch(url, {
            method: method,
            credentials: 'include',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                title,
                content,
                category,
                priority,
                is_important: isImportant
            })
        });

        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }

        const result = await response.json();
        
        if (result.success) {
            showAlert('success', currentNoteId ? 'Not güncellendi' : 'Not eklendi');
            loadStudentNotes();
            
            // Close modal
            const modal = bootstrap.Modal.getInstance(document.getElementById('studentNoteModal'));
            modal.hide();
        } else {
            throw new Error(result.message);
        }
    } catch (error) {
        console.error('❌ Error saving student note:', error);
        showAlert('danger', 'Not kaydedilirken hata oluştu: ' + error.message);
    }
}

// Edit student note
async function editStudentNote(noteId) {
    try {
        console.log('🔧 Editing student note:', noteId);
        const response = await fetch(`/api/admin/users/<%= user.id %>/notes/${noteId}`, {
            credentials: 'include'
        });
        const result = await response.json();

        if (!result.success || !result.note) {
            throw new Error(result.message || 'Not bulunamadı');
        }

        showAddNoteModal(result.note);
        
    } catch (error) {
        console.error('❌ Error editing student note:', error);
        showAlert('danger', 'Not düzenlenirken hata oluştu');
    }
}

// Delete student note
async function deleteStudentNote(noteId) {
    if (!confirm('Bu notu silmek istediğinizden emin misiniz?')) {
        return;
    }

    try {
        console.log('🔧 Deleting student note:', noteId);

        const response = await fetch(`/api/admin/users/<%= user.id %>/notes/${noteId}`, {
            method: 'DELETE',
            credentials: 'include'
        });

        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }

        const result = await response.json();
        
        if (result.success) {
            showAlert('success', 'Not silindi');
            loadStudentNotes();
        } else {
            throw new Error(result.message);
        }
    } catch (error) {
        console.error('❌ Error deleting student note:', error);
        showAlert('danger', 'Not silinirken hata oluştu: ' + error.message);
    }
}

// Helper functions for notes
function getNotePriorityClass(priority) {
    switch (priority) {
        case 'high': return 'bg-danger';
        case 'medium': return 'bg-warning';
        case 'low': return 'bg-success';
        default: return 'bg-secondary';
    }
}

function getNoteCategoryClass(category) {
    switch (category) {
        case 'academic': return 'bg-primary';
        case 'personal': return 'bg-info';
        case 'important': return 'bg-warning';
        case 'reminder': return 'bg-secondary';
        default: return 'bg-light text-dark';
    }
}

function getNotePriorityName(priority) {
    switch (priority) {
        case 'high': return 'Yüksek';
        case 'medium': return 'Orta';
        case 'low': return 'Düşük';
        default: return 'Belirsiz';
    }
}

function getNoteCategoryName(category) {
    switch (category) {
        case 'academic': return 'Akademik';
        case 'personal': return 'Kişisel';
        case 'important': return 'Önemli';
        case 'reminder': return 'Hatırlatıcı';
        default: return 'Genel';
    }
}

// Clear note filters
function clearNoteFilters() {
    document.getElementById('noteCategoryFilter').value = '';
    document.getElementById('notePriorityFilter').value = '';
    document.getElementById('noteImportantFilter').value = '';
    loadStudentNotes();
}

// Load notes when grades tab is shown
document.addEventListener('DOMContentLoaded', function() {
    console.log('🔧 DOM Content Loaded - Initializing student details page');
    
    // Hide any remaining "Bilgileri Kaydet" buttons
    function hideRemainingButtonsKaydetButtons() {
        const buttons = document.querySelectorAll('button, .btn');
        buttons.forEach(button => {
            if (button.textContent && button.textContent.includes('Bilgileri Kaydet')) {
                button.style.display = 'none';
                button.classList.add('hidden-save-button');
                console.log('Hidden save button:', button);
            }
        });
    }
    
    // Run immediately
    hideRemainingButtonsKaydetButtons();
    
    // Run again after a short delay in case buttons are added dynamically
    setTimeout(hideRemainingButtonsKaydetButtons, 500);
    setTimeout(hideRemainingButtonsKaydetButtons, 1000);
    
    // Add event listener for grades tab
    const gradesTab = document.getElementById('grades-tab');
    if (gradesTab) {
        gradesTab.addEventListener('shown.bs.tab', function() {
            console.log('🔧 Grades tab shown, loading notes...');
            loadStudentNotes();
            hideRemainingButtonsKaydetButtons();
        });
    }
    
    // Add event listener for services tab
    const servicesTab = document.getElementById('services-tab');
    if (servicesTab) {
        servicesTab.addEventListener('shown.bs.tab', function() {
            console.log('🔧 Services tab shown, loading services...');
            loadServices();
            hideRemainingButtonsKaydetButtons();
        });
    }
    
    // Add event listener for files tab
    const filesTab = document.getElementById('files-tab');
    if (filesTab) {
        filesTab.addEventListener('shown.bs.tab', function() {
            console.log('🔧 Files tab shown, loading files...');
            loadStudentFiles();
            hideRemainingButtonsKaydetButtons();
        });
    }
    
    const checklistTab = document.getElementById('checklist-tab');
    if (checklistTab && checklistTab.parentElement) {
        checklistTab.parentElement.remove();
    }

    const guardiansTab = document.getElementById('guardians-tab');
    if (guardiansTab && guardiansTab.parentElement) {
        guardiansTab.parentElement.remove();
    }
    
    // Initialize tooltips
    var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
    var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl);
    });
    
    console.log('✅ Student details page initialized successfully');
});

// Load guardians information
async function loadGuardians() {
    try {
        const response = await fetch(`/api/admin/users/<%= user.id %>/guardians`, {
            method: 'GET',
            credentials: 'include',
            headers: {
                'Content-Type': 'application/json'
            }
        });

        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }

        const data = await response.json();
        console.log('Guardians data:', data);
        
        if (data.success) {
            updateGuardiansDisplay(data.guardians);
        }
    } catch (error) {
        console.error('Error loading guardians:', error);
    }
}

// Update guardians display
function updateGuardiansDisplay(guardians) {
    const motherFullName = document.getElementById('motherFullName');
    const motherPhone = document.getElementById('motherPhone');
    const motherTc = document.getElementById('motherTc');
    const fatherFullName = document.getElementById('fatherFullName');
    const fatherPhone = document.getElementById('fatherPhone');
    const fatherTc = document.getElementById('fatherTc');

    if (motherFullName) {
        motherFullName.textContent = `${guardians.mother_name || ''} ${guardians.mother_surname || ''}`.trim() || 'Belirtilmemiş';
        motherFullName.className = `guardian-info-value ${(guardians.mother_name || guardians.mother_surname) ? '' : 'empty'}`;
    }
    
    if (motherPhone) {
        motherPhone.textContent = guardians.mother_phone || 'Belirtilmemiş';
        motherPhone.className = `guardian-info-value ${guardians.mother_phone ? '' : 'empty'}`;
    }
    
    if (motherTc) {
        motherTc.textContent = guardians.mother_tc || 'Belirtilmemiş';
        motherTc.className = `guardian-info-value ${guardians.mother_tc ? '' : 'empty'}`;
    }
    
    if (fatherFullName) {
        fatherFullName.textContent = `${guardians.father_name || ''} ${guardians.father_surname || ''}`.trim() || 'Belirtilmemiş';
        fatherFullName.className = `guardian-info-value ${(guardians.father_name || guardians.father_surname) ? '' : 'empty'}`;
    }
    
    if (fatherPhone) {
        fatherPhone.textContent = guardians.father_phone || 'Belirtilmemiş';
        fatherPhone.className = `guardian-info-value ${guardians.father_phone ? '' : 'empty'}`;
    }
    
    if (fatherTc) {
        fatherTc.textContent = guardians.father_tc || 'Belirtilmemiş';
        fatherTc.className = `guardian-info-value ${guardians.father_tc ? '' : 'empty'}`;
    }
}

// Show edit guardians modal
function showEditGuardiansModal() {
    const modal = new bootstrap.Modal(document.getElementById('editGuardiansModal'));
    modal.show();
}

// Save guardians information
async function saveGuardiansInfo() {
    try {
        const form = document.getElementById('guardiansForm');
        const formData = new FormData(form);
        const data = Object.fromEntries(formData);
        
        const response = await fetch(`/admin/users/${<%= user.id %>}/guardians`, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(data)
        });
        
        const result = await response.json();
        
        if (result.success) {
            // Update the display with proper styling
            const motherFullName = document.getElementById('motherFullName');
            const motherPhone = document.getElementById('motherPhone');
            const motherTc = document.getElementById('motherTc');
            const fatherFullName = document.getElementById('fatherFullName');
            const fatherPhone = document.getElementById('fatherPhone');
            const fatherTc = document.getElementById('fatherTc');
            
            // Update mother info
            const motherName = (data.mother_name || data.mother_surname) ? `${data.mother_name || ''} ${data.mother_surname || ''}`.trim() : 'Belirtilmemiş';
            motherFullName.textContent = motherName;
            motherFullName.className = `guardian-info-value ${(data.mother_name || data.mother_surname) ? '' : 'empty'}`;
            
            motherPhone.textContent = data.mother_phone || 'Belirtilmemiş';
            motherPhone.className = `guardian-info-value ${data.mother_phone ? '' : 'empty'}`;
            
            motherTc.textContent = data.mother_tc || 'Belirtilmemiş';
            motherTc.className = `guardian-info-value ${data.mother_tc ? '' : 'empty'}`;
            
            // Update father info
            const fatherName = (data.father_name || data.father_surname) ? `${data.father_name || ''} ${data.father_surname || ''}`.trim() : 'Belirtilmemiş';
            fatherFullName.textContent = fatherName;
            fatherFullName.className = `guardian-info-value ${(data.father_name || data.father_surname) ? '' : 'empty'}`;
            
            fatherPhone.textContent = data.father_phone || 'Belirtilmemiş';
            fatherPhone.className = `guardian-info-value ${data.father_phone ? '' : 'empty'}`;
            
            fatherTc.textContent = data.father_tc || 'Belirtilmemiş';
            fatherTc.className = `guardian-info-value ${data.father_tc ? '' : 'empty'}`;
            
            // Close modal
            const modal = bootstrap.Modal.getInstance(document.getElementById('editGuardiansModal'));
            modal.hide();
            
            // Show success message
            alert('Veli bilgileri başarıyla güncellendi!');
        } else {
            alert('Hata: ' + result.message);
        }
    } catch (error) {
        console.error('Error updating guardians:', error);
        alert('Veli bilgileri güncellenirken bir hata oluştu.');
    }
}

