<!-- Admin University Add Content -->
<div class="admin-container">
    <!-- Sidebar -->
    <div class="admin-sidebar">
        <div class="sidebar-header">
            <h6 class="mb-0"><i class="fas fa-cog me-2"></i>Yönetim Paneli</h6>
        </div>
        <nav class="sidebar-nav">
            <a href="/admin/dashboard" class="nav-item">
                <i class="fas fa-tachometer-alt"></i>
                <span>Dashboard</span>
            </a>
            <a href="/admin/users" class="nav-item">
                <i class="fas fa-users"></i>
                <span>Öğrenciler</span>
            </a>
            <a href="/admin/applications" class="nav-item">
                <i class="fas fa-file-alt"></i>
                <span>Başvurular</span>
            </a>
            <a href="/admin/universities" class="nav-item active">
                <i class="fas fa-university"></i>
                <span>Üniversiteler</span>
            </a>
        </nav>
    </div>

    <!-- Main Content Area -->
    <div class="admin-main">
        <!-- Header -->
        <div class="section-header">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2><i class="fas fa-plus-circle me-2"></i>Yeni Üniversite Ekle</h2>
                    <p class="text-muted">Yeni üniversite bilgilerini girin</p>
                </div>
                <div class="btn-group">
                    <a href="/admin/universities" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-2"></i>Geri Dön
                    </a>
                </div>
            </div>
        </div>

        <!-- University Add Form -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="fas fa-university me-2"></i>Üniversite Bilgileri
                        </h5>
                    </div>
                    <div class="card-body">
                        <form id="universityAddForm" enctype="multipart/form-data">
                            <!-- Temel Bilgiler -->
                            <div class="row mb-4">
                                <div class="col-12">
                                    <h6 class="text-primary mb-3">
                                        <i class="fas fa-info-circle me-2"></i>Temel Bilgiler
                                    </h6>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="name" class="form-label">Üniversite Adı *</label>
                                        <input type="text" class="form-control" id="name" name="name" required>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="country" class="form-label">Ülke *</label>
                                        <select class="form-select" id="country" name="country" required>
                                            <option value="">Seçiniz</option>
                                            <option value="Germany">Almanya</option>
                                            <option value="Austria">Avusturya</option>
                                            <option value="Czech Republic">Çek Cumhuriyeti</option>
                                            <option value="Hungary">Macaristan</option>
                                            <option value="Italy">İtalya</option>
                                            <option value="Poland">Polonya</option>
                                            <option value="United Kingdom">İngiltere</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="city" class="form-label">Şehir *</label>
                                        <input type="text" class="form-control" id="city" name="city" required>
                                    </div>
                                </div>
                            </div>

                            <!-- Logo -->
                            <div class="row mb-4">
                                <div class="col-12">
                                    <h6 class="text-primary mb-3">
                                        <i class="fas fa-image me-2"></i>Logo
                                    </h6>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="logo_file" class="form-label">Logo Dosyası</label>
                                        <input type="file" class="form-control" id="logo_file" name="logo_file" accept="image/*">
                                        <small class="text-muted">PNG, JPG, SVG formatları desteklenir</small>
                                    </div>
                                </div>
                            </div>

                            <!-- Akademik Bilgiler -->
                            <div class="row mb-4">
                                <div class="col-12">
                                    <h6 class="text-primary mb-3">
                                        <i class="fas fa-graduation-cap me-2"></i>Akademik Bilgiler
                                    </h6>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="world_ranking" class="form-label">Dünya Sıralaması</label>
                                        <input type="number" class="form-control" id="world_ranking" name="world_ranking" min="1" placeholder="Örn: 100">
                                    </div>
                                </div>
                            </div>

                            <!-- Açıklama -->
                            <div class="row mb-4">
                                <div class="col-12">
                                    <h6 class="text-primary mb-3">
                                        <i class="fas fa-align-left me-2"></i>Açıklama
                                    </h6>
                                </div>
                                <div class="col-12">
                                    <div class="mb-3">
                                        <label for="description" class="form-label">Açıklama</label>
                                        <textarea class="form-control" id="description" name="description" rows="4" placeholder="Üniversite hakkında detaylı bilgi..."></textarea>
                                    </div>
                                </div>
                            </div>

                            <!-- Bölümler -->
                            <div class="row mb-4">
                                <div class="col-12">
                                    <h6 class="text-primary mb-3">
                                        <i class="fas fa-graduation-cap me-2"></i>Bölümler
                                    </h6>
                                    <p class="text-muted">Bu üniversitede bulunan bölümleri ekleyin</p>
                                </div>
                                <div class="col-12">
                                    <div id="departmentsContainer">
                                        <!-- Bölümler buraya dinamik olarak eklenecek -->
                                    </div>
                                    <button type="button" class="btn btn-outline-primary btn-sm" id="addDepartmentBtn">
                                        <i class="fas fa-plus me-2"></i>Bölüm Ekle
                                    </button>
                                </div>
                            </div>

                            <!-- Gereksinimler -->
                            <div class="row mb-4">
                                <div class="col-12">
                                    <h6 class="text-primary mb-3">
                                        <i class="fas fa-clipboard-list me-2"></i>Gereksinimler
                                    </h6>
                                </div>
                                <div class="col-12">
                                    <div class="mb-3">
                                        <label for="requirements" class="form-label">Gereksinimler</label>
                                        <textarea class="form-control" id="requirements" name="requirements" rows="4" placeholder="Üniversiteye başvuru için gerekli şartlar, belgeler, sınavlar..."></textarea>
                                        <small class="text-muted">Örnek: Lise diploması, İngilizce seviyesi, sınav sonuçları, referans mektupları</small>
                                    </div>
                                </div>
                            </div>


                            <!-- Form Buttons -->
                            <div class="row">
                                <div class="col-12">
                                    <div class="d-flex gap-2 justify-content-end">
                                        <button type="button" class="btn btn-secondary" id="clearFormBtn">
                                            <i class="fas fa-eraser me-2"></i>Temizle
                                        </button>
                                        <button type="button" class="btn btn-primary" id="addUniversityBtn" onclick="addUniversity()">
                                            <i class="fas fa-save me-2"></i>Üniversite Ekle
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const form = document.getElementById('universityAddForm');
        const clearBtn = document.getElementById('clearFormBtn');
        const addDepartmentBtn = document.getElementById('addDepartmentBtn');
        const departmentsContainer = document.getElementById('departmentsContainer');
        let departmentCount = 0;

        // Bölüm ekleme fonksiyonu
        function addDepartment(name = '', price = '') {
            const departmentDiv = document.createElement('div');
            departmentDiv.className = 'department-field mb-3 p-3 border rounded';
            departmentDiv.innerHTML = `
                <div class="row">
                    <div class="col-md-5">
                        <label class="form-label">Bölüm Adı</label>
                        <input type="text" class="form-control department-name" name="departments[${departmentCount}][name_tr]" value="${name}" placeholder="Örn: Mühendislik">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Fiyat (€)</label>
                        <input type="number" class="form-control department-price" name="departments[${departmentCount}][price]" value="${price}" placeholder="Örn: 5000" min="0" step="0.01">
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <button type="button" class="btn btn-outline-danger btn-sm remove-department">
                            <i class="fas fa-trash"></i> Kaldır
                        </button>
                    </div>
                </div>
            `;
            
            departmentsContainer.appendChild(departmentDiv);
            departmentCount++;
        }

        // Bölüm silme fonksiyonu
        departmentsContainer.addEventListener('click', function(e) {
            if (e.target.closest('.remove-department')) {
                e.target.closest('.department-field').remove();
            }
        });

        // Bölüm ekle butonu
        addDepartmentBtn.addEventListener('click', function() {
            addDepartment();
        });

        // Clear form
        clearBtn.addEventListener('click', function() {
            if (confirm('Formu temizlemek istediğinizden emin misiniz?')) {
                form.reset();
                departmentsContainer.innerHTML = '';
                departmentCount = 0;
            }
        });

        // Add University Function
        window.addUniversity = async function() {
            console.log('🚀 Add University button clicked!');
            
            // Get form data
            const name = document.getElementById('name').value;
            const country = document.getElementById('country').value;
            const city = document.getElementById('city').value;
            const world_ranking = document.getElementById('world_ranking').value;
            const description = document.getElementById('description').value;
            const requirements = document.getElementById('requirements').value;
            
            // Validate required fields
            if (!name || !country || !city) {
                alert('Üniversite adı, ülke ve şehir alanları zorunludur!');
                return;
            }
            
            // Show loading
            const btn = document.getElementById('addUniversityBtn');
            const originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Ekleniyor...';
            
            try {
                // Collect departments
                const departments = [];
                const departmentFields = document.querySelectorAll('.department-field');
                departmentFields.forEach((field, index) => {
                    const nameInput = field.querySelector('.department-name');
                    const priceInput = field.querySelector('.department-price');
                    if (nameInput && nameInput.value.trim()) {
                        departments.push({
                            name_tr: nameInput.value.trim(),
                            name_en: nameInput.value.trim(),
                            price: priceInput ? priceInput.value : 0
                        });
                    }
                });
                
                // Prepare data
                const formData = new URLSearchParams();
                formData.append('name', name);
                formData.append('country', country);
                formData.append('city', city);
                formData.append('world_ranking', world_ranking);
                formData.append('description', description);
                formData.append('requirements', requirements);
                formData.append('departments', JSON.stringify(departments));
                
                console.log('📝 Sending data:', {
                    name, country, city, world_ranking, description, requirements, departments
                });
                
                // Send request
                const response = await fetch('/api/admin/universities', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: formData
                });
                
                const result = await response.json();
                console.log('📝 Response:', result);
                
                if (result.success) {
                    alert('Üniversite başarıyla eklendi!');
                    window.location.href = '/admin/universities';
                } else {
                    alert('Hata: ' + result.message);
                }
                
            } catch (error) {
                console.error('❌ Error:', error);
                alert('Bir hata oluştu: ' + error.message);
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        };

        // Form submit (keep as backup)
        form.addEventListener('submit', async function(e) {
            e.preventDefault();

            // Form verilerini topla
            const formData = new URLSearchParams();
            const logoFile = document.getElementById('logo_file').files[0];
            let logoUrl = null;
            
            // Temel bilgileri topla
            formData.append('name', document.getElementById('name').value);
            formData.append('country', document.getElementById('country').value);
            formData.append('city', document.getElementById('city').value);
            formData.append('world_ranking', document.getElementById('world_ranking').value);
            formData.append('description', document.getElementById('description').value);
            formData.append('requirements', document.getElementById('requirements').value);

            // Durum ayarları kaldırıldı - tüm üniversiteler aktif olacak
            
            // Debug: FormData içeriğini kontrol et
            console.log('📝 FormData Debug:');
            for (let [key, value] of formData.entries()) {
                console.log(`   ${key}:`, value);
            }

            try {
                // Önce logo'yu yükle (eğer seçilmişse)
                if (logoFile) {
                    console.log('📝 Uploading logo...');
                    const logoFormData = new FormData();
                    logoFormData.append('logo_file', logoFile);
                    
                    const logoResponse = await fetch('/api/admin/universities/upload-logo', {
                        method: 'POST',
                        body: logoFormData
                    });
                    
                    const logoResult = await logoResponse.json();
                    if (logoResult.success) {
                        logoUrl = logoResult.logo_url;
                        console.log('✅ Logo uploaded:', logoUrl);
                    } else {
                        throw new Error('Logo yükleme hatası: ' + logoResult.message);
                    }
                }
                
                // FormData'yı URLSearchParams'a çevir (logo_file hariç)
                const urlParams = new URLSearchParams();
                for (let [key, value] of formData.entries()) {
                    if (key !== 'logo_file') { // logo_file'ı atla
                        urlParams.append(key, value);
                    }
                }
                
                // Logo URL'ini ekle
                if (logoUrl) {
                    urlParams.append('logo_url', logoUrl);
                }
                
                // Collect departments data
                const departments = {};
                departmentsContainer.querySelectorAll('.department-item').forEach((item, index) => {
                    const nameInput = item.querySelector('input[name*="[name_tr]"]');
                    const priceInput = item.querySelector('input[name*="[price]"]');
                    if (nameInput && nameInput.value.trim()) {
                        departments[index] = { 
                            name_tr: nameInput.value.trim(), 
                            name_en: nameInput.value.trim(), 
                            price: priceInput ? priceInput.value : 0 
                        };
                    }
                });
                urlParams.append('departments', JSON.stringify(departments));
                
                console.log('📝 URLSearchParams Debug:');
                for (let [key, value] of urlParams.entries()) {
                    console.log(`   ${key}:`, value);
                }
                
                // Üniversiteyi oluştur
                console.log('📝 Creating university...');
                const response = await fetch('/admin/universities', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: urlParams
                });
                
                const result = await response.json();
                if (result.success) {
                    alert('Üniversite başarıyla eklendi!');
                    window.location.href = '/admin/universities';
                } else {
                    alert('Hata: ' + result.message);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Bir hata oluştu: ' + error.message);
            }
        });
    });
</script>
