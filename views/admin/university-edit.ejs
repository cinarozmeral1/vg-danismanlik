<!-- Admin University Edit Content -->
<div class="admin-container">
    <!-- Sidebar -->
    <div class="admin-sidebar">
        <div class="sidebar-header">
            <h6 class="mb-0"><i class="fas fa-cog me-2"></i>Yönetim Paneli</h6>
        </div>
        <nav class="sidebar-nav">
            <a href="/admin/dashboard" class="nav-item">
                <i class="fas fa-tachometer-alt"></i>
                <span>Dashboard</span>
            </a>
            <a href="/admin/users" class="nav-item">
                <i class="fas fa-users"></i>
                <span>Öğrenciler</span>
                <span class="badge bg-primary ms-auto"><%= userCount %></span>
            </a>
            <a href="/admin/applications" class="nav-item">
                <i class="fas fa-file-alt"></i>
                <span>Başvurular</span>
                <span class="badge bg-success ms-auto"><%= applicationCount %></span>
            </a>
            <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin) { %>
            <a href="/admin/partners" class="nav-item">
                <i class="fas fa-handshake"></i>
                <span>Partnerler</span>
                <% if (typeof partnerCount !== 'undefined' && partnerCount > 0) { %>
                    <span class="badge bg-info ms-auto"><%= partnerCount %></span>
                <% } %>
            </a>
            <% } %>
            <a href="/admin/universities" class="nav-item active">
                <i class="fas fa-university"></i>
                <span>Üniversiteler</span>
            </a>
            <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin) { %>
            <a href="/admin/backups" class="nav-item">
                <i class="fas fa-database"></i>
                <span>Yedekleme</span>
            </a>
            <a href="/admin/admins" class="nav-item">
                <i class="fas fa-user-shield"></i>
                <span>Adminler</span>
            </a>
            <% } %>
        </nav>
    </div>

    <!-- Main Content Area -->
    <div class="admin-main">
        <!-- Header -->
        <div class="section-header">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2><i class="fas fa-edit me-2"></i>Üniversite Düzenle</h2>
                    <p class="text-muted"><%= university.name %></p>
                </div>
                <a href="/admin/universities" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Geri Dön
                </a>
            </div>
        </div>

        <!-- Edit Form -->
        <div class="card">
            <div class="card-header">
                <h5><i class="fas fa-university me-2"></i>Üniversite Bilgileri</h5>
            </div>
            <div class="card-body">
                <form id="universityEditForm" enctype="multipart/form-data">
                    <!-- Temel Bilgiler -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <h6 class="text-primary mb-3">
                                <i class="fas fa-info-circle me-2"></i>Temel Bilgiler
                            </h6>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="name" class="form-label">Üniversite Adı *</label>
                                <input type="text" class="form-control" id="name" name="name" value="<%= university.name %>" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="country" class="form-label">Ülke *</label>
                                <select class="form-select" id="country" name="country" required>
                                    <option value="">Seçiniz</option>
                                    <option value="Germany" <%= university.country === 'Germany' ? 'selected' : '' %>>Almanya</option>
                                    <option value="UK" <%= (university.country === 'UK' || university.country === 'United Kingdom') ? 'selected' : '' %>>İngiltere</option>
                                    <option value="Austria" <%= university.country === 'Austria' ? 'selected' : '' %>>Avusturya</option>
                                    <option value="Italy" <%= university.country === 'Italy' ? 'selected' : '' %>>İtalya</option>
                                    <option value="Czech Republic" <%= university.country === 'Czech Republic' ? 'selected' : '' %>>Çek Cumhuriyeti</option>
                                    <option value="Poland" <%= university.country === 'Poland' ? 'selected' : '' %>>Polonya</option>
                                    <option value="Hungary" <%= university.country === 'Hungary' ? 'selected' : '' %>>Macaristan</option>
                                    <option value="Netherlands" <%= university.country === 'Netherlands' ? 'selected' : '' %>>Hollanda</option>
                                    <option value="Spain" <%= university.country === 'Spain' ? 'selected' : '' %>>İspanya</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="city" class="form-label">Şehir *</label>
                                <input type="text" class="form-control" id="city" name="city" value="<%= university.city %>" required>
                            </div>
                        </div>
                    </div>

                    <!-- Logo -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <h6 class="text-primary mb-3">
                                <i class="fas fa-image me-2"></i>Logo
                            </h6>
                        </div>
                        <div class="col-md-4">
                            <div class="text-center mb-3 p-3 border rounded bg-light" id="logoPreviewContainer">
                                <% if (university.logo_url) { %>
                                    <img src="<%= university.logo_url %>" alt="Logo" id="logoPreview" style="max-width: 150px; max-height: 150px; object-fit: contain;">
                                <% } else { %>
                                    <i class="fas fa-image fa-3x text-muted" id="logoPlaceholder"></i>
                                    <p class="text-muted mt-2 mb-0">Logo yok</p>
                                <% } %>
                            </div>
                        </div>
                        <div class="col-md-8">
                            <div class="mb-3">
                                <label class="form-label">Logo Yükle</label>
                                <input type="file" class="form-control" id="logo_file" accept="image/*">
                                <small class="text-muted">PNG, JPG veya SVG formatında logo yükleyin (max 2MB)</small>
                            </div>
                            <input type="hidden" id="logo_url_input" name="logo_url" value="<%= university.logo_url || '' %>">
                        </div>
                    </div>

                    <!-- Akademik Bilgiler -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <h6 class="text-primary mb-3">
                                <i class="fas fa-graduation-cap me-2"></i>Akademik Bilgiler
                            </h6>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="world_ranking" class="form-label">Dünya Sıralaması</label>
                                <input type="number" class="form-control" id="world_ranking" name="world_ranking" value="<%= university.world_ranking || '' %>" min="1" placeholder="Örn: 100">
                            </div>
                        </div>
                    </div>

                    <!-- Son Başvuru Tarihi -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <h6 class="text-primary mb-3">
                                <i class="fas fa-calendar-alt me-2"></i>Son Başvuru Tarihi
                            </h6>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="application_deadline" class="form-label">Son Başvuru Tarihi</label>
                                <input type="date" class="form-control" id="application_deadline" name="application_deadline" value="<%= university.application_deadline ? new Date(university.application_deadline).toISOString().split('T')[0] : '' %>">
                                <small class="text-muted">Üniversitenin son başvuru tarihini seçin</small>
                            </div>
                        </div>
                    </div>

                    <!-- Açıklama -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <h6 class="text-primary mb-3">
                                <i class="fas fa-align-left me-2"></i>Açıklama
                            </h6>
                        </div>
                        <div class="col-12">
                            <div class="mb-3">
                                <label for="description" class="form-label">Açıklama</label>
                                <textarea class="form-control" id="description" name="description" rows="4" placeholder="Üniversite hakkında detaylı bilgi..."><%= university.description || '' %></textarea>
                            </div>
                        </div>
                    </div>

                    <!-- Bölümler -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <h6 class="text-primary mb-3">
                                <i class="fas fa-graduation-cap me-2"></i>Bölümler
                            </h6>
                            <p class="text-muted">
                                <i class="fas fa-info-circle me-1"></i>
                                Bölümleri sürükleyerek sıralayabilirsiniz (Spotify tarzı)
                            </p>
                        </div>
                        <div class="col-12">
                            <div id="departmentsContainer" class="sortable-container">
                                <!-- Bölümler buraya dinamik olarak eklenecek -->
                            </div>
                            <button type="button" class="btn btn-outline-primary btn-sm" id="addDepartmentBtn">
                                <i class="fas fa-plus me-2"></i>Bölüm Ekle
                            </button>
                        </div>
                    </div>

                    <!-- SortableJS CDN -->
                    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
                    
                    <style>
                        .sortable-container {
                            min-height: 50px;
                        }
                        .department-field {
                            background: #f8f9fa;
                            transition: all 0.2s ease;
                            cursor: default;
                        }
                        .department-field:hover {
                            background: #e9ecef;
                        }
                        .department-field.sortable-ghost {
                            opacity: 0.4;
                            background: #dee2e6;
                        }
                        .department-field.sortable-chosen {
                            box-shadow: 0 4px 15px rgba(0,0,0,0.15);
                            transform: scale(1.02);
                        }
                        .drag-handle {
                            cursor: grab;
                            color: #6c757d;
                            padding: 8px;
                            transition: color 0.2s;
                        }
                        .drag-handle:hover {
                            color: #495057;
                        }
                        .drag-handle:active {
                            cursor: grabbing;
                        }
                        .sort-order-badge {
                            background: #6c757d;
                            color: white;
                            font-size: 0.75rem;
                            padding: 2px 8px;
                            border-radius: 10px;
                            min-width: 24px;
                            text-align: center;
                        }
                    </style>




            <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary" id="submitBtn">
                            <i class="fas fa-save me-2"></i>Değişiklikleri Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('universityEditForm');
    const submitBtn = document.getElementById('submitBtn');
    const goBackBtn = document.getElementById('goBackBtn');
    const deleteBtn = document.getElementById('deleteUniversityBtn');
    const addDepartmentBtn = document.getElementById('addDepartmentBtn');
    const departmentsContainer = document.getElementById('departmentsContainer');
    // Logo dosya yükleme
    const logoInput = document.getElementById('logo_file');
    const logoUrlInput = document.getElementById('logo_url_input');
    const logoPreviewContainer = document.getElementById('logoPreviewContainer');
    
    if (logoInput) {
        logoInput.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (!file) return;
            
            // Boyut kontrolü (2MB)
            if (file.size > 2 * 1024 * 1024) {
                alert('Logo dosyası 2MB\'dan küçük olmalıdır!');
                logoInput.value = '';
                return;
            }
            
            // Base64'e çevir
            const reader = new FileReader();
            reader.onload = function(event) {
                const base64 = event.target.result;
                logoUrlInput.value = base64;
                
                // Önizleme güncelle
                logoPreviewContainer.innerHTML = `<img src="${base64}" alt="Logo" id="logoPreview" style="max-width: 150px; max-height: 150px; object-fit: contain;">`;
            };
            reader.readAsDataURL(file);
        });
    }

    // Mevcut bölümleri yükle (sort_order'a göre sıralı)
    let existingDepartments = <%- JSON.stringify((typeof departments !== 'undefined' && departments) ? departments : (university.departments || [])) %>;
    let departmentCount = 0;

    // Sort_order'a göre sırala (sayısal olarak)
    if (existingDepartments && existingDepartments.length > 0) {
        existingDepartments.sort((a, b) => {
            const orderA = parseInt(a.sort_order) || 9999;
            const orderB = parseInt(b.sort_order) || 9999;
            return orderA - orderB;
        });
    }

    // Mevcut bölümleri göster
    if (existingDepartments && existingDepartments.length > 0) {
        existingDepartments.forEach(dept => {
            addDepartmentField(dept.name_tr, dept.price);
        });
    }

    // Bölüm ekleme fonksiyonu - Spotify tarzı drag-drop destekli
    function addDepartmentField(name = '', price = '') {
        const departmentDiv = document.createElement('div');
        departmentDiv.className = 'department-field mb-3 p-3 border rounded';
        departmentDiv.setAttribute('data-sort-order', departmentCount);
        departmentDiv.innerHTML = `
            <div class="row align-items-center">
                <div class="col-auto">
                    <div class="drag-handle" title="Sıralamak için sürükle">
                        <i class="fas fa-grip-vertical fa-lg"></i>
                    </div>
                </div>
                <div class="col-auto">
                    <span class="sort-order-badge">${departmentCount + 1}</span>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Bölüm Adı</label>
                    <input type="text" class="form-control department-name" name="departments[${departmentCount}][name_tr]" value="${name}" placeholder="Örn: Mühendislik">
                </div>
                <div class="col-md-3">
                    <label class="form-label">Fiyat (€)</label>
                    <input type="number" class="form-control department-price" name="departments[${departmentCount}][price]" value="${price}" placeholder="Örn: 5000" min="0" step="0.01">
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="button" class="btn btn-outline-danger btn-sm remove-department">
                        <i class="fas fa-trash"></i> Kaldır
                    </button>
                </div>
            </div>
        `;
        
        departmentsContainer.appendChild(departmentDiv);
        departmentCount++;
        updateSortOrderBadges();
    }
    
    // Sıra numaralarını güncelle
    function updateSortOrderBadges() {
        const departments = departmentsContainer.querySelectorAll('.department-field');
        departments.forEach((dept, index) => {
            const badge = dept.querySelector('.sort-order-badge');
            if (badge) {
                badge.textContent = index + 1;
            }
            dept.setAttribute('data-sort-order', index);
        });
    }
    
    // SortableJS başlat - Spotify tarzı sürükle-bırak
    const sortable = new Sortable(departmentsContainer, {
        handle: '.drag-handle',
        animation: 150,
        ghostClass: 'sortable-ghost',
        chosenClass: 'sortable-chosen',
        dragClass: 'sortable-drag',
        onEnd: function(evt) {
            updateSortOrderBadges();
            console.log('🎵 Bölüm sıralaması güncellendi');
        }
    });

    // Bölüm ekle butonu
    addDepartmentBtn.addEventListener('click', function() {
        addDepartmentField();
    });

    // Bölüm kaldır butonu
    departmentsContainer.addEventListener('click', function(e) {
        if (e.target.closest('.remove-department')) {
            e.target.closest('.department-field').remove();
        }
    });

    // Geri dön butonu
    if (goBackBtn) {
        goBackBtn.addEventListener('click', function() {
            window.location.href = '/admin/universities';
        });
    }

    // Form gönderimi
    form.addEventListener('submit', async function(e) {
        e.preventDefault();
        console.log('🚀 Form submission started');
        
        const submitButton = submitBtn;
        const originalText = submitButton.innerHTML;
        
        try {
            submitButton.disabled = true;
            submitButton.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Kaydediliyor...';

            const payload = {
                name: document.getElementById('name').value,
                country: document.getElementById('country').value,
                city: document.getElementById('city').value,
                world_ranking: document.getElementById('world_ranking').value,
                description: document.getElementById('description').value,
                application_deadline: document.getElementById('application_deadline').value || null,
                logo_url: document.getElementById('logo_url_input').value || null
            };

            // Bölümleri sırasıyla topla (Spotify tarzı sıralama)
            const departments = [];
            document.querySelectorAll('.department-field').forEach((field, index) => {
                const name = field.querySelector('.department-name').value.trim();
                const price = field.querySelector('.department-price').value;
                if (name) {
                    departments.push({
                        name_tr: name,
                        name_en: name,
                        price: price || 0,
                        sort_order: index + 1 // Sıralama numarası
                    });
                }
            });
            payload.departments = departments;

            const response = await fetch(`/admin/universities/<%= university.id %>`, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(payload)
            });

            if (!response.ok) {
                const errorText = await response.text();
                throw new Error(errorText || `HTTP ${response.status}`);
            }

            const result = await response.json();
            if (result.success) {
                alert('Üniversite başarıyla güncellendi!');
                window.location.href = '/admin/universities';
            } else {
                alert('Hata: ' + (result.message || 'Bilinmeyen hata'));
            }
        } catch (error) {
            console.error('University update error:', error);
            alert('Bir hata oluştu. Lütfen tekrar deneyin. Hata: ' + error.message);
        } finally {
            submitButton.disabled = false;
            submitButton.innerHTML = originalText;
        }
    });

    // Üniversite silme
    if (deleteBtn) {
        deleteBtn.addEventListener('click', function() {
            if (confirm('Bu üniversiteyi silmek istediğinizden emin misiniz? Bu işlem geri alınamaz.')) {
                fetch(`/api/admin/universities/<%= university.id %>`, {
                    method: 'DELETE'
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Üniversite başarıyla silindi!');
                        window.location.href = '/admin/universities';
                    } else {
                        alert('Hata: ' + data.message);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Bir hata oluştu.');
                });
            }
        });
    }
});
</script>