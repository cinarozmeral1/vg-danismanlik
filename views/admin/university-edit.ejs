<!-- Admin University Edit Content -->
<div class="admin-container">
    <!-- Sidebar -->
    <div class="admin-sidebar">
        <div class="sidebar-header">
            <h6 class="mb-0"><i class="fas fa-cog me-2"></i>Yönetim Paneli</h6>
        </div>
        <nav class="sidebar-nav">
            <a href="/admin/dashboard" class="nav-item">
                <i class="fas fa-tachometer-alt"></i>
                <span>Dashboard</span>
            </a>
            <a href="/admin/users" class="nav-item">
                <i class="fas fa-users"></i>
                <span>Öğrenciler</span>
            </a>
            <a href="/admin/applications" class="nav-item">
                <i class="fas fa-file-alt"></i>
                <span>Başvurular</span>
            </a>
            <a href="/admin/universities" class="nav-item active">
                <i class="fas fa-university"></i>
                <span>Üniversiteler</span>
            </a>
        </nav>
    </div>

    <!-- Main Content Area -->
    <div class="admin-main">
        <!-- Header -->
        <div class="section-header">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2><i class="fas fa-edit me-2"></i>Üniversite Düzenle</h2>
                    <p class="text-muted"><%= university.name %></p>
                </div>
                <div class="btn-group">
                    <a href="/admin/universities/<%= university.id %>" class="btn btn-secondary">
                        <i class="fas fa-eye me-2"></i>Görüntüle
                    </a>
                    <a href="/admin/universities" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left me-2"></i>Geri Dön
                    </a>
                </div>
            </div>
        </div>

        <!-- Edit Form -->
        <div class="card">
            <div class="card-header">
                <h5><i class="fas fa-university me-2"></i>Üniversite Bilgileri</h5>
            </div>
            <div class="card-body">
                <form id="universityEditForm" enctype="multipart/form-data">
                    <!-- Temel Bilgiler -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <h6 class="text-primary mb-3">
                                <i class="fas fa-info-circle me-2"></i>Temel Bilgiler
                            </h6>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="name" class="form-label">Üniversite Adı *</label>
                                <input type="text" class="form-control" id="name" name="name" value="<%= university.name %>" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="country" class="form-label">Ülke *</label>
                                <select class="form-select" id="country" name="country" required>
                                    <option value="">Seçiniz</option>
                                    <option value="Germany" <%= university.country === 'Germany' ? 'selected' : '' %>>Almanya</option>
                                    <option value="UK" <%= university.country === 'UK' ? 'selected' : '' %>>İngiltere</option>
                                    <option value="France" <%= university.country === 'France' ? 'selected' : '' %>>Fransa</option>
                                    <option value="Netherlands" <%= university.country === 'Netherlands' ? 'selected' : '' %>>Hollanda</option>
                                    <option value="Switzerland" <%= university.country === 'Switzerland' ? 'selected' : '' %>>İsviçre</option>
                                    <option value="Austria" <%= university.country === 'Austria' ? 'selected' : '' %>>Avusturya</option>
                                    <option value="Italy" <%= university.country === 'Italy' ? 'selected' : '' %>>İtalya</option>
                                    <option value="Czech Republic" <%= university.country === 'Czech Republic' ? 'selected' : '' %>>Çek Cumhuriyeti</option>
                                    <option value="Poland" <%= university.country === 'Poland' ? 'selected' : '' %>>Polonya</option>
                                    <option value="Hungary" <%= university.country === 'Hungary' ? 'selected' : '' %>>Macaristan</option>
                                    <option value="Spain" <%= university.country === 'Spain' ? 'selected' : '' %>>İspanya</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="city" class="form-label">Şehir *</label>
                                <input type="text" class="form-control" id="city" name="city" value="<%= university.city %>" required>
                            </div>
                        </div>
                    </div>

                    <!-- Logo Yükleme -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <h6 class="text-primary mb-3">
                                <i class="fas fa-image me-2"></i>Logo
                            </h6>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="logo_file" class="form-label">Logo Dosyası</label>
                                <input type="file" class="form-control" id="logo_file" name="logo_file" accept="image/*,.heic,.heif">
                                <small class="text-muted">PNG, JPG, SVG, HEIC formatları desteklenir</small>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <% if (university.logo_url) { %>
                            <div class="mb-3">
                                <label class="form-label">Mevcut Logo</label>
                                <div class="d-flex align-items-center">
                                    <img src="<%= university.logo_url %>" alt="Mevcut Logo" class="img-thumbnail me-2" style="max-width: 100px; max-height: 100px;">
                                    <div>
                                        <small class="text-muted d-block">Mevcut logo korunacak</small>
                                        <small class="text-muted">Yeni dosya yüklerseniz değişecek</small>
                                    </div>
                                </div>
                            </div>
                            <% } %>
                        </div>
                    </div>

                    <!-- Akademik Bilgiler -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <h6 class="text-primary mb-3">
                                <i class="fas fa-graduation-cap me-2"></i>Akademik Bilgiler
                            </h6>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="world_ranking" class="form-label">Dünya Sıralaması</label>
                                <input type="number" class="form-control" id="world_ranking" name="world_ranking" value="<%= university.world_ranking || '' %>" min="1" placeholder="Örn: 100">
                            </div>
                        </div>
                    </div>

                    <!-- Açıklama -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <h6 class="text-primary mb-3">
                                <i class="fas fa-align-left me-2"></i>Açıklama
                            </h6>
                        </div>
                        <div class="col-12">
                            <div class="mb-3">
                                <label for="description" class="form-label">Açıklama</label>
                                <textarea class="form-control" id="description" name="description" rows="4" placeholder="Üniversite hakkında detaylı bilgi..."><%= university.description || '' %></textarea>
                            </div>
                        </div>
                    </div>

                    <!-- Bölümler -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <h6 class="text-primary mb-3">
                                <i class="fas fa-graduation-cap me-2"></i>Bölümler
                            </h6>
                            <p class="text-muted">Bu üniversitede bulunan bölümleri düzenleyin</p>
                        </div>
                        <div class="col-12">
                            <div id="departmentsContainer">
                                <!-- Bölümler buraya dinamik olarak eklenecek -->
                            </div>
                            <button type="button" class="btn btn-outline-primary btn-sm" id="addDepartmentBtn">
                                <i class="fas fa-plus me-2"></i>Bölüm Ekle
                            </button>
                        </div>
                    </div>

                    <!-- Gereksinimler -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <h6 class="text-primary mb-3">
                                <i class="fas fa-clipboard-list me-2"></i>Gereksinimler
                            </h6>
                        </div>
                        <div class="col-12">
                            <div class="mb-3">
                                <label for="requirements" class="form-label">Gereksinimler</label>
                                <textarea class="form-control" id="requirements" name="requirements" rows="4" placeholder="Üniversiteye başvuru için gerekli şartlar, belgeler, sınavlar..."><%= university.requirements || '' %></textarea>
                                <small class="text-muted">Örnek: Lise diploması, İngilizce seviyesi, sınav sonuçları, referans mektupları</small>
                            </div>
                        </div>
                    </div>


                    <!-- Hidden input for current logo URL -->
                    <input type="hidden" name="logo_url" value="<%= university.logo_url || '' %>">

                    <div class="d-flex justify-content-between">
                        <button type="button" class="btn btn-secondary" id="goBackBtn">
                            <i class="fas fa-arrow-left me-2"></i>Geri Dön
                        </button>
                        <div>
                            <button type="button" class="btn btn-danger me-2" id="deleteUniversityBtn" data-university-id="<%= university.id %>">
                                <i class="fas fa-trash me-2"></i>Sil
                            </button>
                            <button type="submit" class="btn btn-primary" id="submitBtn">
                                <i class="fas fa-save me-2"></i>Değişiklikleri Kaydet
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('universityEditForm');
    const submitBtn = document.getElementById('submitBtn');
    const goBackBtn = document.getElementById('goBackBtn');
    const deleteBtn = document.getElementById('deleteUniversityBtn');
    const addDepartmentBtn = document.getElementById('addDepartmentBtn');
    const departmentsContainer = document.getElementById('departmentsContainer');

    // Mevcut bölümleri yükle
    const existingDepartments = <%- JSON.stringify(university.departments || []) %>;
    let departmentCount = 0;

    // Mevcut bölümleri göster
    if (existingDepartments && existingDepartments.length > 0) {
        existingDepartments.forEach(dept => {
            addDepartmentField(dept.name_tr, dept.price);
        });
    }

    // Bölüm ekleme fonksiyonu
    function addDepartmentField(name = '', price = '') {
        const departmentDiv = document.createElement('div');
        departmentDiv.className = 'department-field mb-3 p-3 border rounded';
        departmentDiv.innerHTML = `
            <div class="row">
                <div class="col-md-5">
                    <label class="form-label">Bölüm Adı</label>
                    <input type="text" class="form-control department-name" name="departments[${departmentCount}][name_tr]" value="${name}" placeholder="Örn: Mühendislik">
                </div>
                <div class="col-md-4">
                    <label class="form-label">Fiyat (€)</label>
                    <input type="number" class="form-control department-price" name="departments[${departmentCount}][price]" value="${price}" placeholder="Örn: 5000" min="0" step="0.01">
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="button" class="btn btn-outline-danger btn-sm remove-department">
                        <i class="fas fa-trash"></i> Kaldır
                    </button>
                </div>
            </div>
        `;
        
        departmentsContainer.appendChild(departmentDiv);
        departmentCount++;
    }

    // Bölüm ekle butonu
    addDepartmentBtn.addEventListener('click', function() {
        addDepartmentField();
    });

    // Bölüm kaldır butonu
    departmentsContainer.addEventListener('click', function(e) {
        if (e.target.closest('.remove-department')) {
            e.target.closest('.department-field').remove();
        }
    });

    // Geri dön butonu
    goBackBtn.addEventListener('click', function() {
        window.location.href = '/admin/universities';
    });

    // Form gönderimi
    form.addEventListener('submit', async function(e) {
        e.preventDefault();
        console.log('🚀 Form submission started');
        
        const submitButton = submitBtn;
        const originalText = submitButton.innerHTML;
        
        try {
            submitButton.disabled = true;
            submitButton.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Kaydediliyor...';
            
            // Form verilerini topla
            const formData = new URLSearchParams();
            const logoFile = document.getElementById('logo_file').files[0];
            let logoUrl = document.querySelector('input[name="logo_url"]').value; // Mevcut logo URL'ini al
            
            // Temel bilgileri topla
            formData.append('name', document.getElementById('name').value);
            formData.append('country', document.getElementById('country').value);
            formData.append('city', document.getElementById('city').value);
            formData.append('world_ranking', document.getElementById('world_ranking').value);
            formData.append('description', document.getElementById('description').value);
            formData.append('requirements', document.getElementById('requirements').value);
            formData.append('logo_url', logoUrl);
            
            console.log('📝 Form data collected:', {
                name: formData.get('name'),
                country: formData.get('country'),
                city: formData.get('city'),
                logoFile: logoFile ? logoFile.name : 'No file',
                currentLogoUrl: logoUrl
            });
            
            // Yeni logo yüklendiyse
            if (logoFile) {
                console.log('📝 Uploading new logo...');
                const logoFormData = new FormData();
                logoFormData.append('logo_file', logoFile);
                
                try {
                    const logoResponse = await fetch('/api/admin/universities/upload-logo', {
                        method: 'POST',
                        body: logoFormData
                    });
                    
                    if (!logoResponse.ok) {
                        throw new Error(`Logo upload failed with status: ${logoResponse.status}`);
                    }
                    
                    const logoResult = await logoResponse.json();
                    console.log('📝 Logo upload response:', logoResult);
                    
                    if (logoResult.success) {
                        logoUrl = logoResult.logo_url;
                        console.log('✅ Logo uploaded:', logoUrl);
                    } else {
                        throw new Error('Logo yükleme hatası: ' + logoResult.message);
                    }
                } catch (logoError) {
                    console.error('❌ Logo upload error:', logoError);
                    throw new Error('Logo yükleme başarısız: ' + logoError.message);
                }
            }
            
            // Logo URL'ini güncelle
            if (logoUrl) {
                formData.set('logo_url', logoUrl);
            }
            
            // Bölümleri topla
            const departments = [];
            const departmentFields = document.querySelectorAll('.department-field');
            console.log('📝 Found department fields:', departmentFields.length);
            
            departmentFields.forEach((field, index) => {
                const name = field.querySelector('.department-name').value.trim();
                const price = field.querySelector('.department-price').value;
                console.log(`📝 Department ${index}:`, { name, price });
                
                if (name) {
                    departments.push({
                        name_tr: name,
                        name_en: name, // İngilizce adı Türkçe ile aynı yap
                        price: price || 0
                    });
                }
            });
            
            console.log('📝 Final departments:', departments);
            formData.append('departments', JSON.stringify(departments));
            
            // Form data'yı logla
            console.log('📝 Sending form data:');
            for (let [key, value] of formData.entries()) {
                console.log(`  ${key}:`, value);
            }
            
            // Timeout ile fetch işlemi
            const controller = new AbortController();
            const timeoutId = setTimeout(() => controller.abort(), 30000); // 30 saniye timeout
            
            const response = await fetch(`/api/admin/universities/<%= university.id %>`, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: formData,
                signal: controller.signal
            });
            
            clearTimeout(timeoutId);
            console.log('📝 Response status:', response.status);
            console.log('📝 Response ok:', response.ok);
            
            if (response.ok) {
                const result = await response.json();
                console.log('📝 Response result:', result);
                
                if (result.success) {
                    alert('Üniversite başarıyla güncellendi!');
                    window.location.href = '/admin/universities';
                } else {
                    alert('Hata: ' + (result.message || 'Bilinmeyen hata'));
                }
            } else {
                const errorText = await response.text();
                console.error('❌ Server error:', errorText);
                alert('Bir hata oluştu. Lütfen tekrar deneyin. Hata: ' + errorText);
            }
        } catch (error) {
            console.error('Network error:', error);
            if (error.name === 'AbortError') {
                alert('İşlem zaman aşımına uğradı. Lütfen tekrar deneyin.');
            } else {
                alert('Bağlantı hatası. Lütfen tekrar deneyin. Hata: ' + error.message);
            }
        } finally {
            submitButton.disabled = false;
            submitButton.innerHTML = originalText;
        }
    });

    // Üniversite silme
    deleteBtn.addEventListener('click', function() {
        if (confirm('Bu üniversiteyi silmek istediğinizden emin misiniz? Bu işlem geri alınamaz.')) {
            fetch(`/api/admin/universities/<%= university.id %>`, {
                method: 'DELETE'
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Üniversite başarıyla silindi!');
                    window.location.href = '/admin/universities';
                } else {
                    alert('Hata: ' + data.message);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Bir hata oluştu.');
            });
        }
    });
});
</script>