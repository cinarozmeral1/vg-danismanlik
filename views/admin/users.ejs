<!-- Admin Users Content -->
<div class="admin-container">
    <%- include('partials/sidebar') %>

    <!-- Main Content Area -->
    <div class="admin-main">
        <div class="section-header">
            <h2><i class="fas fa-users me-2"></i>Öğrenciler</h2>
            <p class="text-muted">Sistemdeki tüm öğrencileri yönetin</p>
        </div>

<!-- Advanced Filter Panel -->
<div class="card mb-3">
    <div class="card-body py-3">
        <div class="row g-3 align-items-end">
            <!-- Text Search -->
            <div class="col-lg-4 col-md-6">
                <label class="form-label fw-semibold mb-1"><i class="fas fa-search me-1"></i>Ara</label>
                <input type="text" class="form-control" id="userSearchInput" placeholder="Ad, telefon, TC, okul, veli adı...">
            </div>
            <!-- Class Filter -->
            <div class="col-lg-2 col-md-3">
                <label class="form-label fw-semibold mb-1"><i class="fas fa-graduation-cap me-1"></i>Sınıf</label>
                <select class="form-select" id="classFilter">
                    <option value="">Tümü</option>
                    <option value="11">11. Sınıf</option>
                    <option value="12">12. Sınıf</option>
                    <option value="Mezun">Mezun</option>
                </select>
            </div>
            <!-- Payment Filters -->
            <div class="col-lg-4 col-md-6">
                <label class="form-label fw-semibold mb-1"><i class="fas fa-credit-card me-1"></i>Ödeme Durumu</label>
                <div class="d-flex gap-3 flex-wrap mt-1">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="filterHazirlik">
                        <label class="form-check-label small" for="filterHazirlik">11. Sınıf Hazırlık Ödemiş</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="filterKabulOncesi">
                        <label class="form-check-label small" for="filterKabulOncesi">Kabul Öncesi Ödemiş</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="filterKabulSonrasi">
                        <label class="form-check-label small" for="filterKabulSonrasi">Kabul Sonrası Ödemiş</label>
                    </div>
                </div>
            </div>
            <!-- Reset Button -->
            <div class="col-lg-2 col-md-3">
                <button class="btn btn-outline-secondary w-100" id="resetFilters">
                    <i class="fas fa-undo me-1"></i>Sıfırla
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Status Tabs -->
<ul class="nav nav-tabs mb-0" id="statusTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" data-status-tab="active" type="button" role="tab">
            <i class="fas fa-check-circle text-success me-1"></i>Aktif
            <span class="badge bg-success ms-1" id="tabActiveCount"><%= typeof activeCount !== 'undefined' ? activeCount : 0 %></span>
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" data-status-tab="pending" type="button" role="tab">
            <i class="fas fa-clock text-warning me-1"></i>Beklemede
            <span class="badge bg-warning text-dark ms-1" id="tabPendingCount"><%= typeof pendingCount !== 'undefined' ? pendingCount : 0 %></span>
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" data-status-tab="negative" type="button" role="tab">
            <i class="fas fa-times-circle text-danger me-1"></i>Olumsuz
            <span class="badge bg-danger ms-1" id="tabNegativeCount"><%= typeof negativeCount !== 'undefined' ? negativeCount : 0 %></span>
        </button>
    </li>
</ul>

<!-- Users Table -->
<div class="card border-top-0" style="border-top-left-radius:0; border-top-right-radius:0;">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Öğrenci Listesi (<span id="visibleCount"><%= users.length %></span> / <%= users.length %>)</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Ad Soyad</th>
                                <th>E-posta</th>
                                <th>Telefon</th>
                                <th>İngilizce Seviyesi</th>
                                <th>Aktiflik Durumu</th>
                                <th>Kayıt Tarihi</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                <tbody id="usersTableBody">
                            <% users.forEach(user => { %>
                    <tr class="student-row"
                        data-name="<%= (user.first_name + ' ' + user.last_name).toLowerCase() %>"
                        data-phone="<%= (user.phone || '').toLowerCase() %>"
                        data-email="<%= (user.email || '').toLowerCase() %>"
                        data-tc="<%= user.tc_number || '' %>"
                        data-school="<%= (user.current_school || '').toLowerCase() %>"
                        data-class="<%= user.active_class || '' %>"
                        data-guardians="<%= (user.guardian_names || '').toLowerCase() %>"
                        data-kabul-oncesi="<%= user.kabul_oncesi_paid ? 'true' : 'false' %>"
                        data-kabul-sonrasi="<%= user.kabul_sonrasi_paid ? 'true' : 'false' %>"
                        data-hazirlik="<%= user.hazirlik_paid ? 'true' : 'false' %>"
                        data-active="<%= user.has_any_paid_service ? 'true' : 'false' %>"
                        data-student-status="<%= user.student_status || 'pending' %>">
                                <td><%= user.id %></td>
                                <td><%= user.first_name %> <%= user.last_name %></td>
                                <td><%= user.email %></td>
                                <td><%= user.phone %></td>
                                <td><span class="badge bg-info"><%= user.english_level %></span></td>
                                <td class="status-badge-cell">
                                    <% if (user.student_status === 'negative') { %>
                                        <span class="badge bg-danger">Olumsuz</span>
                                    <% } else if (user.student_status === 'pending') { %>
                                        <span class="badge bg-warning text-dark">Beklemede</span>
                                    <% } else { %>
                                        <span class="badge bg-success">Aktif</span>
                                    <% } %>
                                </td>
                                <td><%= new Date(user.created_at).toLocaleDateString('tr-TR') %></td>
                                <td>
                                    <div class="d-flex align-items-center gap-1">
                                        <button class="btn btn-sm js-set-status <%= user.student_status === 'active' ? 'btn-success' : 'btn-outline-success' %>" data-user-id="<%= user.id %>" data-set-status="active" title="Aktif">
                                            <i class="fas fa-check-circle"></i>
                                        </button>
                                        <button class="btn btn-sm js-set-status <%= user.student_status === 'pending' ? 'btn-warning' : 'btn-outline-warning' %>" data-user-id="<%= user.id %>" data-set-status="pending" title="Beklemede">
                                            <i class="fas fa-clock"></i>
                                        </button>
                                        <button class="btn btn-sm js-set-status <%= user.student_status === 'negative' ? 'btn-danger' : 'btn-outline-danger' %>" data-user-id="<%= user.id %>" data-set-status="negative" title="Olumsuz">
                                            <i class="fas fa-times-circle"></i>
                                        </button>
                                        <span class="border-start ms-1 ps-1"></span>
                                        <button class="btn btn-sm btn-outline-info js-view-details" data-user-id="<%= user.id %>">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger js-delete-user" data-user-id="<%= user.id %>" data-user-name="<%= user.first_name %> <%= user.last_name %>">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
        <!-- No results message -->
        <div id="noResultsMsg" class="text-center text-muted py-4" style="display: none;">
            <i class="fas fa-search me-2"></i>Filtrelere uygun öğrenci bulunamadı.
        </div>
    </div>
</div>
    </div> <!-- /.admin-main -->
</div> <!-- /.admin-container -->

<script>
    document.addEventListener('DOMContentLoaded', function() {
        let currentTab = 'active';

        // --- Status Tab System ---
        const tabButtons = document.querySelectorAll('[data-status-tab]');
        tabButtons.forEach(btn => {
            btn.addEventListener('click', function() {
                tabButtons.forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                currentTab = this.getAttribute('data-status-tab');
                applyFilters();
            });
        });

        // --- Set Status Buttons ---
        document.addEventListener('click', async function(e) {
            const statusBtn = e.target.closest('.js-set-status');
            if (statusBtn) {
                const userId = statusBtn.getAttribute('data-user-id');
                const newStatus = statusBtn.getAttribute('data-set-status');
                try {
                    const res = await fetch(`/admin/users/${userId}/status`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify({ status: newStatus })
                    });
                    const data = await res.json();
                    if (data.success) {
                        const row = statusBtn.closest('tr');
                        row.setAttribute('data-student-status', newStatus);

                        const statusMap = {
                            active:   { cls: 'bg-success', text: 'Aktif' },
                            pending:  { cls: 'bg-warning text-dark', text: 'Beklemede' },
                            negative: { cls: 'bg-danger',  text: 'Olumsuz' }
                        };
                        const badgeCell = row.querySelector('.status-badge-cell');
                        const info = statusMap[newStatus];
                        badgeCell.innerHTML = '<span class="badge ' + info.cls + '">' + info.text + '</span>';

                        const btnGroup = row.querySelectorAll('.js-set-status');
                        btnGroup.forEach(b => {
                            const s = b.getAttribute('data-set-status');
                            b.className = b.className
                                .replace(/btn-(success|warning|danger|outline-success|outline-warning|outline-danger)/g, '');
                            if (s === newStatus) {
                                b.classList.add(s === 'active' ? 'btn-success' : s === 'pending' ? 'btn-warning' : 'btn-danger');
                            } else {
                                b.classList.add(s === 'active' ? 'btn-outline-success' : s === 'pending' ? 'btn-outline-warning' : 'btn-outline-danger');
                            }
                        });

                        refreshTabCounts();
                        applyFilters();
                        showAlert('success', 'Durum güncellendi.');
                    } else {
                        showAlert('danger', data.message || 'Durum güncellenemedi.');
                    }
                } catch (err) {
                    console.error(err);
                    showAlert('danger', 'Durum güncellenirken hata oluştu.');
                }
                return;
            }

            const detailsBtn = e.target.closest('.js-view-details');
            const deleteBtn = e.target.closest('.js-delete-user');

            if (detailsBtn) {
                viewUserDetails(detailsBtn.getAttribute('data-user-id'));
            }
            if (deleteBtn) {
                deleteUser(deleteBtn.getAttribute('data-user-id'), deleteBtn.getAttribute('data-user-name'));
            }
        });

        function refreshTabCounts() {
            const allRows = document.querySelectorAll('.student-row');
            let a = 0, p = 0, n = 0;
            allRows.forEach(r => {
                const s = r.getAttribute('data-student-status');
                if (s === 'active') a++;
                else if (s === 'pending') p++;
                else if (s === 'negative') n++;
            });
            document.getElementById('tabActiveCount').textContent = a;
            document.getElementById('tabPendingCount').textContent = p;
            document.getElementById('tabNegativeCount').textContent = n;
        }

        // --- Advanced Filter System ---
        const searchInput = document.getElementById('userSearchInput');
        const classFilter = document.getElementById('classFilter');
        const filterHazirlik = document.getElementById('filterHazirlik');
        const filterKabulOncesi = document.getElementById('filterKabulOncesi');
        const filterKabulSonrasi = document.getElementById('filterKabulSonrasi');
        const resetBtn = document.getElementById('resetFilters');
        const visibleCountEl = document.getElementById('visibleCount');
        const noResultsMsg = document.getElementById('noResultsMsg');

        function applyFilters() {
            const allRows = document.querySelectorAll('.student-row');
            const searchTerm = searchInput.value.toLowerCase().trim();
            const selectedClass = classFilter.value;
            const requireHazirlik = filterHazirlik.checked;
            const requireKabulOncesi = filterKabulOncesi.checked;
            const requireKabulSonrasi = filterKabulSonrasi.checked;

            let visibleCount = 0;

            allRows.forEach(row => {
                let show = true;

                // 0. Status tab filter
                const rowStatus = row.getAttribute('data-student-status') || 'active';
                if (rowStatus !== currentTab) show = false;

                // 1. Text search
                if (show && searchTerm) {
                    const fields = ['data-name','data-phone','data-email','data-tc','data-school','data-guardians'];
                    const textMatch = fields.some(f => (row.getAttribute(f) || '').includes(searchTerm));
                    if (!textMatch) show = false;
                }

                // 2. Class filter
                if (show && selectedClass) {
                    if ((row.getAttribute('data-class') || '') !== selectedClass) show = false;
                }

                // 3. Payment filters
                if (show && (requireHazirlik || requireKabulOncesi || requireKabulSonrasi)) {
                    const hasH = row.getAttribute('data-hazirlik') === 'true';
                    const hasKO = row.getAttribute('data-kabul-oncesi') === 'true';
                    const hasKS = row.getAttribute('data-kabul-sonrasi') === 'true';
                    const matchesAny = (requireHazirlik && hasH) ||
                                      (requireKabulOncesi && hasKO) ||
                                      (requireKabulSonrasi && hasKS);
                    if (!matchesAny) show = false;
                }

                row.style.display = show ? '' : 'none';
                if (show) visibleCount++;
            });

            visibleCountEl.textContent = visibleCount;
            noResultsMsg.style.display = visibleCount === 0 ? '' : 'none';
        }

        searchInput.addEventListener('input', applyFilters);
        classFilter.addEventListener('change', applyFilters);
        filterHazirlik.addEventListener('change', applyFilters);
        filterKabulOncesi.addEventListener('change', applyFilters);
        filterKabulSonrasi.addEventListener('change', applyFilters);

        resetBtn.addEventListener('click', function() {
            searchInput.value = '';
            classFilter.value = '';
            filterHazirlik.checked = false;
            filterKabulOncesi.checked = false;
            filterKabulSonrasi.checked = false;
            applyFilters();
        });

        // Initial filter (show only active tab)
        applyFilters();
    });

    function viewUserDetails(userId) {
        window.location.href = `/admin/users/${userId}/details`;
    }

    async function deleteUser(userId, userName) {
        if (!confirm(`"${userName}" adlı öğrenciyi silmek istediğinizden emin misiniz?\n\nBu işlem geri alınamaz ve öğrencinin tüm verileri silinecektir.`)) {
            return;
        }

        try {
            const response = await fetch(`/admin/users/${userId}`, {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include'
            });

            const result = await response.json();

            if (result.success) {
                showAlert('success', result.message);
                const row = document.querySelector(`[data-user-id="${userId}"]`).closest('tr');
                if (row) row.remove();
            } else {
                showAlert('danger', result.message);
            }
        } catch (error) {
            console.error('Delete user error:', error);
            showAlert('danger', 'Öğrenci silinirken bir hata oluştu.');
        }
    }

    function showAlert(type, message) {
        const alertDiv = document.createElement('div');
        alertDiv.className = `alert alert-${type} alert-dismissible fade show position-fixed`;
        alertDiv.style.top = '20px';
        alertDiv.style.right = '20px';
        alertDiv.style.zIndex = '9999';
        alertDiv.innerHTML = `
            <i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-triangle'} me-2"></i>
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;
        document.body.appendChild(alertDiv);

        setTimeout(() => {
            if (alertDiv.parentNode) alertDiv.parentNode.removeChild(alertDiv);
        }, 5000);
    }
</script>
