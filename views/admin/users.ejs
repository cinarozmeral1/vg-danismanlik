<!-- Admin Users Content -->
<div class="admin-container">
    <%- include('partials/sidebar') %>

    <!-- Main Content Area -->
    <div class="admin-main">
        <div class="section-header">
            <h2><i class="fas fa-users me-2"></i>Öğrenciler</h2>
            <p class="text-muted">Sistemdeki tüm öğrencileri yönetin</p>
        </div>

<!-- Advanced Filter Panel -->
<div class="card mb-3">
    <div class="card-body py-3">
        <div class="row g-3 align-items-end">
            <!-- Text Search -->
            <div class="col-lg-4 col-md-6">
                <label class="form-label fw-semibold mb-1"><i class="fas fa-search me-1"></i>Ara</label>
                <input type="text" class="form-control" id="userSearchInput" placeholder="Ad, telefon, TC, okul, veli adı...">
            </div>
            <!-- Class Filter -->
            <div class="col-lg-2 col-md-3">
                <label class="form-label fw-semibold mb-1"><i class="fas fa-graduation-cap me-1"></i>Sınıf</label>
                <select class="form-select" id="classFilter">
                    <option value="">Tümü</option>
                    <option value="11">11. Sınıf</option>
                    <option value="12">12. Sınıf</option>
                    <option value="Mezun">Mezun</option>
                </select>
            </div>
            <!-- Payment Filters -->
            <div class="col-lg-4 col-md-6">
                <label class="form-label fw-semibold mb-1"><i class="fas fa-credit-card me-1"></i>Ödeme Durumu</label>
                <div class="d-flex gap-3 flex-wrap mt-1">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="filterHazirlik">
                        <label class="form-check-label small" for="filterHazirlik">11. Sınıf Hazırlık Ödemiş</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="filterKabulOncesi">
                        <label class="form-check-label small" for="filterKabulOncesi">Kabul Öncesi Ödemiş</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="filterKabulSonrasi">
                        <label class="form-check-label small" for="filterKabulSonrasi">Kabul Sonrası Ödemiş</label>
                    </div>
                </div>
            </div>
            <!-- Reset Button -->
            <div class="col-lg-2 col-md-3">
                <button class="btn btn-outline-secondary w-100" id="resetFilters">
                    <i class="fas fa-undo me-1"></i>Sıfırla
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Users Table -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Öğrenci Listesi (<span id="visibleCount"><%= users.length %></span> / <%= users.length %>) <span class="ms-3 text-success" style="font-size: 0.85rem;"><i class="fas fa-check-circle me-1"></i>Aktif Öğrenci: <span id="activeCount"><%= typeof activeCount !== 'undefined' ? activeCount : 0 %></span>/<%= users.length %></span></h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Ad Soyad</th>
                                <th>E-posta</th>
                                <th>Telefon</th>
                                <th>İngilizce Seviyesi</th>
                                <th>Aktiflik Durumu</th>
                                <th>Kayıt Tarihi</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                <tbody id="usersTableBody">
                            <% users.forEach(user => { %>
                    <tr class="student-row"
                        data-name="<%= (user.first_name + ' ' + user.last_name).toLowerCase() %>"
                        data-phone="<%= (user.phone || '').toLowerCase() %>"
                        data-email="<%= (user.email || '').toLowerCase() %>"
                        data-tc="<%= user.tc_number || '' %>"
                        data-school="<%= (user.current_school || '').toLowerCase() %>"
                        data-class="<%= user.active_class || '' %>"
                        data-guardians="<%= (user.guardian_names || '').toLowerCase() %>"
                        data-kabul-oncesi="<%= user.kabul_oncesi_paid ? 'true' : 'false' %>"
                        data-kabul-sonrasi="<%= user.kabul_sonrasi_paid ? 'true' : 'false' %>"
                        data-hazirlik="<%= user.hazirlik_paid ? 'true' : 'false' %>"
                        data-active="<%= user.has_any_paid_service ? 'true' : 'false' %>">
                                <td><%= user.id %></td>
                                <td><%= user.first_name %> <%= user.last_name %></td>
                                <td><%= user.email %></td>
                                <td><%= user.phone %></td>
                                <td><span class="badge bg-info"><%= user.english_level %></span></td>
                                <td>
                                    <% if (user.has_any_paid_service) { %>
                                        <span class="badge bg-success">Aktif</span>
                                    <% } else { %>
                                        <span class="badge bg-warning text-dark">Ödeme Bekleniyor</span>
                                    <% } %>
                                </td>
                                <td><%= new Date(user.created_at).toLocaleDateString('tr-TR') %></td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <button class="btn btn-sm btn-outline-info js-view-details" data-user-id="<%= user.id %>">
                                            <i class="fas fa-eye"></i> Detaylar
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger js-delete-user" data-user-id="<%= user.id %>" data-user-name="<%= user.first_name %> <%= user.last_name %>">
                                            <i class="fas fa-trash"></i> Sil
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
        <!-- No results message -->
        <div id="noResultsMsg" class="text-center text-muted py-4" style="display: none;">
            <i class="fas fa-search me-2"></i>Filtrelere uygun öğrenci bulunamadı.
        </div>
    </div>
</div>
    </div> <!-- /.admin-main -->
</div> <!-- /.admin-container -->

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Event delegation for buttons
        document.addEventListener('click', function(e) {
            const detailsBtn = e.target.closest('.js-view-details');
            const deleteBtn = e.target.closest('.js-delete-user');
            
            if (detailsBtn) {
                const userId = detailsBtn.getAttribute('data-user-id');
                viewUserDetails(userId);
            }
            
            if (deleteBtn) {
                const userId = deleteBtn.getAttribute('data-user-id');
                const userName = deleteBtn.getAttribute('data-user-name');
                deleteUser(userId, userName);
            }
        });

        // --- Advanced Filter System ---
        const searchInput = document.getElementById('userSearchInput');
        const classFilter = document.getElementById('classFilter');
        const filterHazirlik = document.getElementById('filterHazirlik');
        const filterKabulOncesi = document.getElementById('filterKabulOncesi');
        const filterKabulSonrasi = document.getElementById('filterKabulSonrasi');
        const resetBtn = document.getElementById('resetFilters');
        const visibleCountEl = document.getElementById('visibleCount');
        const noResultsMsg = document.getElementById('noResultsMsg');
        const allRows = document.querySelectorAll('.student-row');

        function applyFilters() {
            const searchTerm = searchInput.value.toLowerCase().trim();
            const selectedClass = classFilter.value;
            const requireHazirlik = filterHazirlik.checked;
            const requireKabulOncesi = filterKabulOncesi.checked;
            const requireKabulSonrasi = filterKabulSonrasi.checked;

            let visibleCount = 0;

            allRows.forEach(row => {
                let show = true;

                // 1. Text search: name, phone, TC, school, guardians, email
                if (searchTerm) {
                    const name = row.getAttribute('data-name') || '';
                    const phone = row.getAttribute('data-phone') || '';
                    const email = row.getAttribute('data-email') || '';
                    const tc = row.getAttribute('data-tc') || '';
                    const school = row.getAttribute('data-school') || '';
                    const guardians = row.getAttribute('data-guardians') || '';

                    const textMatch = name.includes(searchTerm) ||
                                     phone.includes(searchTerm) ||
                                     email.includes(searchTerm) ||
                                     tc.includes(searchTerm) ||
                                     school.includes(searchTerm) ||
                                     guardians.includes(searchTerm);
                    if (!textMatch) show = false;
                }

                // 2. Class filter
                if (show && selectedClass) {
                    const rowClass = row.getAttribute('data-class') || '';
                    if (rowClass !== selectedClass) show = false;
                }

                // 3. Payment filters (OR logic - show if ANY checked condition matches)
                if (show && (requireHazirlik || requireKabulOncesi || requireKabulSonrasi)) {
                    const hasHazirlik = row.getAttribute('data-hazirlik') === 'true';
                    const hasKabulOncesi = row.getAttribute('data-kabul-oncesi') === 'true';
                    const hasKabulSonrasi = row.getAttribute('data-kabul-sonrasi') === 'true';
                    const matchesAny = (requireHazirlik && hasHazirlik) ||
                                      (requireKabulOncesi && hasKabulOncesi) ||
                                      (requireKabulSonrasi && hasKabulSonrasi);
                    if (!matchesAny) show = false;
                }

                row.style.display = show ? '' : 'none';
                if (show) visibleCount++;
            });

            visibleCountEl.textContent = visibleCount;
            noResultsMsg.style.display = visibleCount === 0 ? '' : 'none';
        }

        // Attach filter events
        searchInput.addEventListener('input', applyFilters);
        classFilter.addEventListener('change', applyFilters);
        filterHazirlik.addEventListener('change', applyFilters);
        filterKabulOncesi.addEventListener('change', applyFilters);
        filterKabulSonrasi.addEventListener('change', applyFilters);

        // Reset all filters
        resetBtn.addEventListener('click', function() {
            searchInput.value = '';
            classFilter.value = '';
            filterHazirlik.checked = false;
            filterKabulOncesi.checked = false;
            filterKabulSonrasi.checked = false;
            applyFilters();
        });
    });

    function viewUserDetails(userId) {
        window.location.href = `/admin/users/${userId}/details`;
    }

    async function deleteUser(userId, userName) {
        if (!confirm(`"${userName}" adlı öğrenciyi silmek istediğinizden emin misiniz?\n\nBu işlem geri alınamaz ve öğrencinin tüm verileri silinecektir.`)) {
            return;
        }

        try {
            const response = await fetch(`/admin/users/${userId}`, {
                method: 'DELETE',
                headers: {
                    'Content-Type': 'application/json',
                },
                credentials: 'include'
            });

            const result = await response.json();

            if (result.success) {
                showAlert('success', result.message);
                // Remove the row from table
                const row = document.querySelector(`[data-user-id="${userId}"]`).closest('tr');
                if (row) {
                    row.remove();
                }
                // Update user count
                const badge = document.querySelector('.badge.bg-primary');
                if (badge) {
                    const currentCount = parseInt(badge.textContent);
                    badge.textContent = currentCount - 1;
                }
            } else {
                showAlert('danger', result.message);
            }
        } catch (error) {
            console.error('Delete user error:', error);
            showAlert('danger', 'Öğrenci silinirken bir hata oluştu.');
        }
    }

    function showAlert(type, message) {
        const alertDiv = document.createElement('div');
        alertDiv.className = `alert alert-${type} alert-dismissible fade show position-fixed`;
        alertDiv.style.top = '20px';
        alertDiv.style.right = '20px';
        alertDiv.style.zIndex = '9999';
        alertDiv.innerHTML = `
            <i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-triangle'} me-2"></i>
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;
        document.body.appendChild(alertDiv);
        
        setTimeout(() => {
            if (alertDiv.parentNode) {
                alertDiv.parentNode.removeChild(alertDiv);
            }
        }, 10000);
    }
</script>
