<!-- Hero Section -->
<body data-page="contact">
<section class="bg-primary text-white py-5">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center">
                <h1 class="display-4 fw-bold"><%= t.contact.hero.title %></h1>
                <p class="lead"><%= t.contact.hero.subtitle %></p>
            </div>
        </div>
    </div>
</section>

<!-- Contact Section -->
<section class="py-5">
    <div class="container">
        <div class="row">
            <!-- Contact Form + WCEP (Sol Taraf) -->
            <div class="col-lg-8 mb-5">
                <!-- Contact Form -->
                <div class="card shadow mb-4 reveal">
                    <div class="card-header">
                        <h3 class="mb-0">
                            <i class="fas fa-envelope me-2"></i>
                            <%= t.contact.form.title %>
                        </h3>
                    </div>
                    <div class="card-body">
                        <form id="contactForm">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="contactFirstName" class="form-label" style="color: black !important;"><%= t.contact.form.firstName %> *</label>
                                    <input type="text" class="form-control" id="contactFirstName" name="firstName" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="contactLastName" class="form-label" style="color: black !important;"><%= t.contact.form.lastName %> *</label>
                                    <input type="text" class="form-control" id="contactLastName" name="lastName" required>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="contactEmail" class="form-label" style="color: black !important;"><%= t.contact.form.email %> *</label>
                                    <input type="email" class="form-control" id="contactEmail" name="email" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="contactPhone" class="form-label" style="color: black !important;"><%= t.contact.form.phone %></label>
                                    <input type="tel" class="form-control" id="contactPhone" name="phone">
                                </div>
                            </div>
                            <div class="mb-3">
                                <label for="contactInquiryType" class="form-label" style="color: black !important;"><%= t.contact.form.inquiryType %> *</label>
                                <select class="form-select" id="contactInquiryType" name="inquiryType" required>
                                    <option value="" selected disabled><%= t.contact.form.selectInquiry %></option>
                                    <option value="university"><%= t.contact.form.inquiryOptions.university %></option>
                                    <option value="language"><%= t.contact.form.inquiryOptions.language %></option>
                                    <option value="visa"><%= t.contact.form.inquiryOptions.visa %></option>
                                    <option value="accommodation"><%= t.contact.form.inquiryOptions.accommodation %></option>
                                    <option value="other"><%= t.contact.form.inquiryOptions.other %></option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label for="contactMessage" class="form-label" style="color: black !important;"><%= t.contact.form.message %> *</label>
                                <textarea class="form-control" id="contactMessage" name="message" rows="5" required placeholder="<%= t.contact.form.messagePlaceholder %>"></textarea>
                            </div>
                            <div class="text-center">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="fas fa-paper-plane me-2"></i>
                                    <%= t.contact.form.sendMessage %>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
                
                <!-- WCEP Tanıtım Kutucuğu (Formun Altında - Dikdörtgen) -->
                <div class="card shadow reveal" style="background: linear-gradient(135deg, #1a365d 0%, #2c5282 100%); border: none; overflow: hidden;">
                    <div class="card-body text-white py-4">
                        <div class="row align-items-center">
                            <!-- Sol: Logo ve Başlık -->
                            <div class="col-md-3 text-center mb-3 mb-md-0">
                                <div class="d-inline-block p-3 rounded-3 mb-3" style="background: white;">
                                    <img src="/images/partners/wcep/channels4_profile.jpg" alt="WCEP" style="height: 70px; border-radius: 8px;">
                                </div>
                                <h5 class="fw-bold mb-0" style="font-size: 1.1rem;">
                                    <%= t.contact.wcep.title %>
                                </h5>
                            </div>
                            
                            <!-- Orta: Avantajlar -->
                            <div class="col-md-5 mb-3 mb-md-0">
                                <p class="mb-3" style="opacity: 0.95;"><%= t.contact.wcep.description %></p>
                                <div class="d-flex align-items-center mb-2">
                                    <span><%= t.contact.wcep.advantage1 %></span>
                                </div>
                                <div class="d-flex align-items-center mb-2">
                                    <span><%= t.contact.wcep.advantage2 %></span>
                                </div>
                                <div class="d-flex align-items-center">
                                    <span><%= t.contact.wcep.advantage3 %></span>
                                </div>
                            </div>
                            
                            <!-- Sağ: Buton -->
                            <div class="col-md-4 d-flex flex-column align-items-center justify-content-center text-center">
                                <a href="/partners/wcep" class="btn w-100 fw-bold py-2" style="background: white; color: #1a365d;">
                                    <%= t.contact.wcep.cta %>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contact Information (Sağ Taraf) -->
            <div class="col-lg-4">
                <div class="card shadow mb-4 reveal">
                    <div class="card-header text-white" style="background: #005A9E;">
                        <h5 class="mb-0">
                            <i class="fas fa-phone me-2"></i>
                            <%= t.contact.info.title %>
                        </h5>
                    </div>
                    <div class="card-body">
                        <p class="mb-2">
                            <i class="fas fa-phone me-2"></i>
                            <strong><%= t.contact.info.phone %>:</strong><br>
                            +90 539 927 30 08 / +420 776 791 541
                        </p>
                        <p class="mb-2">
                            <i class="fas fa-envelope me-2"></i>
                            <strong><%= t.contact.info.email %>:</strong><br>
                            info@vgedu.org
                        </p>
                    </div>
                </div>

                <!-- Google Yorumları -->
                <div class="card shadow mb-4 reveal" style="border: 2px solid #fbbc04; border-radius: 12px; overflow: hidden;">
                    <div style="background: #fff; padding: 14px 18px; border-bottom: 1px solid #f0f0f0;">
                        <h5 class="mb-0" style="font-size: 15px; font-weight: 700; color: #333;">
                            <img src="https://www.google.com/images/branding/googlelogo/2x/googlelogo_color_92x30dp.png" alt="Google" style="height: 16px; vertical-align: middle; margin-right: 6px;">
                            <%= currentLanguage === 'en' ? 'Rate Us on Google' : 'Google\'da Bizi Değerlendirin' %>
                        </h5>
                    </div>
                    <div class="card-body" style="padding: 16px 18px;">
                        <p class="mb-3" style="font-size: 13px; color: #555;">
                            <%= currentLanguage === 'en' ? 'Your reviews help other students find us. Share your experience!' : 'Yorumlarınız diğer öğrencilerin bizi bulmasına yardımcı olur. Deneyiminizi paylaşın!' %>
                        </p>
                        <div class="d-flex flex-column gap-2">
                            <a href="https://g.page/r/CcdwdU_f8l7lEBM/review" target="_blank" rel="noopener noreferrer"
                               class="btn btn-sm w-100 fw-semibold d-flex align-items-center justify-content-center gap-2"
                               style="background: #fbbc04; color: #1a1a1a; border: none; border-radius: 8px; padding: 8px 12px; font-size: 0.8rem; white-space: normal; word-break: break-word;">
                                <i class="fas fa-star" style="flex-shrink:0"></i>
                                <%= currentLanguage === 'en' ? 'Rate VG Danışmanlık (Turkey)' : 'VG Danışmanlık\'ı Değerlendir (Türkiye)' %>
                            </a>
                            <a href="https://g.page/r/CRz-bfL0IjttEBM/review" target="_blank" rel="noopener noreferrer"
                               class="btn btn-sm w-100 fw-semibold d-flex align-items-center justify-content-center gap-2"
                               style="background: #4285f4; color: #fff; border: none; border-radius: 8px; padding: 8px 12px; font-size: 0.8rem; white-space: normal; word-break: break-word;">
                                <i class="fas fa-star" style="flex-shrink:0"></i>
                                <%= currentLanguage === 'en' ? 'Rate VG Danışmanlık (Czechia)' : 'VG Danışmanlık Çekya\'yı Değerlendir' %>
                            </a>
                        </div>
                    </div>
                </div>
                <div class="card shadow mb-4 reveal" style="border: 2px solid #005A9E; border-radius: 12px; overflow: hidden;">
                    <div style="background: linear-gradient(135deg, #005A9E, #003d6b); padding: 14px 18px; color: #fff;">
                        <h5 class="mb-0" style="font-size: 15px; font-weight: 700;">
                            <i class="fas fa-calendar-check me-2"></i><%= currentLanguage === 'en' ? 'Online Appointment' : 'Online Randevu' %>
                        </h5>
                    </div>
                    <div class="card-body text-center" style="padding: 18px;">
                        <p class="mb-3" style="font-size: 13px; color: #555;"><%= currentLanguage === 'en' ? 'Book a video meeting with our expert advisors for personalized guidance.' : 'Uzman danışmanlarımızla görüntülü görüşme için hemen randevu alın.' %></p>
                        <a href="/#randevu" class="btn w-100 fw-bold" style="background: #005A9E; color: white; border-radius: 8px;">
                            <i class="fas fa-calendar-check me-2"></i><%= currentLanguage === 'en' ? 'Book an Appointment' : 'Randevu Al' %>
                        </a>
                    </div>
                </div>
                <div class="card shadow mb-4 reveal">
                    <div class="card-header text-white" style="background: #005A9E;">
                        <h5 class="mb-0">
                            <i class="fas fa-shield-alt me-2"></i>
                            <%= t.contact.security.title %>
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="security-notice">
                            <i class="fas fa-lock"></i>
                            <small><strong><%= t.contact.security.sslTitle %>:</strong> <%= t.contact.security.sslText %></small>
                        </div>
                        <div class="security-notice mt-2">
                            <i class="fas fa-user-shield"></i>
                            <small><strong><%= t.contact.security.privacyTitle %>:</strong> <%= t.contact.security.privacyText %></small>
                        </div>
                    </div>
                </div>
                
            </div>
        </div>
    </div>
</section>

<!-- FAQ Section -->
<section class="py-5">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center mb-5 reveal">
                <h2><%= t.contact.faq.title %></h2>
                <p class="lead"><%= t.contact.faq.subtitle %></p>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-8 mx-auto reveal">
                <div class="accordion" id="faqAccordion">
                    <% if (t.contact.faq.items && t.contact.faq.items.length) { %>
                        <% t.contact.faq.items.forEach(function(item, index) { %>
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="faq<%= index + 1 %>">
                                <button class="accordion-button<%= index === 0 ? '' : ' collapsed' %>" type="button" data-bs-toggle="collapse" data-bs-target="#collapse<%= index + 1 %>" aria-expanded="<%= index === 0 ? 'true' : 'false' %>" aria-controls="collapse<%= index + 1 %>">
                                    <%= item.question %>
                                </button>
                            </h2>
                            <div id="collapse<%= index + 1 %>" class="accordion-collapse collapse<%= index === 0 ? ' show' : '' %>" aria-labelledby="faq<%= index + 1 %>" data-bs-parent="#faqAccordion">
                                <div class="accordion-body">
                                    <%= item.answer %>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
document.getElementById('contactForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    
    // Form validation
    const formData = new FormData(this);
    const data = Object.fromEntries(formData);
    
    // Check required fields
    if (!data.firstName || !data.lastName || !data.email || !data.message) {
        alert('<%= t.contact.form.requiredFields %>');
        return;
    }
    
    // Email validation
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(data.email)) {
        alert('<%= t.contact.form.invalidEmail %>');
        return;
    }
    
    // Submit button state
    const submitBtn = this.querySelector('button[type="submit"]');
    const originalText = submitBtn.innerHTML;
    
    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span><%= t.contact.form.submitting %>';
    submitBtn.disabled = true;
    
    try {
        const response = await fetch('/api/contact', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(data)
        });
        
        const result = await response.json();
        
        if (result.success) {
            alert(result.message);
            this.reset();
        } else {
            alert(result.error || '<%= t.contact.form.error %>');
        }
    } catch (error) {
        alert('<%= t.contact.form.connectionError %>');
    } finally {
        submitBtn.innerHTML = originalText;
        submitBtn.disabled = false;
    }
});
</script>

<script>
(function() {
    var reveals = document.querySelectorAll('.reveal');
    if (!reveals.length) return;
    var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry, i) {
            if (entry.isIntersecting) {
                setTimeout(function() { entry.target.classList.add('visible'); }, i * 80);
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.15 });
    reveals.forEach(function(el) { observer.observe(el); });
})();
</script>

