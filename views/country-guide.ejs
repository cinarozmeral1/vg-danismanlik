                            <div style="width:44px; height:44px; background:linear-gradient(135deg,#0078D7,#00BCF2); border-radius:12px; display:flex; align-items:center; justify-content:center; margin-bottom:14px;">
                                <i class="fas fa-heart" style="color:#fff; font-size:1.1rem;"></i>
                            </div>
                            <h5 style="color:#1a1a2e; font-weight:700; font-size:1rem; margin-bottom:6px;"><%= lang === 'en' ? 'Student Life in ' + countryData.nameEN : countryData.nameTR + '\'da Öğrenci Yaşamı' %></h5>
                            <p style="color:#666; font-size:0.88rem; margin:0;"><%= lang === 'en' ? 'Daily life, accommodation, transport and student culture.' : 'Günlük yaşam, konaklama, ulaşım ve öğrenci kültürü.' %></p>
                        </a>
                    </div>
                    <div class="col-md-4">
                        <a href="/universities?country=<%= encodeURIComponent(countryData.dbCountry) %>" style="display:block; background:#fff; border-radius:14px; padding:24px; text-decoration:none; box-shadow:0 2px 12px rgba(0,0,0,0.06); transition:transform 0.2s, box-shadow 0.2s; height:100%;" onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 6px 20px rgba(0,0,0,0.1)'" onmouseout="this.style.transform='';this.style.boxShadow='0 2px 12px rgba(0,0,0,0.06)'">
                            <div style="width:44px; height:44px; background:linear-gradient(135deg,#0078D7,#00BCF2); border-radius:12px; display:flex; align-items:center; justify-content:center; margin-bottom:14px;">
                                <i class="fas fa-university" style="color:#fff; font-size:1.1rem;"></i>
                            </div>
                            <h5 style="color:#1a1a2e; font-weight:700; font-size:1rem; margin-bottom:6px;"><%= lang === 'en' ? 'Universities in ' + countryData.nameEN : countryData.nameTR + ' Üniversiteleri' %></h5>
                            <p style="color:#666; font-size:0.88rem; margin:0;"><%= lang === 'en' ? 'Browse all partner universities and programs.' : 'Tüm partner üniversiteleri ve programları inceleyin.' %></p>
                        </a>
                    </div>
                    <div class="col-md-4">
                        <a href="/blog" style="display:block; background:#fff; border-radius:14px; padding:24px; text-decoration:none; box-shadow:0 2px 12px rgba(0,0,0,0.06); transition:transform 0.2s, box-shadow 0.2s; height:100%;" onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 6px 20px rgba(0,0,0,0.1)'" onmouseout="this.style.transform='';this.style.boxShadow='0 2px 12px rgba(0,0,0,0.06)'">
                            <div style="width:44px; height:44px; background:linear-gradient(135deg,#0078D7,#00BCF2); border-radius:12px; display:flex; align-items:center; justify-content:center; margin-bottom:14px;">
                                <i class="fas fa-newspaper" style="color:#fff; font-size:1.1rem;"></i>
                            </div>
                            <h5 style="color:#1a1a2e; font-weight:700; font-size:1rem; margin-bottom:6px;"><%= lang === 'en' ? 'Blog Articles' : 'Blog Yazıları' %></h5>
                            <p style="color:#666; font-size:0.88rem; margin:0;"><%= lang === 'en' ? 'Latest articles about studying abroad.' : 'Yurt dışı eğitim hakkında güncel makaleler.' %></p>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="cg-cta">
    <div class="container">
        <h2><%= lang === 'en' ? 'Ready to Study in ' + countryData.nameEN + '?' : countryData.nameTR + '\'da Eğitim Almaya Hazır mısınız?' %></h2>
        <p>
            <%= lang === 'en'
                ? 'Book a free consultation with our expert advisors and start your application process today.'
                : 'Uzman danışmanlarımızla ücretsiz görüşme ayarlayın ve başvuru sürecinizi bugün başlatın.' %>
        </p>
        <div class="d-flex flex-wrap justify-content-center gap-3">
            <a href="/contact" class="btn btn-light btn-lg">
                <i class="fas fa-phone me-2"></i><%= lang === 'en' ? 'Free Consultation' : 'Ücretsiz Danışmanlık' %>
            </a>
            <a href="/#randevu" class="btn btn-outline-light btn-lg">
                <i class="fas fa-calendar-check me-2"></i><%= lang === 'en' ? 'Book Appointment' : 'Randevu Al' %>
            </a>
        </div>
    </div>
</section>

<!-- JSON-LD: BreadcrumbList -->
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {
            "@type": "ListItem",
            "position": 1,
            "name": "<%= lang === 'en' ? 'Home' : 'Ana Sayfa' %>",
            "item": "<%= baseUrl %>"
        },
        {
            "@type": "ListItem",
            "position": 2,
            "name": "<%= lang === 'en' ? 'Universities' : 'Üniversiteler' %>",
            "item": "<%= baseUrl %>/universities"
        },
        {
            "@type": "ListItem",
            "position": 3,
            "name": "<%= countryName %>",
            "item": "<%= pageUrl %>"
        }
    ]
}
</script>

<!-- JSON-LD: FAQPage -->
<% if (guideContent.faq && guideContent.faq.items && guideContent.faq.items.length > 0) { %>
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        <% guideContent.faq.items.forEach(function(item, i) { %><% if (i > 0) { %>,<% } %>
        {
            "@type": "Question",
            "name": "<%- item.q.replace(/"/g, '\\"') %>",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "<%- item.a.replace(/"/g, '\\"') %>"
            }
        }
        <% }); %>
    ]
}
</script>
<% } %>
