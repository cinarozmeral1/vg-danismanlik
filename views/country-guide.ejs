<!-- Education System -->
<section class="cg-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <h2 class="cg-section-title">
                    <i class="fas fa-graduation-cap"></i><%= guideContent.educationSystem.title %>
                </h2>
                <div class="cg-content-block">
                    <%- guideContent.educationSystem.content %>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Why Study Here -->
<section class="cg-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <h2 class="cg-section-title">
                    <i class="fas fa-star"></i><%= guideContent.whyStudy.title %>
                </h2>
                <ul class="cg-reason-list">
                    <% const reasonIcons = ['fa-check-circle','fa-globe','fa-coins','fa-book','fa-users','fa-briefcase','fa-heart','fa-shield-alt','fa-award','fa-lightbulb']; %>
                    <% guideContent.whyStudy.reasons.forEach(function(reason, i) { %>
                    <li class="cg-reason-item">
                        <div class="cg-reason-icon">
                            <i class="fas <%= reasonIcons[i % reasonIcons.length] %>"></i>
                        </div>
                        <span class="cg-reason-text"><%= reason %></span>
                    </li>
                    <% }); %>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- Application Process -->
<section class="cg-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <h2 class="cg-section-title">
                    <i class="fas fa-clipboard-list"></i><%= guideContent.application.title %>
                </h2>
                <div class="cg-steps">
                    <% guideContent.application.steps.forEach(function(step, i) { %>
                    <div class="cg-step">
                        <div class="cg-step-number"><%= i + 1 %></div>
                        <div class="cg-step-text"><%= step %></div>
                    </div>
                    <% }); %>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Visa & Residence Permit -->
<section class="cg-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <h2 class="cg-section-title">
                    <i class="fas fa-passport"></i><%= guideContent.visa.title %>
                </h2>
                <div class="cg-content-block">
                    <%- guideContent.visa.content %>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Partner Universities -->
<% if (universities && universities.length > 0) { %>
<section class="cg-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-11">
                <h2 class="cg-section-title text-center mb-4">
                    <i class="fas fa-university"></i>
                    <%= lang === 'en'
                        ? 'Our Partner Universities in ' + countryData.nameEN
                        : countryData.nameTR + ' Partner Üniversitelerimiz' %>
                </h2>
                <div class="cg-uni-grid">
                    <% universities.forEach(function(uni) { %>
                    <a href="/universities/<%= uni.slug %>" class="cg-uni-card">
                        <% if (uni.logo_url) { %>
                        <img src="<%= uni.logo_url %>" alt="<%= uni.name %>" class="cg-uni-logo" loading="lazy">
                        <% } else { %>
                        <div class="cg-uni-logo-placeholder">
                            <i class="fas fa-university"></i>
                        </div>
                        <% } %>
                        <div class="cg-uni-name"><%= uni.name %></div>
                        <div class="cg-uni-city"><i class="fas fa-map-marker-alt me-1"></i><%= uni.city %></div>
                        <% if (uni.department_count) { %>
                        <span class="cg-uni-dept-badge">
                            <%= uni.department_count %> <%= lang === 'en' ? 'Programs' : 'Program' %>
                        </span>
                        <% } %>
                    </a>
                    <% }); %>
                </div>
                <div class="text-center mt-4">
                    <a href="/universities?country=<%= encodeURIComponent(countryData.dbCountry) %>" class="btn btn-outline-primary btn-lg" style="border-radius: 50px; padding: 12px 36px; font-weight: 600;">
                        <i class="fas fa-search me-2"></i>
                        <%= lang === 'en' ? 'View All Universities' : 'Tüm Üniversiteleri Gör' %>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
<% } else { %>
<!-- Coming Soon — No universities in DB yet -->
<section class="cg-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <div style="background: linear-gradient(135deg, #f8fbff 0%, #e8f1fb 100%); border: 2px dashed #0078D7; border-radius: 24px; padding: 60px 40px; text-align: center; box-shadow: 0 4px 24px rgba(0,120,215,0.08);">
                    <div style="font-size: 4.5rem; margin-bottom: 1rem; line-height: 1;">
                        <span><%= countryData.flag %></span>
                        <i class="fas fa-clock" style="color: #005A9E; font-size: 2.8rem; margin-left: 12px;"></i>
                    </div>
                    <h2 style="font-size: 2rem; font-weight: 800; color: #003d6b; margin-bottom: 0.75rem;">
                        <%= lang === 'en'
                            ? 'Coming Soon — ' + countryData.nameEN + ' University List Is Being Prepared'
                            : 'Yakında — ' + countryData.nameTR + ' Üniversite Listesi Hazırlanıyor' %>
                    </h2>
                    <p style="font-size: 1.1rem; color: #4a5b6e; max-width: 640px; margin: 0 auto 1.5rem;">
                        <%= lang === 'en'
                            ? 'We are finalizing partnerships with top universities in ' + countryData.nameEN + '. In the meantime, our advisors are ready to help you explore study options today.'
                            : countryData.nameTR + '\'daki anlaşmalı üniversitelerimizi yakında burada listeleyeceğiz. O zamana kadar uzman danışmanlarımız ' + countryData.nameTR + ' eğitim seçeneklerinizi sizinle birlikte değerlendirmeye hazır.' %>
                    </p>
                    <div class="d-flex flex-column flex-md-row gap-3 justify-content-center mt-4">
                        <a href="/contact?subject=<%= encodeURIComponent(countryData.nameTR) %>" class="btn btn-primary btn-lg px-4" style="border-radius: 50px; font-weight: 600; background: linear-gradient(135deg, #005A9E 0%, #0078D7 100%); border: 0;">
                            <i class="fas fa-graduation-cap me-2"></i>
                            <%= lang === 'en'
                                ? 'I Want to Study in ' + countryData.nameEN
                                : 'Bu Ülkede Okumak İstiyorum' %>
                        </a>
                        <a href="/#randevu" class="btn btn-outline-primary btn-lg px-4" style="border-radius: 50px; font-weight: 600; border-width: 2px;">
                            <i class="fas fa-calendar-check me-2"></i>
                            <%= lang === 'en' ? 'Book a Free Appointment' : 'Ücretsiz Randevu Al' %>
                        </a>
                    </div>
                    <p style="font-size: 0.875rem; color: #6c8197; margin-top: 1.5rem; margin-bottom: 0;">
                        <i class="fas fa-info-circle me-1"></i>
                        <%= lang === 'en'
                            ? 'Our consultants have direct contacts with leading institutions and can guide you through programs, fees, scholarships and the application process.'
                            : 'Danışmanlarımız önde gelen kurumlarla doğrudan iletişim halindedir; programlar, ücretler, burslar ve başvuru süreci konusunda size rehberlik edebilirler.' %>
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>
<% } %>

<!-- University Departments Table -->
<% if (typeof departments !== 'undefined' && departments && departments.length > 0) { %>
<%
const visibleCount = Math.min(Math.max(Math.ceil(departments.length * 0.1), 4), 6);
const allDepts = departments.slice(0, 80);
const hasMore = allDepts.length > visibleCount;
%>
<section class="cg-section" style="background:#f8f9fa;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-11">
                <h2 class="cg-section-title text-center mb-4">
                    <i class="fas fa-list-alt"></i>
                    <%= lang === 'en'
                        ? 'Available Programs in ' + countryData.nameEN
                        : countryData.nameTR + '\'daki Mevcut Programlar' %>
                </h2>
                <p class="text-center text-muted mb-4"><%= lang === 'en' ? 'Browse all departments and tuition fees at our partner universities.' : 'Partner üniversitelerimizdeki tüm bölümleri ve ücretleri inceleyin.' %></p>
                <div class="table-responsive" style="border-radius:12px; box-shadow:0 2px 14px rgba(0,0,0,0.06); background:#fff; position:relative;" id="deptTableWrap">
                    <table class="table table-hover mb-0" style="font-size:0.92rem;">
                        <thead style="background:#0078D7; color:#fff;">
                            <tr>
                                <th style="padding:14px 16px; font-weight:600;"><%= lang === 'en' ? 'University' : 'Üniversite' %></th>
                                <th style="padding:14px 16px; font-weight:600;"><%= lang === 'en' ? 'Department' : 'Bölüm' %></th>
                                <th style="padding:14px 16px; font-weight:600; text-align:right;"><%= lang === 'en' ? 'Tuition/Year' : 'Yıllık Ücret' %></th>
                            </tr>
                        </thead>
                        <tbody id="deptTableBody">
                            <% allDepts.forEach(function(d, i) { %>
                            <tr class="dept-row" style="<%= i % 2 === 0 ? '' : 'background:#f8f9fa;' %><%= (hasMore && i >= visibleCount) ? 'display:none;' : '' %>">
                                <td style="padding:12px 16px;"><a href="/universities/<%= d.university_slug %>" style="color:#005A9E; text-decoration:none; font-weight:500;"><%= d.university_name %></a></td>
                                <td style="padding:12px 16px;"><%= lang === 'en' ? (d.name_en || d.name_tr) : d.name_tr %></td>
                                <td style="padding:12px 16px; text-align:right; white-space:nowrap;"><%= d.price ? (d.price.toLocaleString() + ' ' + (d.currency || 'EUR')) : (lang === 'en' ? 'Contact us' : 'Bilgi alınız') %></td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                    <% if (hasMore) { %>
                    <div id="deptFade" style="position:absolute; bottom:0; left:0; right:0; height:80px; background:linear-gradient(transparent, #fff); pointer-events:none;"></div>
                    <% } %>
                </div>
                <% if (hasMore) { %>
                <div class="text-center mt-3" id="deptShowMoreWrap">
                    <button onclick="(function(){document.querySelectorAll('.dept-row').forEach(function(r){r.style.display=''});document.getElementById('deptShowMoreWrap').style.display='none';document.getElementById('deptFade').style.display='none';})()" class="btn btn-outline-primary" style="border-radius:50px; padding:10px 32px; font-weight:600;">
                        <i class="fas fa-chevron-down me-2"></i><%= lang === 'en' ? 'Show All ' + allDepts.length + ' Programs' : 'Tüm ' + allDepts.length + ' Programı Göster' %>
                    </button>
                </div>
                <% } %>
            </div>
        </div>
    </div>
</section>
<% } %>

<!-- YouTube Videos -->
<% const ytVideos = typeof countryVideos !== 'undefined' ? countryVideos : []; %>
<% if (ytVideos.length > 0) { %>
<section class="cg-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-11">
                <h2 class="cg-section-title text-center mb-4">
                    <i class="fab fa-youtube" style="color:#FF0000;"></i>
                    <%= lang === 'en'
                        ? 'Videos About Studying in ' + countryData.nameEN
                        : countryData.nameTR + '\'da Eğitim Hakkında Videolar' %>
                </h2>
                <div class="row g-4">
                    <% ytVideos.forEach(function(vid) { %>
                    <div class="col-lg-4 col-md-6">
                        <div style="border-radius:14px; overflow:hidden; box-shadow:0 2px 14px rgba(0,0,0,0.08); background:#000;">
                            <div style="position:relative; padding-bottom:56.25%; height:0;">
                                <iframe src="https://www.youtube-nocookie.com/embed/<%= vid %>" style="position:absolute; top:0; left:0; width:100%; height:100%; border:0; border-radius:14px;" allowfullscreen loading="lazy" title="<%= countryData.nameTR %> Education Video"></iframe>
                            </div>
                        </div>
                    </div>
                    <% }); %>
                </div>
            </div>
        </div>
    </div>
</section>
<% } %>

<!-- Related Blog Posts -->
<% if (blogPosts && blogPosts.length > 0) { %>
<section class="cg-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-11">
                <h2 class="cg-section-title text-center mb-4">
                    <i class="fas fa-newspaper"></i>
                    <%= lang === 'en'
                        ? 'Articles About ' + countryData.nameEN
                        : countryData.nameTR + ' Hakkında Yazılar' %>
                </h2>
                <div class="cg-blog-grid">
                    <% blogPosts.slice(0, 6).forEach(function(post) { %>
                    <a href="/blog/<%= post.slug %>" class="cg-blog-card">
                        <div class="cg-blog-date">
                            <i class="far fa-calendar-alt me-1"></i>
                            <%= new Date(post.published_at).toLocaleDateString(lang === 'en' ? 'en-GB' : 'tr-TR', { day: 'numeric', month: 'long', year: 'numeric' }) %>
                        </div>
                        <div class="cg-blog-title"><%= lang === 'en' ? (post.title_en || post.title_tr) : post.title_tr %></div>
                        <div class="cg-blog-excerpt">
                            <%= (lang === 'en' ? (post.excerpt_en || post.excerpt_tr) : post.excerpt_tr || '').substring(0, 140) %>...
                        </div>
                    </a>
                    <% }); %>
                </div>
            </div>
        </div>
    </div>
</section>
<% } %>

<!-- FAQ -->
<% if (guideContent.faq && guideContent.faq.items && guideContent.faq.items.length > 0) { %>
<section class="cg-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <h2 class="cg-section-title text-center mb-4">
                    <i class="fas fa-question-circle"></i><%= guideContent.faq.title %>
                </h2>
                <div class="cg-faq">
                    <div class="accordion" id="cgFaqAccordion">
                        <% guideContent.faq.items.forEach(function(item, i) { %>
                        <div class="accordion-item">
                            <h3 class="accordion-header" id="cgFaqHead<%= i %>">
                                <button class="accordion-button collapsed" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#cgFaqBody<%= i %>"
                                    aria-expanded="false" aria-controls="cgFaqBody<%= i %>">
                                    <%= item.q %>
                                </button>
                            </h3>
                            <div id="cgFaqBody<%= i %>" class="accordion-collapse collapse"
                                 aria-labelledby="cgFaqHead<%= i %>" data-bs-parent="#cgFaqAccordion">
                                <div class="accordion-body"><%= item.a %></div>
                            </div>
                        </div>
                        <% }); %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<% } %>

<!-- Related Pages / Internal Links -->
<section class="cg-section" style="background:#f0f7ff;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <h2 class="cg-section-title text-center mb-4">
                    <i class="fas fa-compass"></i>
                    <%= lang === 'en' ? 'Explore More About ' + countryData.nameEN : countryData.nameTR + ' Hakkında Daha Fazlası' %>
                </h2>
                <div class="row g-3">
                    <div class="col-md-4">
