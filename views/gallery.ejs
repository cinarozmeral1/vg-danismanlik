<!-- Hero Section -->
<section class="bg-primary text-white py-5">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center">
                <h1 class="display-4 fw-bold">Galeri</h1>
                <p class="lead">Venture Global ailesinden kareler</p>
            </div>
        </div>
    </div>
</section>

<!-- Gallery Content -->
<section class="py-5">
    <div class="container">
        <% if (topics.length === 0) { %>
            <div class="text-center py-5">
                <i class="fas fa-images fa-3x text-muted mb-3"></i>
                <h5 class="text-muted">Galeri yakında güncellenecek</h5>
            </div>
        <% } else { %>
            <% topics.forEach(function(topic, topicIndex) { %>
                <div class="mb-5">
                    <div class="text-center mb-4">
                        <h2 class="fw-bold text-primary"><%= topic.title %></h2>
                        <hr style="width: 80px; border-top: 3px solid #2980b9; margin: 10px auto;">
                    </div>
                    
                    <% if (imagesByTopic[topic.id] && imagesByTopic[topic.id].length > 0) { %>
                        <div class="gallery-masonry">
                            <% imagesByTopic[topic.id].forEach(function(img, imgIndex) { %>
                                <div class="gallery-item">
                                    <img src="<%= img.image_url %>" 
                                         alt="<%= img.caption || topic.title %>" 
                                         loading="lazy">
                                    <% if (img.caption) { %>
                                        <div class="gallery-caption"><%= img.caption %></div>
                                    <% } %>
                                </div>
                            <% }); %>
                        </div>
                    <% } %>
                </div>
            <% }); %>
        <% } %>
    </div>
</section>

<!-- Lightbox Modal -->
<div class="modal fade" id="lightboxModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content" style="background: transparent; border: none;">
            <div class="modal-body p-0 text-center position-relative">
                <button type="button" class="btn-close btn-close-white position-absolute" 
                        data-bs-dismiss="modal" aria-label="Close" 
                        style="top: 10px; right: 10px; z-index: 10; background-color: rgba(0,0,0,0.5); border-radius: 50%; padding: 10px;"></button>
                <img id="lightboxImage" src="" alt="" 
                     class="img-fluid rounded" style="max-height: 85vh; width: auto;">
                <p id="lightboxCaption" class="text-white mt-2" style="text-shadow: 1px 1px 3px rgba(0,0,0,0.7);"></p>
            </div>
        </div>
    </div>
</div>

<style>
.gallery-masonry {
    position: relative;
    width: 100%;
}
.gallery-item {
    position: absolute;
    border-radius: 10px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}
.gallery-item img {
    width: 100%;
    height: auto;
    display: block;
}
.gallery-caption {
    padding: 10px 14px;
    font-size: 0.88rem;
    color: #555;
    background: #f8f9fa;
    border-top: 1px solid #eee;
    text-align: center;
    line-height: 1.4;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const gap = 16;
    
    function layoutMasonry(container) {
        const items = Array.from(container.querySelectorAll('.gallery-item'));
        if (items.length === 0) return;
        
        const containerWidth = container.offsetWidth;
        let cols = 3;
        if (containerWidth < 576) cols = 1;
        else if (containerWidth < 992) cols = 2;
        
        const colWidth = (containerWidth - gap * (cols - 1)) / cols;
        const colHeights = new Array(cols).fill(0);
        
        items.forEach(item => {
            item.style.width = colWidth + 'px';
            item.style.visibility = 'hidden';
            item.style.position = 'absolute';
        });
        
        // Wait for images to have dimensions
        const images = items.map(item => item.querySelector('img'));
        const promises = images.map(img => {
            if (img && img.complete) return Promise.resolve();
            return new Promise(resolve => {
                if (!img) return resolve();
                img.onload = resolve;
                img.onerror = resolve;
            });
        });
        
        Promise.all(promises).then(() => {
            items.forEach(item => {
                const shortest = colHeights.indexOf(Math.min(...colHeights));
                const x = shortest * (colWidth + gap);
                const y = colHeights[shortest];
                
                item.style.left = x + 'px';
                item.style.top = y + 'px';
                item.style.visibility = 'visible';
                
                colHeights[shortest] += item.offsetHeight + gap;
            });
            
            container.style.height = Math.max(...colHeights) + 'px';
        });
    }
    
    function layoutAll() {
        document.querySelectorAll('.gallery-masonry').forEach(layoutMasonry);
    }
    
    layoutAll();
    window.addEventListener('resize', layoutAll);
});
</script>
