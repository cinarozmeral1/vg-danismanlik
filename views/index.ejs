            .stats-counter-container {
                display: grid !important;
                grid-template-columns: repeat(2, 1fr);
                gap: 1rem;
                justify-items: center;
            }
            
            /* Son tek eleman (Memnuniyet) tam genişlikte ve ortalı */
            .stat-counter:last-child:nth-child(odd) {
                grid-column: 1 / -1;
                justify-self: center;
            }
            
