<script>
(function() {
    var video = document.getElementById('heroVideo');
    var playBtn = document.getElementById('heroPlayBtn');
    var playIcon = document.getElementById('heroPlayIcon');
    var textContainer = document.getElementById('heroTextContainer');
    if (!video || !playBtn) return;

    var watching = false;
    var playing = false;

    function tryPlay() {
        if (playing) return;
        video.muted = true;
        video.play().then(function() { playing = true; clearInterval(ri); }).catch(function() {});
    }

    var ri = setInterval(tryPlay, 500);

    video.addEventListener('loadeddata', tryPlay);
    video.addEventListener('canplay', tryPlay);
    video.addEventListener('canplaythrough', tryPlay);
    video.addEventListener('playing', function() { playing = true; clearInterval(ri); });
    tryPlay();

    playBtn.addEventListener('click', function() {
        if (!watching) {
            watching = true;
            playBtn.classList.add('active');
            playIcon.className = 'fas fa-eye-slash';
            textContainer.classList.add('faded');
            video.classList.add('bright');
        } else {
            watching = false;
            playBtn.classList.remove('active');
            playIcon.className = 'fas fa-play';
            textContainer.classList.remove('faded');
            video.classList.remove('bright');
        }
    });
})();
</script>

<script>
(function() {
    var reveals = document.querySelectorAll('.reveal');
    if (!reveals.length) return;
    var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry, i) {
            if (entry.isIntersecting) {
                setTimeout(function() { entry.target.classList.add('visible'); }, i * 80);
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.15 });
    reveals.forEach(function(el) { observer.observe(el); });
})();
</script> 