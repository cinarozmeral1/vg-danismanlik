<style>
/* === HERO VIDEO BACKGROUND === */
.hero-bg-video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.75);
    z-index: 2;
    transition: filter 0.8s ease;
}

.hero-bg-video::-webkit-media-controls {
    display: none !important;
}
.hero-bg-video::-webkit-media-controls-start-playback-button {
    display: none !important;
    -webkit-appearance: none;
}
.hero-bg-video::-webkit-media-controls-play-button {
    display: none !important;
    -webkit-appearance: none;
}
.hero-bg-video::-webkit-media-controls-overlay-play-button {
    display: none !important;
    -webkit-appearance: none;
}

.hero-bg-video.bright {
    filter: brightness(0.95);
}

/* === HERO TEXT === */
.hero-text-container {
    position: absolute;
    bottom: 3%;
    left: 120px;
    z-index: 10;
    text-align: left;
    max-width: 700px;
    transition: opacity 0.8s ease;
}

.hero-text-container.faded {
    opacity: 0.08;
}

.hero-text-container.faded .hero-main-title {
    pointer-events: none;
}

.hero-text-container.faded .hero-play-btn {
    opacity: 1;
    pointer-events: auto;
}

.hero-main-title {
    font-size: 2.2rem;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.35;
    margin: 0;
    text-shadow: 2px 2px 8px rgba(0,0,0,0.7), 0 0 30px rgba(0,0,0,0.5);
}

.hero-main-title span {
    color: #ffffff;
}

/* === PLAY BUTTON === */
.hero-play-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.8);
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(4px);
    color: #fff;
    font-size: 16px;
    cursor: pointer;
    margin-top: 20px;
    transition: all 0.3s ease;
    animation: heroPulse 2.5s ease-in-out infinite;
}

.hero-play-btn:hover {
    background: rgba(255,255,255,0.3);
    border-color: #fff;
    transform: scale(1.1);
}

.hero-play-btn.active {
    animation: none;
    background: rgba(255,255,255,0.25);
}

.hero-play-btn i {
    padding-left: 3px;
}

@keyframes heroPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(255,255,255,0.4); }
    50% { box-shadow: 0 0 0 12px rgba(255,255,255,0); }
}

/* === MOBILE === */
@media (max-width: 991px) {
    .main-hero {
        min-height: 60vh;
    }
    .hero-text-container {
        position: absolute;
        top: auto;
