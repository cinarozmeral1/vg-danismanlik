            <script>
            function smoothScrollTo(id) {
                var el = document.getElementById(id);
                if (!el) return;
                var navH = document.querySelector('nav, .navbar');
                var offset = navH ? navH.offsetHeight + 20 : 80;
                var targetY = el.getBoundingClientRect().top + window.pageYOffset - offset;
                var startY = window.pageYOffset;
                var diff = targetY - startY;
                var duration = Math.min(Math.max(Math.abs(diff) * 0.8, 800), 2000);
                var start = null;
                function step(ts) {
                    if (!start) start = ts;
                    var t = Math.min((ts - start) / duration, 1);
                    var ease = t < 0.5 ? 4*t*t*t : 1 - Math.pow(-2*t+2,3)/2;
                    window.scrollTo(0, startY + diff * ease);
                    if (t < 1) requestAnimationFrame(step);
                }
                requestAnimationFrame(step);
            }
            </script>
