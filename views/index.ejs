<!-- Hero Section -->
<section class="hero-section text-white main-hero">
    <!-- Background Images -->
    <div class="hero-background">
        <img src="/images/backgrounds/campus-location-hero.jpg" class="hero-bg-img active" alt="Campus Hero">
        <img src="/images/backgrounds/campus-glasgow.jpg" class="hero-bg-img" alt="Glasgow University">
        <img src="/images/backgrounds/photo-1568792923760-d70635a89fdc.jpg" class="hero-bg-img" alt="Campus 3">
        <img src="/images/backgrounds/cambridge.jpg" class="hero-bg-img" alt="Cambridge">
        <img src="/images/backgrounds/photo-1618255630366-f402c45736f6.jpg" class="hero-bg-img" alt="Kampüs 4">
        <img src="/images/backgrounds/photo-1564910443496-5fd2d76b47fa.jpg" class="hero-bg-img" alt="Kampüs 6">
        <img src="/images/backgrounds/photo-1583373834259-46cc92173cb7.jpg" class="hero-bg-img" alt="Kampüs 7">
        <img src="/images/backgrounds/photo-1606761568499-6d2451b23c66.jpg" class="hero-bg-img" alt="Kampüs 8">
        <img src="/images/backgrounds/photo-1607013407627-6ee814329547.jpg" class="hero-bg-img" alt="Kampüs 9">
    </div>
    
    <div class="container position-relative" style="z-index: 3;">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <div class="hero-content">
                    <h1 class="hero-title">
                        <%= t.home.hero.title %><br>
                        <span style="color: #ffffff;"><%= t.home.hero.subtitle %></span>
                    </h1>
                    <p class="hero-subtitle">
                        <%= t.home.hero.description %>
                    </p>
                    <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
                        
                    </div>
                    <div class="hero-stats">
                        <div class="stat-item">
                            <h3>7</h3>
                            <p><%= t.home.stats.countries %></p>
                        </div>
                        <div class="stat-item">
                            <h3>50+</h3>
                            <p><%= t.home.stats.universities %></p>
                        </div>
                        <div class="stat-item">
                            <h3>%98</h3>
                            <p><%= t.home.stats.satisfaction %></p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="text-center">
                    <div class="position-relative">
                        <!-- Ana sayfadaki büyük logo görselini kaldır -->
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="section bg-light text-dark">
    <div class="container">
        <div class="section-title">
            <h2 class="text-black"><%= t.home.features.title %></h2>
            <p><%= t.home.features.subtitle %></p>
        </div>
        <% if (Array.isArray(t.home.features.body)) { %>
            <div class="row justify-content-center mb-4 features-description">
                <div class="col-lg-10">
                    <% t.home.features.body.forEach(function (paragraph) { %>
                        <p class="features-description-text mb-4"><%= paragraph %></p>
                    <% }) %>
                </div>
            </div>
        <% } %>
        <div class="row g-4">
            <div class="col-lg-3 col-md-6">
                <div class="feature-card h-100 text-center">
                    <div class="feature-icon bg-primary text-white">
                        <i class="fas fa-globe-europe"></i>
                    </div>
                    <h5><%= t.home.features.network.title %></h5>
                    <p><%= t.home.features.network.description %></p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="feature-card h-100 text-center">
                    <div class="feature-icon bg-success text-white">
                        <i class="fas fa-headset"></i>
                    </div>
                    <h5><%= t.home.features.support.title %></h5>
                    <p><%= t.home.features.support.description %></p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="feature-card h-100 text-center">
                    <div class="feature-icon bg-info text-white">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <h5><%= t.home.features.security.title %></h5>
                    <p><%= t.home.features.security.description %></p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="feature-card h-100 text-center">
                    <div class="feature-icon bg-warning text-white">
                        <i class="fas fa-hands-helping"></i>
                    </div>
                    <h5><%= t.home.features.integration?.title || 'Mentorluk ve Uyum' %></h5>
                    <p><%= t.home.features.integration?.description || 'Vize, konaklama ve Avrupa yaşamına uyum sürecinde kapsamlı destek' %></p>
                </div>
            </div>
        </div>
    </div>
</section>

