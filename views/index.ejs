<!-- Appointment Booking Section -->
<section class="section py-5" style="background: #fff8f1; scroll-margin-top: 90px;" id="randevu">
    <div class="container">
        <div class="text-center mb-4 reveal">
            <h2 class="fw-bold mb-2" style="color: #005A9E;">
                <%= currentLanguage === 'en' ? 'Schedule a Free Interview' : 'Ücretsiz Mülakat Planla' %>
            </h2>
            <p class="text-muted mb-0" style="max-width: 650px; margin: 0 auto; line-height: 1.7;">
                <%= currentLanguage === 'en'
                    ? 'Take the first step towards your education abroad. Schedule a free 30-minute interview with our expert advisors to explore your options and build a personalized roadmap.'
                    : 'Yurt dışı eğitim yolculuğunuzda ilk adımı atın. Uzman danışmanlarımızla 30 dakikalık ücretsiz mülakatınızı planlayarak size özel bir yol haritası oluşturun ve tüm seçeneklerinizi keşfedin.' %>
            </p>
            <div class="mt-3" style="max-width: 520px; margin: 0 auto;">
                <div style="background: #e8f4fd; border: 1px solid #b6d4fe; border-radius: 10px; padding: 10px 16px; font-size: 13px; color: #084298; display: flex; align-items: center; gap: 8px;">
                    <i class="fas fa-user-check" style="font-size: 15px;"></i>
                    <span><%= currentLanguage === 'en'
                        ? 'VG registered students can book instantly by logging in — no forms needed.'
                        : 'VG Danışmanlık kayıtlı öğrencileri giriş yaparak form doldurmadan hızlıca randevu alabilir.' %></span>
                </div>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="card border-0 shadow-sm" style="border-radius: 16px; overflow: hidden;">

                    <!-- Step Indicator -->
                    <div style="background: #005A9E; padding: 16px 24px;" class="d-flex align-items-center justify-content-center gap-3 flex-wrap">
                        <div class="booking-step active" data-step="1">
                            <span class="step-num">1</span>
                            <span class="step-label"><%= currentLanguage === 'en' ? 'Date' : 'Tarih' %></span>
                        </div>
                        <div class="step-divider"></div>
                        <div class="booking-step" data-step="2">
                            <span class="step-num">2</span>
                            <span class="step-label"><%= currentLanguage === 'en' ? 'Time' : 'Saat' %></span>
                        </div>
                        <div class="step-divider"></div>
                        <div class="booking-step" data-step="3">
                            <span class="step-num">3</span>
                            <span class="step-label"><%= currentLanguage === 'en' ? 'Info' : 'Bilgiler' %></span>
                        </div>
                        <div class="step-divider"></div>
                        <div class="booking-step" data-step="4">
                            <span class="step-num">4</span>
                            <span class="step-label"><%= currentLanguage === 'en' ? 'Verify' : 'Doğrula' %></span>
                        </div>
                    </div>

                    <div class="card-body p-4">

                        <% if (typeof isLoggedIn !== 'undefined' && isLoggedIn && !isAdmin) { %>
                        <div class="alert alert-info mb-3 d-flex align-items-center" style="border-radius: 10px; background: #e8f4fd; border: 1px solid #b6d4fe; font-size: 14px;">
                            <i class="fas fa-bolt text-primary me-2"></i>
                            <span><strong><%= currentUser.first_name %></strong>, kayıtlı öğrenci olarak form doldurmadan hızlıca randevu alabilirsiniz.</span>
                        </div>
                        <% } %>

                        <!-- Step 1: Calendar -->
                        <div id="bookingStep1" class="booking-panel">
                            <div id="bookingCalendar" class="mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <button class="btn btn-sm" style="color: #005A9E;" onclick="changeMonth(-1)" id="prevMonthBtn"><i class="fas fa-chevron-left"></i></button>
                                    <h5 class="mb-0 fw-bold" id="calendarMonthLabel" style="color: #1a1a1a;"></h5>
                                    <button class="btn btn-sm" style="color: #005A9E;" onclick="changeMonth(1)" id="nextMonthBtn"><i class="fas fa-chevron-right"></i></button>
                                </div>
                                <div class="booking-calendar-grid">
                                    <div class="cal-header"><%= currentLanguage === 'en' ? 'Mon' : 'Pzt' %></div>
                                    <div class="cal-header"><%= currentLanguage === 'en' ? 'Tue' : 'Sal' %></div>
                                    <div class="cal-header"><%= currentLanguage === 'en' ? 'Wed' : 'Çar' %></div>
                                    <div class="cal-header"><%= currentLanguage === 'en' ? 'Thu' : 'Per' %></div>
                                    <div class="cal-header"><%= currentLanguage === 'en' ? 'Fri' : 'Cum' %></div>
                                    <div class="cal-header"><%= currentLanguage === 'en' ? 'Sat' : 'Cmt' %></div>
                                    <div class="cal-header"><%= currentLanguage === 'en' ? 'Sun' : 'Paz' %></div>
                                </div>
                                <div id="calendarDays" class="booking-calendar-grid"></div>
                            </div>
                            <div class="text-center mt-2">
                                <small class="text-muted"><i class="fas fa-clock me-1"></i><%= currentLanguage === 'en' ? 'Times shown in Turkey time (TSİ)' : 'Saatler Türkiye saatine (TSİ) göredir' %></small>
                            </div>
                        </div>

                        <!-- Step 2: Time Slots -->
                        <div id="bookingStep2" class="booking-panel d-none">
                            <div class="text-center mb-3">
                                <p class="mb-1 text-muted"><%= currentLanguage === 'en' ? 'Selected Date' : 'Seçilen Tarih' %></p>
                                <h5 class="fw-bold" id="selectedDateLabel" style="color: #005A9E;"></h5>
                            </div>
                            <div id="timeSlotsContainer" class="row g-2 justify-content-center"></div>
                            <div class="text-center mt-3">
                                <button class="btn btn-outline-secondary btn-sm" onclick="goToStep(1)"><i class="fas fa-arrow-left me-1"></i><%= currentLanguage === 'en' ? 'Back' : 'Geri' %></button>
                            </div>
                        </div>

                        <!-- Step 3: Form -->
                        <div id="bookingStep3" class="booking-panel d-none">
                            <div class="text-center mb-3">
                                <span class="badge" style="background: #005A9E; font-size: 13px; padding: 8px 16px;" id="selectedDateTimeBadge"></span>
                            </div>
                            <form id="bookingForm" onsubmit="return false;">
                                <input type="text" name="website_url" style="display:none;" tabindex="-1" autocomplete="off">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label fw-semibold"><%= currentLanguage === 'en' ? 'Full Name' : 'Ad Soyad' %> *</label>
                                        <input type="text" class="form-control" id="bkFullName" required placeholder="<%= currentLanguage === 'en' ? 'John Doe' : 'Adınız Soyadınız' %>">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-semibold">WhatsApp *</label>
                                        <div class="input-group">
                                            <select id="bkCountryCode" class="form-select" style="max-width: 110px; background: #e9ecef; font-weight: 600; color: #005A9E; border-right: none;">
                                                <option value="+90" selected>+90</option>
                                                <option value="+1">+1</option>
                                                <option value="+44">+44</option>
                                                <option value="+49">+49</option>
                                                <option value="+43">+43</option>
                                                <option value="+39">+39</option>
                                                <option value="+420">+420</option>
                                                <option value="+48">+48</option>
                                                <option value="+36">+36</option>
                                                <option value="+31">+31</option>
                                                <option value="+33">+33</option>
                                                <option value="+34">+34</option>
                                            </select>
                                            <input type="tel" class="form-control" id="bkPhone" required placeholder="5XX XXX XX XX" maxlength="13" style="border-left: none;">
                                        </div>
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label fw-semibold"><%= currentLanguage === 'en' ? 'Email' : 'E-posta' %> *</label>
                                        <input type="email" class="form-control" id="bkEmail" required placeholder="ornek@mail.com">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-semibold"><%= currentLanguage === 'en' ? 'Target Country' : 'Hedef Ülke' %> *</label>
                                        <select class="form-select" id="bkCountry" required>
                                            <option value=""><%= currentLanguage === 'en' ? 'Select...' : 'Seçiniz...' %></option>
                                            <option value="Almanya">Almanya</option>
                                            <option value="Çekya">Çekya</option>
                                            <option value="İtalya">İtalya</option>
                                            <option value="İngiltere">İngiltere</option>
                                            <option value="Macaristan">Macaristan</option>
                                            <option value="Polonya">Polonya</option>
                                            <option value="Avusturya">Avusturya</option>
                                            <option value="Hollanda">Hollanda</option>
                                            <option value="İspanya">İspanya</option>
                                            <option value="Fransa">Fransa</option>
                                            <option value="Henüz Karar Vermedim"><%= currentLanguage === 'en' ? 'Not Decided Yet' : 'Henüz Karar Vermedim' %></option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-semibold"><%= currentLanguage === 'en' ? 'Field of Interest' : 'İlgilendiğiniz Alan' %> *</label>
                                        <select class="form-select" id="bkField" required>
                                            <option value=""><%= currentLanguage === 'en' ? 'Select...' : 'Seçiniz...' %></option>
                                            <option value="Tıp"><%= currentLanguage === 'en' ? 'Medicine' : 'Tıp' %></option>
                                            <option value="Diş Hekimliği"><%= currentLanguage === 'en' ? 'Dentistry' : 'Diş Hekimliği' %></option>
                                            <option value="Mühendislik"><%= currentLanguage === 'en' ? 'Engineering' : 'Mühendislik' %></option>
                                            <option value="İşletme/Ekonomi"><%= currentLanguage === 'en' ? 'Business/Economics' : 'İşletme/Ekonomi' %></option>
                                            <option value="Hukuk"><%= currentLanguage === 'en' ? 'Law' : 'Hukuk' %></option>
                                            <option value="Mimarlık/Tasarım"><%= currentLanguage === 'en' ? 'Architecture/Design' : 'Mimarlık/Tasarım' %></option>
                                            <option value="Bilgisayar Bilimleri"><%= currentLanguage === 'en' ? 'Computer Science' : 'Bilgisayar Bilimleri' %></option>
                                            <option value="Diğer"><%= currentLanguage === 'en' ? 'Other' : 'Diğer' %></option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-semibold"><%= currentLanguage === 'en' ? 'Education Level' : 'Eğitim Seviyesi' %> *</label>
                                        <select class="form-select" id="bkEducation" required onchange="toggleGradeField()">
                                            <option value=""><%= currentLanguage === 'en' ? 'Select...' : 'Seçiniz...' %></option>
                                            <option value="Lise Öğrencisi"><%= currentLanguage === 'en' ? 'High School Student' : 'Lise Öğrencisi' %></option>
                                            <option value="Lise Mezunu"><%= currentLanguage === 'en' ? 'High School Graduate' : 'Lise Mezunu' %></option>
                                            <option value="Üniversite Öğrencisi/Mezunu"><%= currentLanguage === 'en' ? 'University Student/Graduate' : 'Üniversite Öğrencisi/Mezunu' %></option>
                                        </select>
                                    </div>
                                    <div class="col-md-6 d-none" id="gradeField">
                                        <label class="form-label fw-semibold"><%= currentLanguage === 'en' ? 'Grade' : 'Sınıf' %></label>
                                        <select class="form-select" id="bkGrade">
                                            <option value="">-</option>
                                            <option value="11">11</option>
                                            <option value="12">12</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-semibold"><%= currentLanguage === 'en' ? 'Budget Range' : 'Bütçe Aralığı' %> <small class="text-muted">(<%= currentLanguage === 'en' ? 'optional' : 'opsiyonel' %>)</small></label>
                                        <select class="form-select" id="bkBudget">
                                            <option value="">-</option>
                                            <option value="0-5.000€">0 - 5.000€</option>
                                            <option value="5.000-10.000€">5.000 - 10.000€</option>
                                            <option value="10.000-20.000€">10.000 - 20.000€</option>
                                            <option value="20.000€+">20.000€+</option>
                                            <option value="Burs Arıyorum"><%= currentLanguage === 'en' ? 'Looking for Scholarship' : 'Burs Arıyorum' %></option>
                                        </select>
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label fw-semibold"><%= currentLanguage === 'en' ? 'Notes' : 'Not/Mesaj' %> <small class="text-muted">(<%= currentLanguage === 'en' ? 'optional' : 'opsiyonel' %>)</small></label>
                                        <textarea class="form-control" id="bkNotes" rows="2" placeholder="<%= currentLanguage === 'en' ? 'Anything you want to share...' : 'Eklemek istediğiniz bir şey varsa...' %>"></textarea>
                                    </div>
                                </div>
                                <div class="text-center mt-4 d-flex justify-content-center gap-2">
                                    <button class="btn btn-outline-secondary" onclick="goToStep(2)"><i class="fas fa-arrow-left me-1"></i><%= currentLanguage === 'en' ? 'Back' : 'Geri' %></button>
                                    <button class="btn text-white px-4" style="background: #005A9E;" onclick="submitFormAndVerify()"><%= currentLanguage === 'en' ? 'Verify Email' : 'E-postayı Doğrula' %> <i class="fas fa-arrow-right ms-1"></i></button>
                                </div>
                            </form>
                        </div>

                        <!-- Step 4: Verification -->
                        <div id="bookingStep4" class="booking-panel d-none">
                            <div class="text-center">
                                <div style="width: 64px; height: 64px; background: #f0f7ff; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 16px;">
                                    <i class="fas fa-envelope" style="font-size: 28px; color: #005A9E;"></i>
                                </div>
                                <h5 class="fw-bold mb-2"><%= currentLanguage === 'en' ? 'Enter Verification Code' : 'Doğrulama Kodunu Girin' %></h5>
                                <p class="text-muted mb-3" id="verificationEmailHint"></p>
                                <div style="max-width: 300px; margin: 0 auto;">
                                    <input type="text" class="form-control form-control-lg text-center" id="bkVerifyCode" maxlength="6" placeholder="______" style="letter-spacing: 8px; font-size: 24px; font-weight: 700;">
                                </div>
                                <div class="mt-3 d-flex justify-content-center gap-2">
                                    <button class="btn btn-outline-secondary btn-sm" onclick="goToStep(3)"><i class="fas fa-arrow-left me-1"></i><%= currentLanguage === 'en' ? 'Back' : 'Geri' %></button>
                                    <button class="btn text-white px-4" style="background: #005A9E;" onclick="verifyAndBook()" id="verifyBookBtn"><%= currentLanguage === 'en' ? 'Confirm Appointment' : 'Randevuyu Onayla' %></button>
                                </div>
                                <p class="mt-2 mb-0"><small class="text-muted" id="resendCodeLink" style="cursor:pointer; display:none;" onclick="resendCode()"><%= currentLanguage === 'en' ? 'Resend code' : 'Kodu tekrar gönder' %></small></p>
                            </div>
                        </div>

                        <!-- Step Fast: Quick confirm for logged-in students -->
                        <div id="bookingStepFast" class="booking-panel d-none">
                            <div class="text-center py-3">
                                <div style="width: 64px; height: 64px; background: #e8f4fd; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 16px;">
                                    <i class="fas fa-bolt" style="font-size: 28px; color: #005A9E;"></i>
                                </div>
                                <h5 class="fw-bold mb-3">Randevunuzu Onaylayın</h5>
                                <div class="card mx-auto" style="max-width: 360px; border-radius: 12px; border: 2px solid #005A9E;">
                                    <div class="card-body p-3">
                                        <p class="mb-2"><strong><i class="fas fa-user me-1"></i></strong> <span id="fastConfirmName"></span></p>
                                        <p class="mb-2"><strong><i class="fas fa-envelope me-1"></i></strong> <span id="fastConfirmEmail"></span></p>
                                        <p class="mb-0"><strong><i class="fas fa-calendar me-1"></i></strong> <span id="fastConfirmDateTime"></span></p>
                                    </div>
                                </div>
                                <div class="mt-3 d-flex justify-content-center gap-2">
                                    <button class="btn btn-outline-secondary btn-sm" onclick="goToStep(2)"><i class="fas fa-arrow-left me-1"></i>Geri</button>
                                    <button class="btn text-white px-4" style="background: #005A9E;" onclick="fastBookConfirm()" id="fastBookBtn">
                                        <i class="fas fa-check me-1"></i>Randevuyu Onayla
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Success -->
                        <div id="bookingSuccess" class="booking-panel d-none">
                            <div class="text-center py-4">
                                <div style="width: 80px; height: 80px; background: #ecfdf5; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 16px;">
                                    <i class="fas fa-check" style="font-size: 36px; color: #059669;"></i>
                                </div>
                                <h4 class="fw-bold mb-2" style="color: #059669;"><%= currentLanguage === 'en' ? 'Appointment Confirmed!' : 'Randevunuz Onaylandı!' %></h4>
                                <p class="text-muted mb-3" id="successDetails"></p>
                                <p class="mb-0"><small class="text-muted"><%= currentLanguage === 'en' ? 'You will receive a confirmation email shortly.' : 'Kısa süre içinde onay e-postanız gelecektir.' %></small></p>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
.booking-step{display:flex;align-items:center;gap:8px;opacity:0.5;transition:opacity .3s}
.booking-step.active{opacity:1}
.booking-step.done{opacity:0.8}
.step-num{width:28px;height:28px;border-radius:50%;background:rgba(255,255,255,0.2);color:#fff;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700}
.booking-step.active .step-num{background:#fff;color:#005A9E}
.booking-step.done .step-num{background:#059669;color:#fff}
.step-label{color:#fff;font-size:13px;font-weight:500}
.step-divider{width:30px;height:2px;background:rgba(255,255,255,0.3);border-radius:1px}
.booking-calendar-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;text-align:center}
.cal-header{padding:8px 0;font-size:12px;font-weight:600;color:#6b7280}
.cal-day{padding:10px 0;border-radius:10px;font-size:14px;cursor:pointer;transition:all .2s;border:none;background:transparent;width:100%;color:#1a1a1a}
.cal-day:hover:not(.disabled):not(.empty){background:#e0efff}
.cal-day.available{font-weight:600;color:#005A9E}
.cal-day.selected{background:#005A9E!important;color:#fff!important;font-weight:700}
.cal-day.disabled{color:#d1d5db;cursor:default}
.cal-day.today{border:2px solid #005A9E}
.cal-day.empty{cursor:default}
.time-slot-btn{border:2px solid #e5e7eb;border-radius:12px;padding:14px 20px;background:#fff;cursor:pointer;transition:all .2s;text-align:center;width:100%}
.time-slot-btn:hover{border-color:#005A9E;background:#f0f7ff}
.time-slot-btn.selected{border-color:#005A9E;background:#005A9E;color:#fff}
.time-slot-btn .slot-time{font-size:18px;font-weight:700}
.time-slot-btn .slot-label{font-size:11px;opacity:0.7}
.booking-panel{min-height:200px}
@media(max-width:576px){.step-label{display:none}.step-divider{width:16px}.booking-calendar-grid{gap:2px}.cal-day{padding:8px 0;font-size:13px}}
</style>

<script>
(function(){
    let availableDates = [];
    let currentMonth = new Date();
    let selectedDate = null;
    let selectedSlot = null;

    currentMonth.setDate(1);

    const months = ['<%= currentLanguage === "en" ? "January" : "Ocak" %>','<%= currentLanguage === "en" ? "February" : "Şubat" %>','<%= currentLanguage === "en" ? "March" : "Mart" %>','<%= currentLanguage === "en" ? "April" : "Nisan" %>','<%= currentLanguage === "en" ? "May" : "Mayıs" %>','<%= currentLanguage === "en" ? "June" : "Haziran" %>','<%= currentLanguage === "en" ? "July" : "Temmuz" %>','<%= currentLanguage === "en" ? "August" : "Ağustos" %>','<%= currentLanguage === "en" ? "September" : "Eylül" %>','<%= currentLanguage === "en" ? "October" : "Ekim" %>','<%= currentLanguage === "en" ? "November" : "Kasım" %>','<%= currentLanguage === "en" ? "December" : "Aralık" %>'];

    fetch('/api/appointments/available-dates')
        .then(r => r.json())
        .then(data => {
            if (data.success) { availableDates = data.dates; renderCalendar(); }
        });

    window.changeMonth = function(dir) {
        currentMonth.setMonth(currentMonth.getMonth() + dir);
        renderCalendar();
    };

    function renderCalendar() {
        const y = currentMonth.getFullYear();
        const m = currentMonth.getMonth();
        document.getElementById('calendarMonthLabel').textContent = months[m] + ' ' + y;

        const firstDay = new Date(y, m, 1).getDay();
        const offset = firstDay === 0 ? 6 : firstDay - 1;
        const daysInMonth = new Date(y, m + 1, 0).getDate();
        const today = new Date(); today.setHours(0,0,0,0);

        const maxDate = new Date(); maxDate.setMonth(maxDate.getMonth() + 3);
        const prevEnabled = new Date(y, m, 1) > new Date(today.getFullYear(), today.getMonth(), 1);
        const nextEnabled = new Date(y, m + 1, 1) <= maxDate;
        document.getElementById('prevMonthBtn').disabled = !prevEnabled;
        document.getElementById('nextMonthBtn').disabled = !nextEnabled;

        let html = '';
        for (let i = 0; i < offset; i++) html += '<div class="cal-day empty"></div>';

        for (let d = 1; d <= daysInMonth; d++) {
            const dateStr = y + '-' + String(m+1).padStart(2,'0') + '-' + String(d).padStart(2,'0');
            const dateObj = new Date(y, m, d);
            const isPast = dateObj <= today;
            const av = availableDates.find(a => a.date === dateStr);
            const isAvailable = av && av.slotsAvailable > 0;
            const isToday = dateObj.getTime() === today.getTime();
            const isSelected = selectedDate === dateStr;

            let cls = 'cal-day';
            if (isPast) cls += ' disabled';
            else if (isAvailable) cls += ' available';
            else cls += ' disabled';
            if (isToday) cls += ' today';
            if (isSelected) cls += ' selected';

            if (isAvailable && !isPast) {
                html += '<button class="'+cls+'" onclick="selectDate(\''+dateStr+'\')">'+d+'</button>';
            } else {
                html += '<div class="'+cls+'">'+d+'</div>';
            }
        }
        document.getElementById('calendarDays').innerHTML = html;
    }

    window.selectDate = function(dateStr) {
        selectedDate = dateStr;
        renderCalendar();
        const d = new Date(dateStr + 'T12:00:00');
        const dayNames = ['<%= currentLanguage === "en" ? "Sunday" : "Pazar" %>','<%= currentLanguage === "en" ? "Monday" : "Pazartesi" %>','<%= currentLanguage === "en" ? "Tuesday" : "Salı" %>','<%= currentLanguage === "en" ? "Wednesday" : "Çarşamba" %>','<%= currentLanguage === "en" ? "Thursday" : "Perşembe" %>','<%= currentLanguage === "en" ? "Friday" : "Cuma" %>','<%= currentLanguage === "en" ? "Saturday" : "Cumartesi" %>'];
        document.getElementById('selectedDateLabel').textContent = dayNames[d.getDay()] + ', ' + d.getDate() + ' ' + months[d.getMonth()] + ' ' + d.getFullYear();

        document.getElementById('timeSlotsContainer').innerHTML = '<div class="text-center py-3"><div class="spinner-border text-primary" role="status"></div></div>';
        goToStep(2);

        fetch('/api/appointments/available-slots/' + dateStr)
            .then(r => r.json())
            .then(data => {
                if (!data.success || data.slots.length === 0) {
                    document.getElementById('timeSlotsContainer').innerHTML = '<div class="col-12 text-center text-muted py-3"><%= currentLanguage === "en" ? "No available slots for this date." : "Bu tarih için müsait saat bulunmuyor." %></div>';
                    return;
                }
                let html = '';
                data.slots.forEach(s => {
                    const val = s.czechTime + '|' + s.turkeyTime + '|' + s.startUTC + '|' + s.endUTC;
                    html += '<div class="col-6 col-md-4 col-lg-3"><button class="time-slot-btn" onclick="selectSlot(this,\'' + val.replace(/'/g,"\\'") + '\')">' +
                        '<div class="slot-time">' + s.turkeyTime + '</div>' +
                        '<div class="slot-label">TSİ</div></button></div>';
                });
                document.getElementById('timeSlotsContainer').innerHTML = html;
            });
    };

    const isStudentLoggedIn = <%= (typeof isLoggedIn !== 'undefined' && isLoggedIn && !isAdmin) ? 'true' : 'false' %>;
    const studentData = isStudentLoggedIn ? {
        name: '<%= typeof currentUser !== "undefined" && currentUser ? (currentUser.first_name || "") + " " + (currentUser.last_name || "") : "" %>',
        email: '<%= typeof currentUser !== "undefined" && currentUser ? (currentUser.email || "") : "" %>'
    } : null;

    window.selectSlot = function(btn, val) {
        document.querySelectorAll('.time-slot-btn').forEach(b => b.classList.remove('selected'));
        btn.classList.add('selected');
        selectedSlot = val;
        const parts = val.split('|');
        const d = new Date(selectedDate + 'T12:00:00');
        const dateTimeStr = d.getDate() + ' ' + months[d.getMonth()] + ' ' + d.getFullYear() + ' - ' + parts[1] + ' TSİ';
        document.getElementById('selectedDateTimeBadge').textContent = dateTimeStr;

        if (isStudentLoggedIn && studentData) {
            document.getElementById('fastConfirmName').textContent = studentData.name;
            document.getElementById('fastConfirmEmail').textContent = studentData.email;
            document.getElementById('fastConfirmDateTime').textContent = dateTimeStr;
            setTimeout(() => goToStepFast(), 300);
        } else {
            setTimeout(() => goToStep(3), 300);
        }
    };

    function goToStepFast() {
        document.querySelectorAll('.booking-panel').forEach(p => p.classList.add('d-none'));
        document.getElementById('bookingStepFast').classList.remove('d-none');
        document.querySelectorAll('.booking-step').forEach(s => {
            const sn = parseInt(s.dataset.step);
            s.classList.remove('active','done');
            if (sn <= 2) s.classList.add('done');
            else s.classList.add('done');
        });
    }

    window.fastBookConfirm = function() {
        const btn = document.getElementById('fastBookBtn');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Oluşturuluyor...';

        fetch('/api/appointments/create-fast', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ date: selectedDate, timeSlot: selectedSlot })
        })
        .then(r => r.json())
        .then(data => {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-check me-1"></i>Randevuyu Onayla';
            if (data.success) {
                const d = new Date(selectedDate + 'T12:00:00');
                document.getElementById('successDetails').textContent = d.getDate() + ' ' + months[d.getMonth()] + ' ' + d.getFullYear() + ' - ' + data.appointment.turkeyTime + ' TSİ';
                document.querySelectorAll('.booking-panel').forEach(p => p.classList.add('d-none'));
                document.getElementById('bookingSuccess').classList.remove('d-none');
                document.querySelectorAll('.booking-step').forEach(s => s.classList.add('done'));
            } else {
                alert(data.message);
            }
        })
        .catch(() => {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-check me-1"></i>Randevuyu Onayla';
            alert('Bir hata oluştu. Lütfen tekrar deneyin.');
        });
    };

    window.goToStep = function(step) {
        document.querySelectorAll('.booking-panel').forEach(p => p.classList.add('d-none'));
        document.getElementById('bookingStep' + step).classList.remove('d-none');
        document.querySelectorAll('.booking-step').forEach(s => {
            const sn = parseInt(s.dataset.step);
            s.classList.remove('active','done');
            if (sn === step) s.classList.add('active');
            else if (sn < step) s.classList.add('done');
        });
    };

    window.toggleGradeField = function() {
        const edu = document.getElementById('bkEducation').value;
        document.getElementById('gradeField').classList.toggle('d-none', edu !== 'Lise Öğrencisi');
    };

    (function() {
        const phoneInput = document.getElementById('bkPhone');
        if (phoneInput) {
            phoneInput.addEventListener('input', function() {
                let v = this.value.replace(/\D/g, '');
                if (v.length > 10) v = v.substring(0, 10);
                if (v.length > 7) v = v.substring(0,3) + ' ' + v.substring(3,6) + ' ' + v.substring(6,8) + ' ' + v.substring(8);
                else if (v.length > 6) v = v.substring(0,3) + ' ' + v.substring(3,6) + ' ' + v.substring(6);
                else if (v.length > 3) v = v.substring(0,3) + ' ' + v.substring(3);
                this.value = v;
            });
        }
    })();

    window.submitFormAndVerify = function() {
        const form = document.getElementById('bookingForm');
        const fullName = document.getElementById('bkFullName').value.trim();
        const rawPhone = document.getElementById('bkPhone').value.trim().replace(/\D/g, '');
        const phone = document.getElementById('bkCountryCode').value + rawPhone;
        const email = document.getElementById('bkEmail').value.trim();
        const country = document.getElementById('bkCountry').value;
        const field = document.getElementById('bkField').value;
        const education = document.getElementById('bkEducation').value;

        if (!fullName || !rawPhone || !email || !country || !field || !education) {
            alert('<%= currentLanguage === "en" ? "Please fill in all required fields." : "Lütfen tüm zorunlu alanları doldurun." %>');
            return;
        }
        const selectedCode = document.getElementById('bkCountryCode').value;
        if (selectedCode === '+90' && (rawPhone.length !== 10 || rawPhone[0] !== '5')) {
            alert('<%= currentLanguage === "en" ? "Please enter a valid phone number starting with 5." : "Lütfen 5 ile başlayan 10 haneli geçerli bir telefon numarası girin." %>');
            return;
        }
        if (selectedCode !== '+90' && rawPhone.length < 7) {
            alert('<%= currentLanguage === "en" ? "Please enter a valid phone number." : "Lütfen geçerli bir telefon numarası girin." %>');
            return;
        }

        const btn = event.target;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>';

        fetch('/api/appointments/send-verification', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, fullName })
        })
        .then(r => r.json())
        .then(data => {
            btn.disabled = false;
            btn.innerHTML = '<%= currentLanguage === "en" ? "Verify Email" : "E-postayı Doğrula" %> <i class="fas fa-arrow-right ms-1"></i>';
            if (data.success) {
                document.getElementById('verificationEmailHint').textContent = email + '<%= currentLanguage === "en" ? " - check your inbox" : " adresine kod gönderildi" %>';
                goToStep(4);
                setTimeout(() => { document.getElementById('resendCodeLink').style.display = 'inline'; }, 60000);
            } else {
                alert(data.message);
            }
        });
    };

    window.resendCode = function() {
        const email = document.getElementById('bkEmail').value.trim();
        const fullName = document.getElementById('bkFullName').value.trim();
        document.getElementById('resendCodeLink').style.display = 'none';
        fetch('/api/appointments/send-verification', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, fullName })
        }).then(() => {
            setTimeout(() => { document.getElementById('resendCodeLink').style.display = 'inline'; }, 60000);
        });
    };

    window.verifyAndBook = function() {
        const code = document.getElementById('bkVerifyCode').value.trim();
        const email = document.getElementById('bkEmail').value.trim();
        if (!code || code.length !== 6) {
            alert('<%= currentLanguage === "en" ? "Please enter the 6-digit code." : "Lütfen 6 haneli doğrulama kodunu girin." %>');
            return;
        }
        const btn = document.getElementById('verifyBookBtn');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>';

        fetch('/api/appointments/verify-code', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, code })
        })
        .then(r => r.json())
        .then(data => {
            if (!data.success) {
                btn.disabled = false;
                btn.innerHTML = '<%= currentLanguage === "en" ? "Confirm Appointment" : "Randevuyu Onayla" %>';
                alert(data.message);
                return;
            }
            const honeypot = document.querySelector('[name="website_url"]').value;
            const body = {
                fullName: document.getElementById('bkFullName').value.trim(),
                phone: document.getElementById('bkCountryCode').value + document.getElementById('bkPhone').value.trim().replace(/\D/g, ''),
                email,
                targetCountry: document.getElementById('bkCountry').value,
                fieldOfInterest: document.getElementById('bkField').value,
                educationLevel: document.getElementById('bkEducation').value,
                grade: document.getElementById('bkGrade') ? document.getElementById('bkGrade').value : '',
                budget: document.getElementById('bkBudget').value,
                notes: document.getElementById('bkNotes').value.trim(),
                date: selectedDate,
                timeSlot: selectedSlot,
                honeypot
            };
            return fetch('/api/appointments/create', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            }).then(r => r.json());
        })
        .then(data => {
            if (!data) return;
            btn.disabled = false;
            btn.innerHTML = '<%= currentLanguage === "en" ? "Confirm Appointment" : "Randevuyu Onayla" %>';
            if (data.success) {
                const d = new Date(selectedDate + 'T12:00:00');
                document.getElementById('successDetails').textContent = d.getDate() + ' ' + months[d.getMonth()] + ' ' + d.getFullYear() + ' - ' + data.appointment.turkeyTime + ' TSİ';
                document.querySelectorAll('.booking-panel').forEach(p => p.classList.add('d-none'));
                document.getElementById('bookingSuccess').classList.remove('d-none');
                document.querySelectorAll('.booking-step').forEach(s => s.classList.add('done'));
            } else {
                alert(data.message);
            }
        });
    };
})();
</script>

