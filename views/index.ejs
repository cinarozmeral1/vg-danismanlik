        transition-timing-function: linear !important;
        align-items: stretch;
        pointer-events: none;
    }
    
    .university-logo-slider .swiper-slide {
        width: auto;
        height: auto;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 20px;
        pointer-events: none;
    }
    
    .university-logo-slider .swiper-slide .logo-card {
        background: #ffffff;
        border-radius: 16px;
        padding: 25px 30px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        border: 1px solid rgba(0, 0, 0, 0.05);
        display: flex;
        align-items: center;
        justify-content: center;
        height: 140px;
        width: 260px;
        transition: all 0.3s ease;
        overflow: hidden;
        pointer-events: none; /* Tıklama slider'ı durdurmasın */
        user-select: none;
    }
    
    .university-logo-slider .swiper-slide .logo-card:hover {
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
        transform: translateY(-3px);
    }
    
    .university-logo-slider .swiper-slide img {
        max-height: 90px;
        max-width: 200px;
        width: auto;
        height: auto;
        object-fit: contain;
        filter: none;
        opacity: 1;
    }
    
    /* Küçük yazılı logolar için - kart aynı boyutta, logo içeride büyük */
    .university-logo-slider .swiper-slide .logo-card.logo-large img {
        max-height: 115px;
        max-width: 240px;
    }
    
    /* Çok küçük yazılı logolar için - maksimum büyütme */
    .university-logo-slider .swiper-slide .logo-card.logo-xlarge img {
        max-height: 130px;
        max-width: 250px;
    }
    
    /* En küçük yazılı logolar için - ekstra büyütme */
    .university-logo-slider .swiper-slide .logo-card.logo-xxlarge img {
        max-height: 135px;
        max-width: 255px;
    }
    
    /* Mobilde taşan logolar için özel ayar */
    .university-logo-slider .swiper-slide .logo-card.logo-mobile-fit img {
        max-height: 115px;
        max-width: 230px;
    }
    
    @media (max-width: 768px) {
        .university-logo-slider .swiper-slide .logo-card.logo-xxlarge img {
            max-height: 75px;
            max-width: 155px;
        }
        
        .university-logo-slider .swiper-slide .logo-card.logo-xlarge img {
            max-height: 70px;
            max-width: 150px;
        }
        
        .university-logo-slider .swiper-slide .logo-card.logo-large img {
            max-height: 65px;
            max-width: 145px;
        }
        
        .university-logo-slider .swiper-slide .logo-card.logo-mobile-fit img {
            max-height: 55px;
            max-width: 130px;
        }
    }
    
    
    @media (max-width: 992px) {
        .university-logo-slider .swiper-slide .logo-card {
            padding: 20px 25px;
            height: 120px;
            width: 220px;
        }
        
        .university-logo-slider .swiper-slide img {
            max-height: 70px;
            max-width: 170px;
        }
    }
    
    @media (max-width: 768px) {
        .university-logo-slider .swiper-slide {
            padding: 0 8px;
        }
        
        .university-logo-slider .swiper-slide .logo-card {
            padding: 15px 20px;
            height: 100px;
            width: 180px;
        }
        
        .university-logo-slider .swiper-slide img {
            max-height: 60px;
            max-width: 140px;
        }
    }
    </style>
    
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        if (typeof Swiper !== 'undefined') {
            new Swiper('#universitySlider', {
                slidesPerView: 'auto',
                spaceBetween: 0,
                loop: true,
                loopAdditionalSlides: 5,
                speed: 2500,
                autoplay: {
                    delay: 0,
                    disableOnInteraction: false,
                    pauseOnMouseEnter: false,
                    stopOnLastSlide: false,
                },
                allowTouchMove: false,
                simulateTouch: false,
                preventClicks: true,
                preventClicksPropagation: true,
                noSwiping: true,
                noSwipingClass: 'swiper-slide',
                freeMode: {
                    enabled: true,
                    momentum: false,
                },
                grabCursor: false,
                watchSlidesProgress: true,
            });
        }
    });
    </script>
</section>

