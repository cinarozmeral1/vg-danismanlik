    <script>
    // ===== ÇEREZ YÖNETİM SİSTEMİ =====
    // Çerezler şunlar için kullanılır:
    // 1. Oturum yönetimi (giriş durumu)
    // 2. Dil tercihi
    // 3. Kullanıcı deneyimi tercihleri
    // 4. Analytics (kabul edilirse)
    
    // Çerez Consent - Kabul veya reddedilene kadar göster
    function showCookieConsent() {
        const cookieChoice = localStorage.getItem('cookieChoice');
        
        // Seçim yapılmamışsa göster
        if (!cookieChoice) {
            setTimeout(() => {
                const banner = document.getElementById('cookieConsent');
                if (banner) {
                    banner.style.display = 'block';
                    banner.classList.add('cookie-slide-in');
                }
            }, 1000);
        }
    }
    
    function acceptCookies() {
        localStorage.setItem('cookieChoice', 'accepted');
        localStorage.setItem('cookieChoiceDate', new Date().toISOString());
        
        // Analytics çerezlerini etkinleştir
        enableAnalytics();
        
        // Banner'ı kapat
        const banner = document.getElementById('cookieConsent');
        if (banner) {
            banner.classList.add('cookie-slide-out');
        setTimeout(() => {
                banner.style.display = 'none';
            }, 300);
    }
    
        console.log('✅ Çerezler kabul edildi - Analytics aktif');
    }
    
    function declineCookies() {
        localStorage.setItem('cookieChoice', 'declined');
        localStorage.setItem('cookieChoiceDate', new Date().toISOString());
        
        // Sadece gerekli çerezleri tut
        disableAnalytics();
        
        // Banner'ı kapat
        const banner = document.getElementById('cookieConsent');
        if (banner) {
            banner.classList.add('cookie-slide-out');
            setTimeout(() => {
                banner.style.display = 'none';
            }, 300);
        }
        
        console.log('❌ Çerezler reddedildi - Sadece gerekli çerezler aktif');
    }
    
    // Analytics etkinleştir (Google Analytics 4)
    function enableAnalytics() {
        // GA4 için - loadGoogleAnalytics fonksiyonunu çağır
        if (typeof loadGoogleAnalytics === 'function') {
            loadGoogleAnalytics();
        }
        
        // GA disable flag'ini kaldır
        if (window.GA_MEASUREMENT_ID) {
            window['ga-disable-' + window.GA_MEASUREMENT_ID] = false;
        }
        
        console.log('📊 Analytics enabled');
    }
    
    // Analytics devre dışı bırak
    function disableAnalytics() {
        // GA4 için disable flag
        if (window.GA_MEASUREMENT_ID) {
            window['ga-disable-' + window.GA_MEASUREMENT_ID] = true;
        }
        
        // Analytics çerezlerini temizle
        document.cookie.split(";").forEach(function(c) {
            const name = c.split("=")[0].trim();
            // Analytics çerezlerini sil (_ga, _gid, _gat, _fbp vb.)
            if (name.startsWith('_ga') || name.startsWith('_gid') || name.startsWith('_gat') || name.startsWith('_fbp')) {
                document.cookie = name + '=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/;domain=' + window.location.hostname;
                document.cookie = name + '=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/';
            }
        });
        
        console.log('📊 Analytics disabled');
    }
    
    // Kullanıcı tercihine göre analytics yönet
    function initCookiePreferences() {
        const choice = localStorage.getItem('cookieChoice');
        if (choice === 'accepted') {
            enableAnalytics();
        } else if (choice === 'declined') {
            disableAnalytics();
        }
    }
    
    // Sayfa yüklendiğinde
    document.addEventListener('DOMContentLoaded', function() {
        initCookiePreferences();
        showCookieConsent();
    });
    </script>

    <!-- MOBILE MENU - BOOTSTRAP OFFCANVAS -->
    <script>
    // Bootstrap Offcanvas için basit ayarlar
    document.addEventListener('DOMContentLoaded', function() {
        var mobileNav = document.getElementById('mobileNav');
        if (!mobileNav) return;
        
        var savedScrollY = 0;
        
        // Bootstrap offcanvas instance al veya oluştur
        var bsOffcanvas = bootstrap.Offcanvas.getOrCreateInstance(mobileNav, {
            backdrop: true,
            keyboard: true,
            scroll: false
        });
        
        // Menü açılınca - scroll engelle
        mobileNav.addEventListener('show.bs.offcanvas', function() {
            savedScrollY = window.scrollY;
            document.documentElement.style.overflow = 'hidden';
            document.body.style.overflow = 'hidden';
            document.body.classList.add('mobile-menu-open');
        });
        
        // Menü kapanınca - scroll geri aç
        mobileNav.addEventListener('hidden.bs.offcanvas', function() {
            document.body.classList.remove('mobile-menu-open');
            document.documentElement.style.overflow = '';
            document.body.style.overflow = '';
            window.scrollTo(0, savedScrollY);
        });
    });

    // Force reload if page restored from bfcache (fixes stale login state after logout)
    window.addEventListener('pageshow', function(e) {
        if (e.persisted) { window.location.reload(); }
    });
    </script>

    <!-- Bootstrap Modal fix: move modals to body and fix z-index above navbar -->
    <style>
    .modal-backdrop { z-index: 10050 !important; }
    .modal { z-index: 10055 !important; }
    </style>
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.modal').forEach(function(m) {
            if (m.parentElement !== document.body) document.body.appendChild(m);
        });
        document.addEventListener('hidden.bs.modal', function() {
            document.querySelectorAll('.modal-backdrop').forEach(function(b) { b.remove(); });
            document.body.classList.remove('modal-open');
            document.body.style.removeProperty('overflow');
            document.body.style.removeProperty('padding-right');
        });
    });
    </script>

</body>
</html> 