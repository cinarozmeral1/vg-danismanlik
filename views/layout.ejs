    <script>
    // ===== ÇEREZ YÖNETİM SİSTEMİ =====
    // Çerezler şunlar için kullanılır:
    // 1. Oturum yönetimi (giriş durumu)
    // 2. Dil tercihi
    // 3. Kullanıcı deneyimi tercihleri
    // 4. Analytics (kabul edilirse)
    
    // Çerez Consent - Kabul veya reddedilene kadar göster
    function showCookieConsent() {
        const cookieChoice = localStorage.getItem('cookieChoice');
        
        // Seçim yapılmamışsa göster
        if (!cookieChoice) {
            setTimeout(() => {
                const banner = document.getElementById('cookieConsent');
                if (banner) {
                    banner.style.display = 'block';
                    banner.classList.add('cookie-slide-in');
                }
            }, 1000);
        }
    }
    
    function acceptCookies() {
        localStorage.setItem('cookieChoice', 'accepted');
        localStorage.setItem('cookieChoiceDate', new Date().toISOString());
        
        // Analytics çerezlerini etkinleştir
        enableAnalytics();
        
        // Banner'ı kapat
        const banner = document.getElementById('cookieConsent');
        if (banner) {
            banner.classList.add('cookie-slide-out');
        setTimeout(() => {
                banner.style.display = 'none';
            }, 300);
    }
    
        console.log('✅ Çerezler kabul edildi - Analytics aktif');
    }
    
    function declineCookies() {
        localStorage.setItem('cookieChoice', 'declined');
        localStorage.setItem('cookieChoiceDate', new Date().toISOString());
        
        // Sadece gerekli çerezleri tut
        disableAnalytics();
        
        // Banner'ı kapat
        const banner = document.getElementById('cookieConsent');
        if (banner) {
            banner.classList.add('cookie-slide-out');
            setTimeout(() => {
                banner.style.display = 'none';
            }, 300);
        }
        
        console.log('❌ Çerezler reddedildi - Sadece gerekli çerezler aktif');
    }
    
    // Analytics etkinleştir (Google Analytics 4)
    function enableAnalytics() {
        // GA4 için - loadGoogleAnalytics fonksiyonunu çağır
        if (typeof loadGoogleAnalytics === 'function') {
            loadGoogleAnalytics();
        }
        
        // GA disable flag'ini kaldır
        if (window.GA_MEASUREMENT_ID) {
            window['ga-disable-' + window.GA_MEASUREMENT_ID] = false;
        }
        
        console.log('📊 Analytics enabled');
    }
    
    // Analytics devre dışı bırak
    function disableAnalytics() {
        // GA4 için disable flag
        if (window.GA_MEASUREMENT_ID) {
            window['ga-disable-' + window.GA_MEASUREMENT_ID] = true;
        }
        
        // Analytics çerezlerini temizle
        document.cookie.split(";").forEach(function(c) {
            const name = c.split("=")[0].trim();
            // Analytics çerezlerini sil (_ga, _gid, _gat, _fbp vb.)
            if (name.startsWith('_ga') || name.startsWith('_gid') || name.startsWith('_gat') || name.startsWith('_fbp')) {
                document.cookie = name + '=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/;domain=' + window.location.hostname;
                document.cookie = name + '=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/';
            }
        });
        
        console.log('📊 Analytics disabled');
    }
    
    // Kullanıcı tercihine göre analytics yönet
    function initCookiePreferences() {
        const choice = localStorage.getItem('cookieChoice');
        if (choice === 'accepted') {
            enableAnalytics();
        } else if (choice === 'declined') {
            disableAnalytics();
        }
    }
    
    // Sayfa yüklendiğinde
    document.addEventListener('DOMContentLoaded', function() {
        initCookiePreferences();
        showCookieConsent();
    });
    </script>

