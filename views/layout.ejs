<!DOCTYPE html>
<html lang="<%= typeof currentLanguage !== 'undefined' ? currentLanguage : 'tr' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- Primary Meta Tags -->
    <title><%= typeof seoTitle !== 'undefined' && seoTitle ? seoTitle : 'Venture Global - Profesyonel Eğitim Danışmanlığı' %></title>
    <meta name="title" content="<%= typeof seoTitle !== 'undefined' && seoTitle ? seoTitle : 'Venture Global - Profesyonel Eğitim Danışmanlığı' %>">
    <meta name="description" content="<%= typeof seoDescription !== 'undefined' && seoDescription ? seoDescription : 'Venture Global - Avrupa üniversite ve dil okulu danışmanlığı. Almanya, Çekya, İtalya, Avusturya, İngiltere, Polonya ve Macaristan\'da üniversite başvuru süreçlerinizde profesyonel danışmanlık hizmeti.' %>">
    <meta name="keywords" content="<%= typeof seoKeywords !== 'undefined' && seoKeywords ? seoKeywords : 'yurtdışı eğitim, avrupa üniversite, dil okulu, eğitim danışmanlığı, almanya üniversite, çekya üniversite, italya üniversite, avusturya üniversite, ingiltere üniversite, polonya üniversite, macaristan üniversite, üniversite başvurusu, vize danışmanlığı' %>">
    <meta name="author" content="Venture Global">
    <meta name="robots" content="<%= typeof seoRobots !== 'undefined' && seoRobots ? seoRobots : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1' %>">
    <meta name="language" content="<%= typeof currentLanguage !== 'undefined' ? currentLanguage : 'tr' %>">
    <meta name="revisit-after" content="7 days">
    <meta name="distribution" content="global">
    <meta name="rating" content="general">
    
    <!-- Canonical URL -->
    <link rel="canonical" href="<%= typeof canonicalUrl !== 'undefined' && canonicalUrl ? canonicalUrl : (typeof baseUrl !== 'undefined' ? baseUrl : 'https://ventureglobal.com') + (typeof currentPath !== 'undefined' ? currentPath : '') %>">
    
    <!-- Alternate Languages -->
    <link rel="alternate" hreflang="tr" href="<%= typeof baseUrl !== 'undefined' ? baseUrl : 'https://ventureglobal.com' %>/change-language/tr">
    <link rel="alternate" hreflang="en" href="<%= typeof baseUrl !== 'undefined' ? baseUrl : 'https://ventureglobal.com' %>/change-language/en">
    <link rel="alternate" hreflang="x-default" href="<%= typeof baseUrl !== 'undefined' ? baseUrl : 'https://ventureglobal.com' %>">
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="<%= typeof ogType !== 'undefined' && ogType ? ogType : 'website' %>">
    <meta property="og:url" content="<%= typeof ogUrl !== 'undefined' && ogUrl ? ogUrl : (typeof baseUrl !== 'undefined' ? baseUrl : 'https://ventureglobal.com') + (typeof currentPath !== 'undefined' ? currentPath : '') %>">
    <meta property="og:title" content="<%= typeof ogTitle !== 'undefined' && ogTitle ? ogTitle : (typeof seoTitle !== 'undefined' && seoTitle ? seoTitle : 'Venture Global - Profesyonel Eğitim Danışmanlığı') %>">
    <meta property="og:description" content="<%= typeof ogDescription !== 'undefined' && ogDescription ? ogDescription : (typeof seoDescription !== 'undefined' && seoDescription ? seoDescription : 'Avrupa üniversite ve dil okulu danışmanlığı. Profesyonel eğitim danışmanlığı hizmetleri ile hayallerinizi gerçeğe dönüştürün.') %>">
