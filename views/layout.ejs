    /* Cookie Consent - Modern Tasarım */
    .cookie-consent {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: linear-gradient(135deg, #1e3a5f, #0d2137);
        color: white;
        padding: 20px;
        z-index: 99999;
        box-shadow: 0 -5px 30px rgba(0,0,0,0.3);
        border-top: 3px solid #3b82f6;
    }
    
    .cookie-consent.cookie-slide-in {
        animation: slideInUp 0.4s ease-out;
    }
    
    .cookie-consent.cookie-slide-out {
        animation: slideOutDown 0.3s ease-in forwards;
    }
    
    @keyframes slideInUp {
        from {
            transform: translateY(100%);
            opacity: 0;
        }
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }
    
    @keyframes slideOutDown {
        from {
            transform: translateY(0);
            opacity: 1;
        }
        to {
            transform: translateY(100%);
            opacity: 0;
        }
    }
    
    .cookie-content {
        max-width: 1200px;
