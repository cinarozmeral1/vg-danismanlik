    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="Venture Global - Eğitim Danışmanlığı">
    <meta property="og:site_name" content="Venture Global">
    <meta property="og:locale" content="<%= typeof currentLanguage !== 'undefined' && currentLanguage === 'en' ? 'en_US' : 'tr_TR' %>">
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content="<%= typeof ogUrl !== 'undefined' && ogUrl ? ogUrl : (typeof baseUrl !== 'undefined' ? baseUrl : 'https://ventureglobal.com') + (typeof currentPath !== 'undefined' ? currentPath : '') %>">
    <meta name="twitter:title" content="<%= typeof ogTitle !== 'undefined' && ogTitle ? ogTitle : (typeof seoTitle !== 'undefined' && seoTitle ? seoTitle : 'Venture Global - Profesyonel Eğitim Danışmanlığı') %>">
    <meta name="twitter:description" content="<%= typeof ogDescription !== 'undefined' && ogDescription ? ogDescription : (typeof seoDescription !== 'undefined' && seoDescription ? seoDescription : 'Avrupa üniversite ve dil okulu danışmanlığı. Profesyonel eğitim danışmanlığı hizmetleri.') %>">
    <meta name="twitter:image" content="<%= typeof ogImage !== 'undefined' && ogImage ? ogImage : (typeof baseUrl !== 'undefined' ? baseUrl : 'https://ventureglobal.com') + '/images/logos/venture-global-logo.png' %>">
    <meta name="twitter:image:alt" content="Venture Global - Eğitim Danışmanlığı">
    <meta name="twitter:site" content="@ventureglobal">
    <meta name="twitter:creator" content="@ventureglobal">
    
    <!-- Additional Meta Tags for Competitive SEO -->
    <meta name="application-name" content="Venture Global - Yurt Dışı Danışmanlık">
    <meta name="apple-mobile-web-app-title" content="Venture Global">
    <meta name="theme-color" content="#fff8f2">
    
    <!-- Geographic Targeting -->
    <meta name="geo.region" content="TR">
    <meta name="geo.placename" content="İstanbul">
    <meta name="ICBM" content="41.0082, 28.9784">
    
    <!-- Business Information for Local SEO -->
    <meta name="contact" content="info@ventureglobal.com">
    <meta name="copyright" content="Venture Global">
    <meta name="category" content="Education, Consulting, Yurt Dışı Danışmanlık, Yurt Dışı Eğitim Danışmanlığı">
    
    <!-- Performance optimizations -->
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    
    <!-- DNS prefetch for external resources -->
    <link rel="dns-prefetch" href="//cdn.jsdelivr.net">
    <link rel="dns-prefetch" href="//cdnjs.cloudflare.com">
    <link rel="dns-prefetch" href="//fonts.googleapis.com">
    <link rel="dns-prefetch" href="//fonts.gstatic.com">
    
    <!-- Favicon -->
    <link rel="icon" href="/favicon.png?v=6" type="image/png">
    <link rel="shortcut icon" href="/favicon.ico?v=6" type="image/x-icon">
    <link rel="apple-touch-icon" href="/favicon.png?v=6">
    <meta name="msapplication-TileImage" content="/favicon.png?v=6">
    <meta name="msapplication-TileColor" content="#ffffff">
    
    <!-- Preload critical resources -->
    <link rel="preload" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM" crossorigin="anonymous">
    
    <!-- Font Awesome - Load asynchronously -->
    <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"></noscript>
    
    <!-- Google Fonts - Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css?v=20241126-premium-popup-redesign">
</head>
