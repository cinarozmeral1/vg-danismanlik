    <script>
        // Prevent multiple initializations
        if (window.mobileMenuInitialized) {
            console.log('Mobile menu already initialized, skipping...');
        } else {
            window.mobileMenuInitialized = true;
            
            // Single initialization function
            function initializeMobileMenu() {
                console.log('Initializing mobile menu...');
                
                // Initialize dropdowns only once
                if (typeof bootstrap !== 'undefined') {
            initializeDropdowns();
                } else {
                    // Wait for Bootstrap with shorter interval
                    setTimeout(initializeMobileMenu, 100);
                    return;
                }
                
                // Setup logout handlers only once
                setupLogoutHandlers();
                
                // Setup mobile nav events only once
                setupMobileNavEvents();
            }
            
            function initializeDropdowns() {
                const dropdownTriggers = document.querySelectorAll('.dropdown-toggle');
                
                dropdownTriggers.forEach(trigger => {
                    try {
                        // Dispose existing instance
                        const existingInstance = bootstrap.Dropdown.getInstance(trigger);
                        if (existingInstance) {
                            existingInstance.dispose();
                        }
                        
                        // Initialize with optimized options
                        new bootstrap.Dropdown(trigger, {
                            autoClose: true,
                            boundary: 'viewport'
                        });
                        
                    } catch (error) {
                        console.warn('Dropdown initialization failed:', error);
                    }
                });
            }
            
            function setupLogoutHandlers() {
                // Remove existing listeners first
                document.removeEventListener('click', handleLogoutClick);
                
                // Add single event listener
                document.addEventListener('click', handleLogoutClick);
            }
            
            function handleLogoutClick(e) {
                if (e.target.matches('[data-action="logout"]') || 
                    e.target.closest('[data-action="logout"]')) {
                e.preventDefault();
                    e.stopPropagation();
                    handleLogout();
                }
            }
            
            function handleLogout() {
                const controller = new AbortController();
                const timeoutId = setTimeout(() => controller.abort(), 5000);
                
                fetch('/api/auth/logout', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    signal: controller.signal
                })
                .then(res => res.json())
                .then(data => {
                    clearTimeout(timeoutId);
                        window.location.href = '/';
                })
                .catch(err => {
                    clearTimeout(timeoutId);
                    window.location.href = '/';
                });
            }
            
            function setupMobileNavEvents() {
                const mobileNav = document.getElementById('mobileNav');
                if (!mobileNav) return;
                
                // Completely remove all event listeners
                const newMobileNav = mobileNav.cloneNode(true);
                mobileNav.parentNode.replaceChild(newMobileNav, mobileNav);
                
                // Add only essential event listeners
                newMobileNav.addEventListener('show.bs.offcanvas', function() {
                    // Force show class for CSS animation
                    this.classList.add('show');
                });
                
                newMobileNav.addEventListener('hidden.bs.offcanvas', function() {
                    // Clean up
                    this.classList.remove('show');
                });
            }
            
            // Initialize on DOM ready
            document.addEventListener('DOMContentLoaded', function() {
                // Use requestAnimationFrame for better performance
                requestAnimationFrame(initializeMobileMenu);
                
                // Disable Bootstrap's automatic offcanvas initialization
                const mobileNav = document.getElementById('mobileNav');
                if (mobileNav) {
                    mobileNav.removeAttribute('data-bs-toggle');
                    mobileNav.removeAttribute('data-bs-target');
                    
                    const toggleBtn = document.querySelector('[data-bs-target="#mobileNav"]');
                    if (toggleBtn) {
                        toggleBtn.addEventListener('click', function(e) {
                            e.preventDefault();
                            if (mobileNav.classList.contains('show')) {
                                closeMobileMenu();
                            } else {
                                openMobileMenu();
                            }
                        });
                    }
                    
                    const closeBtn = mobileNav.querySelector('.btn-close');
                    if (closeBtn) {
                        closeBtn.addEventListener('click', function(e) {
                            e.preventDefault();
                            closeMobileMenu();
                        });
                    }
                    
                    function openMobileMenu() {
                        // First, force close any existing menu
                        closeMobileMenu();
                        
                        // Wait a bit for cleanup
                        setTimeout(() => {
                            // Disable all transitions before showing
                            mobileNav.style.transition = 'none';
                            mobileNav.style.animation = 'none';
                            
                            mobileNav.classList.add('show');
                            
                            // Force remove any existing backdrops first
                            const existingBackdrops = document.querySelectorAll('.mobile-menu-backdrop, .offcanvas-backdrop, .modal-backdrop');
                            existingBackdrops.forEach(backdrop => backdrop.remove());
                            
                            // Add new backdrop for left side darkening
                            const backdrop = document.createElement('div');
                            backdrop.className = 'mobile-menu-backdrop';
                            backdrop.id = 'mobileMenuBackdrop';
                            backdrop.style.opacity = '1';
                            backdrop.style.transition = 'none';
                            document.body.appendChild(backdrop);
                            
                            // Close on backdrop click
                            backdrop.addEventListener('click', function() {
                                closeMobileMenu();
                            });
                            
                            // Prevent body scroll
                            document.body.style.overflow = 'hidden';
                        }, 10);
                    }
                    
                    function closeMobileMenu() {
                        // Disable transitions before hiding
                        mobileNav.style.transition = 'none';
                        mobileNav.style.animation = 'none';
                        
                        mobileNav.classList.remove('show');
                        
                        // Force remove ALL backdrops
                        const allBackdrops = document.querySelectorAll('.mobile-menu-backdrop, .offcanvas-backdrop, .modal-backdrop, [class*="backdrop"]');
                        allBackdrops.forEach(backdrop => {
                            if (backdrop && backdrop.parentNode) {
                                backdrop.parentNode.removeChild(backdrop);
                            }
                        });
                        
                        // Remove any remaining backdrop classes from body
                        document.body.classList.remove('modal-open', 'offcanvas-open');
                        document.body.style.overflow = '';
                        document.body.style.paddingRight = '';
                        document.body.style.removeProperty('overflow');
                        document.body.style.removeProperty('padding-right');
                        
                        // Force cleanup of any remaining backdrop elements
                        setTimeout(() => {
                            const remainingBackdrops = document.querySelectorAll('.mobile-menu-backdrop, .offcanvas-backdrop, .modal-backdrop');
                            remainingBackdrops.forEach(backdrop => {
                                if (backdrop && backdrop.parentNode) {
                                    backdrop.parentNode.removeChild(backdrop);
                                }
                            });
                        }, 10);
                    }
                }
            });
            
            // Expose for global access
            window.initializeGlobalDropdowns = initializeDropdowns;
        }
    </script>
