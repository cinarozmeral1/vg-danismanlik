    <!-- PROMO POPUP INLINE SCRIPT - Garantili Çalışma -->
    <script>
    (function() {
        let currentSlide = 0;
        let autoInterval = null;
        const autoDelay = 10000; // 10 seconds
        
        function init() {
            const overlay = document.querySelector('.promo-popup-overlay');
            if (!overlay) return;
            
            const slides = document.querySelectorAll('.promo-slide');
            const totalSlides = slides.length;
            if (totalSlides === 0) return;
            
            // Close button
            const closeBtn = document.querySelector('.promo-popup-close');
            if (closeBtn) {
                closeBtn.addEventListener('click', closePopup);
            }
            
            // Backdrop click
            overlay.addEventListener('click', function(e) {
                if (e.target === overlay) {
                    closePopup();
                }
            });
            
            // Arrow buttons
            const prevBtn = document.querySelector('.promo-arrow-prev');
            const nextBtn = document.querySelector('.promo-arrow-next');
            
            if (prevBtn) {
                prevBtn.addEventListener('click', prevSlide);
            }
            if (nextBtn) {
                nextBtn.addEventListener('click', nextSlide);
            }
            
            // Dots
            const dots = document.querySelectorAll('.promo-dot');
            dots.forEach(function(dot, index) {
                dot.addEventListener('click', function() {
                    goToSlide(index);
                });
            });
            
            // Keyboard
            document.addEventListener('keydown', function(e) {
                if (!overlay.classList.contains('active')) return;
                if (e.key === 'Escape') closePopup();
                if (e.key === 'ArrowLeft') prevSlide();
                if (e.key === 'ArrowRight') nextSlide();
            });
            
            // Show popup after 1 second
            setTimeout(function() {
                showPopup();
            }, 1000);
        }
        
        function showPopup() {
            const overlay = document.querySelector('.promo-popup-overlay');
            if (overlay) {
                overlay.classList.add('active');
                document.body.classList.add('promo-popup-open');
                startAuto();
            }
        }
        
        function closePopup() {
            const overlay = document.querySelector('.promo-popup-overlay');
            if (overlay) {
                overlay.classList.remove('active');
                document.body.classList.remove('promo-popup-open');
                stopAuto();
            }
        }
        
        function goToSlide(index) {
            const slides = document.querySelectorAll('.promo-slide');
            const dots = document.querySelectorAll('.promo-dot');
            
            slides.forEach(function(slide) {
                slide.classList.remove('active');
            });
            dots.forEach(function(dot) {
                dot.classList.remove('active');
            });
            
            if (slides[index]) {
                slides[index].classList.add('active');
            }
            if (dots[index]) {
                dots[index].classList.add('active');
            }
            
            currentSlide = index;
            resetAuto();
        }
        
        function nextSlide() {
            const totalSlides = document.querySelectorAll('.promo-slide').length;
            const nextIndex = (currentSlide + 1) % totalSlides;
            goToSlide(nextIndex);
        }
        
        function prevSlide() {
            const totalSlides = document.querySelectorAll('.promo-slide').length;
            const prevIndex = (currentSlide - 1 + totalSlides) % totalSlides;
            goToSlide(prevIndex);
        }
        
        function startAuto() {
            stopAuto();
            autoInterval = setInterval(nextSlide, autoDelay);
        }
        
        function stopAuto() {
            if (autoInterval) {
                clearInterval(autoInterval);
                autoInterval = null;
            }
        }
        
        function resetAuto() {
            if (document.querySelector('.promo-popup-overlay').classList.contains('active')) {
                startAuto();
            }
        }
        
        // Initialize when DOM is ready
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', init);
        } else {
            init();
        }
    })();
    </script>
