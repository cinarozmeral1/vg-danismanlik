    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js?v=20250930-1"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            console.log('DOM Content Loaded, starting initialization...');
            
            // Initialize dropdowns after a small delay to ensure Bootstrap is ready
            setTimeout(function() {
                initializeDropdowns();
            }, 100);

            const globalLogoutBtn = document.getElementById('globalLogoutBtn');
            if (globalLogoutBtn) {
                globalLogoutBtn.addEventListener('click', handleLogout);
            }

            // Add logout event listeners with better error handling
            document.querySelectorAll('[data-action="logout"]').forEach(el => {
                el.addEventListener('click', handleLogout);
                console.log('Added logout listener to element:', el); // Debug log
            });

            function handleLogout(e) {
                e.preventDefault();
                console.log('Logout clicked'); // Debug log
                fetch('/api/auth/logout', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include'
                })
                .then(res => {
                    console.log('Logout response status:', res.status); // Debug log
                    return res.json();
                })
                .then(data => {
                    console.log('Logout response data:', data); // Debug log
                    if (data.success) {
                        console.log('Logout successful, redirecting...'); // Debug log
                        window.location.href = '/';
                    } else {
                        console.error('Logout failed:', data.message);
                        // Force redirect anyway
                        window.location.href = '/';
                    }
                })
                .catch(err => {
                    console.error('Logout error:', err);
                    // Force redirect on error
                    window.location.href = '/';
                });
            }

            function initializeDropdowns() {
                console.log('Initializing dropdowns...');
                
                // Wait for Bootstrap to be fully loaded
                if (typeof bootstrap === 'undefined') {
                    console.error('Bootstrap not loaded!');
                    setTimeout(initializeDropdowns, 100);
                    return;
                }
                
                // Remove any existing dropdown instances
                document.querySelectorAll('.dropdown-toggle').forEach(trigger => {
                    const existingInstance = bootstrap.Dropdown.getInstance(trigger);
                    if (existingInstance) {
                        existingInstance.dispose();
                    }
                });
                
                // Initialize all dropdowns
                document.querySelectorAll('.dropdown-toggle').forEach(trigger => {
                    try {
                        console.log('Initializing dropdown for:', trigger);
                        const dropdown = new bootstrap.Dropdown(trigger, { 
                            autoClose: true,
                            boundary: 'viewport'
                        });
                        
                        // Add event listeners for debugging
                        trigger.addEventListener('click', function(e) {
                            console.log('Dropdown clicked:', trigger);
                        });
                        
                        trigger.addEventListener('show.bs.dropdown', function(e) {
                            console.log('Dropdown showing:', trigger);
                        });
                        
                    } catch (error) {
                        console.error('Error initializing dropdown:', error);
                    }
                });
                
                console.log('Dropdowns initialized successfully');
            }

            window.initializeGlobalDropdowns = initializeDropdowns;
        });
    </script>
</body>
