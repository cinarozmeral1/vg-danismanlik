                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <%= (typeof t !== 'undefined' && t.nav) ? t.nav.studentLife : 'Öğrenci Hayatı' %>
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/student-life/germany"><i class="fas fa-flag me-2"></i><%= (typeof t !== 'undefined' && t.countries) ? t.countries.germany : 'Almanya' %></a></li>
                            <li><a class="dropdown-item" href="/student-life/czech"><i class="fas fa-flag me-2"></i><%= (typeof t !== 'undefined' && t.countries) ? t.countries.czech : 'Çek Cumhuriyeti' %></a></li>
                            <li><a class="dropdown-item" href="/student-life/italy"><i class="fas fa-flag me-2"></i><%= (typeof t !== 'undefined' && t.countries) ? t.countries.italy : 'İtalya' %></a></li>
                            <li><a class="dropdown-item" href="/student-life/austria"><i class="fas fa-flag me-2"></i><%= (typeof t !== 'undefined' && t.countries) ? t.countries.austria : 'Avusturya' %></a></li>
                            <li><a class="dropdown-item" href="/student-life/uk"><i class="fas fa-flag me-2"></i><%= (typeof t !== 'undefined' && t.countries) ? t.countries.uk : 'İngiltere' %></a></li>
                            <li><a class="dropdown-item" href="/student-life/poland"><i class="fas fa-flag me-2"></i><%= (typeof t !== 'undefined' && t.countries) ? t.countries.poland : 'Polonya' %></a></li>
                            <li><a class="dropdown-item" href="/student-life/hungary"><i class="fas fa-flag me-2"></i><%= (typeof t !== 'undefined' && t.countries) ? t.countries.hungary : 'Macaristan' %></a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/services"><%= (typeof t !== 'undefined' && t.nav) ? t.nav.services : 'Hizmetler' %></a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/universities"><%= (typeof t !== 'undefined' && t.nav) ? t.nav.universities : 'Üniversiteler' %></a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/assessment"><%= (typeof t !== 'undefined' && t.nav) ? t.nav.assessment : 'Değerlendirme' %></a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/about-us"><%= (typeof t !== 'undefined' && t.nav) ? t.nav.aboutUs : 'Tanışalım' %></a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/contact"><%= (typeof t !== 'undefined' && t.nav) ? t.nav.contact : 'İletişim' %></a>
                    </li>
                </ul>
                
                <!-- Right Side - User Actions -->
                <ul class="navbar-nav ms-auto align-items-center">
                    <!-- Language Selector -->
                    <li class="nav-item dropdown me-3">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fas fa-globe me-1"></i>
                            <span id="currentLanguage"><%= currentLanguage === 'tr' ? 'TR' : 'EN' %></span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item language-option" href="#" data-language="tr"><i class="fas fa-flag me-2"></i>Türkçe</a></li>
                            <li><a class="dropdown-item language-option" href="#" data-language="en"><i class="fas fa-flag me-2"></i>English</a></li>
                        </ul>
                    </li>
                    
                    <!-- User Profile / Auth -->
                    <% if (typeof isLoggedIn !== 'undefined' && isLoggedIn === true) { %>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fas fa-user-circle me-1"></i>
                                <% if (typeof currentUser !== 'undefined' && currentUser) { %>
                                    <%= currentUser.first_name || currentUser.name || t.nav.profile %>
                                <% } else { %>
                                    <%= t.nav.profile %>
                                <% } %>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <% if (typeof currentUser !== 'undefined' && currentUser && currentUser.is_admin) { %>
                                    <li><a class="dropdown-item" href="/admin/dashboard"><i class="fas fa-user-shield me-2"></i>Admin Panel</a></li>
                                    <li><a class="dropdown-item" href="/admin/users"><i class="fas fa-users me-2"></i>Öğrenciler</a></li>
                                    <li><a class="dropdown-item" href="/admin/applications"><i class="fas fa-file-alt me-2"></i>Başvurular</a></li>
                                    <li><a class="dropdown-item" href="/admin/universities"><i class="fas fa-university me-2"></i>Üniversiteler</a></li>
                                <% } else { %>
                                    <li><a class="dropdown-item" href="/user/dashboard"><i class="fas fa-user me-2"></i>Profil Bilgileri</a></li>
                                    <li><a class="dropdown-item" href="/user/applications"><i class="fas fa-tachometer-alt me-2"></i>Başvurularım</a></li>
                                <% } %>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="/logout"><i class="fas fa-sign-out-alt me-2"></i>Çıkış Yap</a></li>
                            </ul>
                        </li>
                    <% } else { %>
                        <li class="nav-item me-2">
                            <a class="btn btn-outline-primary btn-sm" href="/login">
                                <%= (typeof t !== 'undefined' && t.auth && t.auth.login) ? t.auth.login.title : 'Giriş' %>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-primary btn-sm" href="/register">
                                <%= (typeof t !== 'undefined' && t.auth && t.auth.register) ? t.auth.register.title : 'Kayıt Ol' %>
                            </a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main style="margin-top: 0;">
        <%- body %>
    </main>

    <!-- Professional Footer -->
    <footer class="footer bg-primary text-white py-5 mt-5">
        <div class="container">
            <div class="row">
                <!-- Company Info -->
                <div class="col-lg-4 mb-4">
                    <div class="d-flex align-items-center mb-3">
                        <i class="fas fa-globe-americas fa-2x me-3"></i>
                        <h5 class="mb-0">Venture Global</h5>
                    </div>
                    <p class="mb-3">Profesyonel eğitim danışmanlığı ile hayallerinizi gerçeğe dönüştürüyoruz. Yurtdışı eğitim sürecinizde yanınızdayız.</p>
                    <div class="d-flex align-items-center">
                        <i class="fas fa-shield-alt me-2"></i>
                        <small>SSL Güvenli Bağlantı</small>
                    </div>
                </div>
                
                <!-- Quick Links -->
                <div class="col-lg-2 col-md-6 mb-4">
                    <h6 class="mb-3">Hızlı Linkler</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="/services" class="text-white-50 text-decoration-none">Hizmetler</a></li>
                        <li class="mb-2"><a href="/universities" class="text-white-50 text-decoration-none">Üniversiteler</a></li>
                        <li class="mb-2"><a href="/countries" class="text-white-50 text-decoration-none">Ülkeler</a></li>
                        <li class="mb-2"><a href="/contact" class="text-white-50 text-decoration-none">İletişim</a></li>
                    </ul>
                </div>
                
                <!-- Services -->
                <div class="col-lg-2 col-md-6 mb-4">
                    <h6 class="mb-3">Hizmetler</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="/assessment" class="text-white-50 text-decoration-none">Değerlendirme</a></li>
                        <li class="mb-2"><a href="/visa" class="text-white-50 text-decoration-none">Vize</a></li>
                        <li class="mb-2"><a href="/accommodation" class="text-white-50 text-decoration-none">Konaklama</a></li>
                    </ul>
                </div>
                
                <!-- Contact Info -->
                <div class="col-lg-4 mb-4">
                    <h6 class="mb-3">İletişim</h6>
                    <div class="mb-3">
                        <i class="fas fa-map-marker-alt me-2"></i>
                        <span>İstanbul, Türkiye</span>
                    </div>
                    <div class="mb-3">
                        <i class="fas fa-phone me-2"></i>
                        <span>+90 (212) 555 0123</span>
                    </div>
                    <div class="mb-3">
                        <i class="fas fa-envelope me-2"></i>
                        <span>info@ventureglobal.com</span>
                    </div>
                    
                    <!-- Social Media -->
                    <div class="d-flex gap-3 mt-4">
                        <a href="#" class="text-white-50 text-decoration-none"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="text-white-50 text-decoration-none"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="text-white-50 text-decoration-none"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="text-white-50 text-decoration-none"><i class="fab fa-linkedin-in"></i></a>
                    </div>
                </div>
            </div>
            
            <!-- Footer Bottom -->
            <div class="border-top border-white-25 pt-4 mt-4">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <small class="text-white-50">&copy; 2024 Venture Global. Tüm hakları saklıdır.</small>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <div class="d-flex gap-3 justify-content-md-end">
                            <small class="text-white-50">Gizlilik Politikası</small>
                            <small class="text-white-50">Kullanım Şartları</small>
                            <small class="text-white-50">KVKK</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Custom JS -->
    <script>
        // Logout functionality
        document.addEventListener('DOMContentLoaded', function() {
            const logoutLinks = document.querySelectorAll('a[href="/logout"]');
            logoutLinks.forEach(link => {
                link.addEventListener('click', function(e) {
                    e.preventDefault();
                    fetch('/logout', {
                        method: 'POST',
                        credentials: 'same-origin'
                    }).then(() => {
                        window.location.href = '/';
                    });
                });
            });
            
            // Language change functionality
            const languageOptions = document.querySelectorAll('.language-option');
            const currentLanguageSpan = document.getElementById('currentLanguage');
            
            languageOptions.forEach(option => {
                option.addEventListener('click', function(e) {
                    e.preventDefault();
                    const language = this.getAttribute('data-language');
                    
                    console.log('Language change requested:', language);
                    
                    // AJAX ile dil değiştirme isteği gönder
                    fetch('/change-language', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({ language: language })
                    })
                    .then(response => response.json())
                    .then(data => {
                        console.log('Language change response:', data);
                        
                        if (data.success) {
                            // Dil göstergesini güncelle
                            if (currentLanguageSpan) {
                                currentLanguageSpan.textContent = language.toUpperCase();
                            }
                            
                            // Navbar butonlarını güncelle
                            updateNavbarButtons(language);
                            
                            // Sayfayı yenile
                            window.location.reload();
                        } else {
                            console.error('Language change failed:', data.message);
                        }
                    })
                    .catch(error => {
                        console.error('Error changing language:', error);
                    });
                });
            });
            
            // Navbar butonlarını güncelleme fonksiyonu
            function updateNavbarButtons(language) {
                const loginBtn = document.querySelector('a[href="/login"]');
                const registerBtn = document.querySelector('a[href="/register"]');
                
                if (loginBtn) {
                    loginBtn.textContent = language === 'tr' ? 'Giriş Yap' : 'Login';
                }
                
                if (registerBtn) {
                    registerBtn.textContent = language === 'tr' ? 'Kayıt Ol' : 'Register';
                }
                
                console.log('Navbar buttons updated for language:', language);
            }
            
            // Hero Background Image Rotation
            const heroImages = document.querySelectorAll('.hero-bg-img');
            let currentImageIndex = 0;
            
            if (heroImages.length > 0) {
                // Show first image
                heroImages[0].classList.add('active');
                
                // Rotate images every 5 seconds
                setInterval(() => {
                    heroImages[currentImageIndex].classList.remove('active');
                    currentImageIndex = (currentImageIndex + 1) % heroImages.length;
                    heroImages[currentImageIndex].classList.add('active');
                }, 5000);
            }
        });
    </script>
</body>
</html> 