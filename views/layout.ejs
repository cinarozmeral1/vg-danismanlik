        color: #fbbf24;
        animation: cookieBounce 2s infinite;
    }
    
    @keyframes cookieBounce {
        0%, 100% { transform: rotate(0deg); }
        25% { transform: rotate(-10deg); }
        75% { transform: rotate(10deg); }
    }
    
        .cookie-text {
        flex: 1;
