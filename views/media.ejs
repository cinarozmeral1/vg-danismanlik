<!-- Hero Section -->
<section class="bg-primary text-white py-5">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center">
                <h1 class="display-4 fw-bold"><%= t.media.heroTitle %></h1>
                <p class="lead"><%= t.media.heroSubtitle %></p>
            </div>
        </div>
    </div>
</section>

<!-- Instagram Section -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <i class="fab fa-instagram fa-3x mb-3" style="color: #E1306C;"></i>
            <h2 class="fw-bold"><%= t.media.instagram.title %></h2>
            <p class="text-muted"><%= t.media.instagram.subtitle %></p>
        </div>
        
        <div class="row g-4 justify-content-center" id="instagram-feed">
            <!-- Instagram Reels Grid -->
            <!-- Reel 1 -->
            <div class="col-lg-4 col-md-6 mb-4">
<div style="background: white; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); overflow: hidden; max-width: 540px; margin: 0 auto;">
                    <iframe src="https://www.instagram.com/reel/DRfHW9ijQUa/embed/" width="100%" height="700" frameborder="0" scrolling="no" allowtransparency="true" allow="encrypted-media"></iframe>
                </div>
            </div>
            
            <!-- Reel 2 -->
            <div class="col-lg-4 col-md-6 mb-4">
<div style="background: white; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); overflow: hidden; max-width: 540px; margin: 0 auto;">
