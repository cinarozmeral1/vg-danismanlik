            <div class="col-lg-3 col-md-6">
                <div class="seo-card">
                    <div class="icon-circle"><i class="fas fa-newspaper"></i></div>
                    <h5>Blog</h5>
                    <p class="text-muted small mb-2"><%= lang === 'en' ? 'Study abroad articles' : 'Yurt dışı eğitim makaleleri' %></p>
                    <a href="/blog"><%= lang === 'en' ? 'Read' : 'Oku' %> <i class="fas fa-arrow-right ms-1"></i></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="seo-card">
                    <div class="icon-circle"><i class="fas fa-comments"></i></div>
