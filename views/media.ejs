                    <a href="/ulkede-universite/almanya"><%= lang === 'en' ? 'Explore' : 'İncele' %> <i class="fas fa-arrow-right ms-1"></i></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="seo-card">
                    <div class="icon-circle"><i class="fas fa-university"></i></div>
