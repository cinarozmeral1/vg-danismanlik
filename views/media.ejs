                    <p class="text-muted small mb-2"><%= lang === 'en' ? 'Free initial consultation' : 'Ücretsiz ön görüşme' %></p>
                    <a href="/contact"><%= lang === 'en' ? 'Contact' : 'İletişim' %> <i class="fas fa-arrow-right ms-1"></i></a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Deferred Instagram embed.js for performance -->
<script>
(function() {
    var s = document.createElement('script');
    s.async = true;
    s.defer = true;
    s.src = '//www.instagram.com/embed.js';
    document.body.appendChild(s);
})();
</script>
