<% const lang = typeof locals.lang !== 'undefined' ? locals.lang : (typeof locals.currentLanguage !== 'undefined' ? locals.currentLanguage : 'tr'); %>

<style>
.m-hero {
    background: linear-gradient(135deg, #003d6b 0%, #005A9E 50%, #0078D7 100%);
    padding: 80px 0 50px;
    position: relative;
    overflow: hidden;
}
.m-hero::after {
    content: '';
    position: absolute;
    top: -40%;
    right: -10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(255,255,255,0.06) 0%, transparent 70%);
    border-radius: 50%;
}
.m-hero h1 { font-size: 3.5rem; font-weight: 800; position: relative; z-index: 1; }
.m-hero .lead { opacity: 0.92; max-width: 680px; margin: 0 auto; position: relative; z-index: 1; font-size: 1.15rem; }

.m-section { padding: 60px 0; }
.m-section-alt { background: #f8f9fa; }

.m-section-title {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 10px;
}
.m-section-title h2 {
    font-size: 1.7rem;
    font-weight: 700;
    color: #1a1a2e;
    margin: 0;
}
.m-section-desc {
    color: #666;
    margin-bottom: 32px;
    max-width: 550px;
}

/* Instagram embed cards */
.ig-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
}
.ig-embed-card {
    background: #fff;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 2px 16px rgba(0,0,0,0.07);
    transition: transform 0.25s, box-shadow 0.25s;
}
.ig-embed-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 28px rgba(0,0,0,0.12);
}
.ig-embed-card {
    max-height: 520px;
    overflow: hidden;
}
.ig-embed-card .instagram-media {
    margin: 0 !important;
    min-width: 0 !important;
    max-width: 100% !important;
    width: 100% !important;
}

/* YouTube shorts */
.yt-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
}
.yt-short {
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 2px 14px rgba(0,0,0,0.08);
    background: #000;
    transition: transform 0.25s, box-shadow 0.25s;
}
.yt-short:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(255,0,0,0.16);
}
.yt-short iframe {
    display: block;
    width: 100%;
    aspect-ratio: 9/16;
    border: 0;
}

/* CTA buttons */
.btn-ig {
    background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
    color: #fff;
    border: none;
    font-weight: 600;
    padding: 14px 36px;
    border-radius: 10px;
    font-size: 1rem;
    transition: transform 0.2s, box-shadow 0.2s;
    max-width: 100%;
    white-space: normal;
}
.btn-ig:hover { transform: scale(1.04); box-shadow: 0 6px 20px rgba(225,48,108,0.35); color: #fff; }
.btn-yt {
    background: #FF0000;
    color: #fff;
    border: none;
    font-weight: 600;
    padding: 14px 36px;
    border-radius: 10px;
    font-size: 1rem;
    transition: transform 0.2s, box-shadow 0.2s;
    max-width: 100%;
    white-space: normal;
}
.btn-yt:hover { transform: scale(1.04); box-shadow: 0 6px 20px rgba(255,0,0,0.3); color: #fff; }

/* SEO links */
.seo-section { background: linear-gradient(135deg, #eef4fb 0%, #e3ecf7 100%); padding: 60px 0; }
.seo-card {
    background: #fff;
    border-radius: 14px;
    padding: 28px 22px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.05);
    transition: transform 0.2s, box-shadow 0.2s;
    text-align: center;
    height: 100%;
}
.seo-card:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,0,0,0.1); }
.seo-card .icon-circle {
    width: 56px; height: 56px;
    background: linear-gradient(135deg, #0078D7, #00BCF2);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 1.3rem;
    margin-bottom: 14px;
}
.seo-card h5 { font-weight: 700; color: #1a1a2e; font-size: 1rem; }
.seo-card a { color: #005A9E; font-weight: 600; text-decoration: none; font-size: 0.9rem; }
.seo-card a:hover { text-decoration: underline; }

@media (max-width: 991px) {
    .ig-row { grid-template-columns: repeat(2, 1fr); }
    .yt-row { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 767px) {
    .ig-row { grid-template-columns: 1fr; }
    .yt-row { grid-template-columns: repeat(2, 1fr); }
    .m-hero h1 { font-size: 2rem; }
    .btn-ig, .btn-yt { padding: 12px 20px; font-size: 0.93rem; }
}
@media (max-width: 480px) {
    .yt-row { grid-template-columns: 1fr; }
}
</style>

<!-- Hero -->
<section class="m-hero text-white text-center">
    <div class="container">
        <h1><%= t.media.heroTitle %></h1>
        <p class="lead mt-3"><%= lang === 'en' ? 'Campus tours, student experiences and study abroad tips.' : 'Kampüs turları, öğrenci deneyimleri ve yurt dışı eğitim ipuçları.' %></p>
    </div>
</section>

