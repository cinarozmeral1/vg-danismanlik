<!-- LinkedIn Section -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <i class="fab fa-linkedin fa-3x mb-3" style="color: #0077B5;"></i>
            <h2 class="fw-bold"><%= t.media.linkedin.title %></h2>
            <p class="text-muted"><%= t.media.linkedin.subtitle %></p>
        </div>
        
        <div class="row g-4" id="linkedin-feed">
            <!-- LinkedIn Posts Grid -->
            <!-- Placeholder for LinkedIn embeds -->
            <div class="col-12 text-center">
                <div class="alert alert-info" role="alert">
                    <i class="fab fa-linkedin fa-2x mb-3 d-block"></i>
                    <p class="mb-3"><%= t.media.linkedin.comingSoon || 'LinkedIn postlarımız yakında burada görünecek!' %></p>
                    <a href="https://www.linkedin.com/company/venture-global-consultancy-start-up/" target="_blank" rel="noopener" class="btn btn-primary">
                        <i class="fab fa-linkedin me-2"></i><%= t.media.linkedin.followButton || 'LinkedIn\'de Takip Et' %>
                    </a>
                </div>
            </div>
            
            <!-- Example LinkedIn Embed Structure (to be filled with actual posts)
            <div class="col-lg-4 col-md-6">
                <div class="card shadow-sm h-100" style="border: 2px solid #0077B5; border-radius: 12px; overflow: hidden;">
                    <div class="card-body p-0">
                        <iframe src="YOUR_LINKEDIN_EMBED_URL" height="500" width="100%" frameborder="0" allowfullscreen="" title="LinkedIn Post"></iframe>
                    </div>
                </div>
            </div>
            -->
        </div>
    </div>
</section>

<!-- Hover Effect CSS -->
<style>
.instagram-reel-card:hover {
    transform: scale(1.05);
}
.instagram-reel-card {
    cursor: pointer;
}
</style>

<!-- Call to Action -->
<section class="py-5 bg-primary text-white text-center">
    <div class="container">
        <h3 class="mb-4"><%= t.media.cta.title || 'Sosyal Medyada Bizi Takip Edin!' %></h3>
        <p class="lead mb-4"><%= t.media.cta.subtitle || 'Güncel haberler, öğrenci hikayeleri ve daha fazlası için sosyal medya hesaplarımızı takip edin.' %></p>
        <div class="d-flex justify-content-center gap-3">
            <a href="https://www.instagram.com/vg.danismanlik" target="_blank" rel="noopener" class="btn btn-light btn-lg">
                <i class="fab fa-instagram me-2"></i>Instagram
            </a>
            <a href="https://www.linkedin.com/company/venture-global-consultancy-start-up/" target="_blank" rel="noopener" class="btn btn-light btn-lg">
                <i class="fab fa-linkedin me-2"></i>LinkedIn
            </a>
        </div>
    </div>
</section>





