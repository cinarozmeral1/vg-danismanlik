            </div>
            <div class="ig-embed-card">
                <blockquote class="instagram-media" data-instgrm-permalink="https://www.instagram.com/p/DVJRuAxjXQH/" data-instgrm-version="14" style="background:#FFF; border:0; border-radius:3px; box-shadow:none; margin:0; padding:0; width:100%;"></blockquote>
            </div>
