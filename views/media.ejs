    <div class="container">
        <div class="m-section-title">
            <i class="fab fa-youtube fa-lg" style="color:#FF0000;"></i>
            <h2>YouTube Shorts</h2>
        </div>
        <p class="m-section-desc"><%= lang === 'en' ? 'Quick tips and campus tours — subscribe for study abroad content.' : 'Kısa videolarımız ile yurt dışı eğitim hakkında her şey — abone olun.' %></p>

        <div class="yt-row">
            <% const ytShorts = [
                'GF6aOzB72og', 'fVuZgMm1JQ8', 'pNj5EMNSSaE', 'dgao11VKd3E',
                'Jht5FjvOC-s', 'JFMODyS17J8', 'XKaOobmneNg', 'eoca6qNT0dE'
            ]; %>
            <% ytShorts.forEach(function(id) { %>
            <div class="yt-short">
                <iframe src="https://www.youtube-nocookie.com/embed/<%= id %>" title="VG Danışmanlık YouTube Short" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
            </div>
            <% }); %>
        </div>

        <div class="text-center mt-5">
            <a href="https://www.youtube.com/@VentureGlobal" target="_blank" rel="noopener" class="btn btn-yt">
                <i class="fab fa-youtube me-2"></i><%= t.media.youtube.subscribeButton %>
            </a>
        </div>
    </div>
</section>

<!-- SEO Internal Links -->
