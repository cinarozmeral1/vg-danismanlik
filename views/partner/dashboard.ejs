<!-- Main Content -->
<section class="section bg-light text-dark" style="min-height: 80vh;">
    <div class="container">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-lg-3 mb-4 d-none d-lg-block">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="fas fa-handshake me-2"></i>Partner Menüsü</h5>
                    </div>
                    <div class="list-group list-group-flush">
                        <a href="/partner/dashboard" class="list-group-item list-group-item-action active">
                            <i class="fas fa-tachometer-alt me-2"></i>Dashboard
                        </a>
                        <a href="#ogrencilerim" class="list-group-item list-group-item-action" onclick="scrollToSection('studentsSection')">
                            <i class="fas fa-users me-2"></i>Öğrencilerim
                            <span class="badge bg-primary float-end"><%= students.length %></span>
                        </a>
                        <a href="#kazanclarim" class="list-group-item list-group-item-action" onclick="scrollToSection('earningsSection')">
                            <i class="fas fa-euro-sign me-2"></i>Kazançlarım
                        </a>
                        <a href="/partner/settings" class="list-group-item list-group-item-action">
                            <i class="fas fa-cog me-2"></i>Ayarlar
                        </a>
                        <a href="#" class="list-group-item list-group-item-action text-danger" onclick="logout()">
                            <i class="fas fa-sign-out-alt me-2"></i>Çıkış Yap
                        </a>
                    </div>
                </div>
                
                <!-- Partner Info Card -->
                <div class="card shadow-sm mt-3">
                    <div class="card-header bg-secondary text-white">
                        <h6 class="mb-0"><i class="fas fa-info-circle me-2"></i>Partner Bilgileri</h6>
                    </div>
                    <div class="card-body">
                        <p class="mb-1"><strong><%= partner.first_name %> <%= partner.last_name %></strong></p>
                        <p class="mb-1 text-muted small"><%= partner.email %></p>
                        <% if (partner.company_name) { %>
                            <p class="mb-0 text-muted small"><i class="fas fa-building me-1"></i><%= partner.company_name %></p>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Main Content -->
            <div class="col-lg-9">
                <!-- Welcome Card -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0"><i class="fas fa-hand-wave me-2"></i>Hoş Geldiniz, <%= partner.first_name %>!</h4>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-0">Partner panelinizden öğrencilerinizi ve kazançlarınızı takip edebilirsiniz.</p>
                    </div>
                </div>

                <!-- Stats Cards -->
                <div class="row mb-4">
                    <div class="col-md-3 col-6 mb-3">
                        <div class="card shadow-sm h-100">
                            <div class="card-body text-center">
                                <i class="fas fa-users fa-2x text-primary mb-2"></i>
                                <h3 class="mb-0"><%= students.length %></h3>
                                <small class="text-muted">Toplam Öğrenci</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 col-6 mb-3">
                        <div class="card shadow-sm h-100">
                            <div class="card-body text-center">
                                <i class="fas fa-check-circle fa-2x text-success mb-2"></i>
                                <h3 class="mb-0"><%= earnings.filter(e => e.is_paid).reduce((sum, e) => sum + parseFloat(e.amount), 0).toFixed(2) %> €</h3>
                                <small class="text-muted">Ödenen Kazanç</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 col-6 mb-3">
                        <div class="card shadow-sm h-100">
                            <div class="card-body text-center">
                                <i class="fas fa-clock fa-2x text-warning mb-2"></i>
                                <h3 class="mb-0"><%= earnings.filter(e => !e.is_paid).reduce((sum, e) => sum + parseFloat(e.amount), 0).toFixed(2) %> €</h3>
                                <small class="text-muted">Bekleyen Kazanç</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 col-6 mb-3">
                        <div class="card shadow-sm h-100">
                            <div class="card-body text-center">
                                <i class="fas fa-wallet fa-2x text-info mb-2"></i>
                                <h3 class="mb-0"><%= earnings.reduce((sum, e) => sum + parseFloat(e.amount), 0).toFixed(2) %> €</h3>
                                <small class="text-muted">Toplam Kazanç</small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Students Section -->
                <div class="card shadow-sm mb-4" id="studentsSection">
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="fas fa-users me-2"></i>Öğrencilerim</h5>
                        <span class="badge bg-light text-primary"><%= students.length %> öğrenci</span>
                    </div>
                    <div class="card-body">
                        <% if (students.length === 0) { %>
                            <div class="text-center py-4">
                                <i class="fas fa-user-graduate fa-3x text-muted mb-3"></i>
                                <p class="text-muted">Henüz size atanmış öğrenci bulunmuyor.</p>
                            </div>
                        <% } else { %>
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Öğrenci</th>
                                            <th>E-posta</th>
                                            <th>Kayıt Tarihi</th>
                                            <th>Kazanç</th>
                                            <th>Durum</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% students.forEach(student => { 
                                            const studentEarnings = earnings.filter(e => e.user_id === student.id);
                                            const totalEarning = studentEarnings.reduce((sum, e) => sum + parseFloat(e.amount), 0);
                                            const isPaid = studentEarnings.length > 0 && studentEarnings.every(e => e.is_paid);
                                        %>
                                        <tr>
                                            <td>
                                                <strong><%= student.first_name %> <%= student.last_name %></strong>
                                            </td>
                                            <td><%= student.email %></td>
                                            <td><%= (() => { const d = new Date(student.created_at); return String(d.getUTCDate()).padStart(2,'0') + '.' + String(d.getUTCMonth()+1).padStart(2,'0') + '.' + d.getUTCFullYear(); })() %></td>
                                            <td>
                                                <% if (totalEarning > 0) { %>
                                                    <strong class="text-success"><%= totalEarning.toFixed(2) %> €</strong>
                                                <% } else { %>
                                                    <span class="text-muted">-</span>
                                                <% } %>
                                            </td>
                                            <td>
                                                <% if (studentEarnings.length === 0) { %>
                                                    <span class="badge bg-secondary">Kazanç Yok</span>
                                                <% } else if (isPaid) { %>
                                                    <span class="badge bg-success">Ödendi</span>
                                                <% } else { %>
                                                    <span class="badge bg-warning text-dark">Beklemede</span>
                                                <% } %>
                                            </td>
                                        </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        <% } %>
                    </div>
                </div>

                <!-- Earnings Section -->
                <div class="card shadow-sm" id="earningsSection">
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="fas fa-euro-sign me-2"></i>Kazanç Detayları</h5>
                        <span class="badge bg-light text-primary"><%= earnings.length %> kayıt</span>
                    </div>
                    <div class="card-body">
                        <% if (earnings.length === 0) { %>
                            <div class="text-center py-4">
                                <i class="fas fa-coins fa-3x text-muted mb-3"></i>
                                <p class="text-muted">Henüz kazanç kaydı bulunmuyor.</p>
                            </div>
                        <% } else { %>
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Öğrenci</th>
                                            <th>Tutar</th>
                                            <th>Ödeme Tarihi</th>
                                            <th>Durum</th>
                                            <th>Not</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% earnings.forEach(earning => { %>
                                        <tr>
                                            <td><strong><%= earning.student_name %></strong></td>
                                            <td><strong class="text-success"><%= parseFloat(earning.amount).toFixed(2) %> <%= earning.currency %></strong></td>
                                            <td>
                                                <% if (earning.is_paid && earning.earning_date) { %>
                                                    <%= (() => { const d = new Date(earning.earning_date); return String(d.getUTCDate()).padStart(2,'0') + '.' + String(d.getUTCMonth()+1).padStart(2,'0') + '.' + d.getUTCFullYear(); })() %>
                                                <% } else { %>
                                                    <span class="text-muted">-</span>
                                                <% } %>
                                            </td>
                                            <td>
                                                <% if (earning.is_paid) { %>
                                                    <span class="badge bg-success"><i class="fas fa-check me-1"></i>Ödendi</span>
                                                <% } else { %>
                                                    <span class="badge bg-warning text-dark"><i class="fas fa-clock me-1"></i>Beklemede</span>
                                                <% } %>
                                            </td>
                                            <td><%= earning.notes || '-' %></td>
                                        </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                            
                            <!-- Summary -->
                            <div class="row mt-4">
                                <div class="col-md-4">
                                    <div class="alert alert-success mb-0">
                                        <strong><i class="fas fa-check-circle me-2"></i>Ödenen:</strong>
                                        <%= earnings.filter(e => e.is_paid).reduce((sum, e) => sum + parseFloat(e.amount), 0).toFixed(2) %> €
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="alert alert-warning mb-0">
                                        <strong><i class="fas fa-clock me-2"></i>Bekleyen:</strong>
                                        <%= earnings.filter(e => !e.is_paid).reduce((sum, e) => sum + parseFloat(e.amount), 0).toFixed(2) %> €
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="alert alert-info mb-0">
                                        <strong><i class="fas fa-wallet me-2"></i>Toplam:</strong>
                                        <%= earnings.reduce((sum, e) => sum + parseFloat(e.amount), 0).toFixed(2) %> €
                                    </div>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    function scrollToSection(sectionId) {
        const element = document.getElementById(sectionId);
        if (element) {
            element.scrollIntoView({ behavior: 'smooth' });
        }
    }

    function logout() {
        fetch('/api/auth/partner-logout', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include'
        })
        .then(response => response.json())
        .then(data => {
            window.location.href = '/login';
        })
        .catch(error => {
            console.error('Logout error:', error);
            // Clear cookie manually and redirect
            document.cookie = 'partnerToken=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;';
            window.location.href = '/login';
        });
    }

    document.addEventListener('DOMContentLoaded', function() {
        // Handle logout from dropdown if exists
        document.querySelectorAll('[data-action="partner-logout"]').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                logout();
            });
        });
    });
</script>
