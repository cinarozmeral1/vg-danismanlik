<div class="partners-page">
    <section class="partner-hero bestschool-hero py-5">
        <div class="container">
            <div class="row align-items-center g-4">
                <div class="col-md-4">
                    <div class="partner-logo-card p-4 bg-white shadow-sm rounded-4 text-center">
                        <div style="background: #1e4c72; padding: 2.5rem 1.5rem; border-radius: 12px; display: flex; align-items: center; justify-content: center; gap: 1rem;">
                            <i class="fas fa-graduation-cap" style="font-size: 3.5rem; color: #fff;"></i>
                            <div style="display: flex; flex-direction: column; align-items: flex-start;">
                                <div style="font-size: 1.8rem; font-weight: bold; color: #fff; line-height: 1; text-shadow: 1px 1px 2px rgba(0,0,0,0.3);">Best</div>
                                <div style="font-size: 1.8rem; font-weight: bold; color: #fff; line-height: 1; text-shadow: 1px 1px 2px rgba(0,0,0,0.3);">School</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-8">
                    <div class="partner-hero-text">
                        <span class="partner-badge text-primary bg-light">Best School Prague</span>
                        <h1 class="display-5 fw-bold mt-3 text-dark">
                            <% if (currentLanguage === 'en') { %>
                                Your Path to Czech Universities
                            <% } else { %>
                                Çekya Üniversitelerine Yolunuz
                            <% } %>
                        </h1>
                        <p class="lead text-body-secondary mb-3">
                            <% if (currentLanguage === 'en') { %>
                                Accredited foundation programs and comprehensive support for international students
                            <% } else { %>
                                Akredite hazırlık programları ve uluslararası öğrenciler için kapsamlı destek
                            <% } %>
                        </p>
                        <a href="https://bestschool.cz/en/home/" target="_blank" rel="noopener" class="partner-hero-link">
                            <i class="fas fa-external-link-alt me-2"></i>
                            <% if (currentLanguage === 'en') { %>Visit Best School Official Website<% } else { %>Best School Resmi Sitesini Ziyaret Et<% } %>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Introduction Section -->
<section class="section py-5">
    <div class="container">
            <div class="row g-4 align-items-stretch">
                <div class="col-lg-7">
                    <article class="partner-card h-100">
                        <h2 class="fw-bold text-dark mb-3">
                            <% if (currentLanguage === 'en') { %>
                                About Best School Prague
                            <% } else { %>
                                Best School Prague Hakkında
                            <% } %>
                        </h2>
                        <% if (currentLanguage === 'en') { %>
                            <p>Best School Prague is an accredited provider that supports international students on their full journey into Czech universities. It offers annual and semi-annual foundation programs, practical help with visas and relocation, and strong university partnerships that align students with the right programs.</p>
                        <% } else { %>
                            <p>Best School Prague, uluslararası öğrencilerin Çekya'da üniversiteye yerleşmesine baştan sona destek veren akredite bir kurumdur. Yıllık ve yarıyıllık hazırlık programları sunar. Vize ve taşınma adımlarında pratik destek verir. Üniversite iş birlikleriyle öğrenciyi uygun bölümlere yönlendirir.</p>
                        <% } %>
                    </article>
                </div>
                <div class="col-lg-5">
                    <div class="partner-card shadow-sm h-100">
                        <h2 class="fw-bold text-dark mb-3">
                            <% if (currentLanguage === 'en') { %>
                                Why Choose Best School
                            <% } else { %>
                                Neden Best School
                            <% } %>
                        </h2>
                        <ul class="list-unstyled">
                            <% if (currentLanguage === 'en') { %>
                                <li><i class="fas fa-certificate text-primary me-2"></i>Accreditation and strong university partnerships</li>
                                <li><i class="fas fa-shield-alt text-primary me-2"></i>End-to-end support covering visa and relocation</li>
                                <li><i class="fas fa-map-marked-alt text-primary me-2"></i>Clear pathway from foundation to university placement</li>
                                <li><i class="fas fa-users text-primary me-2"></i>Comprehensive student support services</li>
                            <% } else { %>
                                <li><i class="fas fa-certificate text-primary me-2"></i>Akreditasyon ve güçlü üniversite ortaklıkları</li>
                                <li><i class="fas fa-shield-alt text-primary me-2"></i>Vize ve taşınma dâhil uçtan uca destek</li>
                                <li><i class="fas fa-map-marked-alt text-primary me-2"></i>Hazırlıktan üniversite yerleşimine net yol haritası</li>
                                <li><i class="fas fa-users text-primary me-2"></i>Kapsamlı öğrenci destek hizmetleri</li>
                            <% } %>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Programs Section -->
    <section class="section py-5 bg-light">
        <div class="container">
            <div class="row g-4">
                <div class="col-12 text-center mb-4">
                    <h2 class="fw-bold text-dark">
                        <% if (currentLanguage === 'en') { %>
                            Programs and Packages
                        <% } else { %>
                            Programlar ve Paketler
                        <% } %>
                    </h2>
                </div>

                <!-- FOUNDATION English Program -->
                <div class="col-lg-6">
                    <div class="partner-card shadow-sm h-100">
                        <h3 class="fw-bold text-primary mb-3">
                            <% if (currentLanguage === 'en') { %>
                                FOUNDATION English Preparatory Program
                            <% } else { %>
                                FOUNDATION İngilizce Hazırlık Programı
                            <% } %>
                        </h3>
                        <% if (currentLanguage === 'en') { %>
                            <p><strong>Goal:</strong> Progress from A2 to C1 within one academic year and start English-taught degrees with confidence.</p>
                            <p><strong>Includes:</strong> One year at a Czech state university, visa support, year-long curator support, trips across Czechia and Europe.</p>
                            <p><strong>Audience:</strong> Students targeting bachelor or master programs in English.</p>
                            <p class="text-muted"><small><strong>Note:</strong> The Assistance support can be offered free during certain campaigns.</small></p>
                        <% } else { %>
                            <p><strong>Hedef:</strong> Bir akademik yıl içinde A2 seviyesinden C1 seviyesine yükselmek ve İngilizce programlara güçlü başlangıç yapmak.</p>
                            <p><strong>İçerik:</strong> Bir yıl bir Çek devlet üniversitesinde eğitim, vize desteği, yıl boyu küratörlük desteği, Çekya ve Avrupa içi geziler.</p>
                            <p><strong>Kitle:</strong> İngilizce lisans ve yüksek lisans düşünen öğrenciler.</p>
                            <p class="text-muted"><small><strong>Not:</strong> Dönemsel kampanyalarda Assistance desteği ücretsiz sunulabilir.</small></p>
                        <% } %>
                    </div>
                </div>

                <!-- FOUNDATION Czech Program -->
                <div class="col-lg-6">
                    <div class="partner-card shadow-sm h-100">
                        <h3 class="fw-bold text-primary mb-3">
                            <% if (currentLanguage === 'en') { %>
                                FOUNDATION Czech Preparatory Program
                            <% } else { %>
                                FOUNDATION Çekçe Hazırlık Programı
                            <% } %>
                        </h3>
                        <% if (currentLanguage === 'en') { %>
                            <p><strong>Goal:</strong> Build Czech proficiency quickly and prepare for admission to public universities.</p>
                            <p><strong>Includes:</strong> Intensive classes with qualified teachers, admission guidance, full Czech environment for daily practice.</p>
                            <p><strong>Duration:</strong> Annual and semi-annual tracks.</p>
                            <p><strong>Outcome:</strong> For students who reach the required level, the pathway to tuition-free study at public universities opens.</p>
                        <% } else { %>
                            <p><strong>Hedef:</strong> Yoğun Çekçe eğitimle kısa sürede yeterlilik kazanmak ve devlet üniversitelerine giriş için hazırlanmak.</p>
                            <p><strong>İçerik:</strong> Nitelikli eğitmenlerle yoğun ders, başvuru ve kabul sürecine hazırlık, tam Çekçe ortamında pratik.</p>
                            <p><strong>Süre:</strong> Yıllık ve yarıyıllık seçenekler.</p>
                            <p><strong>Çıktı:</strong> Gerekli dil düzeyine ulaşan öğrenciler için kamu üniversitelerinde harçsız eğitim yolunun açılması.</p>
                        <% } %>
                    </div>
                </div>

                <!-- ASSISTANCE Program -->
                <div class="col-lg-6">
                    <div class="partner-card shadow-sm h-100">
                        <h3 class="fw-bold text-primary mb-3">
                            <% if (currentLanguage === 'en') { %>
                                ASSISTANCE Support Program
                            <% } else { %>
                                ASSISTANCE Destek Programı
                            <% } %>
                        </h3>
                        <% if (currentLanguage === 'en') { %>
                            <p><strong>Scope:</strong> Around eighteen months of continuous guidance.</p>
                            <p><strong>Services:</strong> Visa resolution, airport pickup, housing arrangement, first steps in the city.</p>
                            <p><strong>Timeline:</strong> From application to arrival and adaptation in Prague.</p>
                        <% } else { %>
                            <p><strong>Kapsam:</strong> Yaklaşık on sekiz ay uçtan uca takip.</p>
                            <p><strong>Hizmetler:</strong> Vize çözümü, havaalanında karşılama, konaklama yerleştirme, şehirde ilk uyum adımları.</p>
                            <p><strong>Zamanlama:</strong> Başvurudan Prag'a varışa ve uyum dönemine kadar kesintisiz destek.</p>
                        <% } %>
                    </div>
                </div>

                <!-- Summer Language Camp -->
                <div class="col-lg-6">
                    <div class="partner-card shadow-sm h-100">
                        <h3 class="fw-bold text-primary mb-3">
                            <% if (currentLanguage === 'en') { %>
                                Summer Language Camp in Czechia
                            <% } else { %>
                                Yaz Dil Kampı Çekya
                            <% } %>
                        </h3>
                        <% if (currentLanguage === 'en') { %>
                            <p><strong>Includes:</strong> English or Czech lessons with native speakers, tickets for trips and cultural visits, three meals a day, public transport card, local sim card, learning materials.</p>
                            <p><strong>Optional:</strong> Faculty-themed add-ons are available.</p>
                            <p><strong>Audience:</strong> High school students and gap year planners.</p>
                        <% } else { %>
                            <p><strong>İçerik:</strong> Anadili İngilizce veya Çekçe olan eğitmenlerle dersler, tüm gezi ve etkinlik biletleri, üç öğün yemek, şehir içi ulaşım kartı, yerel sim kart, eğitim materyalleri.</p>
                            <p><strong>İsteğe bağlı:</strong> Fakülte ve alan tanıtım ekleri bulunur.</p>
                            <p><strong>Kitle:</strong> Lise öğrencileri ve hazırlık yılı planlayanlar.</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Accommodation Section -->
    <section class="section py-5">
        <div class="container">
            <div class="row g-4 align-items-center">
                <div class="col-lg-6">
                    <div class="partner-card shadow-sm h-100">
                        <h2 class="fw-bold text-dark mb-3">
                            <% if (currentLanguage === 'en') { %>
                                Accommodation Options
                            <% } else { %>
                                Konaklama Seçenekleri
                            <% } %>
                        </h2>
                        <% if (currentLanguage === 'en') { %>
                            <p>Best School offers two premium accommodation options to ensure students have a safe and comfortable start in Prague.</p>
                            <ul class="list-unstyled">
                                <li class="mb-3"><i class="fas fa-home text-primary me-2"></i><strong>Bro-coli Co-living:</strong> Fully equipped one and two-room apartments</li>
                                <li class="mb-3"><i class="fas fa-building text-primary me-2"></i><strong>Fabrika Apartments Campus:</strong> Premium apartment-style campus with two-person units</li>
                            </ul>
                            <p class="mb-0"><strong>Purpose:</strong> Safe and comfortable housing for a smooth start.</p>
                        <% } else { %>
                            <p>Best School, öğrencilerin Prag'da güvenli ve konforlu bir başlangıç yapması için iki premium konaklama seçeneği sunar.</p>
                            <ul class="list-unstyled">
                                <li class="mb-3"><i class="fas fa-home text-primary me-2"></i><strong>Bro-coli Co-living:</strong> Tam donanımlı bir ve iki odalı daireler</li>
                                <li class="mb-3"><i class="fas fa-building text-primary me-2"></i><strong>Fabrika Apartments Kampüsü:</strong> İki kişilik birimler bulunan premium daire tipi kampüs</li>
                            </ul>
                            <p class="mb-0"><strong>Amaç:</strong> Güvenli, konforlu ve okula hızlı uyum.</p>
                        <% } %>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="partner-cta">
                        <h2 class="fw-bold text-dark mb-3">
                            <% if (currentLanguage === 'en') { %>
                                Special Packages Available
                            <% } else { %>
                                Özel Paketler
                            <% } %>
                        </h2>
                        <% if (currentLanguage === 'en') { %>
                            <p class="mb-4 text-body-secondary">Special discounted packages are now available exclusively for Venture Global students. Turn your dream of studying in Czechia into reality with us.</p>
                        <% } else { %>
                            <p class="mb-4 text-body-secondary">Venture Global öğrencilerine özel indirimli paketler şimdi erişilebilir. Çekya'da eğitim hayalinizi bizimle gerçeğe dönüştürün.</p>
                        <% } %>
                        <a href="/contact" class="btn btn-primary btn-lg w-100" style="font-size: clamp(0.875rem, 2vw, 1rem); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                            <span class="d-none d-sm-inline">
                                <% if (currentLanguage === 'en') { %>
                                    Request Package Details
                                <% } else { %>
                                    Paket Detaylarını İsteyin
                                <% } %>
                            </span>
                            <span class="d-sm-none">
                                <% if (currentLanguage === 'en') { %>
                                    Package Details
                                <% } else { %>
                                    Paket Detayları
                                <% } %>
                            </span>
                        </a>
                    </div>
            </div>
        </div>
    </div>
</section>

    <!-- Additional Programs Section -->
    <section class="section py-5 bg-light">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-6">
                    <div class="partner-card shadow-sm h-100">
                        <h3 class="fw-bold text-primary mb-3">
                            <% if (currentLanguage === 'en') { %>
                                Online Career Test
                            <% } else { %>
                                Online Kariyer Testi
                            <% } %>
                        </h3>
                        <% if (currentLanguage === 'en') { %>
                            <p><strong>Package:</strong> Four assessments and a one-to-one online consultation with a specialist.</p>
                            <p><strong>Goal:</strong> Data-informed choice of program and career.</p>
                        <% } else { %>
                            <p><strong>Paket:</strong> Dört ayrı değerlendirme ve ardından uzmanla bire bir çevrim içi görüşme.</p>
                            <p><strong>Amaç:</strong> Program ve meslek seçimine veri temelli yön vermek.</p>
                        <% } %>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="partner-card shadow-sm h-100">
                        <h3 class="fw-bold text-primary mb-3">
                            <% if (currentLanguage === 'en') { %>
                                Additional Program
                            <% } else { %>
                                Ek Program
                            <% } %>
                        </h3>
                        <% if (currentLanguage === 'en') { %>
                            <p>Accredited Ukrainian secondary school option in central Prague.</p>
                        <% } else { %>
                            <p>Prag merkezinde akredite Ukrayna lise programı seçeneği.</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
