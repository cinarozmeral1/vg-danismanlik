<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Google Fonts - Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
    
    <style>
        .programs-hero {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 80px 0;
            margin-bottom: 60px;
        }
        
        .program-card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            margin-bottom: 30px;
            overflow: hidden;
        }
        
        .program-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.15);
        }
        
        .program-header {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            color: white;
            padding: 20px;
            position: relative;
        }
        
        .university-logo {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            font-weight: bold;
            color: #333;
            margin-bottom: 15px;
        }
        
        .level-badge {
            position: absolute;
            top: 15px;
            right: 15px;
            background: rgba(255,255,255,0.2);
            color: white;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }
        
        .program-body {
            padding: 25px;
        }
        
        .field-of-study {
            color: #6c757d;
            font-size: 14px;
            margin-bottom: 15px;
        }
        
        .program-details {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 10px;
        }
        
        .detail-item {
            text-align: center;
            flex: 1;
            min-width: 100px;
        }
        
        .detail-value {
            font-size: 18px;
            font-weight: 600;
            color: #333;
        }
        
        .detail-label {
            font-size: 12px;
            color: #6c757d;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .requirements {
            background: #f8f9fa;
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 20px;
        }
        
        .requirements h6 {
            color: #495057;
            margin-bottom: 10px;
        }
        
        .filter-section {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.08);
            margin-bottom: 40px;
        }
        
        .filter-group {
            margin-bottom: 20px;
        }
        
        .filter-label {
            font-weight: 600;
            color: #495057;
            margin-bottom: 8px;
        }
        
        .stats-section {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 40px 0;
            margin-bottom: 60px;
            border-radius: 15px;
        }
        
        .stat-item {
            text-align: center;
        }
        
        .stat-number {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 10px;
        }
        
        .stat-label {
            font-size: 1rem;
            opacity: 0.9;
        }
        
        .back-to-top {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 50%;
            width: 50px;
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s ease;
            opacity: 0;
            visibility: hidden;
        }
        
        .back-to-top.show {
            opacity: 1;
            visibility: visible;
        }
        
        .back-to-top:hover {
            transform: scale(1.1);
        }
        
        @media (max-width: 768px) {
            .programs-hero {
                padding: 60px 0;
                margin-bottom: 40px;
            }
            
            .program-details {
                flex-direction: column;
                text-align: center;
            }
            
            .detail-item {
                min-width: auto;
            }
        }
    </style>
</head>
<body>
    <!-- Hero Section -->
    <section class="programs-hero">
        <div class="container">
            <div class="row text-center">
                <div class="col-lg-8 mx-auto">
                    <h1 class="display-4 fw-bold mb-4">
                        <i class="fas fa-graduation-cap me-3"></i>
                        Avrupa'da Eğitim Programları
                    </h1>
                    <p class="lead mb-0">
                        Prestijli üniversitelerde, kaliteli eğitim programları ile geleceğinizi şekillendirin
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
        <div class="container">
            <div class="row">
                <div class="col-md-3 col-6">
                    <div class="stat-item">
                        <div class="stat-number"><%= programs.length %></div>
                        <div class="stat-label">Toplam Program</div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="stat-item">
                        <div class="stat-number"><%= [...new Set(programs.map(p => p.university_country))].length %></div>
                        <div class="stat-label">Ülke</div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="stat-item">
                        <div class="stat-number"><%= [...new Set(programs.map(p => p.level))].length %></div>
                        <div class="stat-label">Eğitim Seviyesi</div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="stat-item">
                        <div class="stat-number"><%= [...new Set(programs.map(p => p.language))].length %></div>
                        <div class="stat-label">Eğitim Dili</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Filters Section -->
    <section class="filter-section">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <h4 class="mb-4">
                        <i class="fas fa-filter me-2"></i>
                        Program Filtreleme
                    </h4>
                </div>
            </div>
            <div class="row">
                <div class="col-md-3">
                    <div class="filter-group">
                        <label class="filter-label">Ülke</label>
                        <select class="form-select" id="countryFilter">
                            <option value="">Tüm Ülkeler</option>
                            <% [...new Set(programs.map(p => p.university_country))].sort().forEach(country => { %>
                                <option value="<%= country %>"><%= country %></option>
                            <% }); %>
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="filter-group">
                        <label class="filter-label">Eğitim Seviyesi</label>
                        <select class="form-select" id="levelFilter">
                            <option value="">Tüm Seviyeler</option>
                            <% [...new Set(programs.map(p => p.level))].sort().forEach(level => { %>
                                <option value="<%= level %>"><%= level %></option>
                            <% }); %>
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="filter-group">
                        <label class="filter-label">Eğitim Dili</label>
                        <select class="form-select" id="languageFilter">
                            <option value="">Tüm Diller</option>
                            <% [...new Set(programs.map(p => p.language))].sort().forEach(language => { %>
                                <option value="<%= language %>"><%= language %></option>
                            <% }); %>
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="filter-group">
                        <label class="filter-label">Alan</label>
                        <select class="form-select" id="fieldFilter">
                            <option value="">Tüm Alanlar</option>
                            <% [...new Set(programs.map(p => p.field_of_study))].sort().forEach(field => { %>
                                <option value="<%= field %>"><%= field %></option>
                            <% }); %>
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Programs Section -->
    <section class="container mb-5">
        <div class="row" id="programsContainer">
            <% programs.forEach(program => { %>
                <div class="col-lg-6 col-xl-4 program-item" 
                     data-country="<%= program.university_country %>"
                     data-level="<%= program.level %>"
                     data-language="<%= program.language %>"
                     data-field="<%= program.field_of_study %>">
                    
                    <div class="card program-card">
                        <div class="program-header">
                            <div class="level-badge"><%= program.level %></div>
                            <div class="university-logo">
                                <i class="fas fa-university"></i>
                            </div>
                            <h5 class="mb-2"><%= program.name %></h5>
                            <p class="mb-0">
                                <i class="fas fa-map-marker-alt me-2"></i>
                                <%= program.university_name %>, <%= program.university_country %>
                            </p>
                        </div>
                        
                        <div class="program-body">
                            <div class="field-of-study">
                                <i class="fas fa-book me-2"></i>
                                <%= program.field_of_study %>
                            </div>
                            
                            <div class="program-details">
                                <div class="detail-item">
                                    <div class="detail-value"><%= program.duration_months %></div>
                                    <div class="detail-label">Ay</div>
                                </div>
                                <div class="detail-item">
                                    <div class="detail-value">
                                        <% if (program.tuition_fee) { %>
                                            <%= program.currency %> <%= program.tuition_fee.toLocaleString() %>
                                        <% } else { %>
                                            -
                                        <% } %>
                                    </div>
                                    <div class="detail-label">Yıllık Ücret</div>
                                </div>
                                <div class="detail-item">
                                    <div class="detail-value"><%= program.language %></div>
                                    <div class="detail-label">Eğitim Dili</div>
                                </div>
                            </div>
                            
                            <% if (program.requirements) { %>
                                <div class="requirements">
                                    <h6><i class="fas fa-clipboard-list me-2"></i>Gereksinimler</h6>
                                    <p class="mb-0 small"><%= program.requirements %></p>
                                </div>
                            <% } %>
                            
                            <% if (program.description) { %>
                                <p class="text-muted small mb-3"><%= program.description %></p>
                            <% } %>
                            
                            <div class="d-grid">
                                <a href="/universities/<%= program.university_id %>" class="btn btn-outline-primary">
                                    <i class="fas fa-info-circle me-2"></i>
                                    Üniversite Detayı
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
        
        <!-- No Results Message -->
        <div id="noResults" class="text-center py-5" style="display: none;">
            <i class="fas fa-search fa-3x text-muted mb-3"></i>
            <h4 class="text-muted">Sonuç Bulunamadı</h4>
            <p class="text-muted">Seçtiğiniz kriterlere uygun program bulunamadı. Lütfen filtreleri değiştirin.</p>
        </div>
    </section>

    <!-- Back to Top Button -->
    <button class="back-to-top" id="backToTop">
        <i class="fas fa-arrow-up"></i>
    </button>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        // Filter functionality
        function filterPrograms() {
            const countryFilter = document.getElementById('countryFilter').value;
            const levelFilter = document.getElementById('levelFilter').value;
            const languageFilter = document.getElementById('languageFilter').value;
            const fieldFilter = document.getElementById('fieldFilter').value;
            
            const programItems = document.querySelectorAll('.program-item');
            let visibleCount = 0;
            
            programItems.forEach(item => {
                const country = item.dataset.country;
                const level = item.dataset.level;
                const language = item.dataset.language;
                const field = item.dataset.field;
                
                const countryMatch = !countryFilter || country === countryFilter;
                const levelMatch = !levelFilter || level === levelFilter;
                const languageMatch = !languageFilter || language === languageFilter;
                const fieldMatch = !fieldFilter || field === fieldFilter;
                
                if (countryMatch && levelMatch && languageMatch && fieldMatch) {
                    item.style.display = 'block';
                    visibleCount++;
                } else {
                    item.style.display = 'none';
                }
            });
            
            // Show/hide no results message
            const noResults = document.getElementById('noResults');
            if (visibleCount === 0) {
                noResults.style.display = 'block';
            } else {
                noResults.style.display = 'none';
            }
        }
        
        // Add event listeners to filters
        document.getElementById('countryFilter').addEventListener('change', filterPrograms);
        document.getElementById('levelFilter').addEventListener('change', filterPrograms);
        document.getElementById('languageFilter').addEventListener('change', filterPrograms);
        document.getElementById('fieldFilter').addEventListener('change', filterPrograms);
        
        // Back to top functionality
        const backToTop = document.getElementById('backToTop');
        
        window.addEventListener('scroll', () => {
            if (window.pageYOffset > 300) {
                backToTop.classList.add('show');
            } else {
                backToTop.classList.remove('show');
            }
        });
        
        backToTop.addEventListener('click', () => {
            window.scrollTo({
                top: 0,
                behavior: 'smooth'
            });
        });
        
        // Initialize filters
        filterPrograms();
    </script>
</body>
</html>
