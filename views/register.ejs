                            <div class="col-12 mb-2">
                                <small class="text-muted fw-bold"><i class="fas fa-info-circle me-1"></i><%= currentLanguage === 'tr' ? 'Ek Bilgiler (Opsiyonel)' : 'Additional Info (Optional)' %></small>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="desired_country" class="form-label">
                                    <i class="fas fa-globe me-2 text-primary"></i>
                                    <%= currentLanguage === 'tr' ? 'Gitmek İstediği Ülke' : 'Desired Country' %>
                                </label>
                                <input type="text" class="form-control" id="desired_country" name="desired_country"
                                       placeholder="<%= currentLanguage === 'tr' ? 'Örn: Almanya' : 'e.g. Germany' %>">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="current_school" class="form-label">
                                    <i class="fas fa-school me-2 text-primary"></i>
