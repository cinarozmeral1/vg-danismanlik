<!DOCTYPE html>
<html lang="<%= currentLanguage %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t.auth.register.title %> - Venture Global</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>


    <!-- Register Section -->
    <section class="section bg-light text-dark" style="margin-top: 100px; min-height: 80vh;">
        <div class="container-fluid px-4">
            <div class="row justify-content-center">
                <div class="col-xl-10 col-lg-11 col-md-12">
                    <div class="card shadow-lg">
                        <div class="card-header bg-primary text-white text-center">
                            <h3 class="mb-0">
                                <i class="fas fa-user-plus me-2"></i>
                                <%= t.auth.register.title %>
                            </h3>
                        </div>
                        <div class="card-body p-4">
                            <div id="alertContainer"></div>
                            
                            <form id="registerForm">
                                <div class="row">
                                    <!-- Personal Information -->
                                    <div class="col-md-6">
                                        <h5 class="mb-3">
                                            <i class="fas fa-user me-2"></i>
                                            <%= t.auth.register.personalInfo %>
                                        </h5>
                                        
                                        <div class="mb-3">
                                            <label for="first_name" class="form-label">
                                                <i class="fas fa-user me-2"></i>
                                                <%= t.auth.register.firstName %> *
                                            </label>
                                            <input type="text" class="form-control" id="first_name" name="first_name" required>
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label for="last_name" class="form-label">
                                                <i class="fas fa-user me-2"></i>
                                                <%= t.auth.register.lastName %> *
                                            </label>
                                            <input type="text" class="form-control" id="last_name" name="last_name" required>
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label for="email" class="form-label">
                                                <i class="fas fa-envelope me-2"></i>
                                                <%= t.auth.register.email %> *
                                            </label>
                                            <input type="email" class="form-control" id="email" name="email" required>
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label for="tc_number" class="form-label">
                                                <i class="fas fa-id-card me-2"></i>
                                                <%= t.auth.register.tcNumber %> *
                                            </label>
                                            <input type="text" class="form-control" id="tc_number" name="tc_number" maxlength="11" pattern="[0-9]{11}" oninput="this.value = this.value.replace(/[^0-9]/g, '')" required>
                                            <div class="form-text"><%= t.auth.register.tcNumberHelp %></div>
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label for="phone" class="form-label">
                                                <i class="fas fa-phone me-2"></i>
                                                <%= t.auth.register.phone %> *
                                            </label>
                                            <input type="tel" class="form-control" id="phone" name="phone" oninput="this.value = this.value.replace(/[^0-9]/g, '')" required>
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label for="password" class="form-label">
                                                <i class="fas fa-lock me-2"></i>
                                                <%= t.auth.register.password %> *
                                            </label>
                                            <input type="password" class="form-control" id="password" name="password" required>
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label for="confirm_password" class="form-label">
                                                <i class="fas fa-lock me-2"></i>
                                                <%= t.auth.register.confirmPassword %> *
                                            </label>
                                            <input type="password" class="form-control" id="confirm_password" name="confirm_password" required>
                                        </div>
                                    </div>
                                    
                                    <!-- Academic Information -->
                                    <div class="col-md-6">
                                        <h5 class="mb-3">
                                            <i class="fas fa-graduation-cap me-2"></i>
                                            <%= t.auth.register.academicInfo %>
                                        </h5>
                                        
                                        <div class="mb-3">
                                            <label for="english_level" class="form-label">
                                                <i class="fas fa-language me-2"></i>
                                                <%= t.auth.register.englishLevel %> *
                                            </label>
                                            <select class="form-select" id="english_level" name="english_level" required>
                                                <option value=""><%= t.auth.register.selectEnglishLevel %></option>
                                                <option value="A1">A1</option>
                                                <option value="A2">A2</option>
                                                <option value="B1">B1</option>
                                                <option value="B2">B2</option>
                                                <option value="C1">C1</option>
                                                <option value="C2">C2</option>
                                            </select>
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label for="high_school_graduation_date" class="form-label">
                                                <i class="fas fa-calendar me-2"></i>
                                                <%= t.auth.register.highSchoolGraduation %> *
                                            </label>
                                            <input type="date" class="form-control" id="high_school_graduation_date" name="high_school_graduation_date" required>
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label for="birth_date" class="form-label">
                                                <i class="fas fa-birthday-cake me-2"></i>
                                                <%= t.auth.register.birthDate %> *
                                            </label>
                                            <input type="date" class="form-control" id="birth_date" name="birth_date" required>
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label for="passport_number" class="form-label">
                                                <i class="fas fa-passport me-2"></i>
                                                <%= t.auth.register.passportNumber %>
                                            </label>
                                            <input type="text" class="form-control" id="passport_number" name="passport_number" placeholder="Örn: U23456789" oninput="this.value = this.value.toUpperCase()">
                                            <div class="form-text">Pasaport numarası harf ile başlamalıdır (Örn: U23456789)</div>
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label for="passport_type" class="form-label">
                                                <i class="fas fa-passport me-2"></i>
                                                <%= t.auth.register.passportType %>
                                            </label>
                                            <select class="form-select" id="passport_type" name="passport_type">
                                                <option value=""><%= t.auth.register.selectPassportType %></option>
                                                <option value="Bordo"><%= t.auth.register.bordo %></option>
                                                <option value="Yeşil"><%= t.auth.register.yesil %></option>
                                            </select>
                                        </div>
                                        
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="mb-3">
                                                    <label for="schengen_visa_count" class="form-label">
                                                        <i class="fas fa-plane me-2"></i>
                                                        <%= t.auth.register.schengenVisaCount %>
                                                    </label>
                                                    <input type="number" class="form-control" id="schengen_visa_count" name="schengen_visa_count" min="0" value="0" placeholder="0">
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="mb-3">
                                                    <label for="uk_visa_count" class="form-label">
                                                        <i class="fas fa-plane me-2"></i>
                                                        <%= t.auth.register.ukVisaCount %>
                                                    </label>
                                                    <input type="number" class="form-control" id="uk_visa_count" name="uk_visa_count" min="0" value="0" placeholder="0">
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label for="academic_exams" class="form-label">
                                                <i class="fas fa-certificate me-2"></i>
                                                <%= t.auth.register.academicExams %>
                                            </label>
                                            <textarea class="form-control" id="academic_exams" name="academic_exams" rows="3" placeholder="<%= t.auth.register.academicExamsPlaceholder %>"></textarea>
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label for="annual_budget" class="form-label">
                                                <i class="fas fa-euro-sign me-2"></i>
                                                <%= t.auth.register.annualBudget %>
                                            </label>
                                            <input type="number" class="form-control" id="annual_budget" name="annual_budget" min="0" step="1" placeholder="Örn: 15000">
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="mb-3 form-check">
                                    <input type="checkbox" class="form-check-input" id="terms" required>
                                    <label class="form-check-label" for="terms">
                                        <%= t.auth.register.termsText %>
                                        <a href="/terms" target="_blank"><%= t.auth.register.termsLink %></a>
                                    </label>
                                </div>
                                
                                <div class="d-grid gap-2">
                                    <button type="submit" class="btn btn-primary btn-lg">
                                        <i class="fas fa-user-plus me-2"></i>
                                        <%= t.auth.register.submit %>
                                    </button>
                                </div>
                            </form>
                            
                            <hr class="my-4">
                            
                            <div class="text-center">
                                <p class="mb-0">
                                    <%= t.auth.register.haveAccount %>
                                    <a href="/login" class="text-primary">
                                        <%= t.auth.register.login %>
                                    </a>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const registerForm = document.getElementById('registerForm');
            const alertContainer = document.getElementById('alertContainer');
            
            // Password confirmation validation
            const password = document.getElementById('password');
            const confirmPassword = document.getElementById('confirm_password');
            
            function validatePassword() {
                if (password.value !== confirmPassword.value) {
                    confirmPassword.setCustomValidity('<%= t.auth.register.passwordMismatch %>');
                } else {
                    confirmPassword.setCustomValidity('');
                }
            }
            
            password.addEventListener('change', validatePassword);
            confirmPassword.addEventListener('keyup', validatePassword);
            
            registerForm.addEventListener('submit', async function(e) {
                e.preventDefault();
                
                const formData = new FormData(registerForm);
                const data = {
                    first_name: formData.get('first_name'),
                    last_name: formData.get('last_name'),
                    email: formData.get('email'),
                    tc_number: formData.get('tc_number'),
                    phone: formData.get('phone'),
                    password: formData.get('password'),
                    english_level: formData.get('english_level'),
                    high_school_graduation_date: formData.get('high_school_graduation_date'),
                    birth_date: formData.get('birth_date'),
                    passport_number: formData.get('passport_number'),
                    passport_type: formData.get('passport_type'),
                    schengen_visa_count: parseInt(formData.get('schengen_visa_count')) || 0,
                    uk_visa_count: parseInt(formData.get('uk_visa_count')) || 0,
                    academic_exams: formData.get('academic_exams'),
                    annual_budget: parseFloat(formData.get('annual_budget')) || null,
                    language: '<%= currentLanguage %>'
                };
                
                try {
                    const response = await fetch('/api/auth/register', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify(data)
                    });
                    
                    const result = await response.json();
                    
                    if (result.success) {
                        showAlert('success', '<%= t.auth.register.success %>');
                        setTimeout(() => {
                            window.location.href = '/login';
                        }, 2000);
                    } else {
                        showAlert('danger', result.message);
                        // Eğer redirectTo varsa şifremi unuttum sayfasına yönlendir
                        if (result.redirectTo) {
                            setTimeout(() => {
                                window.location.href = result.redirectTo;
                            }, 3000);
                        }
                    }
                } catch (error) {
                    showAlert('danger', '<%= t.auth.register.error %>');
                }
            });
            
            function showAlert(type, message) {
                alertContainer.innerHTML = `
                    <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                        <i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-triangle'} me-2"></i>
                        ${message}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                `;
            }
            
            // Language change functionality
            document.querySelectorAll('.language-option').forEach(option => {
                option.addEventListener('click', function(e) {
                    e.preventDefault();
                    const language = this.getAttribute('data-language');
                    
                    fetch('/change-language', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({ language: language })
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            window.location.reload();
                        }
                    });
                });
            });
        });
    </script>
</body>
</html> 