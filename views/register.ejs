                                <%= currentLanguage === 'tr' ? 'İngilizce Seviyesi' : 'English Level' %> *
                            </label>
                            <select class="form-select" id="english_level" name="english_level" required style="border-radius: 10px; padding: 12px 15px; border: 2px solid #e0e0e0;">
                                <option value=""><%= currentLanguage === 'tr' ? 'Seçiniz' : 'Select' %></option>
                                <option value="A1">A1 - <%= currentLanguage === 'tr' ? 'Başlangıç' : 'Beginner' %></option>
                                <option value="A2">A2 - <%= currentLanguage === 'tr' ? 'Temel' : 'Elementary' %></option>
                                <option value="B1">B1 - <%= currentLanguage === 'tr' ? 'Orta' : 'Intermediate' %></option>
                                <option value="B2">B2 - <%= currentLanguage === 'tr' ? 'Orta-İleri' : 'Upper-Intermediate' %></option>
                                <option value="C1">C1 - <%= currentLanguage === 'tr' ? 'İleri' : 'Advanced' %></option>
                                <option value="C2">C2 - <%= currentLanguage === 'tr' ? 'Profesyonel' : 'Proficient' %></option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label">
                                <i class="fas fa-lock me-2 text-primary"></i>
                                <%= currentLanguage === 'tr' ? 'Şifre' : 'Password' %> *
                            </label>
                            <div class="password-field">
                                <input type="password" class="form-control" id="password" name="password" required 
                                       minlength="6" placeholder="<%= currentLanguage === 'tr' ? 'En az 6 karakter' : 'At least 6 characters' %>">
                                <button type="button" class="password-toggle" onclick="togglePassword('password')">
                                    <i class="fas fa-eye" id="passwordIcon"></i>
                                </button>
                                </div>
                                </div>

                            <div class="mb-3">
                            <label for="confirm_password" class="form-label">
                                <i class="fas fa-lock me-2 text-primary"></i>
                                <%= currentLanguage === 'tr' ? 'Şifre Tekrarı' : 'Confirm Password' %> *
                            </label>
                            <div class="password-field">
                                <input type="password" class="form-control" id="confirm_password" name="confirm_password" required 
                                       minlength="6" placeholder="<%= currentLanguage === 'tr' ? 'Şifreyi tekrar girin' : 'Re-enter password' %>">
                                <button type="button" class="password-toggle" onclick="togglePassword('confirm_password')">
                                    <i class="fas fa-eye" id="confirm_passwordIcon"></i>
                                </button>
                                </div>
                                </div>

                        </div>
                                </div>

                        <!-- Ek Bilgiler - Tam Genişlik -->
