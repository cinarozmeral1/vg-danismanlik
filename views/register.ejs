                                <i class="fas fa-info-circle me-1"></i>
                                <%= currentLanguage === 'tr' ? 'Ülke kodunu seçin ve numaranızı girin' : 'Select country code and enter your number' %>
                            </small>
                            </div>
                        </div>

                        <!-- Sağ Sütun - Hesap Bilgileri -->
