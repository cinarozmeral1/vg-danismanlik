<!DOCTYPE html>
<html lang="<%= currentLanguage %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t.auth.register.title %> - Venture Global</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>


    <!-- Register Section -->
    <section class="section bg-light text-dark" style="margin-top: 100px; min-height: 80vh;">
        <div class="container-fluid px-4">
            <div class="row justify-content-center">
                <div class="col-xl-10 col-lg-11 col-md-12">
                    <div class="card shadow-lg">
                        <div class="card-header bg-primary text-white text-center">
                            <h3 class="mb-0">
                                <i class="fas fa-user-plus me-2"></i>
                                <%= t.auth.register.title %>
                            </h3>
                        </div>
                        <div class="card-body p-4">
                            <div id="alertContainer"></div>
                            
                            <form id="registerForm" class="row g-4">
                                <div class="col-md-6">
                                    <label for="first_name" class="form-label">Ad *</label>
                                    <input type="text" class="form-control" id="first_name" name="first_name" required>
                                </div>
                                <div class="col-md-6">
                                    <label for="last_name" class="form-label">Soyad *</label>
                                    <input type="text" class="form-control" id="last_name" name="last_name" required>
                                </div>

                                <div class="col-md-6">
                                    <label for="tc_number" class="form-label">TC Kimlik No *</label>
                                    <input type="text" class="form-control" id="tc_number" name="tc_number" maxlength="11" pattern="[0-9]{11}" oninput="this.value = this.value.replace(/[^0-9]/g, '')" required>
                                    <small class="text-muted">11 haneli olarak giriniz.</small>
                                </div>
                                <div class="col-md-6">
                                    <label for="email" class="form-label">E-posta *</label>
                                    <input type="email" class="form-control" id="email" name="email" required>
                                </div>

                                <div class="col-md-6">
                                    <label for="phone" class="form-label">Telefon *</label>
                                    <input type="tel" class="form-control" id="phone" name="phone" placeholder="Örn: +90 555 123 45 67" required>
                                </div>
                                <div class="col-md-6">
                                    <label for="english_level" class="form-label">İngilizce Seviyesi *</label>
                                    <select class="form-select" id="english_level" name="english_level" required>
                                        <option value="">Seçiniz</option>
                                        <option value="A1">A1</option>
                                        <option value="A2">A2</option>
                                        <option value="B1">B1</option>
                                        <option value="B2">B2</option>
                                        <option value="C1">C1</option>
                                        <option value="C2">C2</option>
                                    </select>
                                </div>

                                <div class="col-md-6">
                                    <label for="high_school_graduation_date" class="form-label">Lise Mezuniyet Tarihi *</label>
                                    <input type="text" class="form-control" id="high_school_graduation_date" name="high_school_graduation_date" placeholder="GG/AA/YYYY" required>
                                    <small class="text-muted">Tarihi GG/AA/YYYY formatında, slash (/) kullanarak giriniz.</small>
                                </div>
                                <div class="col-md-6">
                                    <label for="birth_date" class="form-label">Doğum Tarihi *</label>
                                    <input type="text" class="form-control" id="birth_date" name="birth_date" placeholder="GG/AA/YYYY" required>
                                    <small class="text-muted">Tarihi GG/AA/YYYY formatında, slash (/) kullanarak giriniz.</small>
                                </div>

                                <div class="col-md-6">
                                    <label for="passport_type" class="form-label">Pasaport Türü *</label>
                                    <input type="text" class="form-control" id="passport_type" name="passport_type" placeholder="Örn: Bordo, Yeşil, Gri, Siyah" required>
                                </div>
                                <div class="col-md-6">
                                    <label for="passport_number" class="form-label">Pasaport Numarası *</label>
                                    <input type="text" class="form-control" id="passport_number" name="passport_number" placeholder="Örn: P1234567" required>
                                </div>

                                <div class="col-md-6">
                                    <label for="desired_country" class="form-label">Gitmek İstediği Ülke *</label>
                                    <input type="text" class="form-control" id="desired_country" name="desired_country" placeholder="Örn: Almanya" required>
                                </div>
                                <div class="col-md-6">
                                    <label for="active_class" class="form-label">Aktif Sınıf *</label>
                                    <input type="text" class="form-control" id="active_class" name="active_class" placeholder="Örn: 11" required>
                                </div>

                                <div class="col-md-6">
                                    <label for="password" class="form-label">Şifre *</label>
                                    <input type="password" class="form-control" id="password" name="password" required>
                                </div>
                                <div class="col-md-6">
                                    <label for="confirm_password" class="form-label">Şifre Tekrar *</label>
                                    <input type="password" class="form-control" id="confirm_password" name="confirm_password" required>
                                </div>

                                <div class="col-12 form-check">
                                    <input type="checkbox" class="form-check-input" id="terms" required>
                                    <label class="form-check-label" for="terms">
                                        <%= t.auth.register.termsText %>
                                        <a href="/terms" target="_blank"><%= t.auth.register.termsLink %></a>
                                    </label>
                                </div>

                                <div class="col-12 d-grid">
                                    <button type="submit" class="btn btn-primary btn-lg">
                                        <i class="fas fa-user-plus me-2"></i>
                                        <%= t.auth.register.submit %>
                                    </button>
                                </div>
                            </form>
                            
                            <hr class="my-4">
                            
                            <div class="text-center">
                                <p class="mb-0">
                                    <%= t.auth.register.haveAccount %>
                                    <a href="/login" class="text-primary">
                                        <%= t.auth.register.login %>
                                    </a>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const registerForm = document.getElementById('registerForm');
            const alertContainer = document.getElementById('alertContainer');
            
            // Password confirmation validation
            const password = document.getElementById('password');
            const confirmPassword = document.getElementById('confirm_password');
            
            function validatePassword() {
                if (password.value !== confirmPassword.value) {
                    confirmPassword.setCustomValidity('<%= t.auth.register.passwordMismatch %>');
                } else {
                    confirmPassword.setCustomValidity('');
                }
            }
            
            password.addEventListener('change', validatePassword);
            confirmPassword.addEventListener('keyup', validatePassword);
            
            registerForm.addEventListener('submit', async function(e) {
                e.preventDefault();
                
                const formData = new FormData(registerForm);
                const toIsoDate = (value) => {
                    if (!value) return null;
                    const isoPattern = /^\d{4}-\d{2}-\d{2}$/;
                    if (isoPattern.test(value)) return value;
                    const parts = value.split(/[\.\/]/);
                    if (parts.length === 3) {
                        const [day, month, year] = parts;
                        if (day.length === 1 || day.length === 2) {
                            return `${year.padStart(4, '0')}-${month.padStart(2, '0')}-${day.padStart(2, '0')}`;
                        }
                    }
                    return value;
                };
                const data = {
                    first_name: formData.get('first_name'),
                    last_name: formData.get('last_name'),
                    email: formData.get('email'),
                    tc_number: formData.get('tc_number'),
                    phone: formData.get('phone'),
                    password: formData.get('password'),
                    english_level: formData.get('english_level'),
                    high_school_graduation_date: formData.get('high_school_graduation_date'),
                    birth_date: formData.get('birth_date'),
                    passport_number: formData.get('passport_number'),
                    passport_type: formData.get('passport_type'),
                    desired_country: formData.get('desired_country'),
                    active_class: formData.get('active_class'),
                    language: '<%= currentLanguage %>'
                };
                data.high_school_graduation_date = toIsoDate(data.high_school_graduation_date);
                data.birth_date = toIsoDate(data.birth_date);
                
                try {
                    const response = await fetch('/api/auth/register', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify(data)
                    });
                    
                    const result = await response.json();
                    
                    if (result.success) {
                        showAlert('success', '<%= t.auth.register.success %>');
                        // Check if coming from wizard
                        const urlParams = new URLSearchParams(window.location.search);
                        const redirect = urlParams.get('redirect');
                        setTimeout(() => {
                            if (redirect === 'wizard') {
                                window.location.href = '/login?redirect=wizard';
                            } else {
                                window.location.href = '/login';
                            }
                        }, 2000);
                    } else {
                        showAlert('danger', result.message);
                        // Eğer redirectTo varsa şifremi unuttum sayfasına yönlendir
                        if (result.redirectTo) {
                            setTimeout(() => {
                                window.location.href = result.redirectTo;
                            }, 3000);
                        }
                    }
                } catch (error) {
                    showAlert('danger', '<%= t.auth.register.error %>');
                }
            });
            
            function showAlert(type, message) {
                alertContainer.innerHTML = `
                    <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                        <i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-triangle'} me-2"></i>
                        ${message}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                `;
            }
            
            // Language change functionality
            document.querySelectorAll('.language-option').forEach(option => {
                option.addEventListener('click', function(e) {
                    e.preventDefault();
                    const language = this.getAttribute('data-language');
                    
                    fetch('/change-language', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({ language: language })
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            window.location.reload();
                        }
                    });
                });
            });
        });
    </script>
</body>
</html> 