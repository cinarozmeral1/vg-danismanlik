    <!-- International Phone Input JS -->
    <script src="https://cdn.jsdelivr.net/npm/intl-tel-input@18.2.1/build/js/intlTelInput.min.js"></script>
    
    <script>
        // Store wizard recommendation ID if coming from wizard
        const urlParams = new URLSearchParams(window.location.search);
        const wizardRecommendationId = urlParams.get('wizard_rec') || sessionStorage.getItem('wizard_recommendation_id');
        
        // Phone input instance
        let formPhoneInput;
        
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize intl-tel-input for form phone
            const phoneField = document.getElementById('phone');
            if (phoneField) {
                formPhoneInput = window.intlTelInput(phoneField, {
                    initialCountry: "tr",
                    preferredCountries: ["tr", "de", "gb", "us", "fr", "it", "es", "nl", "at", "cz"],
                    separateDialCode: true,
                    utilsScript: "https://cdn.jsdelivr.net/npm/intl-tel-input@18.2.1/build/js/utils.js"
                });
            }
            
            // Form validation
            const registerForm = document.getElementById('registerForm');
            const password = document.getElementById('password');
            const confirmPassword = document.getElementById('confirm_password');
            
            function validatePassword() {
                if (password.value !== confirmPassword.value) {
                    confirmPassword.setCustomValidity('<%= t.auth.register.passwordMismatch %>');
                } else {
                    confirmPassword.setCustomValidity('');
                }
            }
            
            password.addEventListener('change', validatePassword);
            confirmPassword.addEventListener('keyup', validatePassword);
            
            // Form submission
            registerForm.addEventListener('submit', async function(e) {
                e.preventDefault();
                
                const submitBtn = document.getElementById('submitBtn');
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Kaydediliyor...';
                
                const email = document.getElementById('email').value;
                const passwordValue = password.value;
                
                // Get full phone number with country code (INTERNATIONAL format: +90 5XX XXX XX XX)
                let phoneNumber = '';
                if (formPhoneInput) {
                    phoneNumber = formPhoneInput.getNumber(intlTelInputUtils.numberFormat.INTERNATIONAL);
                }
                
                // Validate phone
                if (!phoneNumber || phoneNumber.length < 10) {
                    showAlert('danger', '<%= currentLanguage === "tr" ? "Lütfen geçerli bir telefon numarası girin" : "Please enter a valid phone number" %>');
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="fas fa-user-plus me-2"></i><%= t.auth.register.submit %>';
                    return;
                }
                
                // Get english level
                const englishLevel = document.getElementById('english_level').value;
                
                // Validate english level
                if (!englishLevel) {
                    showAlert('danger', '<%= currentLanguage === "tr" ? "Lütfen İngilizce seviyenizi seçin" : "Please select your English level" %>');
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="fas fa-user-plus me-2"></i><%= t.auth.register.submit %>';
                    return;
                }
                
                // Get name and TC fields
                const firstName = document.getElementById('first_name').value.trim();
                const lastName = document.getElementById('last_name').value.trim();
                const tcNumber = document.getElementById('tc_number').value.trim();
                
                // Validate name fields
                if (!firstName || !lastName) {
                    showAlert('danger', '<%= currentLanguage === "tr" ? "Lütfen ad ve soyadınızı girin" : "Please enter your first and last name" %>');
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="fas fa-user-plus me-2"></i><%= t.auth.register.submit %>';
                    return;
                }
                
                // Validate TC number (11 digits)
                if (!tcNumber || tcNumber.length !== 11 || !/^[0-9]{11}$/.test(tcNumber)) {
                    showAlert('danger', '<%= currentLanguage === "tr" ? "Lütfen 11 haneli geçerli bir TC kimlik numarası girin" : "Please enter a valid 11-digit ID number" %>');
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="fas fa-user-plus me-2"></i><%= t.auth.register.submit %>';
                    return;
                }
                
                try {
                    const response = await fetch('/api/auth/register', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            email: email,
                            password: passwordValue,
                            first_name: firstName,
                            last_name: lastName,
                            tc_number: tcNumber,
                            phone: phoneNumber,
                            english_level: englishLevel,
                            desired_country: document.getElementById('desired_country').value.trim() || null,
                            current_school: document.getElementById('current_school').value.trim() || null,
                            active_class: document.getElementById('active_class').value.trim() || null,
                            passport_type: document.getElementById('passport_type').value.trim() || null,
                            passport_number: document.getElementById('passport_number').value.trim() || null,
                            home_address: document.getElementById('home_address').value.trim() || null,
                            language: '<%= currentLanguage %>'
                        })
                    });
                    
                    const result = await response.json();
                    
                    if (result.success) {
                        showAlert('success', '<%= t.auth.register.success %>');
                        
                        // Google Ads Conversion Tracking - Manual Registration
                        if (typeof gtag === 'function') {
                            gtag('event', 'conversion', {
                                'send_to': 'AW-17936806150/cH8RCI-Vj_UbEIbi9-hC',
                                'transaction_id': ''
                            });
                        }
                        
                        // Store wizard recommendation if exists
                        if (wizardRecommendationId) {
                            sessionStorage.setItem('wizard_recommendation_id', wizardRecommendationId);
                        }
                        
                        setTimeout(() => {
                            const redirect = urlParams.get('redirect');
                            if (redirect === 'wizard') {
                                window.location.href = '/login?redirect=wizard';
                            } else {
                                window.location.href = '/login';
                            }
                        }, 2000);
                    } else {
                        showAlert('danger', result.message);
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = '<i class="fas fa-user-plus me-2"></i><%= t.auth.register.submit %>';
                        
                        if (result.redirectTo) {
                            setTimeout(() => {
                                window.location.href = result.redirectTo;
                            }, 3000);
                        }
                    }
                } catch (error) {
                    console.error('Registration error:', error);
                    showAlert('danger', '<%= t.auth.register.error %>');
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="fas fa-user-plus me-2"></i><%= t.auth.register.submit %>';
                }
            });
        });
        
        // Toggle password visibility
        function togglePassword(fieldId) {
            const field = document.getElementById(fieldId);
            const icon = document.getElementById(fieldId + 'Icon');
            
            if (field.type === 'password') {
                field.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            } else {
                field.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            }
        }
        
        // Show alert
            function showAlert(type, message) {
            const alertContainer = document.getElementById('alertContainer');
                alertContainer.innerHTML = `
                    <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                        <i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-triangle'} me-2"></i>
                        ${message}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                `;
            }
            
        // Handle OAuth2 popup response (fallback)
        async function handleGoogleOAuth2Response(userData, accessToken) {
            const btn = document.getElementById('googleSignUpBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>İşleniyor...';
            
            try {
                const result = await fetch('/api/auth/google-oauth2', {
                        method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({
                        access_token: accessToken,
                        user_data: userData,
                        wizard_recommendation_id: wizardRecommendationId,
                        language: '<%= currentLanguage %>'
                    })
                });
                
                const data = await result.json();
                
                if (data.success) {
                    showAlert('success', data.message);
                    
                    // Google Ads Conversion Tracking - Registration
                    if (typeof gtag === 'function') {
                        gtag('event', 'conversion', {
                            'send_to': 'AW-17936806150/cH8RCI-Vj_UbEIbi9-hC',
                            'transaction_id': ''
                        });
                    }
                    
                    // Redirect based on response
                    setTimeout(() => {
                        window.location.href = data.redirect || '/user/dashboard';
                    }, 1000);
                } else {
                    // Show detailed error for debugging
                    const errorMsg = data.error_detail ? `${data.message} (${data.error_detail})` : data.message;
                    console.error('Google OAuth2 error:', data);
                    showAlert('danger', errorMsg);
                    btn.disabled = false;
                    btn.innerHTML = '<img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" alt="Google"><span><%= currentLanguage === "tr" ? "Google ile Kayıt Ol" : "Sign up with Google" %></span>';
                }
            } catch (error) {
                console.error('Google OAuth2 auth error:', error);
                showAlert('danger', '<%= currentLanguage === "tr" ? "Google girişi sırasında bir hata oluştu" : "An error occurred during Google sign-in" %>');
                btn.disabled = false;
                btn.innerHTML = '<img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" alt="Google"><span><%= currentLanguage === "tr" ? "Google ile Kayıt Ol" : "Sign up with Google" %></span>';
            }
        }
    </script>
