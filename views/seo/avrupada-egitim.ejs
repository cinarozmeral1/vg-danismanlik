    margin-bottom: 35px;
    padding-left: 30px;
}

.process-step::before {
    content: attr(data-step);
    position: absolute;
    left: -40px;
    top: 0;
    width: 35px;
    height: 35px;
    background: #0078D7;
    color: white;
