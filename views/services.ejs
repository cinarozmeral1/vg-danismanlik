<!-- Kanpus Exam Preparation Section -->
<section class="py-5" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center text-white mb-5">
                <div class="mb-3">
                    <i class="fas fa-graduation-cap" style="font-size: 3.5rem; color: #fbbf24;"></i>
                </div>
                <h2 class="display-5 fw-bold mb-3"><%= t.services.kanpus.title %></h2>
                <p class="lead"><%= t.services.kanpus.subtitle %></p>
                <div class="mt-4">
                    <span class="badge bg-white text-dark px-4 py-2 me-2 mb-2" style="font-size: 1rem;">
                        <i class="fas fa-star me-2" style="color: #667eea;"></i><%= t.services.kanpus.badge1 %>
                    </span>
                    <span class="badge bg-white text-dark px-4 py-2 me-2 mb-2" style="font-size: 1rem;">
                        <i class="fas fa-star me-2" style="color: #667eea;"></i><%= t.services.kanpus.badge2 %>
                    </span>
                    <span class="badge bg-white text-dark px-4 py-2 mb-2" style="font-size: 1rem;">
                        <i class="fas fa-star me-2" style="color: #667eea;"></i><%= t.services.kanpus.badge3 %>
                    </span>
                </div>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-lg-3 col-md-6">
                <div class="card h-100 shadow-lg" style="border: none;">
                    <div class="card-body text-center">
                        <div class="mb-3">
                            <span class="badge bg-primary" style="font-size: 1.5rem;">HL & SL</span>
                        </div>
                        <h5 class="fw-bold"><%= t.services.kanpus.programs.ib %></h5>
                        <p class="small text-muted"><%= t.services.kanpus.programs.ibDesc %></p>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card h-100 shadow-lg" style="border: none;">
                    <div class="card-body text-center">
                        <div class="mb-3">
                            <span class="badge bg-success" style="font-size: 1.5rem;">College</span>
                        </div>
                        <h5 class="fw-bold"><%= t.services.kanpus.programs.ap %></h5>
                        <p class="small text-muted"><%= t.services.kanpus.programs.apDesc %></p>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card h-100 shadow-lg" style="border: none;">
                    <div class="card-body text-center">
                        <div class="mb-3">
                            <span class="badge bg-warning text-dark" style="font-size: 1.5rem;">1600</span>
                        </div>
                        <h5 class="fw-bold"><%= t.services.kanpus.programs.sat %></h5>
                        <p class="small text-muted"><%= t.services.kanpus.programs.satDesc %></p>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card h-100 shadow-lg" style="border: none;">
                    <div class="card-body text-center">
                        <div class="mb-3">
                            <span class="badge bg-info" style="font-size: 1.5rem;">120</span>
                        </div>
                        <h5 class="fw-bold"><%= t.services.kanpus.programs.toefl %></h5>
                        <p class="small text-muted"><%= t.services.kanpus.programs.toeflDesc %></p>
                    </div>
                </div>
            </div>
        </div>
        <div class="row mt-4">
            <div class="col-lg-12">
                <div class="card shadow-lg" style="border: none; background: rgba(255,255,255,0.95);">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-md-3 text-center mb-3 mb-md-0">
                                <span class="badge bg-danger" style="font-size: 2rem; padding: 1rem 1.5rem;">9.0</span>
                            </div>
                            <div class="col-md-6 mb-3 mb-md-0">
                                <h5 class="fw-bold mb-2"><%= t.services.kanpus.programs.ielts %></h5>
                                <p class="mb-0 small text-muted"><%= t.services.kanpus.programs.ieltsDesc %></p>
                            </div>
                            <div class="col-md-3 text-center">
                                <a href="/partners/kanpus" class="btn btn-primary btn-lg w-100">
                                    <i class="fas fa-arrow-right me-2"></i><%= t.services.kanpus.ctaButton %>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row mt-5">
            <div class="col-12 text-center">
                <div class="p-4 rounded" style="background: rgba(255,255,255,0.1);">
                    <h4 class="text-white fw-bold mb-3"><%= t.services.kanpus.earlyPrepTitle %></h4>
                    <p class="text-white lead mb-0"><%= t.services.kanpus.earlyPrepBody %></p>
                </div>
            </div>
        </div>
    </div>
</section>

