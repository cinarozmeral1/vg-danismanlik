<!-- Hero Section -->
<section class="bg-primary text-white py-5">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center">
                <h1 class="display-4 fw-bold"><%= t.services.hero.title %></h1>
                <p class="lead"><%= t.services.hero.subtitle %></p>
            </div>
        </div>
    </div>
</section>

<!-- Services Section -->
<section class="py-5">
    <div class="container">
        <!-- AI Student Wizard Button (Only Turkish - no English support) -->
        <% if (typeof currentLanguage === 'undefined' || currentLanguage === 'tr') { %>
        <div class="text-center mb-5">
            <div class="wizard-highlight-box">
                <div class="wizard-icon-wrapper">
                    <i class="fas fa-magic"></i>
                </div>
                <h4 class="mb-2">Hangi Üniversite Size Uygun?</h4>
                <p class="text-muted mb-3">Yapay zeka destekli sihirbazımız, profilinize en uygun üniversite ve programı saniyeler içinde bulur.</p>
                <a href="/student-wizard" class="wizard-cta-btn-services">
                    <i class="fas fa-magic me-2"></i>
                    Öğrenci Sihirbazını Dene
                    <span class="wizard-badge-services">ÜCRETSİZ</span>
                </a>
            </div>
        </div>
        <style>
            .wizard-highlight-box {
                background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
                border: 2px dashed #0056b3;
                border-radius: 20px;
                padding: 30px;
                max-width: 600px;
                margin: 0 auto;
            }
            .wizard-icon-wrapper {
                width: 60px;
                height: 60px;
                background: linear-gradient(135deg, #0056b3 0%, #28a745 100%);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 15px;
                color: white;
                font-size: 1.5rem;
            }
            .wizard-cta-btn-services {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
                background: linear-gradient(135deg, #0056b3 0%, #28a745 100%);
                color: white;
                border-radius: 50px;
                font-weight: 600;
                font-size: 1rem;
                padding: 12px 28px;
                text-decoration: none;
                box-shadow: 0 4px 15px rgba(0,86,179,0.3);
                transition: all 0.3s ease;
                position: relative;
            }
            .wizard-cta-btn-services:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(0,86,179,0.4);
                color: white;
            }
            .wizard-badge-services {
                background: #ffc107;
                color: #000;
                font-size: 0.7rem;
                padding: 3px 8px;
                border-radius: 20px;
                font-weight: 700;
                margin-left: 5px;
            }
        </style>
        <% } %>
        
        <div class="row">
            <div class="col-lg-4 mb-4">
                <div class="card h-100 shadow" style="background-color: #e6f0fa !important;">
                    <div class="card-body text-center">
                        <i class="fas fa-university fa-3x text-primary mb-3"></i>
                        <h4><%= t.services.universityConsulting.title %></h4>
                        <p><%= t.services.universityConsulting.description %></p>
                        <ul class="list-unstyled text-start">
                            <% t.services.universityConsulting.features.forEach(function(feature) { %>
                                <li><i class="fas fa-check text-success me-2"></i><%= feature %></li>
                            <% }); %>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 mb-4">
                <div class="card h-100 shadow" style="background-color: #e6f0fa !important;">
                    <div class="card-body text-center">
                        <i class="fas fa-language fa-3x text-primary mb-3"></i>
                        <h4><%= t.services.languageSchool.title %></h4>
                        <p><%= t.services.languageSchool.description %></p>
                        <ul class="list-unstyled text-start">
                            <% t.services.languageSchool.features.forEach(function(feature) { %>
                                <li><i class="fas fa-check text-success me-2"></i><%= feature %></li>
                            <% }); %>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 mb-4">
                <div class="card h-100 shadow" style="background-color: #e6f0fa !important;">
                    <div class="card-body text-center">
                        <i class="fas fa-file-alt fa-3x text-primary mb-3"></i>
                        <h4><%= t.services.documentConsulting.title %></h4>
                        <p><%= t.services.documentConsulting.description %></p>
                        <ul class="list-unstyled text-start">
                            <% t.services.documentConsulting.features.forEach(function(feature) { %>
                                <li><i class="fas fa-check text-success me-2"></i><%= feature %></li>
                            <% }); %>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="row mt-4">
            <div class="col-lg-4 mb-4">
                <div class="card h-100 shadow" style="background-color: #e6f0fa !important;">
                    <div class="card-body text-center">
                        <i class="fas fa-passport fa-3x text-primary mb-3"></i>
                        <h4><%= t.services.visaConsulting.title %></h4>
                        <p><%= t.services.visaConsulting.description %></p>
                        <ul class="list-unstyled text-start">
                            <% t.services.visaConsulting.features.forEach(function(feature) { %>
                                <li><i class="fas fa-check text-success me-2"></i><%= feature %></li>
                            <% }); %>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 mb-4">
                <div class="card h-100 shadow" style="background-color: #e6f0fa !important;">
                    <div class="card-body text-center">
                        <i class="fas fa-home fa-3x text-primary mb-3"></i>
                        <h4><%= t.services.accommodation.title %></h4>
                        <p><%= t.services.accommodation.description %></p>
                        <ul class="list-unstyled text-start">
                            <% t.services.accommodation.features.forEach(function(feature) { %>
                                <li><i class="fas fa-check text-success me-2"></i><%= feature %></li>
                            <% }); %>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 mb-4">
                <div class="card h-100 shadow" style="background-color: #e6f0fa !important;">
                    <div class="card-body text-center">
                        <i class="fas fa-plane fa-3x text-primary mb-3"></i>
                        <h4><%= t.services.transportation.title %></h4>
                        <p><%= t.services.transportation.description %></p>
                        <ul class="list-unstyled text-start">
                            <% t.services.transportation.features.forEach(function(feature) { %>
                                <li><i class="fas fa-check text-success me-2"></i><%= feature %></li>
                            <% }); %>
                        </ul>
                        <div class="mt-3 p-3 bg-warning text-dark rounded">
                            <small><i class="fas fa-info-circle me-2"></i><%= t.services.transportation.note %></small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="row mt-4">
            <div class="col-lg-6 mb-4">
                <div class="card h-100 shadow" style="background-color: #e6f0fa !important;">
                    <div class="card-body text-center">
                        <i class="fas fa-suitcase fa-3x text-primary mb-3"></i>
                        <h4><%= t.services.preDeparture.title %></h4>
                        <p><%= t.services.preDeparture.description %></p>
                        <ul class="list-unstyled text-start">
                            <% t.services.preDeparture.features.forEach(function(feature) { %>
                                <li><i class="fas fa-check text-success me-2"></i><%= feature %></li>
                            <% }); %>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 mb-4">
                <div class="card h-100 shadow" style="background-color: #e6f0fa !important;">
                    <div class="card-body text-center">
                        <i class="fas fa-headset fa-3x text-primary mb-3"></i>
                        <h4><%= t.services.ongoingSupport.title %></h4>
                        <p><%= t.services.ongoingSupport.description %></p>
                        <ul class="list-unstyled text-start">
                            <% t.services.ongoingSupport.features.forEach(function(feature) { %>
                                <li><i class="fas fa-check text-success me-2"></i><%= feature %></li>
                            <% }); %>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Kanpus Exam Preparation Section -->
<section class="py-5" style="background: linear-gradient(135deg, #1a365d 0%, #2c5282 100%);">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center text-white mb-5">
                <h2 class="display-5 fw-bold mb-3">Kanpus <%= t.services.kanpus.title %></h2>
                <p class="lead"><%= t.services.kanpus.subtitle %></p>
                <div class="alert alert-light mt-3 d-inline-block px-5 py-3" style="background: rgba(255,255,255,0.95); border-radius: 15px;">
                    <strong style="color: #1a365d;"><%= t.services.kanpus.exclusiveOffer %></strong>
                </div>
                <div class="mt-4">
                    <span class="badge bg-white text-dark px-4 py-2 me-2 mb-2" style="font-size: 1rem;">
                        <%= t.services.kanpus.badge1 %>
                    </span>
                    <span class="badge bg-white text-dark px-4 py-2 me-2 mb-2" style="font-size: 1rem;">
                        <%= t.services.kanpus.badge2 %>
