<!-- Contact CTA Section -->
<section class="modern-hero-gradient text-white py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <h2 class="mb-4 modern-services-cta-title" data-animation="fadeIn"><%= t.services.cta.title %></h2>
                <p class="lead mb-4 modern-services-cta-subtitle" data-animation="fadeIn" data-delay="100"><%= t.services.cta.subtitle %></p>
                <div class="d-flex flex-wrap justify-content-center gap-3" data-animation="scaleIn" data-delay="200">
                    <a href="/contact" class="btn btn-outline-light btn-lg modern-services-cta-btn">
                        <i class="fas fa-envelope me-2"></i>
                        <%= t.services.cta.contactUs %>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section> 