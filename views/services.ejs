                        <p class="small text-muted"><%= t.services.kanpus.programs.apDesc %></p>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card h-100 shadow-lg" style="border: none;">
                    <div class="card-body text-center">
                        <h5 class="fw-bold"><%= t.services.kanpus.programs.sat %></h5>
                        <p class="small text-muted"><%= t.services.kanpus.programs.satDesc %></p>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card h-100 shadow-lg" style="border: none;">
                    <div class="card-body text-center">
                        <h5 class="fw-bold"><%= t.services.kanpus.programs.toefl %></h5>
                        <p class="small text-muted"><%= t.services.kanpus.programs.toeflDesc %></p>
                    </div>
                </div>
            </div>
        </div>
        <div class="row mt-4">
