<!-- Hero Section -->
<section class="modern-hero-gradient text-white py-5">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center">
                <h1 class="display-4 fw-bold modern-hero-title" data-animation="fadeIn"><%= t.services.hero.title %></h1>
                <p class="lead modern-hero-subtitle" data-animation="fadeIn" data-delay="200"><%= t.services.hero.subtitle %></p>
            </div>
        </div>
    </div>
</section>

<!-- Services Section -->
<section class="py-5">
    <div class="container">
        <div class="row">
            <div class="col-lg-4 mb-4">
                <div class="card h-100 shadow modern-service-card" style="background-color: #e6f0fa !important;" data-animation="fadeIn" data-delay="0">
                    <div class="card-body text-center">
                        <div class="modern-service-icon-wrapper">
                            <i class="fas fa-university fa-3x text-primary mb-3"></i>
                        </div>
                        <h4 class="modern-service-title"><%= t.services.universityConsulting.title %></h4>
                        <p class="modern-service-text"><%= t.services.universityConsulting.description %></p>
                        <ul class="list-unstyled text-start">
                            <% t.services.universityConsulting.features.forEach(function(feature) { %>
                                <li><i class="fas fa-check text-success me-2"></i><%= feature %></li>
                            <% }); %>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 mb-4">
                <div class="card h-100 shadow modern-service-card" style="background-color: #e6f0fa !important;" data-animation="fadeIn" data-delay="100">
