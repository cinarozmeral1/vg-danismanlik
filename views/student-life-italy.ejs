<!-- Hero Section -->
<section class="bg-primary text-white py-5">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center">
                <h1 class="display-4 fw-bold"><%= t.studentLifePage.hero.italy.title %></h1>
                <p class="lead"><%= t.studentLifePage.hero.italy.subtitle %></p>
            </div>
        </div>
    </div>
</section>

<!-- Content Section -->
<section class="py-5">
    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                <div class="card shadow-lg border-0 mb-4 overflow-hidden">
                    <div class="row g-0">
                        <div class="col-md-4">
                            <div class="student-life-card-img-wrapper">
                                <img src="/images/countries/italy/AdobeStock_240966420.jpeg" class="student-life-card-img" alt="Italy University Campus">
                            </div>
                        </div>
                        <div class="col-md-8">
                            <div class="card-body p-4">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="bg-primary rounded-circle p-3 me-3">
                                        <i class="fas fa-graduation-cap text-white fs-4"></i>
                                    </div>
                                    <h3 class="mb-0"><%= t.studentLifePage.sections.educationSystem.title %></h3>
                                </div>
                                <p class="lead text-dark"><%= t.studentLifePage.countries.italy.description1 %></p>
                                <p><%= t.studentLifePage.countries.italy.description2 %></p>
                                
                                <div class="row mt-4">
                                    <div class="col-md-6">
                                        <h5 class="text-primary mb-3"><%= t.studentLifePage.sections.educationSystem.title %></h5>
                                        <ul class="list-unstyled">
                                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i><strong><%= t.studentLifePage.sections.educationSystem.bachelor %>:</strong> 3 <%= t.studentLifePage.units.perYear.replace('/', '') %></li>
                                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i><strong><%= t.studentLifePage.sections.educationSystem.master %>:</strong> 2 <%= t.studentLifePage.units.perYear.replace('/', '') %></li>

                                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i><strong><%= t.studentLifePage.sections.educationSystem.language %>:</strong> <%= t.studentLifePage.languages.italian %>/<%= t.studentLifePage.languages.english %></li>
                                        </ul>
                                    </div>
                                    <div class="col-md-6">
                                        <h5 class="text-primary mb-3"><%= t.studentLifePage.sections.educationSystem.popularDepts %></h5>
                                        <div class="d-flex flex-wrap gap-2">
                                            <% t.studentLifePage.sections.educationSystem.departments.forEach(function(badge, idx) { %>
                                                <span class="badge badge-style-<%= (idx % 3) + 1 %> text-dark fw-semibold bg-white border"><%= badge %></span>
                                            <% }); %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-lg border-0 mb-4 overflow-hidden">
                    <div class="row g-0">
                        <div class="col-md-8">
                            <div class="card-body p-4">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="bg-success rounded-circle p-3 me-3">
                                        <i class="fas fa-home text-white fs-4"></i>
                                    </div>
                                    <h3 class="mb-0"><%= t.studentLifePage.sections.accommodation.title %></h3>
                                </div>
                                <p class="lead text-dark"><%= t.studentLifePage.countries.italy.livingDescription %></p>
                                
                                <div class="row mt-4">
                                                                            <div class="col-md-6">
                                            <h5 class="text-success mb-3"><%= t.studentLifePage.additionalTerms.accommodationOptions %></h5>
                                            <ul class="list-unstyled">
                                                <li class="mb-2"><i class="fas fa-building text-primary me-2"></i><strong><%= t.studentLifePage.sections.accommodation.studentDorms %>:</strong> 200-400€<%= t.studentLifePage.units.perMonth %></li>
                                                <li class="mb-2"><i class="fas fa-home text-primary me-2"></i><strong><%= t.studentLifePage.sections.accommodation.privateDorms %>:</strong> 300-600€<%= t.studentLifePage.units.perMonth %></li>
                                                <li class="mb-2"><i class="fas fa-users text-primary me-2"></i><strong><%= t.studentLifePage.sections.accommodation.sharedFlat %>:</strong> 400-800€<%= t.studentLifePage.units.perMonth %></li>
                                                <li class="mb-2"><i class="fas fa-key text-primary me-2"></i><strong><%= t.studentLifePage.sections.accommodation.studio %>:</strong> 600-1200€<%= t.studentLifePage.units.perMonth %></li>
                                            </ul>
                                        </div>
                                    <div class="col-md-6">
                                        <h5 class="text-success mb-3"><%= t.studentLifePage.sections.accommodation.monthlyLiving %></h5>
                                        <div class="d-flex flex-wrap gap-2 mb-3">
                                            <% const costBadges = [
                                                {icon: 'fa-home', text: t.studentLifePage.sections.accommodation.costs.accommodation + ' 400-800€'},
                                                {icon: 'fa-utensils', text: t.studentLifePage.sections.accommodation.costs.food + ' 200-300€'},
                                                {icon: 'fa-bus', text: t.studentLifePage.sections.accommodation.costs.transport + ' 80-120€'},
                                                {icon: 'fa-shopping-bag', text: t.studentLifePage.sections.accommodation.costs.other + ' 150-250€'}
                                            ]; %>
                                            <% costBadges.forEach(function(badge, idx) { %>
                                                <span class="badge badge-style-<%= (idx % 3) + 1 %> p-2 bg-white text-dark fw-semibold border" style="font-size: 0.85rem;">
                                                    <i class="fas <%= badge.icon %> me-1 text-primary"></i><%= badge.text %>
                                                </span>
                                            <% }); %>
                                        </div>
                                        <div class="alert alert-success">
                                            <strong><%= t.studentLifePage.sections.costs.total %>: 580-1.430€<%= t.studentLifePage.units.perMonth %></strong> <%= t.studentLifePage.sections.costs.variesByCity %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="student-life-card-img-wrapper">
                                <img src="/images/countries/italy/AdobeStock_109671027.jpeg" class="student-life-card-img" alt="Italy Student Life">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-lg border-0 mb-4 overflow-hidden">
                    <div class="row g-0">
                        <div class="col-md-4">
                            <div class="student-life-card-img-wrapper">
                                <img src="/images/countries/italy/AdobeStock_243375670.jpeg" class="student-life-card-img" alt="Italy University Education">
                            </div>
                        </div>
                        <div class="col-md-8">
                            <div class="card-body p-4">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="bg-warning rounded-circle p-3 me-3">
                                        <i class="fas fa-coins text-white fs-4"></i>
                                    </div>
                                    <h3 class="mb-0"><%= t.studentLifePage.sections.costs.title %></h3>
                                </div>
                                <p class="lead text-dark"><%= t.studentLifePage.countries.italy.costsDescription %></p>
                                
                                <div class="row mt-4">
                                    <div class="col-md-6">
                                        <h5 class="text-warning mb-3"><%= t.studentLifePage.sections.costs.educationCosts %></h5>
                                        <div class="card bg-light border-0 mb-3">
                                            <div class="card-body p-3">
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <div>
                                                        <h6 class="mb-1"><%= t.studentLifePage.sections.costs.stateUniversities %></h6>
                                                        <small class="text-muted"><%= t.studentLifePage.sections.costs.basedOnIncome %></small>
                                                    </div>
                                                    <span class="badge bg-success">1.000-3.000€<%= t.studentLifePage.units.yearly %></span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="card bg-light border-0 mb-3">
                                            <div class="card-body p-3">
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <div>
                                                        <h6 class="mb-1"><%= t.studentLifePage.sections.costs.privateUniversities %></h6>
                                                        <small class="text-muted"><%= t.studentLifePage.sections.costs.qualityEducation %></small>
                                                    </div>
                                                    <span class="badge bg-warning">8.000-15.000€<%= t.studentLifePage.units.yearly %></span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="card bg-light border-0 mb-3">
                                            <div class="card-body p-3">
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <div>
                                                        <h6 class="mb-1"><%= t.studentLifePage.sections.costs.medicalFaculties %></h6>
                                                        <small class="text-muted"><%= t.studentLifePage.sections.costs.prestigiousPrograms %></small>
                                                    </div>
                                                    <span class="badge bg-info">3.000-5.000€<%= t.studentLifePage.units.yearly %></span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <h5 class="text-warning mb-3"><%= t.studentLifePage.additionalTerms.scholarshipOpportunities %></h5>
                                        <div class="d-flex flex-column gap-2">
                                            <div class="d-flex align-items-center p-2 border rounded">
                                                <i class="fas fa-star text-warning me-2"></i>
                                                <div>
                                                    <strong><%= t.studentLifePage.additionalTerms.governmentScholarships %></strong>
                                                    <small class="d-block text-muted"><%= t.studentLifePage.countries.italy.scholarships.italy.description %></small>
                                                </div>
                                            </div>
                                            <div class="d-flex align-items-center p-2 border rounded">
                                                <i class="fas fa-university text-warning me-2"></i>
                                                <div>
                                                    <strong><%= t.studentLifePage.sections.costs.scholarships %></strong>
                                                    <small class="d-block text-muted"><%= t.studentLifePage.countries.italy.scholarships.university.description %></small>
                                                </div>
                                            </div>
                                            <div class="d-flex align-items-center p-2 border rounded">
                                                <i class="fas fa-globe-europe text-warning me-2"></i>
                                                <div>
                                                    <strong><%= t.studentLifePage.additionalTerms.erasmusScholarships %></strong>
                                                    <small class="d-block text-muted"><%= t.studentLifePage.countries.italy.scholarships.erasmus.description %></small>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <div class="mt-3 p-3 bg-warning bg-opacity-10 rounded">
                                            <h6 class="text-warning mb-2"><%= t.studentLifePage.sections.costs.workPermit %></h6>
                                            <p class="mb-2"><%= t.studentLifePage.additionalTerms.workingHours %></p>
                                            <small class="text-muted"><%= t.studentLifePage.additionalTerms.hourlyWage %>: 7-12€</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-lg border-0 mb-4">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-info-circle me-2"></i>
                            <%= t.studentLifePage.sections.quickInfo.title %>
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row text-center">
                            <div class="col-6 mb-3">
                                <div class="p-3 bg-primary rounded">
                                    <h4 class="text-white mb-1">2.500€</h4>
                                    <small class="text-white"><%= t.studentLifePage.sections.quickInfo.yearlyTuition %></small>
                                </div>
                            </div>
                            <div class="col-6 mb-3">
                                <div class="p-3 bg-success rounded">
                                    <h4 class="text-white mb-1">900€</h4>
                                    <small class="text-white"><%= t.studentLifePage.additionalTerms.minLiving %></small>
                                </div>
                            </div>
                            <div class="col-6 mb-3">
                                <div class="p-3 bg-warning rounded">
                                    <h4 class="text-white mb-1">20 <%= t.studentLifePage.buttons.hours %></h4>
                                    <small class="text-white"><%= t.studentLifePage.additionalTerms.weeklyWork %></small>
                                </div>
                            </div>
                            <div class="col-6 mb-3">
                                <div class="p-3 bg-info rounded">
                                    <h4 class="text-white mb-1">90+</h4>
                                    <small class="text-white"><%= t.studentLifePage.additionalTerms.universities %></small>
                                </div>
                            </div>
                        </div>
                        
                        <div class="alert alert-primary mt-3 text-dark" style="color: #111 !important; text-shadow: none !important; font-weight: 500 !important;">
                            <i class="fas fa-lightbulb me-2" style="color: #111 !important;"></i>
                            <strong style="color: #111 !important;"><%= t.studentLifePage.sections.quickInfo.tip %>:</strong> <%= t.studentLifePage.countries.italy.alerts.tip %>
                        </div>
                    </div>
                </div>

                <!-- Important Warning - Turkish Diploma -->
                <div class="card shadow-lg border-0 mb-4">
                    <div class="card-header bg-danger text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            <%= t.studentLifePage.diplomaWarnings.turkishInfoTitle %>
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-success mb-3" style="background: #f0fdf4; border-left: 4px solid #22c55e;">
                            <p class="mb-2"><strong><i class="fas fa-check-circle me-2"></i><%= t.studentLifePage.diplomaWarnings.directAdmission %>:</strong></p>
                            <p class="mb-0 text-dark"><%= t.studentLifePage.diplomaWarnings.italy.info %></p>
                        </div>
                        <div class="alert alert-warning mb-0" style="background: #fffbeb; border-left: 4px solid #f59e0b;">
                            <p class="mb-2"><strong><i class="fas fa-stethoscope me-2"></i><%= t.studentLifePage.diplomaWarnings.medicalFaculties %>:</strong></p>
                            <p class="mb-0 text-dark small"><%= t.studentLifePage.diplomaWarnings.italy.medicalWarning %></p>
                        </div>
                    </div>
                </div>

                <!-- Kanada Lise Diploması Avantajı -->
                <div class="card shadow-lg border-0 mb-4">
                    <div class="card-header text-white" style="background: linear-gradient(135deg, #059669 0%, #047857 100%);">
                        <h5 class="mb-0">
                            <i class="fas fa-maple-leaf me-2"></i>
                            <%= t.studentLifePage.diplomaWarnings.canadianAdvantageTitle %>
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-success mb-3" style="background: #ecfdf5; border-left: 4px solid #10b981;">
                            <p class="mb-2"><strong><i class="fas fa-check-circle me-2"></i><%= t.studentLifePage.diplomaWarnings.internationalRecognition %></strong></p>
                            <p class="mb-0 text-dark"><%= t.studentLifePage.diplomaWarnings.italy.advantage %></p>
                        </div>
                        <ul class="list-unstyled mb-3">
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i><%= t.studentLifePage.diplomaWarnings.italy.benefit1 %></li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i><%= t.studentLifePage.diplomaWarnings.italy.benefit2 %></li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i><%= t.studentLifePage.diplomaWarnings.italy.benefit3 %></li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i><%= t.studentLifePage.diplomaWarnings.italy.benefit4 %></li>
                        </ul>
                        <a href="/partners/wcep" class="btn btn-success btn-sm w-100">
                            <i class="fas fa-info-circle me-2"></i><%= t.studentLifePage.diplomaWarnings.aboutWcep %>
                        </a>
                    </div>
                </div>

                <div class="card shadow-lg border-0">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-phone me-2"></i>
                            <%= t.studentLifePage.additionalTerms.consulting %>
                        </h5>
                    </div>
                    <div class="card-body text-center">
                        <div class="mb-3">
                            <i class="fas fa-user-graduate text-secondary fs-1"></i>
                        </div>
                        <p class="text-dark" style="color: #111 !important; text-shadow: none !important; font-weight: 500 !important;"><%= t.studentLifePage.countries.italy.consultingText %></p>
                        <a href="/contact" class="btn btn-primary btn-lg w-100" style="font-size: clamp(0.875rem, 2vw, 1rem); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                            <i class="fas fa-envelope me-2"></i>
                            <span class="d-none d-sm-inline"><%= t.studentLifePage.sections.consulting.freeConsulting %></span>
                            <span class="d-sm-none">Danışmanlık</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section> 