<!-- Hero Section -->
<section class="bg-primary text-white py-5">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center">
                <h1 class="display-4 fw-bold"><%= t.studentLifePage.hero.netherlands.title %></h1>
                <p class="lead"><%= t.studentLifePage.hero.netherlands.subtitle %></p>
            </div>
        </div>
    </div>
</section>

<!-- Content Section -->
<section class="py-5">
    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                <div class="card shadow-lg border-0 mb-4 overflow-hidden">
                    <div class="row g-0">
                        <div class="col-md-4">
                            <div class="student-life-card-img-wrapper">
                                <img src="/images/countries/netherlands/amsterdam-bikes-canal.jpg" class="student-life-card-img" alt="Amsterdam Bisikletler ve Kanallar">
                            </div>
                        </div>
                        <div class="col-md-8">
                            <div class="card-body p-4">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="bg-primary rounded-circle p-3 me-3">
                                        <i class="fas fa-graduation-cap text-white fs-4"></i>
                                    </div>
                                    <h3 class="mb-0"><%= t.studentLifePage.sections.educationSystem.title %></h3>
                                </div>
                                <p class="lead text-dark"><%= t.studentLifePage.countries.netherlands.description1 %></p>
                                <p><%= t.studentLifePage.countries.netherlands.description2 %></p>
                                
                                <div class="row mt-4">
                                    <div class="col-md-6">
                                        <h5 class="text-primary mb-3"><%= t.studentLifePage.sections.educationSystem.title %></h5>
                                        <ul class="list-unstyled">
                                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i><strong><%= t.studentLifePage.sections.educationSystem.bachelor %>:</strong> 3-4 <%= t.studentLifePage.units.perYear.replace('/', '') %></li>
                                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i><strong><%= t.studentLifePage.sections.educationSystem.master %>:</strong> 1-2 <%= t.studentLifePage.units.perYear.replace('/', '') %></li>
                                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i><strong><%= t.studentLifePage.sections.educationSystem.language %>:</strong> <%= t.studentLifePage.languages.dutch %>/<%= t.studentLifePage.languages.english %></li>
                                        </ul>
                                    </div>
                                    <div class="col-md-6">
                                        <h5 class="text-primary mb-3"><%= t.studentLifePage.sections.educationSystem.popularDepts %></h5>
                                        <div class="d-flex flex-wrap gap-2">
                                            <% t.studentLifePage.sections.educationSystem.departments.forEach(function(badge, idx) { %>
                                                <span class="badge badge-style-<%= (idx % 3) + 1 %> text-dark fw-semibold bg-white border"><%= badge %></span>
                                            <% }); %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-lg border-0 mb-4 overflow-hidden">
                    <div class="row g-0">
                        <div class="col-md-8">
                            <div class="card-body p-4">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="bg-success rounded-circle p-3 me-3">
                                        <i class="fas fa-home text-white fs-4"></i>
                                    </div>
                                    <h3 class="mb-0"><%= t.studentLifePage.sections.accommodation.title %></h3>
                                </div>
                                <p class="lead text-dark"><%= t.studentLifePage.countries.netherlands.livingDescription %></p>
                                
                                <div class="row mt-4">
                                    <div class="col-md-6">
                                        <h5 class="text-success mb-3"><%= t.studentLifePage.additionalTerms.accommodationOptions %></h5>
                                        <ul class="list-unstyled">
                                            <li class="mb-2"><i class="fas fa-building text-primary me-2"></i><strong><%= t.studentLifePage.sections.accommodation.studentDorms %>:</strong> 400-700€<%= t.studentLifePage.units.perMonth %></li>
                                            <li class="mb-2"><i class="fas fa-home text-primary me-2"></i><strong><%= t.studentLifePage.sections.accommodation.privateDorms %>:</strong> 500-900€<%= t.studentLifePage.units.perMonth %></li>
                                            <li class="mb-2"><i class="fas fa-users text-primary me-2"></i><strong><%= t.studentLifePage.sections.accommodation.sharedFlat %>:</strong> 400-700€<%= t.studentLifePage.units.perMonth %></li>
                                            <li class="mb-2"><i class="fas fa-key text-primary me-2"></i><strong><%= t.studentLifePage.sections.accommodation.studio %>:</strong> 800-1.500€<%= t.studentLifePage.units.perMonth %></li>
                                        </ul>
                                    </div>
                                    <div class="col-md-6">
                                        <h5 class="text-success mb-3"><%= t.studentLifePage.sections.accommodation.monthlyLiving %></h5>
                                        <div class="d-flex flex-wrap gap-2 mb-3">
                                            <% const costBadges = [
                                                {icon: 'fa-home', text: t.studentLifePage.sections.accommodation.costs.accommodation + ' 400-900€'},
                                                {icon: 'fa-utensils', text: t.studentLifePage.sections.accommodation.costs.food + ' 200-400€'},
                                                {icon: 'fa-bus', text: t.studentLifePage.sections.accommodation.costs.transport + ' 50-100€'},
                                                {icon: 'fa-shopping-bag', text: t.studentLifePage.sections.accommodation.costs.other + ' 150-300€'}
                                            ]; %>
                                            <% costBadges.forEach(function(badge, idx) { %>
                                                <span class="badge badge-style-<%= (idx % 3) + 1 %> p-2 bg-white text-dark fw-semibold border" style="font-size: 0.85rem;">
                                                    <i class="fas <%= badge.icon %> me-1 text-primary"></i><%= badge.text %>
                                                </span>
                                            <% }); %>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="alert alert-info mt-4">
                                    <i class="fas fa-info-circle me-2"></i>
                                    <strong><%= t.studentLifePage.alerts.important %>:</strong> <%= t.studentLifePage.countries.netherlands.alerts.transportInfo %>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="student-life-card-img-wrapper">
                                <img src="/images/countries/netherlands/amsterdam-autumn-canal.jpg" class="student-life-card-img" alt="Amsterdam Sonbahar Kanalları">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-lg border-0 mb-4 overflow-hidden">
                    <div class="row g-0">
                        <div class="col-md-4">
                            <div class="student-life-card-img-wrapper">
                                <img src="/images/countries/netherlands/tulips-windmill.jpg" class="student-life-card-img" alt="Hollanda Laleler ve Yel Değirmeni">
                            </div>
                        </div>
                        <div class="col-md-8">
                            <div class="card-body p-4">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="bg-warning rounded-circle p-3 me-3">
                                        <i class="fas fa-coins text-white fs-4"></i>
                                    </div>
                                    <h3 class="mb-0"><%= t.studentLifePage.sections.costs.title %></h3>
                                </div>
                                <p class="lead text-dark"><%= t.studentLifePage.countries.netherlands.costsDescription %></p>
                                
                                <div class="row mt-4">
                                    <div class="col-md-6">
                                        <h5 class="text-warning mb-3"><%= t.studentLifePage.sections.costs.educationCosts %></h5>
                                        <div class="card bg-light mb-3">
                                            <div class="card-body">
                                                <h6 class="card-title text-primary">AB Vatandaşları</h6>
                                                <p class="mb-1"><strong><%= t.studentLifePage.sections.costs.tuitionFee %>:</strong> 2.000-4.000€<%= t.studentLifePage.units.perYear %></p>
                                                <p class="mb-0"><strong><%= t.studentLifePage.sections.costs.total %>:</strong> 2.000-4.000€<%= t.studentLifePage.units.perYear %></p>
                                            </div>
                                        </div>
                                        <div class="card bg-light">
                                            <div class="card-body">
                                                <h6 class="card-title text-primary">AB Dışı Öğrenciler</h6>
                                                <p class="mb-1"><strong><%= t.studentLifePage.sections.costs.tuitionFee %>:</strong> 8.000-20.000€<%= t.studentLifePage.units.perYear %></p>
                                                <p class="mb-0"><strong><%= t.studentLifePage.sections.costs.total %>:</strong> 8.000-20.000€<%= t.studentLifePage.units.perYear %></p>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <h5 class="text-warning mb-3"><%= t.studentLifePage.sections.costs.scholarships %></h5>
                                        <ul class="list-unstyled">
                                            <li class="mb-3">
                                                <div class="d-flex align-items-center">
                                                    <i class="fas fa-star text-warning me-2"></i>
                                                    <div>
                                                        <strong><%= t.studentLifePage.countries.netherlands.scholarships.holland.title %></strong><br>
                                                        <small class="text-muted"><%= t.studentLifePage.countries.netherlands.scholarships.holland.description %></small>
                                                    </div>
                                                </div>
                                            </li>
                                            <li class="mb-3">
                                                <div class="d-flex align-items-center">
                                                    <i class="fas fa-tulip text-primary me-2"></i>
                                                    <div>
                                                        <strong><%= t.studentLifePage.countries.netherlands.scholarships.orange.title %></strong><br>
                                                        <small class="text-muted"><%= t.studentLifePage.countries.netherlands.scholarships.orange.description %></small>
                                                    </div>
                                                </div>
                                            </li>
                                            <li class="mb-3">
                                                <div class="d-flex align-items-center">
                                                    <i class="fas fa-handshake text-success me-2"></i>
                                                    <div>
                                                        <strong><%= t.studentLifePage.sections.costs.workPermit %></strong><br>
                                                        <small class="text-muted"><%= t.studentLifePage.sections.costs.workHours %></small>
                                                    </div>
                                                </div>
                                            </li>
                                        </ul>
                                    </div>
                                </div>
                                
                                <div class="alert alert-warning mt-4">
                                    <i class="fas fa-exclamation-triangle me-2"></i>
                                    <strong><%= t.studentLifePage.additionalTerms.attention %>:</strong> <%= t.studentLifePage.countries.netherlands.alerts.visaRequirement %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="col-lg-4">
                <!-- Quick Info -->
                <div class="card shadow-lg border-0 mb-4">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-info-circle me-2"></i>
                            <%= t.studentLifePage.sections.quickInfo.title %>
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row text-center">
                            <div class="col-6 mb-3">
                                <div class="p-3 bg-primary rounded">
                                    <h4 class="text-white mb-1">13.000€</h4>
                                    <small class="text-white">AB Dışı Üni Ücreti/Yıl</small>
                                </div>
                            </div>
                            <div class="col-6 mb-3">
                                <div class="p-3 bg-success rounded">
                                    <h4 class="text-white mb-1">1.100€</h4>
                                    <small class="text-white"><%= t.studentLifePage.additionalTerms.minLiving %></small>
                                </div>
                            </div>
                            <div class="col-6 mb-3">
                                <div class="p-3 bg-warning rounded">
                                    <h4 class="text-white mb-1">16 <%= t.studentLifePage.buttons.hours %></h4>
                                    <small class="text-white"><%= t.studentLifePage.additionalTerms.weeklyWork %></small>
                                </div>
                            </div>
                            <div class="col-6 mb-3">
                                <div class="p-3 bg-info rounded">
                                    <h4 class="text-white mb-1">100+</h4>
                                    <small class="text-white"><%= t.studentLifePage.additionalTerms.universities %></small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Important Warning - Turkish Diploma -->
                <div class="card shadow-lg border-0 mb-4">
                    <div class="card-header bg-danger text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            <%= t.studentLifePage.diplomaWarnings.turkishWarningTitle %>
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-danger mb-3" style="background: #fff5f5; border-left: 4px solid #dc3545;">
                            <p class="mb-2"><strong><i class="fas fa-graduation-cap me-2"></i>Araştırma Üniversiteleri (WO):</strong></p>
                            <p class="mb-3 text-dark"><%= t.studentLifePage.diplomaWarnings.netherlands.woWarning %></p>
                        </div>
                        <div class="alert alert-success mb-0" style="background: #f0fff4; border-left: 4px solid #28a745;">
                            <p class="mb-2"><strong><i class="fas fa-university me-2"></i>Uygulamalı Bilimler Üniversiteleri (HBO):</strong></p>
                            <p class="mb-0 text-dark"><%= t.studentLifePage.diplomaWarnings.netherlands.hboInfo %></p>
                        </div>
                        <hr class="my-3">
                        <p class="small text-muted mb-0">
                            <i class="fas fa-info-circle me-1"></i>
                            <strong>Not:</strong> <%= t.studentLifePage.diplomaWarnings.netherlands.apNote %>
                        </p>
                    </div>
                </div>

                <!-- Kanada Lise Diploması Avantajı -->
                <div class="card shadow-lg border-0 mb-4">
                    <div class="card-header text-white" style="background: linear-gradient(135deg, #059669 0%, #047857 100%);">
                        <h5 class="mb-0">
                            <i class="fas fa-maple-leaf me-2"></i>
                            <%= t.studentLifePage.diplomaWarnings.canadianAdvantageTitle %>
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-success mb-3" style="background: #f0fdf4; border-left: 4px solid #22c55e;">
                            <p class="mb-2"><strong><i class="fas fa-check-circle me-2"></i><%= t.studentLifePage.diplomaWarnings.directAdmission %>!</strong></p>
                            <p class="mb-0 text-dark"><%= t.studentLifePage.diplomaWarnings.netherlands.advantage %></p>
                        </div>
                        <ul class="list-unstyled mb-3">
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i><%= t.studentLifePage.diplomaWarnings.netherlands.benefit1 %></li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i><%= t.studentLifePage.diplomaWarnings.netherlands.benefit2 %></li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i><%= t.studentLifePage.diplomaWarnings.netherlands.benefit3 %></li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i><%= t.studentLifePage.diplomaWarnings.netherlands.benefit4 %></li>
                        </ul>
                        <a href="/partners/wcep" class="btn btn-success btn-sm w-100">
                            <i class="fas fa-info-circle me-2"></i><%= t.studentLifePage.diplomaWarnings.aboutWcep %>
                        </a>
                    </div>
                </div>

                <!-- Consulting -->
                <div class="card shadow-lg border-0">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-headset me-2"></i>
                            <%= t.studentLifePage.additionalTerms.consulting %>
                        </h5>
                    </div>
                    <div class="card-body text-center">
                        <p class="mb-4 text-dark" style="color: #111 !important; text-shadow: none !important; font-weight: 500 !important;"><%= t.studentLifePage.countries.netherlands.consultingText %></p>
                        <a href="/contact" class="btn btn-primary btn-lg w-100 mb-3" style="font-size: clamp(0.875rem, 2vw, 1rem); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                            <i class="fas fa-phone me-2"></i>
                            <span class="d-none d-sm-inline"><%= t.studentLifePage.sections.consulting.freeConsulting %></span>
                            <span class="d-sm-none">Danışmanlık</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
