<!-- Hero Section -->
<section class="py-5" style="background: linear-gradient(180deg, #f8f9fa 0%, #e9ecef 100%);">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center">
                <h1 class="display-4 fw-bold text-dark"><%= t.studentLifePage.hero.uk.title %></h1>
                <p class="lead text-muted"><%= t.studentLifePage.hero.uk.subtitle %></p>
            </div>
        </div>
    </div>
</section>

<!-- Content Section -->
<section class="py-5">
    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                <div class="card shadow-lg border-0 mb-4 overflow-hidden reveal">
                    <div class="row g-0">
                        <div class="col-md-4">
                            <div class="student-life-card-img-wrapper">
                                <img src="/images/countries/uk/AdobeStock_284868838.jpeg" class="student-life-card-img" alt="UK University Campus">
                            </div>
                        </div>
                        <div class="col-md-8">
                            <div class="card-body p-4">
                                <div class="d-flex align-items-center mb-3">
                                    <h3 class="mb-0"><%= t.studentLifePage.countries.uk.title || t.studentLifePage.sections.educationSystem.title %></h3>
                                </div>
                                <p class="lead text-dark"><%= t.studentLifePage.countries.uk.description1 %></p>
                                <p><%= t.studentLifePage.countries.uk.description2 %></p>
                                
                                <div class="row mt-4">
                                    <div class="col-md-6">
                                        <h5 class="text-primary mb-3"><%= t.studentLifePage.sections.educationSystem.title %></h5>
                                        <ul class="list-unstyled">
                                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i><strong><%= t.studentLifePage.sections.educationSystem.bachelor %>:</strong> 3 <%= t.studentLifePage.units.perYear.replace('/', '') %></li>
                                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i><strong><%= t.studentLifePage.sections.educationSystem.master %>:</strong> 1 <%= t.studentLifePage.units.perYear.replace('/', '') %></li>

                                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i><strong><%= t.studentLifePage.sections.educationSystem.language %>:</strong> <%= t.studentLifePage.languages.english %></li>
                                        </ul>
                                    </div>
                                    <div class="col-md-6">
                                        <h5 class="text-primary mb-3"><%= t.studentLifePage.sections.educationSystem.popularDepts %></h5>
                                        <div class="d-flex flex-wrap gap-2">
                                            <% t.studentLifePage.sections.educationSystem.departments.forEach(function(badge, idx) { %>
                                                <span class="badge badge-style-<%= (idx % 3) + 1 %> text-dark fw-semibold bg-white border"><%= badge %></span>
                                            <% }); %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-lg border-0 mb-4 overflow-hidden reveal">
                    <div class="row g-0">
                        <div class="col-md-8">
                            <div class="card-body p-4">
                                <div class="d-flex align-items-center mb-3">
                                    <h3 class="mb-0"><%= t.studentLifePage.sections.accommodation.title %></h3>
                                </div>
                                <p class="lead text-dark"><%= t.studentLifePage.countries.uk.livingDescription %></p>
                                
                                <div class="row mt-4">
                                    <div class="col-md-6">
                                        <h5 class="mb-3" style="color: #005A9E;"><%= t.studentLifePage.sections.accommodation.title %></h5>
                                        <ul class="list-unstyled">
                                            <li class="mb-2"><strong><%= t.studentLifePage.sections.accommodation.studentDorms %>:</strong> 400-800£<%= t.studentLifePage.units.perMonth %></li>
                                            <li class="mb-2"><strong><%= t.studentLifePage.sections.accommodation.privateDorms %>:</strong> 500-1.000£<%= t.studentLifePage.units.perMonth %></li>
                                            <li class="mb-2"><strong><%= t.studentLifePage.sections.accommodation.sharedFlat %>:</strong> 300-600£<%= t.studentLifePage.units.perMonth %></li>
                                            <li class="mb-2"><strong><%= t.studentLifePage.sections.accommodation.studio %>:</strong> 600-1.200£<%= t.studentLifePage.units.perMonth %></li>
                                        </ul>
                                    </div>
                                    <div class="col-md-6">
                                        <h5 class="mb-3" style="color: #005A9E;"><%= t.studentLifePage.sections.accommodation.monthlyLiving %></h5>
                                        <div class="d-flex flex-wrap gap-2 mb-3">
                                            <% const costBadges = [
                                                {icon: 'fa-home', text: t.studentLifePage.sections.accommodation.costs.accommodation + ' 400-800€'},
                                                {icon: 'fa-utensils', text: t.studentLifePage.sections.accommodation.costs.food + ' 200-300€'},
                                                {icon: 'fa-bus', text: t.studentLifePage.sections.accommodation.costs.transport + ' 80-120€'},
                                                {icon: 'fa-shopping-bag', text: t.studentLifePage.sections.accommodation.costs.other + ' 150-250€'}
                                            ]; %>
                                            <% costBadges.forEach(function(badge, idx) { %>
                                                <span class="badge badge-style-<%= (idx % 3) + 1 %> p-2 bg-white text-dark fw-semibold border" style="font-size: 0.85rem;">
                                                    <%= badge.text %>
                                                </span>
                                            <% }); %>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="alert mt-4" style="background: #eef6ff; border-left: 4px solid #005A9E;">
                                    <strong><%= t.studentLifePage.alerts.important %>:</strong> <%= t.studentLifePage.countries.uk.alerts.nhsInfo %>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="student-life-card-img-wrapper">
                                <img src="/images/countries/uk/AdobeStock_108472954.jpeg" class="student-life-card-img" alt="UK Student Life">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-lg border-0 mb-4 overflow-hidden reveal">
                    <div class="row g-0">
                        <div class="col-md-4">
                            <div class="student-life-card-img-wrapper">
                                <img src="/images/countries/uk/AdobeStock_191323914.jpeg" class="student-life-card-img" alt="UK Costs">
                            </div>
                        </div>
                        <div class="col-md-8">
                            <div class="card-body p-4">
                                <div class="d-flex align-items-center mb-3">
                                    <h3 class="mb-0"><%= t.studentLifePage.sections.costs.title %></h3>
                                </div>
                                <p class="lead text-dark"><%= t.studentLifePage.countries.uk.costsDescription %></p>
                                
                                <div class="row mt-4">
                                    <div class="col-md-6">
                                        <h5 class="mb-3" style="color: #005A9E;"><%= t.studentLifePage.sections.costs.educationCosts %></h5>
                                        <div class="card bg-light mb-3">
                                            <div class="card-body">
                                                <h6 class="card-title text-primary"><%= t.studentLifePage.sections.educationSystem.bachelor %> Eğitimi</h6>
                                                <p class="mb-1"><strong><%= t.studentLifePage.sections.costs.tuitionFee %>:</strong> 9.250-38.000£<%= t.studentLifePage.units.perYear %></p>
                                                <p class="mb-0"><strong><%= t.studentLifePage.sections.costs.total %>:</strong> 9.250-38.000£<%= t.studentLifePage.units.perYear %></p>
                                            </div>
                                        </div>
                                        <div class="card bg-light">
                                            <div class="card-body">
                                                <h6 class="card-title text-primary"><%= t.studentLifePage.sections.educationSystem.master %></h6>
                                                <p class="mb-1"><strong><%= t.studentLifePage.sections.costs.tuitionFee %>:</strong> 10.000-45.000£<%= t.studentLifePage.units.perYear %></p>
                                                <p class="mb-0"><strong><%= t.studentLifePage.sections.costs.total %>:</strong> 10.000-45.000£<%= t.studentLifePage.units.perYear %></p>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <h5 class="mb-3" style="color: #005A9E;"><%= t.studentLifePage.sections.costs.scholarships %></h5>
                                        <ul class="list-unstyled">
                                            <li class="mb-3">
                                                <div class="d-flex align-items-center">
                                                    <div>
                                                        <strong><%= t.studentLifePage.countries.uk.scholarships.chevening.title %></strong><br>
                                                        <small class="text-muted"><%= t.studentLifePage.countries.uk.scholarships.chevening.description %></small>
                                                    </div>
                                                </div>
                                            </li>
                                            <li class="mb-3">
                                                <div class="d-flex align-items-center">
                                                    <div>
                                                        <strong><%= t.studentLifePage.countries.uk.scholarships.university.title %></strong><br>
                                                        <small class="text-muted"><%= t.studentLifePage.countries.uk.scholarships.university.description %></small>
                                                    </div>
                                                </div>
                                            </li>
                                            <li class="mb-3">
                                                <div class="d-flex align-items-center">
                                                    <div>
                                                        <strong><%= t.studentLifePage.sections.costs.workPermit %></strong><br>
                                                        <small class="text-muted"><%= t.studentLifePage.sections.costs.workHours %></small>
                                                    </div>
                                                </div>
                                            </li>
                                        </ul>
                                    </div>
                                </div>
                                
                                <div class="alert mt-4" style="background: #eef6ff; border-left: 4px solid #005A9E;">
                                    <strong><%= t.studentLifePage.alerts.attention %>:</strong> <%= t.studentLifePage.countries.uk.alerts.visaRequirement %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="col-lg-4">
                <!-- Consulting -->
                <div class="card shadow-lg border-0 mb-4 reveal">
                    <div class="card-header text-white" style="background: #005A9E;">
                        <h5 class="mb-0">
                            <%= t.studentLifePage.sections.consulting.title %>
                        </h5>
                    </div>
                    <div class="card-body text-center">
                        <p class="mb-4 text-dark" style="color: #111 !important; text-shadow: none !important; font-weight: 500 !important;"><%= t.studentLifePage.countries.uk.consultingText %></p>
                        <a href="/contact" class="btn btn-primary btn-lg w-100 mb-3" style="font-size: clamp(0.875rem, 2vw, 1rem); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                            <i class="fas fa-phone me-2"></i>
                            <span class="d-none d-sm-inline"><%= t.studentLifePage.sections.consulting.freeConsulting %></span>
                            <span class="d-sm-none">Danışmanlık</span>
                        </a>
                        <a href="/#randevu" class="btn btn-outline-primary btn-lg w-100" style="font-size: clamp(0.875rem, 2vw, 1rem);">
                            <i class="fas fa-calendar-check me-2"></i><%= currentLanguage === 'en' ? 'Book an Appointment' : 'Randevu Al' %>
                        </a>
                        <p class="mt-2 mb-0 text-muted" style="font-size: 12px;"><%= currentLanguage === 'en' ? 'Want to study in UK? Meet our expert advisors now!' : 'İngiltere\'de okumak mı istiyorsun? Hemen uzman danışmanlarımızla görüş!' %></p>
                    </div>
                </div>

                <!-- Quick Info -->
                <div class="card shadow-lg border-0 mb-4 reveal">
                    <div class="card-header text-white" style="background: #005A9E;">
                        <h5 class="mb-0">
                            <%= t.studentLifePage.sections.quickInfo.title %>
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row text-center">
                            <div class="col-6 mb-3">
                                <div class="p-3 rounded" style="background: #005A9E;">
                                    <h4 class="text-white mb-1">15.000£</h4>
                                    <small class="text-white"><%= t.studentLifePage.sections.quickInfo.yearlyTuition %></small>
                                </div>
                            </div>
                            <div class="col-6 mb-3">
                                <div class="p-3 rounded" style="background: #005A9E;">
                                    <h4 class="text-white mb-1">1.100£</h4>
                                    <small class="text-white"><%= t.studentLifePage.sections.quickInfo.minLiving %></small>
                                </div>
                            </div>
                            <div class="col-6 mb-3">
                                <div class="p-3 rounded" style="background: #005A9E;">
                                    <h4 class="text-white mb-1">20 <%= t.studentLifePage.buttons.hours %></h4>
                                    <small class="text-white"><%= t.studentLifePage.sections.quickInfo.weeklyWork %></small>
                                </div>
                            </div>
                            <div class="col-6 mb-3">
                                <div class="p-3 rounded" style="background: #005A9E;">
                                    <h4 class="text-white mb-1">160+</h4>
                                    <small class="text-white"><%= t.studentLifePage.sections.quickInfo.universities %></small>
                                </div>
                            </div>
                        </div>
                        
                        <div class="alert mt-3" style="background: #eef6ff; border-left: 4px solid #005A9E;">
                            <strong><%= t.studentLifePage.sections.quickInfo.tip %>:</strong> <%= t.studentLifePage.countries.uk.alerts.tip %>
                        </div>
                    </div>
                </div>

                <!-- Important Info - Turkish Diploma Accepted -->
                <div class="card shadow-lg border-0 mb-4 reveal">
                    <div class="card-header text-white" style="background: #005A9E;">
                        <h5 class="mb-0">
                            <%= t.studentLifePage.diplomaWarnings.turkishInfoTitle %>
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="alert mb-3" style="background: #eef6ff; border-left: 4px solid #005A9E;">
                            <p class="mb-2"><strong><%= t.studentLifePage.diplomaWarnings.directAdmission %>:</strong></p>
                            <p class="mb-0 text-dark"><%= t.studentLifePage.diplomaWarnings.uk.info %></p>
                        </div>
                        <div class="alert mb-0" style="background: #eef6ff; border-left: 4px solid #005A9E;">
                            <p class="mb-2"><strong>UCAS Nedir?</strong></p>
                            <p class="mb-0 text-dark small"><%= t.studentLifePage.diplomaWarnings.uk.ucasInfo %></p>
                        </div>
                    </div>
                </div>

                <!-- Kanada Lise Diploması Avantajı -->
                <div class="card shadow-lg border-0 mb-4 reveal">
                    <div class="card-header text-white" style="background: #005A9E;">
                        <h5 class="mb-0">
                            <%= t.studentLifePage.diplomaWarnings.canadianAdvantageTitle %>
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="alert mb-3" style="background: #eef6ff; border-left: 4px solid #005A9E;">
                            <p class="mb-2"><strong>Foundation Year <%= t.studentLifePage.diplomaWarnings.bypass %></strong></p>
                            <p class="mb-0 text-dark"><%= t.studentLifePage.diplomaWarnings.uk.advantage %></p>
                        </div>
                        <ul class="list-unstyled mb-3">
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i><%= t.studentLifePage.diplomaWarnings.uk.benefit1 %></li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i><%= t.studentLifePage.diplomaWarnings.uk.benefit2 %></li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i><%= t.studentLifePage.diplomaWarnings.uk.benefit3 %></li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i><%= t.studentLifePage.diplomaWarnings.uk.benefit4 %></li>
                        </ul>
                        <a href="/partners/wcep" class="btn btn-sm w-100" style="background: #005A9E; color: white;">
                            <%= t.studentLifePage.diplomaWarnings.aboutWcep %>
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </div>

<!-- Country Guide CTA -->
<section class="py-4" style="background: linear-gradient(135deg, #003d6b 0%, #005A9E 100%);">
    <div class="container">
        <div class="d-flex flex-column flex-md-row align-items-center justify-content-between gap-3 py-2">
            <div class="d-flex align-items-center gap-3 text-white">
                <span style="font-size:2.5rem;">🇬🇧</span>
                <div>
                    <h4 class="mb-0 fw-bold">İngiltere Ülke Rehberi</h4>
                    <p class="mb-0 small" style="opacity:0.85;">Üniversiteler, ücretler, burslar, vize süreci ve daha fazlası</p>
                </div>
            </div>
            <a href="/ulkede-universite/ingiltere" class="btn btn-light btn-lg px-4" style="border-radius:50px; font-weight:600; white-space:nowrap;">
                <i class="fas fa-book-open me-2"></i>Rehberi İncele
            </a>
        </div>
    </div>
</section>
</section>

<script>
(function() {
    var reveals = document.querySelectorAll('.reveal');
    if (!reveals.length) return;
    var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry, i) {
            if (entry.isIntersecting) {
                setTimeout(function() { entry.target.classList.add('visible'); }, i * 80);
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.15 });
    reveals.forEach(function(el) { observer.observe(el); });
})();
</script>