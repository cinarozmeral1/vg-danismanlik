                                        <p class="mb-0 small text-dark">Research University'ler için <strong class="text-danger">AP şartı kalkar</strong>. Tüm üniversitelere direkt başvuru!</p>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="mt-4 p-3 text-center" style="background: linear-gradient(135deg, #dc2626, #991b1b); border-radius: 12px; color: white;">
                                <p class="mb-2"><i class="fas fa-star me-2"></i>Tebrikler! Bu avantajlar size hem zaman hem de para tasarrufu sağlayacaktır.</p>
                                <a href="/partners/wcep" class="btn btn-warning">
                                    <i class="fas fa-info-circle me-2"></i>WCEP Hakkında Detaylı Bilgi
                                </a>
                            </div>
                        </div>
                    ` : ''}
                    
                    <!-- WCEP Promotion Banner (Kanada diploması olmayanlar için) -->
                    ${!hasCanadianDiploma ? `
                        <div class="wcep-promo mb-4" style="background: linear-gradient(135deg, #fef2f2, #fee2e2); border: 2px solid #dc2626; border-radius: 15px; padding: 20px;">
                            <div class="d-flex align-items-start">
                                <span style="font-size: 2rem; margin-right: 15px;">🍁</span>
                                <div>
                                    <h6 class="mb-2 text-danger"><i class="fas fa-info-circle me-2"></i>Biliyor muydunuz?</h6>
                                    <p class="mb-2 text-dark" style="font-size: 0.95rem;">
                                        <strong>WCEP (Worldwide Cultural Exchange Program)</strong> ortaklığımız ile 12. sınıfı Kanada'da tamamlayan öğrenciler, 
                                        Avrupa üniversitelerinde hazırlık programlarından muafiyet, sınavsız kabul ve öncelikli değerlendirme gibi 
                                        büyük avantajlar elde ediyor!
                                    </p>
                                    <a href="/partners/wcep" class="btn btn-danger btn-sm">
                                        <i class="fas fa-arrow-right me-2"></i>WCEP'i Keşfet
                                    </a>
                                </div>
                            </div>
                        </div>
                    ` : ''}
                    
                    <div class="text-center mt-4">
                        <a href="/user/dashboard" class="btn btn-primary btn-lg me-2">
                            <i class="fas fa-user me-2"></i>Portalıma Git
                        </a>
                        <a href="https://wa.me/message/O2KRAFDJAMX7F1" target="_blank" class="btn btn-success btn-lg">
                            <i class="fab fa-whatsapp me-2"></i>Danışman ile Görüş
                        </a>
                    </div>
                </div>
            `;
            
            document.getElementById('questionContainer').innerHTML = html;
        }
        
        // Google Client ID
        const GOOGLE_CLIENT_ID = '<%= typeof googleClientId !== "undefined" ? googleClientId.trim() : "" %>';
        let wizardSavedAnswers = null; // Store answers before login
        let wizardPhoneInput = null; // Phone input instance
        let pendingWizardRecommendationId = null; // Store recommendation ID for phone modal
        
        // Initialize intl-tel-input for wizard phone modal
        function initWizardPhoneInput() {
            const phoneField = document.getElementById('wizardPhoneInput');
            if (phoneField && !wizardPhoneInput) {
                wizardPhoneInput = window.intlTelInput(phoneField, {
                    initialCountry: "tr",
                    preferredCountries: ["tr", "de", "gb", "us", "fr", "it", "es", "nl", "at", "cz"],
                    separateDialCode: true,
                    utilsScript: "https://cdn.jsdelivr.net/npm/intl-tel-input@18.2.1/build/js/utils.js"
                });
            }
        }
        
        // Note: Google buttons are now direct links (/api/auth/google/redirect)
        
        // Handle "Kayıt Olun" button - save wizard first, then redirect to register
        document.getElementById('wizardRegisterBtn')?.addEventListener('click', async function() {
            const btn = this;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Yükleniyor...';
            
            try {
                // Submit wizard to get recommendation ID
                const response = await fetch('/api/wizard/submit', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(answers)
                });
                
                const data = await response.json();
                const recommendationId = data.recommendation_id || data.id;
                
                // Store in sessionStorage
                if (recommendationId) {
                    sessionStorage.setItem('wizard_recommendation_id', recommendationId);
                    console.log('Saved wizard recommendation:', recommendationId);
                }
                
                // Redirect to register page
                window.location.href = '/register?redirect=wizard&wizard_rec=' + (recommendationId || '');
                
            } catch (err) {
                console.error('Error saving wizard:', err);
                // Still redirect, just without recommendation
                window.location.href = '/register?redirect=wizard';
            }
        });
        
        // Google button handlers - önce wizard submit et, sonra Google'a wizard_rec ile yönlendir
        async function handleGoogleAuth(action) {
            try {
                // Submit wizard to get recommendation ID
                const response = await fetch('/api/wizard/submit', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(answers)
                });
                
                const data = await response.json();
                const recommendationId = data.recommendation_id || data.id;
                
                // Store in sessionStorage as backup
                if (recommendationId) {
                    sessionStorage.setItem('wizard_recommendation_id', recommendationId);
                    console.log('📎 Saved wizard recommendation for Google auth:', recommendationId);
                }
                
                // Build Google redirect URL with wizard_rec parameter
                let googleUrl = '/api/auth/google/redirect?action=' + action;
                if (recommendationId) {
                    googleUrl += '&wizard_rec=' + recommendationId;
                }
                
                // Also pass english_level from wizard answers
                if (answers.english_level) {
                    googleUrl += '&english_level=' + encodeURIComponent(answers.english_level);
                }
                
                console.log('🔗 Redirecting to Google:', googleUrl);
                window.location.href = googleUrl;
                
            } catch (err) {
                console.error('Error saving wizard before Google auth:', err);
                // Still redirect to Google, just without recommendation
                window.location.href = '/api/auth/google/redirect?action=' + action;
            }
        }
        
        document.getElementById('googleLoginBtn')?.addEventListener('click', async function() {
            const btn = this;
            btn.disabled = true;
            btn.innerHTML = '<img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" alt="Google" style="width:22px;height:22px;margin-right:12px;"><span><i class="fas fa-spinner fa-spin me-1"></i>Yükleniyor...</span>';
            await handleGoogleAuth('login');
        });
        
        document.getElementById('googleRegisterBtn')?.addEventListener('click', async function() {
            const btn = this;
            btn.disabled = true;
            btn.innerHTML = '<img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" alt="Google" style="width:22px;height:22px;margin-right:12px;"><span style="color:#28a745;"><i class="fas fa-spinner fa-spin me-1"></i>Yükleniyor...</span>';
            await handleGoogleAuth('register');
        });
        
        // Login form handler
        document.getElementById('wizardLoginForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const email = document.getElementById('loginEmail').value;
            const password = document.getElementById('loginPassword').value;
            const errorDiv = document.getElementById('loginError');
            const submitBtn = this.querySelector('button[type="submit"]');
            
            // Save current wizard answers before login
            wizardSavedAnswers = { ...answers };
            
            // Disable button during request
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Giriş yapılıyor...';
            errorDiv.classList.add('d-none');
            
            try {
                const response = await fetch('/api/auth/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({ email, password })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    // Admin kontrolü - admin hesapları sihirbazı kullanamaz
                    if (data.is_admin === true) {
                        errorDiv.textContent = 'Admin hesapları sihirbazı kullanamaz. Lütfen öğrenci hesabıyla giriş yapın.';
                        errorDiv.classList.remove('d-none');
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = 'Giriş Yap';
                        return;
                    }
                    
                    isAuthenticated = true;
                    currentUser = data.user;
                    
                    // Close modal
                    const modalEl = document.getElementById('loginModal');
                    const modal = bootstrap.Modal.getInstance(modalEl);
                    if (modal) modal.hide();
                    
                    // Update button to show processing
                    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Analiz başlatılıyor...';
                    
                    // Wait a bit for cookie to be set, then submit
                    setTimeout(async () => {
                        try {
                            await submitWizard();
                        } catch (err) {
                            console.error('Submit error after login:', err);
                            alert('Bir hata oluştu: ' + err.message);
                        }
                    }, 500);
                } else {
                    errorDiv.textContent = data.message || 'E-posta veya şifre hatalı';
                    errorDiv.classList.remove('d-none');
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = 'Giriş Yap';
                }
            } catch (error) {
                console.error('Login error:', error);
                errorDiv.textContent = 'Bağlantı hatası. Lütfen tekrar deneyin.';
                errorDiv.classList.remove('d-none');
                submitBtn.disabled = false;
                submitBtn.innerHTML = 'Giriş Yap';
            }
        });
    </script>
</body>
</html>

