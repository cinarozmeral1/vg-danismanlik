<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
    
    <!-- International Phone Input -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/intl-tel-input@18.2.1/build/css/intlTelInput.css">
    
    <!-- Google OAuth -->
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <style>
        :root {
            --wizard-primary: #0056b3;
            --wizard-secondary: #004494;
            --wizard-accent: #28a745;
            --wizard-bg: #fef6f0;
            --wizard-card-bg: #ffffff;
        }
        
        body {
            background: var(--wizard-bg);
            min-height: 100vh;
        }
        
        .wizard-container {
            max-width: 900px;
            margin: 0 auto;
            padding: 20px;
        }
        
        .wizard-header {
            text-align: center;
            padding: 30px 0;
        }
        
        .wizard-header h1 {
            color: var(--wizard-primary);
            font-weight: 700;
            margin-bottom: 10px;
        }
        
        .wizard-header p {
            color: #666;
            font-size: 1.1rem;
        }
        
        /* Progress Bar */
        .wizard-progress {
            background: #e9ecef;
            border-radius: 10px;
            height: 8px;
            margin-bottom: 30px;
            overflow: hidden;
        }
        
        .wizard-progress-bar {
            background: linear-gradient(90deg, var(--wizard-primary), var(--wizard-accent));
            height: 100%;
            border-radius: 10px;
            transition: width 0.5s ease;
        }
        
        .wizard-step-indicator {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-bottom: 20px;
        }
        
        .step-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: #ddd;
            transition: all 0.3s ease;
        }
        
        .step-dot.active {
            background: var(--wizard-primary);
            transform: scale(1.2);
        }
        
        .step-dot.completed {
            background: var(--wizard-accent);
        }
        
        /* Question Card */
        .wizard-question {
            background: var(--wizard-card-bg);
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
            margin-bottom: 30px;
            min-height: 400px;
            display: flex;
            flex-direction: column;
        }
        
        .question-title {
            font-size: 1.5rem;
            font-weight: 600;
            color: #333;
            margin-bottom: 10px;
            text-align: center;
        }
        
        .question-subtitle {
            color: #666;
            text-align: center;
            margin-bottom: 30px;
        }
        
        /* Selection Cards */
        .selection-cards {
            display: grid;
            gap: 15px;
            flex: 1;
        }
        
        .selection-cards.two-cols {
            grid-template-columns: repeat(2, 1fr);
        }
        
        .selection-cards.three-cols {
            grid-template-columns: repeat(3, 1fr);
        }
        
        .selection-cards.four-cols {
            grid-template-columns: repeat(2, 1fr);
        }
        
        @media (min-width: 768px) {
            .selection-cards.four-cols {
                grid-template-columns: repeat(4, 1fr);
            }
            .selection-cards.six-cols {
                grid-template-columns: repeat(3, 1fr);
            }
        }
        
        .selection-card {
            background: #f8f9fa;
            border: 3px solid transparent;
            border-radius: 15px;
            padding: 25px 20px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .selection-card:hover {
            border-color: var(--wizard-primary);
            transform: translateY(-3px);
            box-shadow: 0 5px 20px rgba(0,86,179,0.15);
        }
        
        .selection-card.selected {
            border-color: var(--wizard-primary);
            background: linear-gradient(135deg, rgba(0,86,179,0.1), rgba(40,167,69,0.1));
        }
        
        .selection-card.selected .card-icon {
            color: var(--wizard-primary);
        }
        
        .selection-card .card-icon {
            font-size: 2.5rem;
            margin-bottom: 15px;
            color: #666;
            transition: color 0.3s ease;
        }
        
        .selection-card .card-title {
            font-weight: 600;
            color: #333;
            margin-bottom: 5px;
        }
        
        .selection-card .card-desc {
            font-size: 0.85rem;
            color: #666;
        }
        
        /* Large Cards (for education level) */
        .selection-card.large {
            padding: 40px 30px;
        }
        
        .selection-card.large .card-icon {
            font-size: 4rem;
        }
        
        /* Country Cards with Flags */
        .country-card {
            position: relative;
        }
        
        .country-card .flag-emoji {
            font-size: 3rem;
            margin-bottom: 10px;
        }
        
        .country-card .preference-badge {
            position: absolute;
            top: 10px;
            right: 10px;
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: var(--wizard-primary);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        
        .country-card.selected .preference-badge {
            opacity: 1;
        }
        
        /* Slider */
        .wizard-slider {
            width: 100%;
            margin: 30px 0;
        }
        
        .wizard-slider input[type="range"] {
            width: 100%;
            height: 10px;
            border-radius: 5px;
            background: #e9ecef;
            outline: none;
            -webkit-appearance: none;
        }
        
        .wizard-slider input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 25px;
            height: 25px;
            border-radius: 50%;
            background: var(--wizard-primary);
            cursor: pointer;
            box-shadow: 0 2px 10px rgba(0,86,179,0.3);
        }
        
        .slider-labels {
            display: flex;
            justify-content: space-between;
            margin-top: 10px;
            color: #666;
            font-size: 0.9rem;
        }
        
        .slider-value {
            text-align: center;
            font-size: 2rem;
            font-weight: bold;
            color: var(--wizard-primary);
            margin-bottom: 10px;
        }
        
        /* Navigation Buttons */
        .wizard-nav {
            display: flex;
            justify-content: space-between;
            gap: 15px;
        }
        
        .btn-wizard {
            padding: 15px 40px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 1.1rem;
            transition: all 0.3s ease;
        }
        
        .btn-wizard-back {
            background: #f8f9fa;
            color: #666;
            border: 2px solid #ddd;
        }
        
        .btn-wizard-back:hover {
            background: #e9ecef;
            color: #333;
        }
        
        .btn-wizard-next {
            background: linear-gradient(135deg, var(--wizard-primary), var(--wizard-secondary));
            color: white;
            border: none;
            flex: 1;
            max-width: 300px;
        }
        
        .btn-wizard-next:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(0,86,179,0.3);
            color: white;
        }
        
        .btn-wizard-next:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }
        
        /* Multi-select info */
        .multi-select-info {
            text-align: center;
            color: #666;
            font-size: 0.9rem;
            margin-top: 15px;
        }
        
        .multi-select-info .count {
            font-weight: bold;
            color: var(--wizard-primary);
        }
        
        /* Result Section */
        .wizard-result {
            background: var(--wizard-card-bg);
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        }
        
        .result-header {
            text-align: center;
            margin-bottom: 30px;
        }
        
        .result-header .success-icon {
            font-size: 5rem;
            color: var(--wizard-accent);
            margin-bottom: 20px;
        }
        
        .result-card {
            background: linear-gradient(135deg, var(--wizard-primary), var(--wizard-secondary));
            color: white;
            border-radius: 15px;
            padding: 30px;
            margin-bottom: 20px;
        }
        
        .result-card h3 {
            margin-bottom: 20px;
            font-weight: 600;
        }
        
        .result-item {
            display: flex;
            align-items: center;
            margin-bottom: 15px;
        }
        
        .result-item i {
            width: 30px;
            font-size: 1.2rem;
        }
        
        .result-item .label {
            width: 120px;
            opacity: 0.8;
        }
        
        .result-item .value {
            font-weight: 600;
            flex: 1;
        }
        
        .prep-warning {
            background: #fff3cd;
            border: 1px solid #ffc107;
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 20px;
        }
        
        .prep-warning h5 {
            color: #856404;
            margin-bottom: 10px;
        }
        
        .prep-warning p {
            color: #856404;
            margin: 0;
        }
        
        .reasoning-card {
            background: #f8f9fa;
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 20px;
        }
        
        .reasoning-card h5 {
            color: var(--wizard-primary);
            margin-bottom: 15px;
        }
        
        /* Login Modal */
        .login-required {
            text-align: center;
            padding: 40px;
        }
        
        .login-required .lock-icon {
            font-size: 4rem;
            color: #ffc107;
            margin-bottom: 20px;
        }
        
        /* Loading */
        .wizard-loading {
            text-align: center;
            padding: 60px;
        }
        
        .wizard-loading .spinner {
            width: 60px;
            height: 60px;
            border: 5px solid #e9ecef;
            border-top-color: var(--wizard-primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 0 auto 20px;
        }
        
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        
        /* Textarea */
        .wizard-textarea {
            width: 100%;
            border: 2px solid #e9ecef;
            border-radius: 10px;
            padding: 15px;
            font-size: 1rem;
            resize: none;
            transition: border-color 0.3s ease;
        }
        
        .wizard-textarea:focus {
            outline: none;
            border-color: var(--wizard-primary);
        }
        
        .char-count {
            text-align: right;
            color: #666;
            font-size: 0.85rem;
            margin-top: 5px;
        }
        
        /* Back to home */
        .back-home {
            position: fixed;
            top: 20px;
            left: 20px;
            z-index: 100;
        }
        
        .back-home a {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--wizard-primary);
            text-decoration: none;
            font-weight: 500;
        }
        
        .back-home a:hover {
            text-decoration: underline;
        }
        
        /* Responsive */
        @media (max-width: 768px) {
            .wizard-container {
                padding: 10px;
            }
            
            .wizard-header {
                padding: 20px 0;
            }
            
            .wizard-header h1 {
                font-size: 1.5rem;
            }
            
            .wizard-header p {
                font-size: 0.95rem;
            }
            
            .wizard-question {
                padding: 20px 15px;
                min-height: auto;
                border-radius: 15px;
            }
            
            .question-title {
                font-size: 1.2rem;
            }
            
            .question-subtitle {
                font-size: 0.9rem;
            }
            
            .selection-cards {
                gap: 10px;
            }
            
            .selection-cards.two-cols {
                grid-template-columns: 1fr 1fr;
            }
            
            .selection-cards.three-cols,
            .selection-cards.four-cols,
            .selection-cards.six-cols {
                grid-template-columns: 1fr 1fr;
            }
            
            .selection-card {
                padding: 15px 10px;
                border-radius: 12px;
            }
            
            .selection-card .card-icon {
                font-size: 1.8rem;
                margin-bottom: 8px;
            }
            
            .selection-card .card-title {
                font-size: 0.85rem;
            }
            
            .selection-card .card-desc {
                font-size: 0.75rem;
                display: none;
            }
            
            .selection-card.large {
                padding: 20px 15px;
            }
            
            .selection-card.large .card-icon {
                font-size: 2.5rem;
            }
            
            .selection-card.large .card-desc {
                display: block;
                font-size: 0.8rem;
            }
            
            .country-card .flag-emoji {
                font-size: 2rem;
            }
            
            .country-card .preference-badge {
                width: 22px;
                height: 22px;
                font-size: 0.75rem;
            }
            
            .wizard-nav {
                flex-direction: column;
                gap: 10px;
            }
            
            .btn-wizard {
                padding: 12px 20px;
                font-size: 1rem;
                width: 100%;
            }
            
            .btn-wizard-next {
                max-width: 100%;
                order: -1;
            }
            
            .back-home {
                position: relative;
                top: 0;
                left: 0;
                padding: 10px 15px;
                background: white;
                margin-bottom: 10px;
                border-radius: 10px;
            }
            
            /* Result section mobile */
            .wizard-result {
                padding: 20px 15px;
            }
            
            .result-header .success-icon {
                font-size: 3.5rem;
            }
            
            .result-card {
                padding: 20px 15px;
            }
            
            .result-item {
                flex-direction: column;
                align-items: flex-start;
                gap: 3px;
            }
            
            .result-item .label {
                width: auto;
                font-size: 0.85rem;
            }
            
            .result-item .value {
                font-size: 1rem;
            }
            
            .reasoning-card {
                padding: 15px;
            }
            
            .reasoning-card p {
                font-size: 0.9rem;
            }
            
            /* Slider mobile */
            .slider-value {
                font-size: 1.5rem;
            }
            
            /* Multi-select info */
            .multi-select-info {
                font-size: 0.85rem;
            }
        }
        
        @media (max-width: 400px) {
            .selection-cards.two-cols {
                grid-template-columns: 1fr;
            }
            
            .selection-card.large {
                padding: 25px 15px;
            }
        }
        
        /* Phone Input Styling */
        .iti {
            width: 100%;
        }
        .iti__flag-container {
            z-index: 10;
        }
        .iti__selected-flag {
            background: transparent !important;
            border-radius: 10px 0 0 10px;
        }
        .iti__country-list {
            max-height: 250px;
            border-radius: 10px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.15);
        }
        .iti__country {
            padding: 10px 15px;
        }
        .iti__country:hover {
            background: #f0f7ff;
        }
        
        /* Phone Modal */
        .wizard-phone-modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.6);
            z-index: 1100;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .wizard-phone-modal.show {
            display: flex;
        }
        .wizard-phone-modal-content {
            background: white;
            border-radius: 20px;
            max-width: 420px;
            width: 100%;
            padding: 30px;
            box-shadow: 0 25px 80px rgba(0,0,0,0.3);
            animation: phoneModalSlideIn 0.3s ease;
            position: relative;
        }
        @keyframes phoneModalSlideIn {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .wizard-phone-modal-header {
            text-align: center;
            margin-bottom: 25px;
        }
        .wizard-phone-modal-header i {
            font-size: 3rem;
            color: #0056b3;
            margin-bottom: 15px;
        }
        .wizard-phone-modal-header h4 {
            margin: 0;
            font-weight: 700;
            color: #333;
        }
        .wizard-phone-modal-header p {
            margin: 10px 0 0;
            color: #666;
            font-size: 0.95rem;
        }
        .wizard-phone-modal-close {
            position: absolute;
            top: 15px;
            right: 15px;
            background: none;
            border: none;
            font-size: 1.5rem;
            color: #999;
            cursor: pointer;
        }
        .wizard-phone-modal-close:hover {
            color: #333;
        }
    </style>

    <!-- Google tag (gtag.js) - Google Ads Conversion Tracking -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-17936806150"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'AW-17936806150');
    </script>
</head>
<body>
    <!-- Back to Home -->
    <div class="back-home">
        <a href="/"><i class="fas fa-arrow-left"></i> Ana Sayfa</a>
    </div>

    <div class="wizard-container">
        <!-- Header -->
        <div class="wizard-header">
            <h1><i class="fas fa-magic me-2"></i>Öğrenci Sihirbazı</h1>
            <p>Birkaç soruya cevap verin, size en uygun üniversiteyi bulalım!</p>
        </div>
        
        <!-- Progress Bar -->
        <div class="wizard-progress">
            <div class="wizard-progress-bar" id="progressBar" style="width: 10%"></div>
        </div>
        
        <!-- Step Indicator -->
        <div class="wizard-step-indicator" id="stepIndicator">
            <!-- Steps will be added dynamically -->
        </div>
        
        <!-- Question Container -->
        <div id="questionContainer">
            <!-- Questions will be loaded here -->
        </div>
        
        <!-- Navigation -->
        <div class="wizard-nav" id="wizardNav">
            <button class="btn btn-wizard btn-wizard-back" id="btnBack" onclick="previousStep()" style="display: none;">
                <i class="fas fa-arrow-left me-2"></i>Geri
            </button>
            <button class="btn btn-wizard btn-wizard-next" id="btnNext" onclick="nextStep()" disabled>
                İleri<i class="fas fa-arrow-right ms-2"></i>
            </button>
        </div>
    </div>

    <!-- Login Modal with Google Button -->
    <div class="modal fade" id="loginModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius: 16px; overflow: hidden;">
                <div class="modal-header" style="background: linear-gradient(135deg, #0056b3 0%, #004494 100%); border: none;">
                    <h5 class="modal-title text-white"><i class="fas fa-user me-2"></i>Giriş Yapın</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <p class="text-center mb-4 text-muted">Sonuçlarınızı görmek için giriş yapın veya kayıt olun.</p>
                    
                    <!-- Google Buttons - Önce wizard submit et, sonra Google'a yönlendir -->
                    <button type="button" id="googleLoginBtn" class="wizard-google-btn" style="margin-bottom: 10px;">
                        <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" alt="Google">
                        <span>Google ile Giriş Yap</span>
                    </button>
                    
                    <button type="button" id="googleRegisterBtn" class="wizard-google-btn" style="background: #f8f9fa; border-color: #28a745;">
                        <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" alt="Google">
                        <span style="color: #28a745;">Google ile Kayıt Ol</span>
                    </button>
                    
                    <div class="wizard-login-divider">
                        <span>veya e-posta ile</span>
                    </div>
                    
                    <form id="wizardLoginForm">
                        <div class="mb-3">
                            <label class="form-label">E-posta</label>
                            <input type="email" class="form-control" id="loginEmail" required style="border-radius: 10px; border: 2px solid #e0e0e0;">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Şifre</label>
                            <input type="password" class="form-control" id="loginPassword" required style="border-radius: 10px; border: 2px solid #e0e0e0;">
                        </div>
                        <div id="loginError" class="alert alert-danger d-none"></div>
                        <button type="submit" class="btn btn-primary w-100" style="border-radius: 10px; padding: 12px; font-weight: 600;">
                            <i class="fas fa-sign-in-alt me-2"></i>Giriş Yap
                        </button>
                    </form>
                    <hr class="my-4">
                    <div class="text-center">
                        <p class="mb-2">Hesabınız yok mu?</p>
                        <button type="button" id="wizardRegisterBtn" class="btn btn-outline-primary w-100" style="border-radius: 10px;">
                            <i class="fas fa-user-plus me-2"></i>Kayıt Olun
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <style>
        .wizard-google-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            width: 100%;
            padding: 14px;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            background: white;
            font-weight: 600;
            font-size: 1rem;
            color: #333;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .wizard-google-btn:hover {
            background: #f8f9fa;
            border-color: #ccc;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
        
        .wizard-google-btn img {
            width: 22px;
            height: 22px;
        }
        
        .wizard-login-divider {
            display: flex;
            align-items: center;
            margin: 20px 0;
        }
        
        .wizard-login-divider::before,
        .wizard-login-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #e0e0e0;
        }
        
        .wizard-login-divider span {
            padding: 0 15px;
            color: #666;
            font-size: 0.9rem;
        }
    </style>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- International Phone Input JS -->
    <script src="https://cdn.jsdelivr.net/npm/intl-tel-input@18.2.1/build/js/intlTelInput.min.js"></script>
    
    <script>
        // Wizard State
        let currentStep = 0;
        let totalSteps = 10;
