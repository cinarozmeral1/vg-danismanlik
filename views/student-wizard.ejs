        // Render current step
        function renderStep() {
            const question = questions[currentStep];
            const container = document.getElementById('questionContainer');
            
            // Update progress
            const progress = ((currentStep + 1) / questions.length) * 100;
            document.getElementById('progressBar').style.width = progress + '%';
            
            // Update step indicator
            renderStepIndicator();
            
            // Update navigation buttons
            document.getElementById('btnBack').style.display = currentStep > 0 ? 'block' : 'none';
            
            if (currentStep === questions.length - 1) {
                document.getElementById('btnNext').innerHTML = 'Sonuçları Gör<i class="fas fa-check ms-2"></i>';
            } else {
                document.getElementById('btnNext').innerHTML = 'İleri<i class="fas fa-arrow-right ms-2"></i>';
            }
            
            // Render question
            let html = `<div class="wizard-question">
                <h2 class="question-title">${question.title}</h2>
                <p class="question-subtitle">${question.subtitle}</p>`;
            
            if (question.type === 'single' || question.type === 'multi') {
                html += `<div class="selection-cards ${question.layout || ''}">`; 
                
                question.options.forEach((opt, idx) => {
                    const isSelected = question.type === 'multi' 
                        ? (answers[question.id] || []).includes(opt.value)
                        : answers[question.id] === opt.value;
                    
                    const selectedClass = isSelected ? 'selected' : '';
                    const largeClass = question.large ? 'large' : '';
                    const countryClass = opt.flag ? 'country-card' : '';
                    
                    let orderBadge = '';
                    if (question.ordered && isSelected) {
                        const order = (answers[question.id] || []).indexOf(opt.value) + 1;
                        orderBadge = `<div class="preference-badge">${order}</div>`;
                    }
                    
                    // Handle numeric values properly
                    const valueParam = typeof opt.value === 'number' ? opt.value : `'${opt.value}'`;
                    
                    // Determine icon content
                    let iconHtml = '';
                    if (opt.flag) {
                        iconHtml = `<div class="flag-emoji">${opt.flag}</div>`;
                    } else if (opt.customIcon) {
                        iconHtml = `<div class="card-icon"><img src="${opt.customIcon}" alt="${opt.label}" style="width: 60px; height: 60px; border-radius: 10px; object-fit: cover;"></div>`;
                    } else if (opt.icon) {
                        iconHtml = `<div class="card-icon"><i class="fas ${opt.icon}"></i></div>`;
                    }
                    
                    html += `
                        <div class="selection-card ${selectedClass} ${largeClass} ${countryClass}" 
                             onclick="selectOption('${question.id}', ${valueParam}, '${question.type}', ${question.maxSelect || 0}, ${question.ordered || false})">
                            ${orderBadge}
                            ${iconHtml}
                            <div class="card-title">${opt.label}</div>
                            ${opt.desc ? `<div class="card-desc">${opt.desc}</div>` : ''}
                        </div>
                    `;
                });
                
                html += '</div>';
                
                if (question.type === 'multi') {
                    const count = (answers[question.id] || []).length;
                    html += `<div class="multi-select-info"><span class="count">${count}</span> / ${question.maxSelect} seçildi</div>`;
                }
            } else if (question.type === 'slider') {
                const value = answers[question.id] || question.default;
                html += `
                    <div class="wizard-slider">
                        <div class="slider-value" id="sliderValue">${value.toFixed(1)}</div>
                        <input type="range" min="${question.min}" max="${question.max}" step="${question.step}" 
                               value="${value}" onchange="updateSlider('${question.id}', this.value)">
                        <div class="slider-labels">
                            <span>${question.min}</span>
                            <span>${question.max}</span>
                        </div>
                    </div>
                `;
                if (!answers[question.id]) answers[question.id] = question.default;
            } else if (question.type === 'textarea') {
                const value = answers[question.id] || '';
                html += `
                    <textarea class="wizard-textarea" id="additionalNotes" 
                              maxlength="${question.maxLength}" 
                              placeholder="${question.placeholder}"
                              oninput="updateTextarea('${question.id}', this.value)">${value}</textarea>
                    <div class="char-count"><span id="charCount">${value.length}</span> / ${question.maxLength}</div>
                `;
            }
            
            html += '</div>';
            
            container.innerHTML = html;
            updateNextButton();
            
            // Handle exam score input
            if (question.hasScore && answers[question.id] && answers[question.id] !== 'none') {
                showScoreInput(answers[question.id]);
            }
        }
        
        // Render step indicator
        function renderStepIndicator() {
            const container = document.getElementById('stepIndicator');
            let html = '';
            
            for (let i = 0; i < questions.length; i++) {
                let className = 'step-dot';
                if (i < currentStep) className += ' completed';
                if (i === currentStep) className += ' active';
                html += `<div class="${className}"></div>`;
            }
            
            container.innerHTML = html;
        }
        
        // Select option
        function selectOption(questionId, value, type, maxSelect, ordered) {
            if (type === 'single') {
                answers[questionId] = value;
                
                // Special handling for education level
                if (questionId === 'education_level') {
                    educationLevel = value;
                    questions = value === 'master' ? masterQuestions : bachelorQuestions;
                    totalSteps = questions.length;
                }
                
                // Special handling for exam type
                if (questionId === 'english_exam') {
                    if (value !== 'none') {
                        setTimeout(() => showScoreInput(value), 300);
                    } else {
                        answers['english_exam_score'] = null;
                    }
                }
            } else {
                // Multi-select
                if (!answers[questionId]) answers[questionId] = [];
                
                const idx = answers[questionId].indexOf(value);
                if (idx > -1) {
                    // Remove if already selected
                    answers[questionId].splice(idx, 1);
                } else if (answers[questionId].length < maxSelect) {
                    // Add if not at max
                    if (value === 'none') {
                        answers[questionId] = ['none'];
                    } else {
                        // Remove 'none' if selecting something else
                        const noneIdx = answers[questionId].indexOf('none');
                        if (noneIdx > -1) answers[questionId].splice(noneIdx, 1);
                        answers[questionId].push(value);
                    }
                }
            }
            
            renderStep();
        }
        
        // Show score input for exams
        function showScoreInput(examType) {
            const scoreRanges = {
                'IELTS': { min: 4.0, max: 9.0, step: 0.5, label: 'IELTS Band Skoru' },
                'TOEFL': { min: 40, max: 120, step: 1, label: 'TOEFL iBT Puanı' },
                'Cambridge': { min: 140, max: 230, step: 1, label: 'Cambridge Scale Puanı', hint: 'FCE: 140-190, CAE: 160-210, CPE: 180-230' }
            };
            
            const range = scoreRanges[examType];
            if (!range) return;
            
            const currentScore = answers['english_exam_score'] || Math.round((range.min + range.max) / 2);
            
            const questionContainer = document.getElementById('questionContainer');
            const existingModal = document.getElementById('scoreModal');
            if (existingModal) existingModal.remove();
            
            questionContainer.insertAdjacentHTML('beforeend', `
                <div class="modal fade show" id="scoreModal" style="display: block; background: rgba(0,0,0,0.5); z-index: 9999;">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">${range.label}</h5>
                                <button type="button" class="btn-close" onclick="closeScoreModal()"></button>
                            </div>
                            <div class="modal-body text-center">
                                <div class="text-center fs-1 fw-bold text-primary mb-3" id="examScoreDisplay">${currentScore}</div>
                                <input type="range" class="form-range" min="${range.min}" max="${range.max}" step="${range.step}" 
                                       value="${currentScore}" id="examScoreSlider" 
                                       oninput="document.getElementById('examScoreDisplay').textContent = this.value">
                                <div class="d-flex justify-content-between text-muted small mt-2">
                                    <span>${range.min}</span>
                                    <span>${range.max}</span>
                                </div>
                                ${range.hint ? `<p class="text-muted small mt-3 mb-0">${range.hint}</p>` : ''}
                                <button class="btn btn-primary btn-lg mt-4 w-100" onclick="setExamScore(document.getElementById('examScoreSlider').value)">
                                    <i class="fas fa-check me-2"></i>Onayla
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            `);
        }
        
        function closeScoreModal() {
            const modal = document.getElementById('scoreModal');
            if (modal) modal.remove();
        }
        
        function setExamScore(score) {
            answers['english_exam_score'] = parseFloat(score);
            answers['english_exam_type'] = answers['english_exam'];
            const modal = document.getElementById('scoreModal');
            if (modal) modal.remove();
            updateNextButton();
        }
        
        // Update slider
        function updateSlider(questionId, value) {
            answers[questionId] = parseFloat(value);
            document.getElementById('sliderValue').textContent = parseFloat(value).toFixed(1);
            updateNextButton();
        }
        
        // Update textarea
        function updateTextarea(questionId, value) {
            answers[questionId] = value;
            document.getElementById('charCount').textContent = value.length;
            updateNextButton();
        }
        
        // Update next button state
        function updateNextButton() {
            const question = questions[currentStep];
            const btn = document.getElementById('btnNext');
            
            if (question.type === 'textarea') {
                btn.disabled = false; // Optional field
            } else if (question.type === 'slider') {
                btn.disabled = !answers[question.id];
            } else if (question.type === 'multi') {
                btn.disabled = !(answers[question.id] && answers[question.id].length > 0);
            } else {
                btn.disabled = !answers[question.id];
            }
        }
        
        // Scroll to question card (so user doesn't have to scroll down on mobile)
        function scrollToQuestion() {
            // Scroll to the question container so it's visible
            const questionContainer = document.getElementById('questionContainer');
            if (questionContainer) {
                questionContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        }
        
        // Next step
        async function nextStep() {
            if (currentStep < questions.length - 1) {
                currentStep++;
                renderStep();
                setTimeout(scrollToQuestion, 100); // Small delay for DOM update
            } else {
                // Final step - submit
                await submitWizard();
            }
        }
        
        // Previous step
        function previousStep() {
            if (currentStep > 0) {
                currentStep--;
                renderStep();
                setTimeout(scrollToQuestion, 100); // Small delay for DOM update
            }
        }
        
        // Submit wizard
        async function submitWizard() {
            // Always show login modal first if not authenticated
            if (!isAuthenticated) {
                showLoginModal();
                return;
            }
            
            // Show loading
            document.getElementById('questionContainer').innerHTML = `
                <div class="wizard-loading">
                    <div class="spinner"></div>
                    <h4>Analiz ediliyor...</h4>
                    <p class="text-muted">Yapay zeka size en uygun üniversiteyi buluyor</p>
                </div>
            `;
            document.getElementById('wizardNav').style.display = 'none';
            
            try {
                // Prepare data
                const submitData = {
                    education_level: answers.education_level,
                    canadian_diploma: answers.canadian_diploma || 'no',
                    has_canadian_diploma: answers.canadian_diploma === 'yes',
                    english_level: answers.english_level,
                    english_exam_type: answers.english_exam_type || null,
                    english_exam_score: answers.english_exam_score || null,
                    interests: answers.interests || [],
                    country_preferences: answers.country_preferences || [],
                    budget_range: answers.budget_range,
                    additional_notes: answers.additional_notes || ''
                };
                
                if (answers.education_level === 'bachelor') {
                    submitData.high_school_gpa = answers.high_school_gpa;
                    submitData.math_level = answers.math_level;
                    submitData.high_school_activities = answers.high_school_activities || [];
                } else {
                    submitData.bachelor_field = answers.bachelor_field;
                    submitData.bachelor_gpa = answers.bachelor_gpa;
                    submitData.bachelor_university_type = answers.bachelor_university_type;
                    submitData.work_experience = answers.work_experience;
                    submitData.bachelor_activities = answers.bachelor_activities || [];
                    submitData.master_interest = answers.master_interest;
                }
                
                console.log('📤 Submitting wizard data:', submitData);
                
                const response = await fetch('/api/wizard/analyze', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify(submitData)
                });
                
                console.log('📥 Response status:', response.status);
                
                // Check if unauthorized - show login modal
                if (response.status === 401) {
                    isAuthenticated = false;
                    showLoginModal();
                    return;
                }
                
                // Check if forbidden (admin trying to use wizard)
                if (response.status === 403) {
                    const errorData = await response.json();
                    throw new Error(errorData.message || 'Bu işlem için yetkiniz yok');
                }
                
                const result = await response.json();
                console.log('📥 Response data:', result);
                
                if (result.success) {
                    showResult(result.data);
                } else {
                    throw new Error(result.message || 'Bir hata oluştu');
                }
                
            } catch (error) {
                console.error('Submit error:', error);
                // Hata durumunda bile kullanıcıya bir sonuç göster
                // Backend artık her zaman success dönüyor, bu kod sadece network hatası için
                showResult({
                    prep_school_needed: false,
                    recommendation_1: {
                        university_name: 'Charles University (CUNI)',
                        program_name: answers.education_level === 'master' ? 'Yüksek Lisans Programı' : 'Lisans Programı',
