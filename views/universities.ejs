<!-- Universities Page Content -->
<div class="universities-page">
    <!-- Universities List Section -->
    <section id="universities-list" class="universities-section">
        <div class="container">
            <div class="section-header text-center mb-5">
                <h2>Partner Üniversitelerimiz</h2>
                <p class="text-muted">Avrupa'nın önde gelen üniversiteleri ile işbirliği yapıyoruz</p>
            </div>

            <!-- Search Bar -->
            <div class="filter-section mb-3" style="padding: 1.2rem 2rem;">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0" style="border-radius: 12px 0 0 12px; border: 2px solid rgba(13, 110, 253, 0.2); border-right: none;">
                        <i class="fas fa-search text-primary"></i>
                    </span>
                    <input type="text" class="form-control border-start-0" id="universitySearchInput" 
                           placeholder="Üniversite adı ara (Türkçe veya İngilizce)..."
                           style="border-radius: 0 12px 12px 0; border: 2px solid rgba(13, 110, 253, 0.2); border-left: none; font-weight: 500;">
                </div>
            </div>

            <!-- Filter Section -->
            <div class="filter-section mb-4">
                <div class="row">
                    <div class="col-md-3">
                        <select class="form-select" id="countryFilter">
                            <option value="">Tüm Ülkeler</option>
                            <option value="Germany">Almanya</option>
                            <option value="UK">İngiltere</option>
                            <option value="Austria">Avusturya</option>
                            <option value="Italy">İtalya</option>
                            <option value="Czech Republic">Çek Cumhuriyeti</option>
                            <option value="Poland">Polonya</option>
                            <option value="Hungary">Macaristan</option>
                            <option value="Netherlands">Hollanda</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <select class="form-select" id="rankingFilter">
                            <option value="">Tüm Sıralamalar</option>
                            <option value="1-50">1-50</option>
                            <option value="51-100">51-100</option>
                            <option value="101-200">101-200</option>
                            <option value="201+">201+</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <select class="form-select" id="programFilter">
                            <option value="">Tüm Bölüm Sayıları</option>
                            <option value="1-5">1-5 Bölüm</option>
                            <option value="6-10">6-10 Bölüm</option>
                            <option value="11-20">11-20 Bölüm</option>
                            <option value="21+">21+ Bölüm</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button class="btn btn-outline-secondary w-100" id="clearFiltersBtn">
                            <i class="fas fa-times me-2"></i>Filtreleri Temizle
                        </button>
                    </div>
                </div>
            </div>

            <!-- Universities Grid -->
            <div class="row" id="universitiesGrid">
                <% if (typeof universities !== 'undefined' && universities && universities.length > 0) { %>
                    <% universities.forEach(university => { %>
                    <div class="col-lg-4 col-md-6 mb-4 university-card" 
                         data-country="<%= university.country || '' %>" 
                         data-ranking="<%= university.world_ranking || 0 %>"
                         data-program-count="<%= university.department_count || 0 %>"
                         data-name="<%= (university.name || '').toLowerCase() %>"
                         data-name-en="<%= (university.name_en || '').toLowerCase() %>"
                         data-name-tr="<%= (university.name_tr || '').toLowerCase() %>"
                         data-uid="<%= university.id %>">
                        <div class="card h-100 university-card-inner">
                            <div class="card-header bg-transparent border-0">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div class="d-flex align-items-center">
                                        <% if (university.logo_url) { %>
                                            <img src="<%= university.logo_url %>" 
                                                 alt="<%= university.name %>" 
                                                 class="university-logo me-3">
                                        <% } else { %>
                                            <div class="university-logo me-3 d-flex align-items-center justify-content-center bg-light rounded" 
                                                 style="width: 60px; height: 60px; border: 1px solid #dee2e6;">
                                                <i class="fas fa-university text-muted" style="font-size: 24px;"></i>
                                            </div>
                                        <% } %>
                                        <div>
                                            <h5 class="card-title university-name mb-1"><%= university.name %></h5>
                                            <p class="text-muted mb-0 small">
                                                <i class="fas fa-map-marker-alt me-1"></i>
                                                <%= university.city %>, <%= university.country %>
                                            </p>
                                        </div>
                                    </div>
                                    <div class="badges">
                                        <% if (university.is_featured) { %>
                                            <span class="badge bg-warning">Öne Çıkan</span>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                            <div class="card-body">
                                
                                <div class="university-stats">
                                    <div class="row">
                                        <div class="col-6">
                                            <div class="stat-item">
                                                <span class="stat-label">Bölümler</span>
                                                <span class="stat-value"><%= university.department_count || 0 %></span>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="stat-item">
                                                <span class="stat-label">Dünya Sıralaması</span>
                                                <span class="stat-value">
                                                    <% if (university.world_ranking) { %>
                                                        #<%= university.world_ranking %>
                                                    <% } else { %>
                                                        -
                                                    <% } %>
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <% if (university.name_en && university.name_en !== university.name) { %>
                                <div class="university-name-en mt-2">
                                    <small class="text-muted"><%= university.name_en %></small>
                                </div>
                                <% } %>
                                
                                <% if (university.website_url) { %>
                                <div class="university-website mt-2">
                                    <a href="<%= university.website_url %>" target="_blank" class="text-decoration-none">
                                        <i class="fas fa-external-link-alt me-1"></i>Resmi Website
                                    </a>
                                </div>
                                <% } %>

                                <div class="university-fees mt-3">
                                    <% if (university.tuition_fee_min || university.tuition_fee_max) { %>
                                        <div class="fee-range">
                                            <span class="fee-label">Yıllık Ücret:</span>
                                            <span class="stat-value">
                                                <% if (university.tuition_fee_min && university.tuition_fee_max) { %>
                                                    €<%= Math.round(university.tuition_fee_min).toLocaleString() %> - €<%= Math.round(university.tuition_fee_max).toLocaleString() %>
                                                <% } else if (university.tuition_fee_min) { %>
                                                    €<%= Math.round(university.tuition_fee_min).toLocaleString() %>+
                                                <% } else if (university.tuition_fee_max) { %>
                                                    €<%= Math.round(university.tuition_fee_max).toLocaleString() %>
                                                <% } %>
                                            </span>
                                        </div>
                                    <% } %>
                                    <% if (university.application_fee) { %>
                                        <div class="fee-range">
                                            <span class="fee-label">Başvuru Ücreti:</span>
                                            <span class="fee-value">€<%= university.application_fee %></span>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                                                                    <div class="card-footer bg-transparent border-0">
                                            <div class="d-flex justify-content-center align-items-center">
                                                <button onclick="window.location.href='/universities/<%= university.slug || university.id %>'" class="btn btn-primary btn-sm">
                                                    <i class="fas fa-info-circle me-2"></i>Detaylar
                                                </button>
                                            </div>
                                        </div>
                        </div>
                    </div>
                    <% }); %>
                <% } else { %>
                    <div class="col-12 text-center py-5">
                        <i class="fas fa-university fa-3x text-muted mb-3"></i>
                        <h4 class="text-muted">Henüz üniversite bulunmuyor</h4>
                        <p class="text-muted">Yakında üniversite bilgileri eklenecek.</p>
                    </div>
                <% } %>
            </div>

        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8 text-center">
                    <h3>Üniversite Seçiminde Yardıma mı İhtiyacınız Var?</h3>
                    <p class="text-muted">Uzman danışmanlarımız size en uygun üniversiteyi bulmanızda yardımcı olur.</p>
                    <div class="cta-buttons">
                        <a href="/contact" class="btn btn-primary btn-lg me-3">
                            <i class="fas fa-phone me-2"></i>İletişime Geçin
                        </a>
                        <a href="/#randevu" class="btn btn-outline-primary btn-lg">
                            <i class="fas fa-calendar-check me-2"></i><%= currentLanguage === 'en' ? 'Book an Appointment' : 'Randevu Al' %>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

        <script>
            document.addEventListener('DOMContentLoaded', function() {
        const countryFilter = document.getElementById('countryFilter');
        const rankingFilter = document.getElementById('rankingFilter');
        const programFilter = document.getElementById('programFilter');
        const searchInput = document.getElementById('universitySearchInput');
        const universityCards = document.querySelectorAll('.university-card');

        function debounce(func, wait) {
            let timeout;
            return function executedFunction(...args) {
                clearTimeout(timeout);
                timeout = setTimeout(() => func(...args), wait);
            };
        }

        function turkishLower(str) {
            return str.replace(/İ/g, 'i').replace(/I/g, 'ı').replace(/Ğ/g, 'ğ').replace(/Ü/g, 'ü')
                      .replace(/Ş/g, 'ş').replace(/Ö/g, 'ö').replace(/Ç/g, 'ç').toLowerCase();
        }

        function filterUniversities() {
            const selectedCountry = countryFilter.value;
            const selectedRanking = rankingFilter.value;
            const selectedProgram = programFilter.value;
            const searchTerm = turkishLower(searchInput.value.trim());
            let visibleCount = 0;

            universityCards.forEach(card => {
                const country = card.dataset.country || '';
                const ranking = parseInt(card.dataset.ranking) || 0;
                const programCount = parseInt(card.dataset.programCount) || 0;
                let showCard = true;

                if (searchTerm) {
                    const name = turkishLower(card.dataset.name || '');
                    const nameEn = turkishLower(card.dataset.nameEn || '');
                    const nameTr = turkishLower(card.dataset.nameTr || '');
                    if (!name.includes(searchTerm) && !nameEn.includes(searchTerm) && !nameTr.includes(searchTerm)) {
                        showCard = false;
                    }
                }

                if (selectedCountry && country !== selectedCountry) showCard = false;

                if (selectedRanking) {
                    const parts = selectedRanking.replace('+', '-Infinity').split('-');
                    const minRank = parseInt(parts[0]);
                    const maxRank = parts[1] === 'Infinity' ? Infinity : parseInt(parts[1]);
                    if (selectedRanking.endsWith('+')) {
                        if (ranking < minRank) showCard = false;
                    } else if (ranking < minRank || ranking > maxRank) {
                        showCard = false;
                    }
                }

                if (selectedProgram) {
                    const parts = selectedProgram.replace('+', '-Infinity').split('-');
                    const minP = parseInt(parts[0]);
                    const maxP = parts[1] === 'Infinity' ? Infinity : parseInt(parts[1]);
                    if (selectedProgram.endsWith('+')) {
                        if (programCount < minP) showCard = false;
                    } else if (programCount < minP || programCount > maxP) {
                        showCard = false;
                    }
                }

                card.style.display = showCard ? 'block' : 'none';
                if (showCard) visibleCount++;
            });

            saveFiltersToSession();
            updateResultCount(visibleCount, universityCards.length);
        }

        function updateResultCount(visible, total) {
            let resultDiv = document.getElementById('filterResults');
            if (!resultDiv) {
                resultDiv = document.createElement('div');
                resultDiv.id = 'filterResults';
                resultDiv.className = 'alert alert-info mt-3';
                document.querySelector('.filter-section:last-of-type').appendChild(resultDiv);
            }
            if (visible === total && !searchInput.value.trim()) {
                resultDiv.style.display = 'none';
            } else {
                resultDiv.innerHTML = '<i class="fas fa-info-circle me-2"></i>' + visible + ' üniversite bulundu (toplam ' + total + ' üniversite)';
                resultDiv.style.display = 'block';
            }
        }

        function saveFiltersToSession() {
            try {
                sessionStorage.setItem('uni_filters', JSON.stringify({
                    country: countryFilter.value,
                    ranking: rankingFilter.value,
                    program: programFilter.value,
                    search: searchInput.value
                }));
            } catch(e) {}
        }

        function restoreFiltersFromSession() {
            try {
                const saved = sessionStorage.getItem('uni_filters');
                if (saved) {
                    const f = JSON.parse(saved);
                    if (f.country) countryFilter.value = f.country;
                    if (f.ranking) rankingFilter.value = f.ranking;
                    if (f.program) programFilter.value = f.program;
                    if (f.search) searchInput.value = f.search;
                    filterUniversities();
                }
            } catch(e) {}
        }

        function clearFilters() {
            countryFilter.value = '';
            rankingFilter.value = '';
            programFilter.value = '';
            searchInput.value = '';
            sessionStorage.removeItem('uni_filters');
            universityCards.forEach(card => { card.style.display = 'block'; });
            const resultDiv = document.getElementById('filterResults');
            if (resultDiv) resultDiv.style.display = 'none';
        }

        const debouncedFilter = debounce(filterUniversities, 200);

        countryFilter.addEventListener('change', debouncedFilter);
        rankingFilter.addEventListener('change', debouncedFilter);
        programFilter.addEventListener('change', debouncedFilter);
        searchInput.addEventListener('input', debouncedFilter);
        document.getElementById('clearFiltersBtn').addEventListener('click', clearFilters);

        restoreFiltersFromSession();
    });
</script>

