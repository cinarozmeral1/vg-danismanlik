<script>
function filterUniversities() {
    const countryFilter = document.getElementById('countryFilter').value;
    const programFilter = document.getElementById('programFilter').value;
    const levelFilter = document.getElementById('levelFilter').value;
    
    const universityCards = document.querySelectorAll('.university-card');
    
    universityCards.forEach(card => {
        const country = card.getAttribute('data-country');
        const programs = card.getAttribute('data-programs').split(',');
        const levels = card.getAttribute('data-levels').split(',');
        
        let showCard = true;
        
        if (countryFilter && country !== countryFilter) {
            showCard = false;
        }
        
        if (programFilter && !programs.includes(programFilter)) {
            showCard = false;
        }
        
        if (levelFilter && !levels.includes(levelFilter)) {
            showCard = false;
        }
        
        card.style.display = showCard ? 'block' : 'none';
    });
}
</script> 