<!-- Hero Section -->
<section class="bg-primary text-white py-5">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center">
                <h1 class="display-4 fw-bold"><%= t.universities.hero.title %></h1>
                <p class="lead"><%= t.universities.hero.subtitle %></p>
            </div>
        </div>
    </div>
</section>

<!-- Filter Section -->
<section class="py-4 bg-light">
    <div class="container">
        <div class="row">
            <div class="col-md-3 mb-3">
                <select class="form-select" id="countryFilter">
                    <option value=""><%= t.universities.filters.allCountries %></option>
                    <option value="germany"><%= t.universities.filters.germany %></option>
                    <option value="italy"><%= t.universities.filters.italy %></option>
                    <option value="czech"><%= t.universities.filters.czech %></option>
                    <option value="austria"><%= t.universities.filters.austria %></option>
                    <option value="uk"><%= t.universities.filters.uk %></option>
                    <option value="poland"><%= t.universities.filters.poland %></option>
                    <option value="hungary"><%= t.universities.filters.hungary %></option>
                </select>
            </div>
            <div class="col-md-3 mb-3">
                <select class="form-select" id="programFilter">
                    <option value=""><%= t.universities.filters.allPrograms %></option>
                    <option value="engineering"><%= t.universities.filters.engineering %></option>
                    <option value="business"><%= t.universities.filters.business %></option>
                    <option value="medicine"><%= t.universities.filters.medicine %></option>
                    <option value="arts"><%= t.universities.filters.arts %></option>
                    <option value="social"><%= t.universities.filters.social %></option>
                    <option value="natural"><%= t.universities.filters.natural %></option>
                    <option value="computer"><%= t.universities.filters.computer %></option>
                    <option value="language"><%= t.universities.filters.language %></option>
                    <option value="law"><%= t.universities.filters.law %></option>
                    <option value="agriculture"><%= t.universities.filters.agriculture %></option>
                    <option value="chemistry"><%= t.universities.filters.chemistry %></option>
                </select>
            </div>
            <div class="col-md-3 mb-3">
                <select class="form-select" id="levelFilter">
                    <option value=""><%= t.universities.filters.allLevels %></option>
                    <option value="bachelor"><%= t.universities.filters.bachelor %></option>
                    <option value="master"><%= t.universities.filters.master %></option>
                    <option value="phd"><%= t.universities.filters.phd %></option>
                </select>
            </div>
            <div class="col-md-3 mb-3">
                <button class="btn btn-primary w-100" onclick="filterUniversities()">
                    <i class="fas fa-filter me-2"></i><%= t.universities.filters.filter %>
                </button>
            </div>
        </div>
    </div>
</section>

<!-- Universities Section -->
<section class="py-5 universities-page">
    <div class="container">
        <div class="row" id="universitiesContainer">
            <!-- Czech Republic - Prague (CTU) -->
            <div class="col-lg-6 mb-4 university-card" data-country="czech" data-programs="engineering,technology" data-levels="bachelor,master">
                <div class="card h-100 shadow">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <img src="/images/logos/ctu-logo.svg" class="rounded me-3" alt="CTU Logo" style="width: 80px; height: 80px; object-fit: contain;">
                            <div>
                                <h5 class="mb-1">Czech Technical University in Prague</h5>
                                <small class="text-muted"><%= t.universityLocations.prague %></small>
                            </div>
                        </div>
                        <p class="card-text"><%= t.universityDescriptions.ctu %></p>
                        <div class="mb-3">
                            <span class="badge bg-warning text-white"><%= t.qsRankings.title %>: <%= t.qsRankings.ctu %></span>
                        </div>
                        <div class="mb-3">
                            
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <small class="text-black fw-bold"><%= t.universities.tuition %>: 3,800€/yıl</small>
                            <a href="/university/ctu" class="btn btn-outline-primary btn-sm"><%= t.universities.details %></a>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Charles University - 2nd position -->
            <div class="col-lg-6 mb-4 university-card" data-country="czech" data-programs="engineering,business,medicine" data-levels="bachelor,master">
                <div class="card h-100 shadow">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <img src="/images/logos/cuni-logo.svg" class="rounded me-3" alt="Charles University" style="width: 80px; height: 80px; object-fit: contain;">
                            <div>
                                <h5 class="mb-1">Charles University</h5>
                                <small class="text-muted"><%= t.universityLocations.prague %></small>
                            </div>
                        </div>
                        <p class="card-text"><%= t.universityDescriptions.charles %></p>
                        <div class="mb-3">
                            
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="badge bg-warning text-white mb-2"><%= t.qsRankings.title %>: <%= t.qsRankings.charles %></span>
                            <small class="text-black fw-bold"><%= t.universities.tuition %>: 4,000€/yıl</small>
                            <a href="/university/charles" class="btn btn-outline-primary btn-sm"><%= t.universities.details %></a>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Germany - Munich -->
            <div class="col-lg-6 mb-4 university-card" data-country="germany" data-programs="engineering,business,medicine" data-levels="bachelor,master">
                <div class="card h-100 shadow">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <img src="/images/logos/tum-logo.png" class="rounded me-3" alt="TUM Logo" style="width: 80px; height: 80px; object-fit: contain;">
                            <div>
                                <h5 class="mb-1">Technical University of Munich</h5>
                                <small class="text-muted"><%= t.universityLocations.munich %></small>
                            </div>
                        </div>
                        <p class="lead" style="color: black !important;"><%= t.universityDescriptions.tum %></p>
                        <div class="mb-3">
                            <span class="badge bg-warning text-white"><%= t.qsRankings.title %>: <%= t.qsRankings.tum %></span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <small class="text-black fw-bold"><%= t.universities.tuition %>: 2,000-6,000€/yıl</small>
                            <a href="/university/tum" class="btn btn-outline-primary btn-sm"><%= t.universities.details %></a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Germany - Dresden -->
