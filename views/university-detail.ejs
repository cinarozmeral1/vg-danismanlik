<!-- University Detail Page -->
<div class="university-detail-page">
    <!-- Hero Section -->
    <section class="university-hero">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/">Ana Sayfa</a></li>
                            <li class="breadcrumb-item"><a href="/universities">Üniversiteler</a></li>
                            <li class="breadcrumb-item active" aria-current="page"><%= university.name %></li>
                        </ol>
                    </nav>
                    
                    <div class="university-header">
                        <div class="d-flex align-items-center mb-3">
                            <% if (university.logo_url) { %>
                                <img src="<%= university.logo_url %>" 
                                     alt="<%= university.name %>" 
                                     class="university-logo-large me-3">
                            <% } else { %>
                                <div class="university-logo-large me-3 d-flex align-items-center justify-content-center bg-light rounded" 
                                     style="width: 80px; height: 80px; border: 1px solid #dee2e6;">
                                    <i class="fas fa-university text-muted" style="font-size: 32px;"></i>
                                </div>
                            <% } %>
                            <div>
                                <h1 class="university-title" data-tr="<%= university.name %>" data-en="<%= university.name_en || university.name %>"><%= university.name %></h1>
                                <p class="university-location">
                                    <i class="fas fa-map-marker-alt me-2"></i>
                                    <%= university.city %>, <%= university.country %>
                                </p>
                            </div>
                        </div>
                        
                        <div class="university-badges mb-3">
                            <% if (university.is_featured) { %>
                                <span class="badge bg-warning me-2">Öne Çıkan</span>
                            <% } %>
                            <% if (university.is_partner) { %>
                                <span class="badge bg-success me-2">Partner</span>
                            <% } %>
                            <% if (university.world_ranking) { %>
                                <span class="badge bg-primary me-2">Dünya Sıralaması: #<%= university.world_ranking %></span>
                            <% } %>

                        </div>
                    </div>
                </div>
                
                <div class="col-lg-4">
                    <div class="quick-stats">
                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-graduation-cap"></i>
                            </div>
                            <div class="stat-content">
                                <h3><%= departments ? departments.length : 0 %></h3>
                                <p>Bölüm</p>
                            </div>
                        </div>
                        
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- University Content -->
    <section class="university-content">
        <div class="container">
            <div class="row">
                <!-- Main Content -->
                <div class="col-lg-8">
                    <!-- About Section -->
                    <div class="content-section">
                        <h2>Üniversite Hakkında</h2>
                        <div class="university-description">
                            <% if (university.description) { %>
                                <p><%= university.description %></p>
                            <% } else { %>
                                <p><%= university.name %>, <%= university.country %>'nin önde gelen üniversitelerinden biridir. 
                                Kaliteli eğitim ve araştırma imkanları sunmaktadır.</p>
                            <% } %>
                        </div>
                    </div>

                    <!-- Requirements Section -->
                    <% if (university.requirements) { %>
                    <div class="content-section">
                        <h2>Gereksinimler</h2>
                        <div class="requirements-content">
                            <p><%= university.requirements %></p>
                        </div>
                    </div>
                    <% } %>

                    <!-- Departments Section -->
                    <% if (departments && departments.length > 0) { %>
                    <div class="content-section">
                        <h2>Bölümler</h2>
                        <div class="departments-grid">
                            <% departments.forEach(department => { %>
                            <div class="department-card">
                                <div class="department-header">
                                    <h4><%= department.name_tr %></h4>
                                    <% if (department.price) { %>
                                        <span class="price-badge">€<%= department.price %></span>
                                    <% } %>
                                </div>
                            </div>
                            <% }); %>
                        </div>
                    </div>
                    <% } %>

                    <!-- Programs Section -->
                    <% if (programs && programs.length > 0) { %>
                    <div class="content-section">
                        <h2>Programlar</h2>
                        <div class="programs-grid">
                            <% programs.forEach(program => { %>
                            <div class="program-card">
                                <div class="program-header">
                                    <h4><%= program.name %></h4>
                                    <% if (program.level) { %>
                                        <span class="badge bg-secondary"><%= program.level %></span>
                                    <% } %>
                                </div>
                                <div class="program-details">
                                    <% if (program.duration_months) { %>
                                        <p><strong>Süre:</strong> <%= program.duration_months %> sömestr</p>
                                    <% } %>
                                    <% if (program.language) { %>
                                        <p><strong>Eğitim Dili:</strong> <%= program.language %></p>
                                    <% } %>
                                    <% if (program.field_of_study) { %>
                                        <p><strong>Çalışma Alanı:</strong> <%= program.field_of_study %></p>
                                    <% } %>
                                    <% if (program.tuition_fee) { %>
                                        <p><strong>Ücret:</strong> €<%= Math.round(Number(program.tuition_fee)).toLocaleString() %></p>
                                    <% } %>
                                    <% if (program.currency) { %>
                                        <p><strong>Para Birimi:</strong> <%= program.currency %></p>
                                    <% } %>
                                </div>
                            </div>
                            <% }); %>
                        </div>
                    </div>
                    <% } %>


                </div>

                <!-- Sidebar -->
                <div class="col-lg-4">
                    <div class="university-sidebar">
                        <!-- Contact Info -->
                        <div class="sidebar-card">
                            <h3>İletişim Bilgileri</h3>
                            <div class="contact-info">
                                <% if (university.website_url) { %>
                                <div class="contact-item">
                                    <i class="fas fa-globe"></i>
                                    <a href="<%= university.website_url %>" target="_blank" rel="noopener">
                                        Resmi Web Sitesi
                                    </a>
                                </div>
                                <% } %>
                                
                                <div class="contact-item">
                                    <i class="fas fa-map-marker-alt"></i>
                                    <span><%= university.city %>, <%= university.country %></span>
                                </div>
                            </div>
                        </div>


                        <!-- Rankings -->
                        <div class="sidebar-card">
                            <h3>Sıralama Bilgileri</h3>
                            <div class="rankings-info">
                                <% if (university.world_ranking) { %>
                                <div class="ranking-item">
                                    <span class="ranking-label">Dünya Sıralaması:</span>
                                    <span class="ranking-value">#<%= university.world_ranking %></span>
                                </div>
                                <% } %>
                                
                                
                            </div>
                        </div>

                        <!-- CTA Buttons -->
                        <div class="sidebar-card">
                            <h3>Başvuru</h3>
                            <div class="cta-buttons">
                                <a href="/contact" class="btn btn-primary w-100 mb-2">
                                    <i class="fas fa-phone me-2"></i>Danışmanlık Al
                                </a>
                                <a href="/assessment" class="btn btn-outline-primary w-100">
                                    <i class="fas fa-clipboard-list me-2"></i>Değerlendirme Testi
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

<style>
/* Modern University Detail Styling */
.university-hero {
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    border-radius: 16px;
    padding: 2rem;
    margin-bottom: 2rem;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
}

.university-sidebar {
    position: sticky;
    top: 2rem;
}

.sidebar-card {
    background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
    border: 1px solid #dee2e6;
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    transition: all 0.3s ease;
}

.sidebar-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(0,0,0,0.12);
}

.sidebar-card h3 {
    color: #2c3e50;
    font-weight: 700;
    margin-bottom: 1rem;
    font-size: 1.2rem;
}

.contact-item, .ranking-item {
    display: flex;
    align-items: center;
    padding: 0.75rem 0;
    border-bottom: 1px solid #f1f3f4;
}

.contact-item:last-child, .ranking-item:last-child {
    border-bottom: none;
}

.contact-item i, .ranking-item i {
    color: #007bff;
    margin-right: 0.75rem;
    width: 20px;
}

.ranking-value {
    background: linear-gradient(135deg, #007bff, #0056b3);
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-weight: 600;
    font-size: 0.9rem;
}

.cta-buttons .btn {
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.3s ease;
    margin-bottom: 0.5rem;
}

.cta-buttons .btn-primary {
    background: linear-gradient(135deg, #007bff, #0056b3);
    border: none;
    box-shadow: 0 2px 8px rgba(0,123,255,0.3);
}

.cta-buttons .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(0,123,255,0.4);
}

.cta-buttons .btn-outline-primary {
    border: 2px solid #007bff;
    color: #007bff;
}

.cta-buttons .btn-outline-primary:hover {
    background: #007bff;
    transform: translateY(-2px);
}

.departments-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-top: 1rem;
}

.department-card {
    background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
    border: 1px solid #dee2e6;
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
}

.department-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #28a745, #20c997);
    opacity: 0;
    transition: opacity 0.3s ease;
}

.department-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.15);
    border-color: #28a745;
}

.department-card:hover::before {
    opacity: 1;
}

.department-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
}

.department-header h4 {
    margin: 0;
    color: #2c3e50;
    font-size: 1.2rem;
    font-weight: 700;
}

.price-badge {
    background: linear-gradient(135deg, #28a745, #20c997);
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 25px;
    font-size: 0.9rem;
    font-weight: 700;
    box-shadow: 0 2px 8px rgba(40,167,69,0.3);
}

.department-details {
    margin-top: 0.5rem;
}

.department-name-en {
    color: #6c757d;
    font-style: italic;
    margin: 0;
    font-size: 0.9rem;
}

.content-section {
    background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
    border: 1px solid #dee2e6;
    border-radius: 12px;
    padding: 2rem;
    margin-bottom: 2rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.content-section h2 {
    color: #2c3e50;
    font-weight: 700;
    margin-bottom: 1rem;
    font-size: 1.5rem;
}

.quick-stats {
    background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
    border: 1px solid #dee2e6;
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.stat-card {
    display: flex;
    align-items: center;
    padding: 1rem;
    background: rgba(255,255,255,0.8);
    border-radius: 8px;
    border: 1px solid #e9ecef;
}

.stat-icon {
    background: linear-gradient(135deg, #007bff, #0056b3);
    color: white;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 1rem;
    font-size: 1.2rem;
}

.stat-content h3 {
    color: #2c3e50;
    font-weight: 700;
    font-size: 1.5rem;
    margin: 0;
}

.stat-content p {
    color: #6c757d;
    margin: 0;
    font-size: 0.9rem;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Dil değiştirme fonksiyonu
    function switchLanguage(lang) {
        if (lang === 'tr') {
            // Türkçe göster
            document.querySelectorAll('.description-tr, .requirements-tr, .department-name-tr').forEach(el => {
                el.style.display = 'block';
            });
            document.querySelectorAll('.description-en, .requirements-en, .department-name-en').forEach(el => {
                el.style.display = 'none';
            });
            
            // Başlıkları güncelle
            document.querySelectorAll('[data-tr]').forEach(el => {
                el.textContent = el.getAttribute('data-tr');
            });
        } else if (lang === 'en') {
            // İngilizce göster
            document.querySelectorAll('.description-en, .requirements-en, .department-name-en').forEach(el => {
                el.style.display = 'block';
            });
            document.querySelectorAll('.description-tr, .requirements-tr, .department-name-tr').forEach(el => {
                el.style.display = 'none';
            });
            
            // Başlıkları güncelle
            document.querySelectorAll('[data-en]').forEach(el => {
                el.textContent = el.getAttribute('data-en');
            });
        }
    }
    
    // Dil değiştirme butonlarına event listener ekle
    const langButtons = document.querySelectorAll('.language-switcher');
    langButtons.forEach(button => {
        button.addEventListener('click', function(e) {
            e.preventDefault();
            const lang = this.getAttribute('data-lang');
            switchLanguage(lang);
        });
    });
});
</script>

<!-- Image Modal -->
<div class="modal fade" id="imageModal" tabindex="-1" aria-labelledby="imageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="imageModalLabel"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <img id="modalImage" src="" alt="" class="img-fluid">
            </div>
        </div>
    </div>
</div>

<script>
// Event delegation for image modal
document.addEventListener('DOMContentLoaded', function() {
    document.addEventListener('click', function(e) {
        const imageModal = e.target.closest('.js-open-image-modal');
        if (imageModal) {
            const imageUrl = imageModal.getAttribute('data-image-url');
            const imageAlt = imageModal.getAttribute('data-image-alt');
            openImageModal(imageUrl, imageAlt);
        }
    });
});

function openImageModal(imageUrl, caption) {
    document.getElementById('modalImage').src = imageUrl;
    document.getElementById('modalImage').alt = caption;
    document.getElementById('imageModalLabel').textContent = caption;
    
    const modal = new bootstrap.Modal(document.getElementById('imageModal'));
    modal.show();
}
</script> 