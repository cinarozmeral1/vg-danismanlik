<!-- University Detail Page -->
<div class="university-detail-page">
    <!-- Hero Section -->
    <section class="university-hero">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-12">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/">Ana Sayfa</a></li>
                            <li class="breadcrumb-item"><a href="/universities">Üniversiteler</a></li>
                            <li class="breadcrumb-item active" aria-current="page"><%= university.name %></li>
                        </ol>
                    </nav>
                    
                    <div class="university-header">
                        <div class="d-flex align-items-center mb-3">
                            <% if (university.logo_url) { %>
                                <img src="<%= university.logo_url %>" 
                                     alt="<%= university.name %>" 
                                     class="university-logo-large me-3">
                            <% } else { %>
                                <div class="university-logo-large me-3 d-flex align-items-center justify-content-center bg-light rounded" 
                                     style="width: 80px; height: 80px; border: 1px solid #dee2e6;">
                                    <i class="fas fa-university text-muted" style="font-size: 32px;"></i>
                                </div>
                            <% } %>
                            <div>
                                <h1 class="university-title" data-tr="<%= university.name %>" data-en="<%= university.name_en || university.name %>"><%= university.name %></h1>
                                <p class="university-location">
                                    <i class="fas fa-map-marker-alt me-2"></i>
                                    <%= university.city %>, <%= university.country %>
                                </p>
                            </div>
                        </div>
                        
                        <div class="university-badges mb-3">
                            <% if (university.is_featured) { %>
                                <span class="badge bg-warning me-2">Öne Çıkan</span>
                            <% } %>
                            <% if (university.world_ranking) { %>
                                <span class="badge bg-primary me-2">Dünya Sıralaması: #<%= university.world_ranking %></span>
                            <% } %>

                        </div>
                    </div>
                </div>
                
            </div>
        </div>
    </section>

    <!-- University Content -->
    <section class="university-content">
        <div class="container">
            <div class="row">
                <!-- Main Content -->
                <div class="col-12">
                    <!-- About Section -->
                    <div class="content-section">
                        <h2>Üniversite Hakkında</h2>
                        <div class="university-description">
                            <% if (university.description) { %>
                                <p><%= university.description %></p>
                            <% } else { %>
                                <p><%= university.name %>, <%= university.country %>'nin önde gelen üniversitelerinden biridir. 
                                Kaliteli eğitim ve araştırma imkanları sunmaktadır.</p>
                            <% } %>
                        </div>
                    </div>

                    <!-- Son Başvuru Tarihi Section -->
                    <% if (university.application_deadline) { %>
                    <div class="content-section deadline-section">
                        <h2><i class="fas fa-calendar-alt me-2"></i>Son Başvuru Tarihi</h2>
                        <div class="deadline-content">
                            <div class="deadline-badge-container">
                                <% 
                                    const deadlineDate = new Date(university.application_deadline);
                                    const now = new Date();
                                    const diffTime = deadlineDate - now;
                                    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                                    const months = ['Ocak', 'Şubat', 'Mart', 'Nisan', 'Mayıs', 'Haziran', 'Temmuz', 'Ağustos', 'Eylül', 'Ekim', 'Kasım', 'Aralık'];
                                    const formattedDate = deadlineDate.getDate() + ' ' + months[deadlineDate.getMonth()] + ' ' + deadlineDate.getFullYear();
                                %>
                                <div class="deadline-date-display">
                                    <div class="deadline-icon">
                                        <i class="fas fa-clock"></i>
                                    </div>
                                    <div class="deadline-info">
                                        <span class="deadline-date"><%= formattedDate %></span>
                                        <% if (diffDays > 0) { %>
                                            <span class="deadline-remaining <%= diffDays <= 30 ? 'deadline-urgent' : 'deadline-normal' %>">
                                                <i class="fas fa-hourglass-half me-1"></i><%= diffDays %> gün kaldı
                                            </span>
                                        <% } else if (diffDays === 0) { %>
                                            <span class="deadline-remaining deadline-urgent">
                                                <i class="fas fa-exclamation-triangle me-1"></i>Son gün!
                                            </span>
                                        <% } else { %>
                                            <span class="deadline-remaining deadline-expired">
                                                <i class="fas fa-times-circle me-1"></i>Başvuru süresi doldu
                                            </span>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% } %>

                    <!-- Requirements Section -->
                    <% if (university.requirements) { %>
                    <div class="content-section">
                        <h2>Gereksinimler</h2>
                        <div class="requirements-content">
                            <p><%= university.requirements %></p>
                        </div>
                    </div>
                    <% } %>

                    <!-- Departments Section -->
                    <% if (departments && departments.length > 0) { %>
                    <div class="content-section">
                        <h2>Bölümler</h2>
                        <div class="departments-grid">
                            <% departments.forEach(department => { %>
                            <div class="department-card">
                                <div class="department-header">
                                    <h4><%= department.name_tr %></h4>
                                    <% if (department.price) { %>
                                        <span class="price-badge">€<%= department.price %></span>
                                    <% } %>
                                </div>
                            </div>
                            <% }); %>
                        </div>
                    </div>
                    <% } %>

                    <!-- Programs Section -->
                    <% if (programs && programs.length > 0) { %>
                    <div class="content-section">
                        <h2>Programlar</h2>
                        <div class="programs-grid">
                            <% programs.forEach(program => { %>
                            <div class="program-card">
                                <div class="program-header">
                                    <h4><%= program.name %></h4>
                                    <% if (program.level) { %>
                                        <span class="badge bg-secondary"><%= program.level %></span>
                                    <% } %>
                                </div>
                                <div class="program-details">
                                    <% if (program.duration_months) { %>
                                        <p><strong>Süre:</strong> <%= program.duration_months %> sömestr</p>
                                    <% } %>
                                    <% if (program.language) { %>
                                        <p><strong>Eğitim Dili:</strong> <%= program.language %></p>
                                    <% } %>
                                    <% if (program.field_of_study) { %>
                                        <p><strong>Çalışma Alanı:</strong> <%= program.field_of_study %></p>
                                    <% } %>
                                    <% if (program.tuition_fee) { %>
                                        <p><strong>Ücret:</strong> €<%= Math.round(Number(program.tuition_fee)).toLocaleString() %></p>
                                    <% } %>
                                    <% if (program.currency) { %>
                                        <p><strong>Para Birimi:</strong> <%= program.currency %></p>
                                    <% } %>
                                </div>
                            </div>
                            <% }); %>
                        </div>
                    </div>
                    <% } %>


                </div>

            </div>
        </div>
    </section>
</div>

<style>
/* Futuristic University Detail Styling */
.university-hero {
    background: #0066cc;
    border: 2px solid transparent;
    border-radius: 24px;
    padding: 3rem;
    margin-bottom: 3rem;
    box-shadow: 0 8px 32px rgba(0, 102, 204, 0.4), 0 2px 8px rgba(0,0,0,0.08);
    backdrop-filter: blur(20px);
    position: relative;
    overflow: hidden;
    color: white;
}

.university-hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(45deg, 
        rgba(255, 255, 255, 0.1) 0%, 
        rgba(255, 255, 255, 0.1) 25%, 
        rgba(255, 255, 255, 0.1) 50%, 
        rgba(255, 255, 255, 0.1) 75%, 
        rgba(255, 255, 255, 0.1) 100%);
    z-index: 1;
}

/* Hero section text colors */
.university-hero h1,
.university-hero h2,
.university-hero h3,
.university-hero h4,
.university-hero h5,
.university-hero h6,
.university-hero p,
.university-hero span,
.university-hero div {
    color: white !important;
    position: relative;
    z-index: 2;
}

.university-hero .breadcrumb-item a {
    color: rgba(255, 255, 255, 0.8) !important;
}

.university-hero .breadcrumb-item.active {
    color: white !important;
}

.university-hero .breadcrumb-item + .breadcrumb-item::before {
    color: rgba(255, 255, 255, 0.6) !important;
}

.university-sidebar {
    position: sticky;
    top: 2rem;
}


.departments-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
}

.department-card {
    background: linear-gradient(145deg, #ffffff 0%, #f8f9ff 100%);
    border: 2px solid rgba(16, 185, 129, 0.1);
    border-radius: 20px;
    padding: 2rem;
    box-shadow: 0 8px 25px rgba(0,0,0,0.1);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(20px);
}

.department-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, #10b981, #059669);
    opacity: 0;
    transition: opacity 0.4s ease;
}

.department-card:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow: 0 15px 35px rgba(0,0,0,0.15);
    border-color: #10b981;
}

.department-card:hover::before {
    opacity: 1;
}

.department-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
}

.department-header h4 {
    margin: 0;
    color: #1e293b;
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: -0.025em;
}

.price-badge {
    background: linear-gradient(135deg, #10b981, #059669);
    color: white;
    padding: 0.6rem 1.2rem;
    border-radius: 30px;
    font-size: 0.9rem;
    font-weight: 800;
    box-shadow: 0 4px 15px rgba(16, 185, 129, 0.4);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.department-details {
    margin-top: 1rem;
}

.department-name-en {
    color: #64748b;
    font-style: italic;
    margin: 0;
    font-size: 0.9rem;
    font-weight: 500;
}

.content-section {
    background: white;
    border: 2px solid rgba(13, 110, 253, 0.2);
    border-radius: 20px;
    padding: 3rem;
    margin-bottom: 3rem;
    box-shadow: 0 8px 25px rgba(0,0,0,0.1);
    backdrop-filter: blur(20px);
    position: relative;
    overflow: hidden;
    color: #1e293b;
}

.content-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, #0d6efd, #0b5ed7, #0a58ca);
    opacity: 0.8;
}

.content-section h2 {
    color: #1e293b !important;
    font-weight: 900;
    margin-bottom: 1.5rem;
    font-size: 1.8rem;
    letter-spacing: -0.025em;
}

/* Deadline Section Styles */
.deadline-section h2 i {
    color: #0d6efd !important;
}

.deadline-content {
    margin-top: 1rem;
}

.deadline-badge-container {
    display: flex;
    align-items: center;
}

.deadline-date-display {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem 2rem;
    background: linear-gradient(145deg, #f0f7ff 0%, #e8f4fd 100%);
    border: 2px solid rgba(13, 110, 253, 0.15);
    border-radius: 16px;
    width: 100%;
}

.deadline-icon {
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, #0d6efd, #0b5ed7);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 4px 15px rgba(13, 110, 253, 0.3);
}

.deadline-icon i {
    font-size: 1.5rem;
    color: white !important;
}

.deadline-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.deadline-date {
    font-size: 1.4rem;
    font-weight: 800;
    color: #1e293b !important;
    letter-spacing: -0.025em;
}

.deadline-remaining {
    font-size: 0.95rem;
    font-weight: 600;
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    display: inline-flex;
    align-items: center;
    width: fit-content;
}

.deadline-normal {
    background: rgba(16, 185, 129, 0.1);
    color: #059669 !important;
}

.deadline-urgent {
    background: rgba(245, 158, 11, 0.1);
    color: #d97706 !important;
}

.deadline-expired {
    background: rgba(239, 68, 68, 0.1);
    color: #dc2626 !important;
}

@media (max-width: 576px) {
    .deadline-date-display {
        flex-direction: column;
        text-align: center;
        gap: 1rem;
        padding: 1.5rem 1rem;
    }
    
    .deadline-info {
        align-items: center;
    }
}

</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Dil değiştirme fonksiyonu
    function switchLanguage(lang) {
        if (lang === 'tr') {
            // Türkçe göster
            document.querySelectorAll('.description-tr, .requirements-tr, .department-name-tr').forEach(el => {
                el.style.display = 'block';
            });
            document.querySelectorAll('.description-en, .requirements-en, .department-name-en').forEach(el => {
                el.style.display = 'none';
            });
            
            // Başlıkları güncelle
            document.querySelectorAll('[data-tr]').forEach(el => {
                el.textContent = el.getAttribute('data-tr');
            });
        } else if (lang === 'en') {
            // İngilizce göster
            document.querySelectorAll('.description-en, .requirements-en, .department-name-en').forEach(el => {
                el.style.display = 'block';
            });
            document.querySelectorAll('.description-tr, .requirements-tr, .department-name-tr').forEach(el => {
                el.style.display = 'none';
            });
            
            // Başlıkları güncelle
            document.querySelectorAll('[data-en]').forEach(el => {
                el.textContent = el.getAttribute('data-en');
            });
        }
    }
    
    // Dil değiştirme butonlarına event listener ekle
    const langButtons = document.querySelectorAll('.language-switcher');
    langButtons.forEach(button => {
        button.addEventListener('click', function(e) {
            e.preventDefault();
            const lang = this.getAttribute('data-lang');
            switchLanguage(lang);
        });
    });
});
</script>

<!-- Image Modal -->
<div class="modal fade" id="imageModal" tabindex="-1" aria-labelledby="imageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="imageModalLabel"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <img id="modalImage" src="" alt="" class="img-fluid">
            </div>
        </div>
    </div>
</div>

<script>
// Event delegation for image modal
document.addEventListener('DOMContentLoaded', function() {
    document.addEventListener('click', function(e) {
        const imageModal = e.target.closest('.js-open-image-modal');
        if (imageModal) {
            const imageUrl = imageModal.getAttribute('data-image-url');
            const imageAlt = imageModal.getAttribute('data-image-alt');
            openImageModal(imageUrl, imageAlt);
        }
    });
});

function openImageModal(imageUrl, caption) {
    document.getElementById('modalImage').src = imageUrl;
    document.getElementById('modalImage').alt = caption;
    document.getElementById('imageModalLabel').textContent = caption;
    
    const modal = new bootstrap.Modal(document.getElementById('imageModal'));
    modal.show();
}
</script>

<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {
            "@type": "ListItem",
            "position": 1,
            "name": "Ana Sayfa",
            "item": "https://vgdanismanlik.com"
        },
        {
            "@type": "ListItem",
            "position": 2,
            "name": "Üniversiteler",
            "item": "https://vgdanismanlik.com/universities"
        },
        {
            "@type": "ListItem",
            "position": 3,
            "name": "<%= university.name %>",
            "item": "https://vgdanismanlik.com/universities/<%= university.slug %>"
        }
    ]
}
</script>

<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "CollegeOrUniversity",
    "name": "<%= university.name %>",
    <% if (university.name_en) { %>"alternateName": "<%= university.name_en %>",<% } %>
    <% if (university.website) { %>"url": "<%= university.website %>",<% } %>
    <% if (university.logo_url) { %>"image": "<%= university.logo_url %>",<% } %>
    "address": {
        "@type": "PostalAddress",
        <% if (university.city) { %>"addressLocality": "<%= university.city %>",<% } %>
        "addressCountry": "<%= university.country || '' %>"
    },
    "description": "<%= (university.description_tr || university.description || '').replace(/"/g, '&quot;').replace(/\n/g, ' ').substring(0, 300) %>"
}
</script> 