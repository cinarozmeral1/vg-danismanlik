    border-radius: 24px;
    padding: 3rem;
    margin-bottom: 3rem;
    box-shadow: 0 8px 32px rgba(13, 110, 253, 0.3), 0 2px 8px rgba(0,0,0,0.08);
    backdrop-filter: blur(20px);
    position: relative;
    overflow: hidden;
    color: white;
}

.university-hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(45deg, 
        rgba(255, 255, 255, 0.1) 0%, 
        rgba(255, 255, 255, 0.1) 25%, 
        rgba(255, 255, 255, 0.1) 50%, 
        rgba(255, 255, 255, 0.1) 75%, 
        rgba(255, 255, 255, 0.1) 100%);
    z-index: 1;
}

/* Hero section text colors */
.university-hero h1,
.university-hero h2,
.university-hero h3,
.university-hero h4,
.university-hero h5,
.university-hero h6,
.university-hero p,
.university-hero span,
.university-hero div {
    color: white !important;
    position: relative;
    z-index: 2;
}

.university-hero .breadcrumb-item a {
    color: rgba(255, 255, 255, 0.8) !important;
}

.university-hero .breadcrumb-item.active {
    color: white !important;
}

.university-hero .breadcrumb-item + .breadcrumb-item::before {
    color: rgba(255, 255, 255, 0.6) !important;
}

.university-sidebar {
    position: sticky;
    top: 2rem;
}

.sidebar-card {
    background: linear-gradient(145deg, #ffffff 0%, #f8f9ff 100%);
    border: 2px solid rgba(13, 110, 253, 0.1);
    border-radius: 20px;
    padding: 2rem;
    margin-bottom: 2rem;
    box-shadow: 0 8px 25px rgba(0,0,0,0.1);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    backdrop-filter: blur(20px);
    position: relative;
    overflow: hidden;
}

.sidebar-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, #0d6efd, #0b5ed7, #0a58ca);
    opacity: 0;
    transition: opacity 0.4s ease;
}

.sidebar-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 35px rgba(0,0,0,0.15);
    border-color: #0d6efd;
}

.sidebar-card:hover::before {
    opacity: 1;
}

.sidebar-card h3 {
    color: #1e293b;
    font-weight: 800;
    margin-bottom: 1.5rem;
    font-size: 1.4rem;
    letter-spacing: -0.025em;
}

.contact-item, .ranking-item {
    display: flex;
    align-items: center;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(99, 102, 241, 0.1);
    transition: all 0.3s ease;
}

.contact-item:hover, .ranking-item:hover {
    background: rgba(13, 110, 253, 0.05);
    border-radius: 8px;
    padding-left: 0.5rem;
    padding-right: 0.5rem;
}

.contact-item:last-child, .ranking-item:last-child {
    border-bottom: none;
}

.contact-item i, .ranking-item i {
    color: #0d6efd;
    margin-right: 1rem;
    width: 24px;
    font-size: 1.1rem;
}

.ranking-value {
    background: linear-gradient(135deg, #0d6efd, #0b5ed7);
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 25px;
    font-weight: 700;
    font-size: 0.9rem;
    box-shadow: 0 4px 12px rgba(13, 110, 253, 0.3);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.cta-buttons .btn {
    border-radius: 12px;
    font-weight: 700;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    position: relative;
    overflow: hidden;
}

.cta-buttons .btn-primary {
    background: linear-gradient(135deg, #0d6efd, #0b5ed7, #0a58ca);
    border: none;
    box-shadow: 0 4px 15px rgba(13, 110, 253, 0.4);
}

.cta-buttons .btn-primary::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
    transition: left 0.6s;
}

.cta-buttons .btn-primary:hover::before {
    left: 100%;
}

.cta-buttons .btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(13, 110, 253, 0.6);
}

.cta-buttons .btn-outline-primary {
    border: 2px solid #0d6efd;
    color: #0d6efd;
    background: rgba(13, 110, 253, 0.05);
}

.cta-buttons .btn-outline-primary:hover {
    background: linear-gradient(135deg, #0d6efd, #0b5ed7);
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(13, 110, 253, 0.4);
}

.departments-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
}

.department-card {
    background: linear-gradient(145deg, #ffffff 0%, #f8f9ff 100%);
    border: 2px solid rgba(16, 185, 129, 0.1);
    border-radius: 20px;
    padding: 2rem;
    box-shadow: 0 8px 25px rgba(0,0,0,0.1);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(20px);
}

.department-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, #10b981, #059669);
    opacity: 0;
    transition: opacity 0.4s ease;
}

.department-card:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow: 0 15px 35px rgba(0,0,0,0.15);
    border-color: #10b981;
}

.department-card:hover::before {
    opacity: 1;
}

.department-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
}

.department-header h4 {
    margin: 0;
    color: #1e293b;
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: -0.025em;
}

.price-badge {
    background: linear-gradient(135deg, #10b981, #059669);
    color: white;
    padding: 0.6rem 1.2rem;
    border-radius: 30px;
    font-size: 0.9rem;
    font-weight: 800;
    box-shadow: 0 4px 15px rgba(16, 185, 129, 0.4);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.department-details {
    margin-top: 1rem;
}

.department-name-en {
    color: #64748b;
    font-style: italic;
    margin: 0;
    font-size: 0.9rem;
    font-weight: 500;
}

.content-section {
    background: linear-gradient(145deg, #ffffff 0%, #f8f9ff 100%);
    border: 2px solid rgba(13, 110, 253, 0.1);
    border-radius: 20px;
    padding: 3rem;
    margin-bottom: 3rem;
    box-shadow: 0 8px 25px rgba(0,0,0,0.1);
    backdrop-filter: blur(20px);
    position: relative;
    overflow: hidden;
}

.content-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, #0d6efd, #0b5ed7, #0a58ca);
    opacity: 0.8;
}

.content-section h2 {
    color: #1e293b;
    font-weight: 900;
    margin-bottom: 1.5rem;
    font-size: 1.8rem;
    letter-spacing: -0.025em;
}

.quick-stats {
    background: linear-gradient(145deg, #ffffff 0%, #f8f9ff 100%);
    border: 2px solid rgba(13, 110, 253, 0.1);
    border-radius: 20px;
    padding: 2rem;
    box-shadow: 0 8px 25px rgba(0,0,0,0.1);
    backdrop-filter: blur(20px);
}

.stat-card {
    display: flex;
    align-items: center;
    padding: 1.5rem;
    background: rgba(255,255,255,0.8);
    border-radius: 16px;
    border: 2px solid rgba(13, 110, 253, 0.1);
    transition: all 0.3s ease;
}

.stat-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.1);
}

.stat-icon {
    background: linear-gradient(135deg, #0d6efd, #0b5ed7);
    color: white;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 1.5rem;
    font-size: 1.4rem;
    box-shadow: 0 4px 15px rgba(13, 110, 253, 0.3);
}

.stat-content h3 {
    color: #1e293b;
    font-weight: 900;
    font-size: 1.8rem;
    margin: 0;
    letter-spacing: -0.025em;
}

.stat-content p {
    color: #64748b;
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Dil değiştirme fonksiyonu
    function switchLanguage(lang) {
        if (lang === 'tr') {
            // Türkçe göster
            document.querySelectorAll('.description-tr, .requirements-tr, .department-name-tr').forEach(el => {
                el.style.display = 'block';
            });
            document.querySelectorAll('.description-en, .requirements-en, .department-name-en').forEach(el => {
                el.style.display = 'none';
            });
            
            // Başlıkları güncelle
            document.querySelectorAll('[data-tr]').forEach(el => {
                el.textContent = el.getAttribute('data-tr');
            });
        } else if (lang === 'en') {
            // İngilizce göster
            document.querySelectorAll('.description-en, .requirements-en, .department-name-en').forEach(el => {
                el.style.display = 'block';
            });
            document.querySelectorAll('.description-tr, .requirements-tr, .department-name-tr').forEach(el => {
                el.style.display = 'none';
            });
            
            // Başlıkları güncelle
            document.querySelectorAll('[data-en]').forEach(el => {
                el.textContent = el.getAttribute('data-en');
            });
        }
    }
    
    // Dil değiştirme butonlarına event listener ekle
    const langButtons = document.querySelectorAll('.language-switcher');
    langButtons.forEach(button => {
        button.addEventListener('click', function(e) {
            e.preventDefault();
            const lang = this.getAttribute('data-lang');
            switchLanguage(lang);
        });
    });
});
</script>

<!-- Image Modal -->
<div class="modal fade" id="imageModal" tabindex="-1" aria-labelledby="imageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="imageModalLabel"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <img id="modalImage" src="" alt="" class="img-fluid">
            </div>
        </div>
    </div>
</div>

<script>
// Event delegation for image modal
document.addEventListener('DOMContentLoaded', function() {
    document.addEventListener('click', function(e) {
        const imageModal = e.target.closest('.js-open-image-modal');
        if (imageModal) {
            const imageUrl = imageModal.getAttribute('data-image-url');
            const imageAlt = imageModal.getAttribute('data-image-alt');
            openImageModal(imageUrl, imageAlt);
        }
    });
});

function openImageModal(imageUrl, caption) {
    document.getElementById('modalImage').src = imageUrl;
    document.getElementById('modalImage').alt = caption;
    document.getElementById('imageModalLabel').textContent = caption;
    
    const modal = new bootstrap.Modal(document.getElementById('imageModal'));
    modal.show();
}
</script> 