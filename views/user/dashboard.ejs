<!-- Main Content -->
    <section class="section bg-light text-dark" style="min-height: 80vh;">
        <div class="container">
            <div class="row">
                <div class="col-lg-3 mb-4 d-none d-lg-block" id="studentSidebarContainer">
                    <div class="card shadow-sm">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="fas fa-user me-2"></i>Öğrenci Menüsü</h5>
                        </div>
                        <div class="list-group list-group-flush">
                            <a href="/user/dashboard" class="list-group-item list-group-item-action active">
                                <i class="fas fa-user me-2"></i>Profil Bilgileri
                            </a>
                            <a href="/user/applications" class="list-group-item list-group-item-action">
                                <i class="fas fa-file-alt me-2"></i>Başvurularım
                            </a>
                        <a href="/user/services" class="list-group-item list-group-item-action">
                            <i class="fas fa-credit-card me-2"></i>Hizmetler & Ödemeler
                        </a>
                            <a href="/user/files" class="list-group-item list-group-item-action">
                                <i class="fas fa-folder-open me-2"></i>Dosyalarım
                            </a>
                            <a href="/user/settings" class="list-group-item list-group-item-action">
                                <i class="fas fa-cog me-2"></i>Ayarlar
                            </a>
                            <a href="#" class="list-group-item list-group-item-action text-danger" data-action="logout">
                                <i class="fas fa-sign-out-alt me-2"></i>Çıkış Yap
                            </a>
                        </div>
                    </div>
                </div>

                <div class="col-lg-9" id="studentMainContent">
                    <!-- Email Doğrulama Uyarısı -->
                    <% if (typeof profile !== 'undefined' && profile && (profile.email_verified === false || profile.email_verified === 0 || profile.email_verified === null)) { %>
                    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert" id="emailVerificationAlert" style="border-radius: 12px; border-left: 5px solid #dc3545;">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-envelope-open me-3" style="font-size: 1.5rem; color: #721c24;"></i>
                            <div class="flex-grow-1">
                                <h5 class="alert-heading mb-2">E-posta Adresinizi Doğrulayın</h5>
                                <p class="mb-2">Hesabınızı aktif hale getirmek için e-posta adresinizi doğrulamanız gerekmektedir.</p>
                                <small class="text-muted d-block mb-3"><%= profile.email %> adresine gönderilen doğrulama linkine tıklayın.</small>
                                <button type="button" class="btn btn-sm btn-outline-danger" id="resendVerificationBtn" onclick="resendVerificationEmail()">
                                    <i class="fas fa-paper-plane me-1"></i>Doğrulama Mailini Tekrar Gönder
                                </button>
                            </div>
                        </div>
                    </div>
                    <% } %>
                    
                    <!-- Eksik Bilgi Uyarısı -->
                    <% 
                        const hasIncompleteProfile = typeof profile !== 'undefined' && profile && (
                            !profile.first_name || profile.first_name === '' ||
                            !profile.last_name || profile.last_name === '' ||
                            !profile.tc_number || profile.tc_number === '' ||
                            !profile.phone || profile.phone === '' ||
                            !profile.birth_date ||
                            !profile.current_school || profile.current_school === '' ||
                            !profile.home_address || profile.home_address === ''
                        );
                        const hasIncompleteGuardians = typeof guardians === 'undefined' || !guardians || guardians.length < 2;
                        const hasIncompleteInfo = hasIncompleteProfile || hasIncompleteGuardians;
                    %>
                    <% if (hasIncompleteInfo) { %>
                    <div class="alert alert-info fade show mb-4" role="alert" style="border-radius: 12px; border-left: 5px solid #0d6efd; background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);">
                        <div class="d-flex align-items-start">
                            <div class="me-3">
                                <i class="fas fa-clock text-primary" style="font-size: 2rem;"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-start flex-wrap">
                                    <div>
                                        <h5 class="alert-heading mb-1">
                                            <i class="fas fa-clipboard-list me-2"></i>Kişisel Bilgilerinizi Tamamlayın
                                        </h5>
                                        <p class="mb-2">Danışmanlık hizmetlerimizden tam olarak faydalanabilmek için lütfen profilinizi ve veli bilgilerinizi tamamlayın.</p>
                                    </div>
                                    <a href="#profileForm" class="btn btn-sm btn-primary">
                                        <i class="fas fa-edit me-1"></i>Hemen Doldur
                                    </a>
                                </div>
                                <hr class="my-2">
                                <small class="text-muted">
                                    <i class="fas fa-info-circle me-1"></i>
                                    Zorunlu alanlar: <strong>Ad, Soyad, TC Kimlik No, Telefon, Doğum Tarihi, Okuduğu Okul, Ev Adresi, Veli Bilgileri (en az 2)</strong>
                                </small>
                            </div>
                        </div>
                    </div>
                    <% } %>
                    
                    <!-- AI Öneri Kartı -->
                    <div id="aiRecommendationCard" class="card shadow-sm mb-4" style="display: none;">
                        <div class="card-header text-white" style="background: linear-gradient(135deg, #0056b3, #28a745);">
                            <h5 class="mb-0"><i class="fas fa-magic me-2"></i>AI Üniversite Öneriniz</h5>
                        </div>
                        <div class="card-body">
                            <div id="aiRecommendationContent">
                                <!-- Content will be loaded dynamically -->
                            </div>
                        </div>
                    </div>

                    <div class="card shadow-sm">
                        <div class="card-header bg-primary text-white">
                            <h4 class="mb-0"><i class="fas fa-user me-2"></i>Profil Bilgileri</h4>
                        </div>
                        <div class="card-body">
                            <div id="alertContainer"></div>
 
                            <form id="profileForm" class="row g-4">
                                <div class="col-md-6">
                                    <label for="first_name" class="form-label">Ad *</label>
                                    <input type="text" class="form-control" id="first_name" name="first_name" value="<%= profile ? profile.first_name : '' %>" required>
                                </div>
                                <div class="col-md-6">
                                    <label for="last_name" class="form-label">Soyad *</label>
                                    <input type="text" class="form-control" id="last_name" name="last_name" value="<%= profile ? profile.last_name : '' %>" required>
                                </div>
 
                                <div class="col-md-6">
                                    <label for="tc_number" class="form-label">TC Kimlik No *</label>
                                    <input type="text" class="form-control" id="tc_number" name="tc_number" value="<%= profile ? profile.tc_number : '' %>" maxlength="11" pattern="[0-9]{11}" oninput="this.value = this.value.replace(/[^0-9]/g, '')" required>
                                </div>
                                <div class="col-md-6">
                                    <label for="phone" class="form-label">Telefon *</label>
                                    <input type="tel" class="form-control" id="phone" name="phone" value="<%= profile ? profile.phone : '' %>" placeholder="Örn: +90 555 123 45 67" required>
                                </div>
 
                                <div class="col-md-6">
                                    <label for="english_level" class="form-label">İngilizce Seviyesi *</label>
                                    <select class="form-select" id="english_level" name="english_level" required>
                                        <option value="">Seçiniz</option>
                                        <option value="A1" <%= profile && profile.english_level === 'A1' ? 'selected' : '' %>>A1</option>
                                        <option value="A2" <%= profile && profile.english_level === 'A2' ? 'selected' : '' %>>A2</option>
                                        <option value="B1" <%= profile && profile.english_level === 'B1' ? 'selected' : '' %>>B1</option>
                                        <option value="B2" <%= profile && profile.english_level === 'B2' ? 'selected' : '' %>>B2</option>
                                        <option value="C1" <%= profile && profile.english_level === 'C1' ? 'selected' : '' %>>C1</option>
                                        <option value="C2" <%= profile && profile.english_level === 'C2' ? 'selected' : '' %>>C2</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label for="high_school_graduation_date" class="form-label">Lise Mezuniyet Tarihi *</label>
                                    <input type="text" class="form-control" id="high_school_graduation_date" name="high_school_graduation_date" value="<%= profile && profile.high_school_graduation_date ? profile.high_school_graduation_date.toISOString().split('T')[0].split('-').reverse().join('/') : '' %>" placeholder="GG/AA/YYYY" required>
                                    <small class="text-muted">GG/AA/YYYY formatında slash (/) kullanarak giriniz.</small>
                                </div>
 
                                <div class="col-md-6">
                                    <label for="birth_date" class="form-label">Doğum Tarihi *</label>
                                    <input type="text" class="form-control" id="birth_date" name="birth_date" value="<%= profile && profile.birth_date ? profile.birth_date.toISOString().split('T')[0].split('-').reverse().join('/') : '' %>" placeholder="GG/AA/YYYY" required>
                                    <small class="text-muted">GG/AA/YYYY formatında slash (/) kullanarak giriniz.</small>
                                </div>
                                <div class="col-md-6">
                                    <label for="passport_type" class="form-label">Pasaport Türü *</label>
                                    <input type="text" class="form-control" id="passport_type" name="passport_type" value="<%= profile ? profile.passport_type : '' %>" placeholder="Örn: Bordo, Yeşil, Gri, Siyah" required>
                                </div>
 
                                <div class="col-md-6">
                                    <label for="passport_number" class="form-label">Pasaport Numarası *</label>
                                    <input type="text" class="form-control" id="passport_number" name="passport_number" value="<%= profile ? profile.passport_number : '' %>" placeholder="Örn: P1234567" required>
                                </div>
                                <div class="col-md-6">
                                    <label for="desired_country" class="form-label">Gitmek İstediği Ülke *</label>
                                    <input type="text" class="form-control" id="desired_country" name="desired_country" value="<%= profile ? profile.desired_country : '' %>" placeholder="Örn: Almanya" required>
                                </div>
 
                                <div class="col-md-6">
                                    <label for="active_class" class="form-label">Aktif Sınıf *</label>
                                    <input type="text" class="form-control" id="active_class" name="active_class" value="<%= profile ? profile.active_class : '' %>" placeholder="Örn: 11" required>
                                </div>
                                <div class="col-md-6">
                                    <label for="email" class="form-label">E-posta *</label>
                                    <input type="email" class="form-control" id="email" name="email" value="<%= user.email %>" readonly>
                                </div>

                                <div class="col-md-6">
                                    <label for="current_school" class="form-label">Aktif Olarak Okuduğu Okul (Lise/Üniversite) *</label>
                                    <input type="text" class="form-control" id="current_school" name="current_school" value="<%= profile ? profile.current_school || '' : '' %>" placeholder="Örn: Galatasaray Lisesi" required>
                                </div>
                                <div class="col-12">
                                    <label for="home_address" class="form-label">Ev Adresi *</label>
                                    <textarea class="form-control" id="home_address" name="home_address" rows="2" placeholder="Tam ev adresinizi giriniz" required><%= profile ? profile.home_address || '' : '' %></textarea>
                                </div>
 
                                <div class="col-12 text-end">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fas fa-save me-2"></i>Değişiklikleri Kaydet
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Veli Bilgileri Section -->
                    <div class="card shadow-sm mt-4">
                        <div class="card-header bg-primary text-white">
                            <h4 class="mb-0"><i class="fas fa-user-friends me-2"></i>Veli Bilgileri</h4>
                        </div>
                        <div class="card-body">
                            <div id="guardiansAlertContainer"></div>
                            <p class="text-muted mb-3"><i class="fas fa-info-circle me-1"></i>En az 2 veli bilgisi (Anne ve Baba) doldurulması zorunludur. Ek veli eklemek isterseniz "Veli Ekle" butonunu kullanabilirsiniz.</p>
                            
                            <div id="guardiansContainer">
                                <!-- Guardian cards will be rendered here -->
                            </div>

                            <div class="d-flex justify-content-between mt-3">
                                <button type="button" class="btn btn-outline-primary" id="addGuardianBtn" onclick="addGuardianCard()">
                                    <i class="fas fa-plus me-2"></i>Veli Ekle
                                </button>
                                <button type="button" class="btn btn-primary" onclick="saveAllGuardians()">
                                    <i class="fas fa-save me-2"></i>Veli Bilgilerini Kaydet
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Custom JS -->
    <script>
        // Logout function
        function logout() {
            console.log('Logout function called'); // Debug için
            fetch('/api/auth/logout', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                credentials: 'include' // Include cookies
            })
            .then(response => {
                console.log('Logout response status:', response.status); // Debug için
                return response.json();
            })
            .then(data => {
                console.log('Logout response:', data); // Debug için
                if (data.success) {
                    console.log('Logout successful, redirecting...'); // Debug için
                    window.location.href = '/';
                } else {
                    console.error('Logout failed:', data.message);
                }
            })
            .catch(error => {
                console.error('Error during logout:', error);
                window.location.href = '/';
            });
        }
        
        // Resend verification email function
        function resendVerificationEmail() {
            const btn = document.getElementById('resendVerificationBtn');
            const originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Gönderiliyor...';
            
            fetch('/api/auth/resend-verification', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    email: '<%= typeof profile !== "undefined" && profile ? profile.email : "" %>',
                    language: 'tr'
                }),
                credentials: 'include'
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    btn.innerHTML = '<i class="fas fa-check me-1"></i>Mail Gönderildi!';
                    btn.classList.remove('btn-outline-danger');
                    btn.classList.add('btn-success');
                    setTimeout(() => {
                        btn.innerHTML = originalText;
                        btn.classList.remove('btn-success');
                        btn.classList.add('btn-outline-danger');
                        btn.disabled = false;
                    }, 5000);
                } else {
                    btn.innerHTML = '<i class="fas fa-times me-1"></i>' + (data.message || 'Hata!');
                    setTimeout(() => {
                        btn.innerHTML = originalText;
                        btn.disabled = false;
                    }, 3000);
                }
            })
            .catch(error => {
                console.error('Error resending verification:', error);
                btn.innerHTML = '<i class="fas fa-times me-1"></i>Hata oluştu';
                setTimeout(() => {
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                }, 3000);
            });
        }

        // Profile form submission
        document.getElementById('profileForm').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const formData = new FormData(this);
            const formatDate = (value) => {
                if (!value) return null;
                const slashRegex = /^(\d{2})\/(\d{2})\/(\d{4})$/;
                if (slashRegex.test(value)) {
                    const [, day, month, year] = value.match(slashRegex);
                    return `${year}-${month}-${day}`;
                }
                const dashRegex = /^(\d{4})-(\d{2})-(\d{2})$/;
                if (dashRegex.test(value)) {
                    return value;
                }
                return value;
            };

            const data = {
                first_name: formData.get('first_name'),
                last_name: formData.get('last_name'),
                phone: formData.get('phone'),
                english_level: formData.get('english_level'),
                high_school_graduation_date: formatDate(formData.get('high_school_graduation_date')),
                birth_date: formatDate(formData.get('birth_date')),
                passport_type: formData.get('passport_type'),
                passport_number: formData.get('passport_number'),
                desired_country: formData.get('desired_country'),
                active_class: formData.get('active_class'),
                tc_number: formData.get('tc_number'),
                current_school: formData.get('current_school'),
                home_address: formData.get('home_address')
            };
            
            fetch('/api/user/profile', {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(data)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showAlert('Profil bilgileriniz başarıyla güncellendi!', 'success');
                    populateProfileForm(data.user);
                } else {
                    showAlert(data.message || 'Bir hata oluştu!', 'danger');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showAlert('Bir hata oluştu!', 'danger');
            });
        });

        async function fetchProfile() {
            try {
                const response = await fetch('/api/user/profile', {
                    method: 'GET',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include'
                });

                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}`);
                }

                const data = await response.json();
                if (data.success && data.user) {
                    populateProfileForm(data.user);
                }
            } catch (error) {
                console.error('Profil verisi alınırken hata:', error);
            }
        }

        function populateProfileForm(user) {
            const setValue = (id, value) => {
                const el = document.getElementById(id);
                if (el) el.value = value || '';
            };

            setValue('first_name', user.first_name);
            setValue('last_name', user.last_name);
            setValue('tc_number', user.tc_number);
            setValue('phone', user.phone);
            setValue('english_level', user.english_level);
            setValue('high_school_graduation_date', formatDate(user.high_school_graduation_date));
            setValue('birth_date', formatDate(user.birth_date));
            setValue('passport_type', user.passport_type);
            setValue('passport_number', user.passport_number);
            setValue('desired_country', user.desired_country);
            setValue('active_class', user.active_class);
            setValue('current_school', user.current_school);
            setValue('home_address', user.home_address);

            const emailField = document.getElementById('email');
            if (emailField) emailField.value = user.email;
        }

        function formatDate(value) {
            if (!value) return '';
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return value;
            const day = String(date.getUTCDate()).padStart(2, '0');
            const month = String(date.getUTCMonth() + 1).padStart(2, '0');
            const year = date.getUTCFullYear();
            return `${day}/${month}/${year}`;
        }

        let dropdownInstance = null;

        // User dropdown is now rendered server-side in layout.ejs
        // No need to update it with JavaScript

        // Alert function
        function showAlert(message, type) {
            const alertContainer = document.getElementById('alertContainer');
            const alert = document.createElement('div');
            alert.className = `alert alert-${type} alert-dismissible fade show`;
            alert.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            alertContainer.appendChild(alert);
            
            // Auto remove after 10 seconds
            setTimeout(() => {
                alert.remove();
            }, 10000);
        }

        // =====================================================
        // GUARDIAN (VELİ) MANAGEMENT
        // =====================================================
        let guardianCounter = 0;
        const relationships = ['Anne', 'Baba', 'Kardes', 'Diger'];
        const relationshipLabels = { 'Anne': 'Anne', 'Baba': 'Baba', 'Kardes': 'Kardeş', 'Diger': 'Diğer' };

        function createGuardianCardHTML(guardian, index, isRequired) {
            const rel = guardian.relationship || (index === 0 ? 'Anne' : index === 1 ? 'Baba' : 'Diger');
            const icon = rel === 'Anne' ? 'fa-female' : rel === 'Baba' ? 'fa-male' : 'fa-user';
            const label = relationshipLabels[rel] || rel;
            const requiredTag = isRequired ? '<span class="badge bg-danger ms-2">Zorunlu</span>' : '<span class="badge bg-secondary ms-2">Opsiyonel</span>';
            const deleteBtn = !isRequired ? `<button type="button" class="btn btn-sm btn-outline-danger" onclick="removeGuardianCard(this)"><i class="fas fa-trash"></i></button>` : '';
            
            return `
            <div class="card mb-3 guardian-card" data-index="${index}" data-required="${isRequired}">
                <div class="card-header bg-primary bg-opacity-10 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="fas ${icon} me-2"></i>${label} Bilgileri ${requiredTag}</h6>
                    ${deleteBtn}
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Ad Soyad ${isRequired ? '*' : ''}</label>
                            <input type="text" class="form-control guardian-fullname" value="${guardian.full_name || ''}" placeholder="Ad Soyad" ${isRequired ? 'required' : ''}>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Yakınlık Derecesi</label>
                            <select class="form-select guardian-relationship">
                                ${relationships.map(r => `<option value="${r}" ${rel === r ? 'selected' : ''}>${relationshipLabels[r]}</option>`).join('')}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">TC Kimlik No</label>
                            <input type="text" class="form-control guardian-tc" value="${guardian.tc_number || ''}" maxlength="11" placeholder="TC Kimlik No" oninput="this.value = this.value.replace(/[^0-9]/g, '')">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Telefon</label>
                            <input type="tel" class="form-control guardian-phone" value="${guardian.phone || ''}" placeholder="Örn: +90 555 123 45 67">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">E-posta</label>
                            <input type="email" class="form-control guardian-email" value="${guardian.email || ''}" placeholder="E-posta adresi">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Ev Adresi</label>
                            <input type="text" class="form-control guardian-address" value="${guardian.address || ''}" placeholder="Ev adresi">
                        </div>
                    </div>
                </div>
            </div>`;
        }

        function renderGuardians(guardiansList) {
            const container = document.getElementById('guardiansContainer');
            container.innerHTML = '';
            guardianCounter = 0;

            // Ensure at least 2 required guardians (Anne, Baba)
            if (!guardiansList || guardiansList.length === 0) {
                guardiansList = [
                    { full_name: '', relationship: 'Anne', tc_number: '', phone: '', email: '', address: '', is_required: true, sort_order: 1 },
                    { full_name: '', relationship: 'Baba', tc_number: '', phone: '', email: '', address: '', is_required: true, sort_order: 2 }
                ];
            } else if (guardiansList.length === 1) {
                guardiansList.push({ full_name: '', relationship: 'Baba', tc_number: '', phone: '', email: '', address: '', is_required: true, sort_order: 2 });
            }

            guardiansList.forEach((g, i) => {
                const isReq = i < 2;
                container.insertAdjacentHTML('beforeend', createGuardianCardHTML(g, guardianCounter, isReq));
                guardianCounter++;
            });
        }

        function addGuardianCard() {
            const container = document.getElementById('guardiansContainer');
            const newGuardian = { full_name: '', relationship: 'Diger', tc_number: '', phone: '', email: '', address: '' };
            container.insertAdjacentHTML('beforeend', createGuardianCardHTML(newGuardian, guardianCounter, false));
            guardianCounter++;
        }

        function removeGuardianCard(btn) {
            const card = btn.closest('.guardian-card');
            if (card && card.dataset.required !== 'true') {
                card.remove();
            }
        }

        function collectGuardianData() {
            const cards = document.querySelectorAll('.guardian-card');
            const guardians = [];
            cards.forEach((card, i) => {
                const fullName = card.querySelector('.guardian-fullname').value.trim();
                guardians.push({
                    full_name: fullName,
                    relationship: card.querySelector('.guardian-relationship').value,
                    tc_number: card.querySelector('.guardian-tc').value.trim(),
                    phone: card.querySelector('.guardian-phone').value.trim(),
                    email: card.querySelector('.guardian-email').value.trim(),
                    address: card.querySelector('.guardian-address').value.trim(),
                    is_required: i < 2,
                    sort_order: i + 1
                });
            });
            return guardians;
        }

        async function saveAllGuardians() {
            const guardians = collectGuardianData();
            
            // Validate: first 2 must have full_name
            const required = guardians.filter(g => g.is_required);
            const filledRequired = required.filter(g => g.full_name !== '');
            if (filledRequired.length < 2) {
                showGuardianAlert('En az 2 veli bilgisi (Anne ve Baba) doldurulmalıdır.', 'danger');
                return;
            }

            try {
                const response = await fetch('/api/user/guardians/save-all', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ guardians })
                });
                const result = await response.json();
                if (result.success) {
                    showGuardianAlert('Veli bilgileri başarıyla kaydedildi!', 'success');
                    renderGuardians(result.guardians);
                } else {
                    showGuardianAlert(result.message || 'Bir hata oluştu!', 'danger');
                }
            } catch (error) {
                console.error('Save guardians error:', error);
                showGuardianAlert('Veli bilgileri kaydedilirken bir hata oluştu.', 'danger');
            }
        }

        function showGuardianAlert(message, type) {
            const container = document.getElementById('guardiansAlertContainer');
            container.innerHTML = `
                <div class="alert alert-${type} alert-dismissible fade show">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>`;
            setTimeout(() => { container.innerHTML = ''; }, 8000);
        }

