<!-- Main Content -->
    <section class="section bg-light text-dark" style="min-height: 80vh;">
        <div class="container">
            <div class="row">
                <div class="col-lg-3 mb-4 d-none d-lg-block" id="studentSidebarContainer">
                    <div class="card shadow-sm">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="fas fa-user me-2"></i>Öğrenci Menüsü</h5>
                        </div>
                        <div class="list-group list-group-flush">
                            <a href="/user/dashboard" class="list-group-item list-group-item-action active">
                                <i class="fas fa-user me-2"></i>Profil Bilgileri
                            </a>
                            <a href="/user/applications" class="list-group-item list-group-item-action">
                                <i class="fas fa-file-alt me-2"></i>Başvurularım
                            </a>
                        <a href="/user/services" class="list-group-item list-group-item-action">
                            <i class="fas fa-credit-card me-2"></i>Hizmetler & Ödemeler
                        </a>
                            <a href="/user/files" class="list-group-item list-group-item-action">
                                <i class="fas fa-folder-open me-2"></i>Dosyalarım
                            </a>
                            <a href="/user/settings" class="list-group-item list-group-item-action">
                                <i class="fas fa-cog me-2"></i>Ayarlar
                            </a>
                            <a href="#" class="list-group-item list-group-item-action text-danger" data-action="logout">
                                <i class="fas fa-sign-out-alt me-2"></i>Çıkış Yap
                            </a>
                        </div>
                    </div>
                </div>

                <div class="col-lg-9" id="studentMainContent">
                    <!-- AI Öneri Kartı -->
                    <div id="aiRecommendationCard" class="card shadow-sm mb-4" style="display: none;">
                        <div class="card-header text-white" style="background: linear-gradient(135deg, #0056b3, #28a745);">
                            <h5 class="mb-0"><i class="fas fa-magic me-2"></i>AI Üniversite Öneriniz</h5>
                        </div>
                        <div class="card-body">
                            <div id="aiRecommendationContent">
                                <!-- Content will be loaded dynamically -->
                            </div>
                        </div>
                    </div>

                    <div class="card shadow-sm">
                        <div class="card-header bg-primary text-white">
                            <h4 class="mb-0"><i class="fas fa-user me-2"></i>Profil Bilgileri</h4>
                        </div>
                        <div class="card-body">
                            <div id="alertContainer"></div>
 
                            <form id="profileForm" class="row g-4">
                                <div class="col-md-6">
                                    <label for="first_name" class="form-label">Ad *</label>
                                    <input type="text" class="form-control" id="first_name" name="first_name" value="<%= profile ? profile.first_name : '' %>" required>
                                </div>
                                <div class="col-md-6">
                                    <label for="last_name" class="form-label">Soyad *</label>
                                    <input type="text" class="form-control" id="last_name" name="last_name" value="<%= profile ? profile.last_name : '' %>" required>
                                </div>
 
                                <div class="col-md-6">
                                    <label for="tc_number" class="form-label">TC Kimlik No *</label>
                                    <input type="text" class="form-control" id="tc_number" name="tc_number" value="<%= profile ? profile.tc_number : '' %>" maxlength="11" pattern="[0-9]{11}" oninput="this.value = this.value.replace(/[^0-9]/g, '')" required>
                                </div>
                                <div class="col-md-6">
                                    <label for="phone" class="form-label">Telefon *</label>
                                    <input type="tel" class="form-control" id="phone" name="phone" value="<%= profile ? profile.phone : '' %>" placeholder="Örn: +90 555 123 45 67" required>
                                </div>
 
                                <div class="col-md-6">
                                    <label for="english_level" class="form-label">İngilizce Seviyesi *</label>
                                    <select class="form-select" id="english_level" name="english_level" required>
                                        <option value="">Seçiniz</option>
                                        <option value="A1" <%= profile && profile.english_level === 'A1' ? 'selected' : '' %>>A1</option>
                                        <option value="A2" <%= profile && profile.english_level === 'A2' ? 'selected' : '' %>>A2</option>
                                        <option value="B1" <%= profile && profile.english_level === 'B1' ? 'selected' : '' %>>B1</option>
                                        <option value="B2" <%= profile && profile.english_level === 'B2' ? 'selected' : '' %>>B2</option>
                                        <option value="C1" <%= profile && profile.english_level === 'C1' ? 'selected' : '' %>>C1</option>
                                        <option value="C2" <%= profile && profile.english_level === 'C2' ? 'selected' : '' %>>C2</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label for="high_school_graduation_date" class="form-label">Lise Mezuniyet Tarihi *</label>
                                    <input type="text" class="form-control" id="high_school_graduation_date" name="high_school_graduation_date" value="<%= profile && profile.high_school_graduation_date ? profile.high_school_graduation_date.toISOString().split('T')[0].split('-').reverse().join('/') : '' %>" placeholder="GG/AA/YYYY" required>
                                    <small class="text-muted">GG/AA/YYYY formatında slash (/) kullanarak giriniz.</small>
                                </div>
 
                                <div class="col-md-6">
                                    <label for="birth_date" class="form-label">Doğum Tarihi *</label>
                                    <input type="text" class="form-control" id="birth_date" name="birth_date" value="<%= profile && profile.birth_date ? profile.birth_date.toISOString().split('T')[0].split('-').reverse().join('/') : '' %>" placeholder="GG/AA/YYYY" required>
                                    <small class="text-muted">GG/AA/YYYY formatında slash (/) kullanarak giriniz.</small>
                                </div>
                                <div class="col-md-6">
                                    <label for="passport_type" class="form-label">Pasaport Türü *</label>
                                    <input type="text" class="form-control" id="passport_type" name="passport_type" value="<%= profile ? profile.passport_type : '' %>" placeholder="Örn: Bordo, Yeşil, Gri, Siyah" required>
                                </div>
 
                                <div class="col-md-6">
                                    <label for="passport_number" class="form-label">Pasaport Numarası *</label>
                                    <input type="text" class="form-control" id="passport_number" name="passport_number" value="<%= profile ? profile.passport_number : '' %>" placeholder="Örn: P1234567" required>
                                </div>
                                <div class="col-md-6">
                                    <label for="desired_country" class="form-label">Gitmek İstediği Ülke *</label>
                                    <input type="text" class="form-control" id="desired_country" name="desired_country" value="<%= profile ? profile.desired_country : '' %>" placeholder="Örn: Almanya" required>
                                </div>
 
                                <div class="col-md-6">
                                    <label for="active_class" class="form-label">Aktif Sınıf *</label>
                                    <input type="text" class="form-control" id="active_class" name="active_class" value="<%= profile ? profile.active_class : '' %>" placeholder="Örn: 11" required>
                                </div>
                                <div class="col-md-6">
                                    <label for="email" class="form-label">E-posta *</label>
                                    <input type="email" class="form-control" id="email" name="email" value="<%= user.email %>" readonly>
                                </div>
 
                                <div class="col-12 text-end">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fas fa-save me-2"></i>Değişiklikleri Kaydet
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Custom JS -->
    <script>
        // Logout function
        function logout() {
            console.log('Logout function called'); // Debug için
            fetch('/api/auth/logout', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                credentials: 'include' // Include cookies
            })
            .then(response => {
                console.log('Logout response status:', response.status); // Debug için
                return response.json();
            })
            .then(data => {
                console.log('Logout response:', data); // Debug için
                if (data.success) {
                    console.log('Logout successful, redirecting...'); // Debug için
                    window.location.href = '/';
                } else {
                    console.error('Logout failed:', data.message);
                }
            })
            .catch(error => {
                console.error('Error during logout:', error);
                window.location.href = '/';
            });
        }

        // Profile form submission
        document.getElementById('profileForm').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const formData = new FormData(this);
            const formatDate = (value) => {
                if (!value) return null;
                const slashRegex = /^(\d{2})\/(\d{2})\/(\d{4})$/;
                if (slashRegex.test(value)) {
                    const [, day, month, year] = value.match(slashRegex);
                    return `${year}-${month}-${day}`;
                }
                const dashRegex = /^(\d{4})-(\d{2})-(\d{2})$/;
                if (dashRegex.test(value)) {
                    return value;
                }
                return value;
            };

            const data = {
                first_name: formData.get('first_name'),
                last_name: formData.get('last_name'),
                phone: formData.get('phone'),
                english_level: formData.get('english_level'),
                high_school_graduation_date: formatDate(formData.get('high_school_graduation_date')),
                birth_date: formatDate(formData.get('birth_date')),
                passport_type: formData.get('passport_type'),
                passport_number: formData.get('passport_number'),
                desired_country: formData.get('desired_country'),
                active_class: formData.get('active_class'),
                tc_number: formData.get('tc_number')
            };
            
            fetch('/api/user/profile', {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(data)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showAlert('Profil bilgileriniz başarıyla güncellendi!', 'success');
                    populateProfileForm(data.user);
                } else {
                    showAlert(data.message || 'Bir hata oluştu!', 'danger');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showAlert('Bir hata oluştu!', 'danger');
            });
        });

        async function fetchProfile() {
            try {
                const response = await fetch('/api/user/profile', {
                    method: 'GET',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include'
                });

                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}`);
                }

                const data = await response.json();
                if (data.success && data.user) {
                    populateProfileForm(data.user);
                }
            } catch (error) {
                console.error('Profil verisi alınırken hata:', error);
            }
        }

        function populateProfileForm(user) {
            const setValue = (id, value) => {
                const el = document.getElementById(id);
                if (el) el.value = value || '';
            };

            setValue('first_name', user.first_name);
            setValue('last_name', user.last_name);
            setValue('tc_number', user.tc_number);
            setValue('phone', user.phone);
            setValue('english_level', user.english_level);
            setValue('high_school_graduation_date', formatDate(user.high_school_graduation_date));
            setValue('birth_date', formatDate(user.birth_date));
            setValue('passport_type', user.passport_type);
            setValue('passport_number', user.passport_number);
            setValue('desired_country', user.desired_country);
            setValue('active_class', user.active_class);

            const emailField = document.getElementById('email');
            if (emailField) emailField.value = user.email;
        }

        function formatDate(value) {
            if (!value) return '';
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return value;
            const day = String(date.getUTCDate()).padStart(2, '0');
            const month = String(date.getUTCMonth() + 1).padStart(2, '0');
            const year = date.getUTCFullYear();
            return `${day}/${month}/${year}`;
        }

        let dropdownInstance = null;

        // User dropdown is now rendered server-side in layout.ejs
        // No need to update it with JavaScript

        // Alert function
        function showAlert(message, type) {
            const alertContainer = document.getElementById('alertContainer');
            const alert = document.createElement('div');
            alert.className = `alert alert-${type} alert-dismissible fade show`;
            alert.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            alertContainer.appendChild(alert);
            
            // Auto remove after 5 seconds
            setTimeout(() => {
                alert.remove();
            }, 5000);
        }

        // Language change function
        function changeLanguage(lang) {
            fetch('/change-language', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ language: lang })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    window.location.reload();
                }
            })
            .catch(error => {
                console.error('Language change error:', error);
            });
        }

        // Language options event listeners
        document.addEventListener('DOMContentLoaded', function() {
            console.log('Dashboard page loaded');
            
            const languageOptions = document.querySelectorAll('.language-option');
            
            languageOptions.forEach(option => {
                option.addEventListener('click', function(e) {
                    e.preventDefault();
                    const language = this.getAttribute('data-language');
                    changeLanguage(language);
                });
            });

            const logoutBtn = document.getElementById('logoutBtn');
            if (logoutBtn) {
                logoutBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    console.log('Logout button clicked');
                    logout();
                });
            }
            
            // Handle all logout links (including dropdown)
            document.querySelectorAll('[data-action="logout"]').forEach(btn => {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    logout();
                });
            });

            fetchProfile();
            loadAIRecommendation();
        });

        // Load AI Recommendation
        async function loadAIRecommendation() {
            try {
                const response = await fetch('/api/wizard/my-recommendation');
                const result = await response.json();
                
                if (result.success && result.data) {
                    const rec = result.data;
                    const card = document.getElementById('aiRecommendationCard');
                    const content = document.getElementById('aiRecommendationContent');
                    
                    const countryFlags = {
                        'Germany': '🇩🇪',
                        'Czech Republic': '🇨🇿',
                        'Italy': '🇮🇹',
                        'Austria': '🇦🇹',
                        'UK': '🇬🇧',
                        'Poland': '🇵🇱',
                        'Hungary': '🇭🇺'
                    };
                    
                    // Parse recommendation data (new format or legacy)
                    const rec1 = rec.recommendation_1 || {
                        university_name: rec.recommended_university_name,
                        program_name: rec.recommended_program_name,
                        country: rec.recommended_country,
                        city: rec.recommended_city,
                        tuition: rec.recommended_tuition,
                        why_this_university: rec.ai_reasoning,
                        city_info: rec.city_info,
                        career_prospects: rec.career_prospects
                    };
                    const rec2 = rec.recommendation_2;
                    
                    let html = '';
                    
                    // Hazırlık uyarısı
                    if (rec.prep_school_needed) {
                        html += `
                            <div class="alert alert-warning mb-3">
                                <h6 class="alert-heading"><i class="fas fa-exclamation-triangle me-2"></i>Hazırlık Önerisi</h6>
                                <p class="mb-0">${rec.prep_school_suggestion || 'İngilizce seviyenizi geliştirmek için bir hazırlık programı öneriyoruz.'}</p>
                            </div>
                        `;
                    }
                    
                    // Summary view (always visible)
                    html += `
                        <div class="row" id="aiSummaryView">
                            <div class="col-md-6">
                                <div class="d-flex align-items-center mb-3">
                                    <span style="font-size: 2.5rem; margin-right: 15px;">${countryFlags[rec1.country] || '🌍'}</span>
                                    <div>
                                        <h5 class="mb-0">${rec1.country || 'Ülke'}</h5>
                                        <small class="text-muted">${rec1.city || 'Şehir'}</small>
                                    </div>
                                </div>
                                <p><strong><i class="fas fa-university me-2"></i>Üniversite:</strong><br>${rec1.university_name || 'Önerilen Üniversite'}</p>
                                <p><strong><i class="fas fa-book me-2"></i>Program:</strong><br>${rec1.program_name || 'Önerilen Program'}</p>
                                <p><strong><i class="fas fa-euro-sign me-2"></i>Tahmini Ücret:</strong><br>${rec1.tuition || 'Değişken'}</p>
                            </div>
                            <div class="col-md-6">
                                <p><strong><i class="fas fa-lightbulb me-2"></i>Öneri Gerekçesi:</strong></p>
                                <p class="text-muted" style="font-size: 0.9rem;">${rec1.why_this_university ? rec1.why_this_university.substring(0, 200) + '...' : 'Profilinize en uygun seçenek.'}</p>
                            </div>
                        </div>
                        
                        <!-- Detailed view (hidden by default) -->
                        <div id="aiDetailedView" style="display: none;">
                            <hr class="my-3">
                            
                            <!-- First Recommendation Details -->
                            <div class="mb-4" style="background: linear-gradient(135deg, #e3f2fd, #e8f5e9); border-radius: 15px; padding: 20px;">
                                <h5 class="text-primary mb-3"><i class="fas fa-star me-2"></i>1. Öneri: ${rec1.university_name}</h5>
                                
                                ${rec1.why_this_university ? `
                                    <div class="mb-3">
                                        <strong><i class="fas fa-university me-2 text-primary"></i>Neden Bu Üniversite?</strong>
                                        <p class="mt-2 mb-0">${rec1.why_this_university}</p>
                                    </div>
                                ` : ''}
                                
                                ${rec1.why_this_program ? `
                                    <div class="mb-3">
                                        <strong><i class="fas fa-book me-2 text-info"></i>Neden Bu Program?</strong>
                                        <p class="mt-2 mb-0">${rec1.why_this_program}</p>
                                    </div>
                                ` : ''}
                                
                                ${rec1.country_info ? `
                                    <div class="mb-3">
                                        <strong><i class="fas fa-globe me-2 text-success"></i>Ülke Hakkında</strong>
                                        <p class="mt-2 mb-0">${rec1.country_info}</p>
                                    </div>
                                ` : ''}
                                
                                ${rec1.city_info ? `
                                    <div class="mb-3">
                                        <strong><i class="fas fa-city me-2 text-warning"></i>Şehir Hakkında</strong>
                                        <p class="mt-2 mb-0">${rec1.city_info}</p>
                                    </div>
                                ` : ''}
                                
                                ${rec1.career_prospects ? `
                                    <div class="mb-0">
                                        <strong><i class="fas fa-briefcase me-2 text-danger"></i>Kariyer Fırsatları</strong>
                                        <p class="mt-2 mb-0">${rec1.career_prospects}</p>
                                    </div>
                                ` : ''}
                            </div>
                            
                            ${rec2 ? `
                                <!-- Second Recommendation Details -->
                                <div class="mb-4" style="background: linear-gradient(135deg, #fff3e0, #fce4ec); border-radius: 15px; padding: 20px;">
                                    <h5 class="text-success mb-3"><i class="fas fa-star me-2"></i>2. Öneri: ${rec2.university_name}</h5>
                                    
                                    <div class="row mb-3">
                                        <div class="col-6">
                                            <small class="text-muted">Ülke</small>
                                            <div><strong>${countryFlags[rec2.country] || ''} ${rec2.country}</strong></div>
                                        </div>
                                        <div class="col-6">
                                            <small class="text-muted">Şehir</small>
                                            <div><strong>${rec2.city}</strong></div>
                                        </div>
                                        <div class="col-6 mt-2">
                                            <small class="text-muted">Program</small>
                                            <div><strong>${rec2.program_name}</strong></div>
                                        </div>
                                        <div class="col-6 mt-2">
                                            <small class="text-muted">Ücret</small>
                                            <div><strong>${rec2.tuition}</strong></div>
                                        </div>
                                    </div>
                                    
                                    ${rec2.why_this_university ? `
                                        <div class="mb-3">
                                            <strong><i class="fas fa-university me-2 text-primary"></i>Neden Bu Üniversite?</strong>
                                            <p class="mt-2 mb-0">${rec2.why_this_university}</p>
                                        </div>
                                    ` : ''}
                                    
                                    ${rec2.country_info ? `
                                        <div class="mb-3">
                                            <strong><i class="fas fa-globe me-2 text-success"></i>Ülke Hakkında</strong>
                                            <p class="mt-2 mb-0">${rec2.country_info}</p>
                                        </div>
                                    ` : ''}
                                    
                                    ${rec2.city_info ? `
                                        <div class="mb-3">
                                            <strong><i class="fas fa-city me-2 text-warning"></i>Şehir Hakkında</strong>
                                            <p class="mt-2 mb-0">${rec2.city_info}</p>
                                        </div>
                                    ` : ''}
                                    
                                    ${rec2.career_prospects ? `
                                        <div class="mb-0">
                                            <strong><i class="fas fa-briefcase me-2 text-danger"></i>Kariyer Fırsatları</strong>
                                            <p class="mt-2 mb-0">${rec2.career_prospects}</p>
                                        </div>
                                    ` : ''}
                                </div>
                            ` : ''}
                            
                            ${rec.comparison ? `
                                <div class="mb-3" style="background: #f5f5f5; border-radius: 10px; padding: 15px;">
                                    <strong><i class="fas fa-balance-scale me-2"></i>Karşılaştırma</strong>
                                    <p class="mt-2 mb-0">${rec.comparison}</p>
                                </div>
                            ` : ''}
                            
                            ${rec.overall_advice ? `
                                <div class="mb-0" style="background: #e8f5e9; border-radius: 10px; padding: 15px;">
                                    <strong><i class="fas fa-lightbulb me-2 text-success"></i>Genel Tavsiyeler</strong>
                                    <p class="mt-2 mb-0">${rec.overall_advice}</p>
                                </div>
                            ` : ''}
                        </div>
                        
                        <div class="mt-3 d-flex gap-2 flex-wrap">
                            <button class="btn btn-primary btn-sm" onclick="toggleDetailedView()" id="toggleDetailBtn">
                                <i class="fas fa-chevron-down me-1"></i>Daha Fazla Göster
                            </button>
                            <a href="/student-wizard" class="btn btn-outline-primary btn-sm">
                                <i class="fas fa-redo me-1"></i>Yeniden Değerlendir
                            </a>
                            <a href="https://wa.me/message/O2KRAFDJAMX7F1" target="_blank" class="btn btn-success btn-sm">
                                <i class="fab fa-whatsapp me-1"></i>Danışman ile Görüş
                            </a>
                        </div>
                    `;
                    
                    content.innerHTML = html;
                    card.style.display = 'block';
                } else {
                    // Öneri yoksa sihirbaz önerisi göster
                    const card = document.getElementById('aiRecommendationCard');
                    const content = document.getElementById('aiRecommendationContent');
                    
                    content.innerHTML = `
                        <div class="text-center py-3">
                            <i class="fas fa-magic text-primary" style="font-size: 3rem; margin-bottom: 15px;"></i>
                            <h5>Henüz bir üniversite öneriniz yok!</h5>
                            <p class="text-muted">Öğrenci Sihirbazı ile size en uygun üniversiteyi bulalım.</p>
                            <a href="/student-wizard" class="btn btn-primary">
                                <i class="fas fa-magic me-2"></i>Sihirbazı Başlat
                            </a>
                        </div>
                    `;
                    card.style.display = 'block';
                }
            } catch (error) {
                console.error('AI recommendation load error:', error);
            }
        }
        
        // Toggle detailed view
        function toggleDetailedView() {
            const detailedView = document.getElementById('aiDetailedView');
            const btn = document.getElementById('toggleDetailBtn');
            
            if (detailedView.style.display === 'none') {
                detailedView.style.display = 'block';
                btn.innerHTML = '<i class="fas fa-chevron-up me-1"></i>Daha Az Göster';
            } else {
                detailedView.style.display = 'none';
                btn.innerHTML = '<i class="fas fa-chevron-down me-1"></i>Daha Fazla Göster';
            }
        }
    </script> 