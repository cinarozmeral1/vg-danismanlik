<!-- Main Content -->
    <section class="section bg-light text-dark" style="min-height: 80vh;">
        <div class="container">
            <div class="row">
                <!-- Sidebar -->
                <div class="col-lg-3 mb-4">
                    <div class="card shadow-sm">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="fas fa-user me-2"></i>Hesap Menüsü</h5>
                        </div>
                        <div class="list-group list-group-flush">
                            <a href="/user/dashboard" class="list-group-item list-group-item-action">
                                <i class="fas fa-user me-2"></i>Profil Bilgileri
                            </a>
                            <a href="/user/applications" class="list-group-item list-group-item-action">
                                <i class="fas fa-file-alt me-2"></i>Başvurularım
                            </a>
                            <a href="/user/services" class="list-group-item list-group-item-action">
                                <i class="fas fa-credit-card me-2"></i>Hizmetler & Ödemeler
                            </a>
                            <a href="/user/files" class="list-group-item list-group-item-action active">
                                <i class="fas fa-folder me-2"></i>Dosyalarım
                            </a>
                            <a href="/user/settings" class="list-group-item list-group-item-action">
                                <i class="fas fa-cog me-2"></i>Ayarlar
                            </a>
                            <a href="#" class="list-group-item list-group-item-action text-danger" data-action="logout">
                                <i class="fas fa-sign-out-alt me-2"></i>Çıkış Yap
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Main Content -->
                <div class="col-lg-9">
                    <div class="card shadow-sm">
                        <div class="card-header bg-primary text-white">
                            <h4 class="mb-0"><i class="fas fa-folder me-2"></i>Dosyalarım</h4>
                        </div>
                        <div class="card-body">
                            <div id="alertContainer"></div>
                            
                            <!-- Upload Section -->
                            <div class="card mb-4">
                                <div class="card-header bg-primary text-white">
                                    <h5 class="mb-0"><i class="fas fa-upload me-2"></i>Dosya Yükle</h5>
                                </div>
                                <div class="card-body">
                                    <form id="fileUploadForm" enctype="multipart/form-data">
                                        <div class="mb-3">
                                            <label for="fileTitle" class="form-label">Dosya Başlığı *</label>
                                            <input type="text" class="form-control" id="fileTitle" name="title" required>
                                        </div>
                                        <div class="mb-3">
                                            <label for="fileDescription" class="form-label">Açıklama</label>
                                            <textarea class="form-control" id="fileDescription" name="description" rows="3"></textarea>
                                        </div>
                                        <div class="mb-3">
                                            <label for="fileInput" class="form-label">Dosya Seç *</label>
                                            <input type="file" class="form-control" id="fileInput" name="file" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png" required>
                                            <div class="form-text">
                                                PDF, DOC, DOCX, JPG, PNG (Max: 3.5 MB) • 
                                                <a href="https://www.ilovepdf.com/compress_pdf" target="_blank">PDF Sıkıştır</a>
                                            </div>
                                            <div id="compressionStatus" class="mt-2 text-primary" style="display:none;">
                                                <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                                                <span id="compressionText">İşleniyor...</span>
                                            </div>
                                        </div>
                                        <button type="submit" class="btn btn-primary">
                                            <i class="fas fa-upload me-2"></i>Dosya Yükle
                                        </button>
                                    </form>
                                </div>
                            </div>

                            <!-- Files List -->
                            <div class="card">
                                <div class="card-header bg-primary text-white">
                                    <h5 class="mb-0"><i class="fas fa-list me-2"></i>Yüklenen Dosyalar</h5>
                                </div>
                                <div class="card-body">
                                    <div id="filesList">
                                        <!-- Files will be loaded here -->
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Custom JS -->
    <script>
        // Load files on page load
        document.addEventListener('DOMContentLoaded', function() {
            console.log('Files page loaded, initializing...');
            try {
                loadFiles();
                console.log('Files loaded successfully');
            } catch (error) {
                console.error('Error loading files:', error);
                showAlert('Dosyalar yüklenirken bir hata oluştu!', 'danger');
            }
        });

        // File upload form with image compression
        const uploadForm = document.getElementById('fileUploadForm');
        if (uploadForm) {
            uploadForm.addEventListener('submit', async function(e) {
                e.preventDefault();
                
                const submitBtn = this.querySelector('button[type="submit"]');
                const originalText = submitBtn.innerHTML;
                const compressionStatus = document.getElementById('compressionStatus');
                const compressionText = document.getElementById('compressionText');
                
                let file = document.getElementById('fileInput').files[0];
                const title = document.getElementById('fileTitle').value;
                const description = document.getElementById('fileDescription').value;
                
                if (!file) {
                    showAlert('Lütfen bir dosya seçin', 'danger');
                    return;
                }
                
                if (!title.trim()) {
                    showAlert('Lütfen dosya başlığı girin', 'danger');
                    return;
                }
                
                const maxSize = 3.5 * 1024 * 1024; // 3.5MB (safe for Vercel)
                const isImage = file.type.startsWith('image/');
                const isPDF = file.type === 'application/pdf';
                
                submitBtn.disabled = true;
                
                try {
                    // If file is too large
                    if (file.size > maxSize) {
                        if (isImage) {
                            // Compress images automatically
                            compressionStatus.style.display = 'block';
                            compressionText.textContent = 'Görsel sıkıştırılıyor...';
                            
                            // Use canvas to compress image
                            file = await compressImageFile(file, maxSize);
                            
                            const newSizeMB = (file.size / 1024 / 1024).toFixed(1);
                            compressionText.textContent = `Sıkıştırıldı: ${newSizeMB} MB`;
                            
                            if (file.size > 4 * 1024 * 1024) {
                                showAlert('Görsel hala çok büyük. Lütfen daha düşük çözünürlüklü görsel seçin.', 'warning');
                                submitBtn.disabled = false;
                                compressionStatus.style.display = 'none';
                                return;
                            }
                        } else if (isPDF) {
                            // PDFs cannot be compressed in browser effectively
                            const sizeMB = (file.size / 1024 / 1024).toFixed(1);
                            showAlert(`PDF çok büyük (${sizeMB} MB). Lütfen <a href="https://www.ilovepdf.com/compress_pdf" target="_blank" style="color: #000; text-decoration: underline; font-weight: bold;">buradan sıkıştırın</a> (Max: 3.5 MB)`, 'warning');
                            submitBtn.disabled = false;
                            return;
                        } else {
                            showAlert('Dosya çok büyük! Maksimum 3.5 MB.', 'danger');
                            submitBtn.disabled = false;
                            return;
                        }
                    }
                    
                    compressionStatus.style.display = 'block';
                    compressionText.textContent = 'Yükleniyor...';
                    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Yükleniyor...';
                    
                    const formData = new FormData();
                    formData.append('file', file);
                    formData.append('title', title);
                    formData.append('description', description);
                    
                    const response = await fetch('/api/user/api/files/upload', {
                        method: 'POST',
                        credentials: 'include',
                        body: formData
                    });
                    
                    const result = await response.json();
                    
                    if (result.success) {
                        showAlert('Dosya başarıyla yüklendi!', 'success');
                        this.reset();
                        loadFiles();
                    } else {
                        showAlert('Hata: ' + (result.message || 'Bilinmeyen hata'), 'danger');
                    }
                } catch (error) {
                    console.error('Upload error:', error);
                    showAlert('Yükleme hatası: ' + error.message, 'danger');
                } finally {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalText;
                    compressionStatus.style.display = 'none';
                }
            });
        }
        
        // Compress image using canvas
        async function compressImageFile(file, maxSizeBytes) {
            return new Promise((resolve) => {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const img = new Image();
                    img.onload = function() {
                        const canvas = document.createElement('canvas');
                        let width = img.width;
                        let height = img.height;
                        
                        // Scale down if very large
                        const maxDimension = 2000;
                        if (width > maxDimension || height > maxDimension) {
                            if (width > height) {
                                height = Math.round(height * maxDimension / width);
                                width = maxDimension;
                            } else {
                                width = Math.round(width * maxDimension / height);
                                height = maxDimension;
                            }
                        }
                        
                        canvas.width = width;
                        canvas.height = height;
                        
                        const ctx = canvas.getContext('2d');
                        ctx.drawImage(img, 0, 0, width, height);
                        
                        // Try different quality levels
                        let quality = 0.8;
                        let blob;
                        
                        const tryCompress = () => {
                            canvas.toBlob((b) => {
                                if (b.size > maxSizeBytes && quality > 0.3) {
                                    quality -= 0.1;
                                    tryCompress();
                                } else {
                                    resolve(new File([b], file.name, { type: 'image/jpeg' }));
                                }
                            }, 'image/jpeg', quality);
                        };
                        
                        tryCompress();
                    };
                    img.src = e.target.result;
                };
                reader.readAsDataURL(file);
            });
        }

        // Load files
        async function loadFiles() {
            try {
                console.log('Loading files...');
                const response = await fetch('/api/user/api/files', {
                    method: 'GET',
                    credentials: 'include'
                });
                
                console.log('Files response status:', response.status);
                
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                
                const result = await response.json();
                console.log('Files response data:', result);
                
                if (result.success) {
                    displayFiles(result.files);
                } else {
                    showAlert('Dosyalar yüklenirken bir hata oluştu: ' + result.message, 'danger');
                }
            } catch (error) {
                console.error('Load files error:', error);
                showAlert('Dosyalar yüklenirken bir hata oluştu: ' + error.message, 'danger');
            }
        }

        // Display files
        function displayFiles(files) {
            const container = document.getElementById('filesList');
            
            if (!container) {
                console.error('Files list container not found!');
                return;
            }
            
            if (!files || files.length === 0) {
                container.innerHTML = '<p class="text-muted">Henüz dosya yüklenmemiş.</p>';
                return;
            }
            
            console.log('Displaying files:', files);
            
            let html = '';
            files.forEach(file => {
                const fileSize = file.file_size ? (file.file_size / 1024 / 1024).toFixed(2) : '0';
                const uploadDate = file.uploaded_at ? new Date(file.uploaded_at).toLocaleDateString('tr-TR') : 'Bilinmiyor';
                
                html += `
                    <div class="card mb-3">
                        <div class="card-body">
                            <div class="row align-items-center">
                                <div class="col-md-8">
                                    <h6 class="mb-1">${file.title || 'Başlıksız'}</h6>
                                    <p class="text-muted mb-1">${file.description || 'Açıklama yok'}</p>
                                    <small class="text-muted">
                                        Kategori: ${getCategoryName(file.category)} | 
                                        Boyut: ${fileSize} MB | 
                                        Yüklenme: ${uploadDate}
                                    </small>
                                </div>
                                <div class="col-md-4 text-end">
                                    <button class="btn btn-sm btn-outline-primary me-2" onclick="downloadFile(${file.id})">
                                        <i class="fas fa-download me-1"></i>İndir
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" onclick="deleteFile(${file.id})">
                                        <i class="fas fa-trash me-1"></i>Sil
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            });
            
            container.innerHTML = html;
        }

        // Get category name
        function getCategoryName(category) {
            const categories = {
                'transcript': 'Transkript',
                'passport': 'Pasaport',
                'language_test': 'Dil Sınavı',
                'reference': 'Referans Mektubu',
                'motivation': 'Motivasyon Mektubu',
                'other': 'Diğer'
            };
            return categories[category] || 'Bilinmiyor';
        }

        // Download file from server
        async function downloadFile(fileId) {
            try {
                const response = await fetch(`/api/user/api/files/${fileId}/download`, {
                    method: 'GET',
                    credentials: 'include'
                });
                
                if (response.ok) {
                    const contentDisposition = response.headers.get('Content-Disposition');
                    let filename = 'dosya';
                    if (contentDisposition) {
                        const match = contentDisposition.match(/filename="?(.+?)"?$/);
                        if (match) filename = decodeURIComponent(match[1]);
                    }
                    
                    const blob = await response.blob();
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = filename;
                    document.body.appendChild(a);
                    a.click();
                    window.URL.revokeObjectURL(url);
                    document.body.removeChild(a);
                } else {
                    const errorData = await response.json().catch(() => ({}));
                    showAlert('Dosya indirilemedi: ' + (errorData.message || 'Hata'), 'danger');
                }
            } catch (error) {
                console.error('Download error:', error);
                showAlert('Dosya indirilemedi: ' + error.message, 'danger');
            }
        }

        // Delete file
        async function deleteFile(fileId) {
            if (!confirm('Bu dosyayı silmek istediğinizden emin misiniz?')) {
                return;
            }
            
            try {
                console.log('Deleting file:', fileId);
                const response = await fetch(`/api/user/api/files/${fileId}`, {
                    method: 'DELETE',
                    credentials: 'include'
                });
                
                const result = await response.json();
                
                if (result.success) {
                    showAlert('Dosya başarıyla silindi!', 'success');
                    loadFiles();
                } else {
                    showAlert('Hata: ' + result.message, 'danger');
                }
            } catch (error) {
                console.error('Delete error:', error);
                showAlert('Dosya silinirken bir hata oluştu: ' + error.message, 'danger');
            }
        }

        // Alert function
        function showAlert(message, type) {
            const alertContainer = document.getElementById('alertContainer');
            const alert = document.createElement('div');
            alert.className = `alert alert-${type} alert-dismissible fade show`;
            alert.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            alertContainer.appendChild(alert);
            
            setTimeout(() => {
                alert.remove();
            }, 10000);
        }

        // Logout function
        function logout() {
            console.log('Logout function called');
            fetch('/api/auth/logout', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                credentials: 'include'
            })
            .then(response => response.json())
            .then(data => {
                console.log('Logout response:', data);
                if (data.success) {
                    window.location.href = '/';
                } else {
                    console.error('Logout failed:', data.message);
                    window.location.href = '/';
                }
            })
            .catch(error => {
                console.error('Error during logout:', error);
                window.location.href = '/';
            });
        }

        // Initialize when page loads
        document.addEventListener('DOMContentLoaded', function() {
            console.log('Files page loaded');
            
            // Handle all logout links (including dropdown)
            document.querySelectorAll('[data-action="logout"]').forEach(btn => {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    logout();
                });
            });
        });
    </script>
