<!-- Main Content -->
<section class="section bg-light text-dark" style="min-height: 80vh;">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0">DEBUG: Hizmetler Test</h4>
                    </div>
                    <div class="card-body">
                        <div id="debugInfo" class="mb-4">
                            <h5>Test Sonuçları:</h5>
                            <pre id="results" style="background: #f8f9fa; padding: 15px; border-radius: 5px; max-height: 500px; overflow-y: auto;"></pre>
                        </div>
                        <button class="btn btn-primary" onclick="runTests()">Testleri Çalıştır</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
async function runTests() {
    const results = document.getElementById('results');
    let output = '';
    
    function log(msg) {
        output += msg + '\n';
        results.textContent = output;
    }
    
    log('🔍 BAŞLIYORUM...\n');
    
    // Test 1: Check if logged in
    log('1. Authentication Test:');
    log('   User: <%= JSON.stringify(currentUser) %>\n');
    
    // Test 2: Stripe Config
    log('2. Stripe Config Test:');
    try {
        const response = await fetch('/api/user/stripe-config', {
            method: 'GET',
            credentials: 'include',
            headers: {
                'Content-Type': 'application/json'
            }
        });
        log('   Status: ' + response.status);
        const data = await response.json();
        log('   Response: ' + JSON.stringify(data, null, 2));
    } catch (error) {
        log('   ❌ ERROR: ' + error.message);
    }
    
    log('\n3. Services API Test:');
    try {
        const response = await fetch('/api/user/services', {
            method: 'GET',
            credentials: 'include',
            headers: {
                'Content-Type': 'application/json'
            }
        });
        log('   Status: ' + response.status);
        const data = await response.json();
        log('   Response: ' + JSON.stringify(data, null, 2));
        
        if (data.success && data.services) {
            log('\n   ✅ Found ' + data.services.length + ' services!');
        }
    } catch (error) {
        log('   ❌ ERROR: ' + error.message);
    }
    
    log('\n✅ TEST COMPLETED!');
}

// Auto-run on load
document.addEventListener('DOMContentLoaded', runTests);
</script>

